      tablePFPTInfoInPages.cells['A8'].value = requestDate;
    }

    // --------------- GET TABLE INFO FROM NUMBERS

    var wagesByMemberTableName = 'V2-Por profissional'; // 🔴🔴🔴 get from Numbers

    var tableTeamForWagesOrTasksProperties = tableTeamForWagesOrTasks(propSheetName, wagesByMemberTableName);

    var teamTasks = tableTeamForWagesOrTasksProperties.teamTasks;
    var teamWages = tableTeamForWagesOrTasksProperties.teamWages;

    // -------------- PF

