    // Remover a indexação para correcto nome do Grupo
    var groupsNamesSelected = groupsNamesSelected.split('. ')[1];

    // Get Group based on Identifier
    var filteredGroup = contactsApp.groups.whose({ name: { _contains: groupsNamesSelected } })()[0];

    var peopleNamesAndPhones = peopleAndPhonesArraysValues();

