    } else if (proposal == 'Manifestação de Interesse' || proposal == 'Proposta Técnica') {
      var pt4Lists = ptInfoLists('Proposta Técnica', ptOptionsSel, scheduleDurationUnit);
      var ptInfoLines = pt4Lists[0];
      var heading1List = pt4Lists[1];
      var heading2List = pt4Lists[2];
      var heading3List = pt4Lists[3];

      var workPhasesNameAndWeeks = pt4Lists[4];

      var ptInfoLinesText = ptInfoLines.join('\n');

      pagesApp.activate();

      if (thisTag.includes('ptInfoLinesText')) {
        delay(d0p1);

        seApp.keyCode(53); // Scape to deselect Table Cover of PT
        delay(d0p1);

        placeHolderTexts_.whose({ tag: thisTag })[0].set(ptInfoLinesText);
      }
      delay(d0p3);

      // Selecionar alguma coisa para activar FORMAT INSPECTOR para permitir a formatação e mostrar a substituição em <paragraphs[i].set(…)> na func numberingHeadings
      menuLib.selectAll();

      numberingHeadings(heading1List, 'H1');
      numberingHeadings(heading2List, 'H2');
      numberingHeadings(heading3List, 'H3');

      // --------------- PAGE BREAKS
      pageBreaking();

      // --------------- COPY AND PAST TABLES

      if (technicalProposalOrInterestExpression == 'Manifestação de Interesse') {
        var technicalProposalOrInterestExpressionTable = 'Manifestação de Interesse';

        docPagesInProposta.tables['Proposta Técnica'].delete();
        seApp.keyCode(51); // Delete
        seApp.keyCode(51); // Delete
      } else if (technicalProposalOrInterestExpression == 'Proposta Técnica') {
        var technicalProposalOrInterestExpressionTable = 'Proposta Técnica';

        docPagesInProposta.tables['Manifestação de Interesse'].delete();
        seApp.keyCode(51); // Delete
        seApp.keyCode(51); // Delete
      }

      // 🔴🔴🔴 DESACTIVADO POIS A SEQUENCIA DE NOMES DE TABELAS CONTA NO CODE ACTUAL PARA A5P ou U5P FAZENDO concat de "Cronograma de Trabalho" acaba dando resultados inesperados

      // var generalTablesToCopy = ["Declaração de Inexistência de Impedimentos", "Composição da Equipa e Tarefas", technicalProposalOrInterestExpressionTable]

      if (consultancyCode == 'A5P' || consultancyCode == 'U5P') {
        var tableNamesToCopyAndOPaste = [
          'Declaração de Inexistência de Impedimentos',
          'Composição da Equipa e Tarefas',
          'Cronograma de Trabalho',
          technicalProposalOrInterestExpressionTable,
        ];
      } else if (consultancyCode == 'A5F') {
        // Cronograma de Trabalho
        docPagesInProposta.tables['projectPlanInPages'].delete();
        seApp.keyCode(51); // Delete
        seApp.keyCode(51); // Delete

        var tableNamesToCopyAndOPaste = [
          'Declaração de Inexistência de Impedimentos',
          'Composição da Equipa e Tarefas',
          technicalProposalOrInterestExpressionTable,
        ];
      }

      copyAndPasteTables(tableNamesToCopyAndOPaste);

      delay(d1);

      // --------------- APPLY TABLE INFO IN PAGES

      var tableTeamInPages = docPagesInProposta.tables['tableTeamInPages'];
      var projectPlanInPages = docPagesInProposta.tables['projectPlanInPages'];

      // ----- Composição da Equipa e Tarefas

      saApp.setTheClipboardTo(teamTasks.join('\n'));
      selectionRange(tableTeamInPages, 'A1:A1');
      delay(d0p3);

      seApp.keystroke('v', { using: 'command down' });
      delay(d0p3);

      // ----- projectPlanInPages // Cronograma de Trabalho
      if (consultancyCode == 'A5P' || consultancyCode == 'U5P') {
        // CODE
        fillWorkSchedule(docPagesInProposta, workPhasesNameAndWeeks, scheduleDurationUnit);
      }

      // ----- DEELTE EXTRA ROWS IN TABLES

      deleteEmptyRowsInPagesTable(tableTeamInPages);
      delay(d0p3);

      // -------------- APPLY LOGO5
      var paragraphs = docPagesInProposta.bodyText.paragraphs;

      for (var i = 0; i < paragraphs.length; i++) {
        var paragraph = paragraphs()[i];

        if (paragraph.includes('Manifestação de Interesse') || paragraph.includes('Proposta Técnica')) {
          pagesApp.activate();
          delay(d0p1);
          seApp.keyCode(53); // Scape
          delay(d0p1);

          // Selecionar alguma coisa para mostrar a substituição em <paragraphs[i].set(paragraph)> abaixo
          menuLib.selectAll();

          delay(d0p1);
          paragraphs[i].set(paragraph);
          delay(d0p1);
          seApp.keyCode(123, { using: 'command down' });
          delay(d0p1);
          seApp.keyCode(76); // Press Enter
          delay(d0p1);
          seApp.keyCode(126); // Up
          delay(d0p1);
          seApp.keyCode(51); // Delete
          delay(d0p1);
          seApp.keyCode([76, 76, 76, 76]);
          delay(d0p3);
          var pagesDocLogo5 = pagesApp.open(Path(pagesDocLogo5PathStr));
          delay(d2);
          menuLib.copyWithSelectAll();
          pagesDocLogo5.close();
          delay(d0p3);
          menuLib.paste();
          delay(d0p3);

          break;
        }
      }
    }
    delay(d0p3);
    menuLib.doMenu('Pages', 'View', 'Page Thumbnails');
    delay(d0p3);

    if (proposal == 'Manifestação de Interesse') {
      // 🔴 SOLUÇÃO ACTUAL USIGNG GUI TO DELETE PAGE 1 (ENVELOPE GERAL) IF IS MI5
      seApp.keyCode(53); // Scape
      delay(d0p3);
      seApp.keyCode(48, { using: ['control down', 'option down'] });
      delay(d0p3);
      menuLib.doSubMenu('Pages', 'View', 'Go To', 'First Page');
      delay(d0p3);
      seApp.keyCode(51); // Delete
      delay(d0p3);
      seApp.keyCode(76); // Press Enter
      delay(d0p3);
    }
    // Save of PF & PT in Pages
    seApp.keystroke('s', { using: 'command down' });
    delay(d0p3); // Era d1
  }

  if (proposalTrack == 'Proposta Financeira') {
    //var destinyFolderName = destinyFolder.name()

    // 🔴 If CP (concurso Público) Update Date in Name in folderName below:
    // + 20220199* S1Q2.2 P&C | 20220116-20220416 | C0,000.00 5%

    var destinyFolderName = destinyFolderStr.split('/').slice(-1)[0];

    if (destinyFolderName.includes('S1Q2.2 P&C')) {
      var destinyFolderName = destinyFolderName.replace(
        /\d{6}99\*\sS1Q2.2|\d{8}\sS1Q2.2/,
        dateToUpdateInPropostasInCP + ' S1Q2.2'
      );
    }

    //destinyFolder.name = destinyFolderName.replace(/C\d[0-9,.]*\sX|C\d[0-9,.]*\s[0-9.]*/, "C" + total + " " + chargedPercentage)

    var folderPathAlias = seApp.aliases.byName(destinyFolderStr);

    folderPathAlias.name = destinyFolderName.replace(
      /C\d[0-9,.]*\sX|C\d[0-9,.]*\s[0-9.]*/,
      'C' + total + ' ' + chargedPercentage
    );

    var proposalTrack = ''; // Reset

    global5ContractDetailsForEventAndFolderAndSubscricoes(
      '',
      'ReadInvoiceInfoAndUpdateJSON',
      '',
      p5PathStrWithSuffixP5,
      '',
      ['All'],
      ['All'],
      yearY4,
      '',
      '',
      3
    );
  }
} else if (production == 'Quitações (Requerimentos)') {
  var destinyFolderStr =
    '/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Plataformas/P2/PROFISSIONAIS/P2DG GESTÃO (G5)/QUITAÇÕES/REQUERIMENTOS/';

  var dischargeInstitutionShortNames = cfl(['ATM', 'INE', 'TJCM'], 'Referência', ['ATM', 'INE', 'TJCM'], 'm');

  var docNumXG5 = numbersApp.open(numXG5PathObj);
  var customerAndSupplierSheet = docNumXG5.sheets['CUSTOMERS&SUPPLIERS'];

  for (var h = 0; h < dischargeInstitutionShortNames.length; h++) {
    const {
      referenceNumber1WithDate,
      // referenceNumber2WithDate,
      dateDotDdMmYyyy,
      referenceNumber1,
      // referenceNumber2,
      // referenceNumberPreviousWithDate,
    } = numbersDateAndReference(docNumXG5, 'X5G', dateY4M2D2__H2M2S2, 'X'); //.split(" / ")

    // var referenceNumberWithDateItems = dateAndReferenceItems[0].split(" // ")
    // var referenceNumber1WithDate = referenceNumberWithDateItems[0]

    // var dateWithDateStr = "Data: " + dateAndReferenceItems[1]
    var dateWithDateStr = `Data: ${dateDotDdMmYyyy}`;

    // var referenceItems = dateAndReferenceItems[2].split(" // ")
    // var referenceNumber1 = referenceItems[0]

    var referenceWithReferenceStr1 = 'Referência: ' + referenceNumber1;
    var dischargeInstitutionShortName = dischargeInstitutionShortNames[h];

    pagesApp.activate();

    if (dischargeInstitutionShortName == 'ATM' || dischargeInstitutionShortName == 'INE') {
      var dischargeInstitutionShortNameTemplate = 'Req-Quitação ' + dischargeInstitutionShortName;

      var docPages = pagesApp.Document({ documentTemplate: pagesApp.templates[dischargeInstitutionShortNameTemplate] }).make();

      var tableHeader = docPages.tables['tableHeader'];
      pagesApplyLetterHeader(tableHeader, '', referenceWithReferenceStr1, dateWithDateStr, production);

      // var placeHolderTexts_ = docPages.placeholderTexts
      // var theseTags = placeHolderTexts_.tag()
      //
      // var uniqueTags = []
      //
      // for(var i=0; i < theseTags.length; i++){
      // 	var thisTag = theseTags[i]
      // 	uniqueTags.push(thisTag)
      // }
      //
      // for(var i=0; i < uniqueTags.length; i++){
      // 	var thisTag = uniqueTags[i]
      //
      // 	if (thisTag == "dateWithDateStr") {
      // 		placeHolderTexts_.whose( { tag: thisTag })[0].set(dateWithDateStr)
      //
      // 	} else if (thisTag == "theReference") {
      // 		placeHolderTexts_.whose( { tag: thisTag })[0].set(referenceNumber1)
      //
      // 	}
      // }
    } else if (dischargeInstitutionShortName == 'TJCM') {
      var tableTjcm = customerAndSupplierSheet.tables['Tribunal Judicial Períodos Quitação'];

      var tableTjcmRowsL = tableTjcm.rowCount();

      for (var i = 1; i < tableTjcmRowsL; i++) {
        var iNum = i + 1;

        var verifcationPeriod = tableTjcm.cells['A' + iNum].value();

        if (verifcationPeriod == null) {
          var verifcationPeriodLast = tableTjcm.cells['A' + (iNum - 1)].value();
          break;
        }
      }

      if (verifcationPeriodLast == undefined) {
        // Caso não tenha nenhuma fila vazia
        var verifcationPeriodLast = tableTjcm.cells['A' + tableTjcmRowsL].value();
      }

      delay(d1);

      var dateStartYyyyMmDd = verifcationPeriodLast.split('-')[1];

      // 20200901-20210708
      var dateStart = `${dateStartYyyyMmDd.slice(6, 8)}/${dateStartYyyyMmDd.slice(4, 6)}/${dateStartYyyyMmDd.slice(0, 4)}`;
      var dateEnd = `${dateDashD2M2Y4.replace(/-/g, '/')}`;

      var dateStartAndDateEnd = `${dateStartYyyyMmDd}-${dateY4M2D2}`;

      var docPages = pagesApp.Document({ documentTemplate: pagesApp.templates['Req-Quitação TJCM'] }).make();

      var tableHeader = docPages.tables['tableHeader'];
      pagesApplyLetterHeader(tableHeader, '', referenceWithReferenceStr1, dateWithDateStr, production);

      var placeHolderTexts_ = docPages.placeholderTexts;
      var theseTags = placeHolderTexts_.tag();

      var uniqueTags = [];

      for (var i = 0; i < theseTags.length; i++) {
        var thisTag = theseTags[i];
        uniqueTags.push(thisTag);
      }

      for (var i = 0; i < uniqueTags.length; i++) {
        var thisTag = uniqueTags[i];

        // if (thisTag == "dateWithDateStr") {
        // 	placeHolderTexts_.whose( { tag: thisTag })[0].set(dateWithDateStr)
        //
        // } else if (thisTag == "theReference") {
        // 	placeHolderTexts_.whose( { tag: thisTag })[0].set(referenceNumber1)
        //
        // } else

        if (thisTag == 'dateStart') {
          placeHolderTexts_.whose({ tag: thisTag })[0].set(dateStart);
        } else if (thisTag == 'dateEnd') {
          placeHolderTexts_.whose({ tag: thisTag })[0].set(dateEnd);
        }
      }

      var blankCellsList = [];

      for (var i = 1; i < tableTjcmRowsL; i++) {
        var value = tableTjcm.rows[i].cells[0].value();

        if (value == '' || value == null) {
          tableTjcm.rows[i].cells[0].value = dateStartAndDateEnd;
          blankCellsList.push(value);
          break;
        }
      }

      if (blankCellsList.length == 0) {
        var newRow = tableTjcm.cells['A' + tableTjcmRowsL].addRowBelow();
        tableTjcm.rows[tableTjcmRowsL].cells[0].value = dateStartAndDateEnd;
      }
    }

    try {
      var pathStrTo = destinyFolderStr + '/+ ARQUIVO REQS QUITAÇÕES';

      moveFile(destinyFolderStr, pathStrTo, dischargeInstitutionShortName);
    } catch (error) {
      dAlert(`${error.name}`, `${error.message}\n\n—\nTalvez não tem o Requeriemnto da Quitação anterior.`);
    }

    var shortNameSelected = dischargeInstitutionShortName.toUpperCase();

    filePathSaved = processSave(docPages, destinyFolderStr, `XG5 ${ND} REQ - QUITAÇÃO ${ND} ${shortNameSelected}`);

    var referenceToWrite1 = `${shortNameSelected} / Requerimento de Quitação`;

    numbersWriteReference(
      numbersApp,
      docNumXG5,
      referenceNumber1WithDate,
      referenceNumberIncrement1,
      referenceToWrite1,
      filePathSaved
    );
    delay(d1);
  }

  dAlert(
    `EXEMPLARES\n\n• ATM — 3 (Dois para JFiscal incluindo protocolado na ATM Zimpeto e 3º protocolado no JFiscal)\n• INE & TRIBUNAL JUDICIAL — 2\n\n\n🔴🔴🔴\nDEL5 THIS AFETR DOMINATE!`,
    ``
  );
} else if (production == '_ Solicitação Garantia (New)*') {
}

if (
  production == 'Propostas' ||
  production == '_ Solicitação Garantia (New)*' ||
  production == 'Contrato' ||
  production == 'Acta (New)' ||
  production == 'Documento X' ||
  production == 'Solicitação Pagamento' ||
  production == 'Quitações (Requerimentos)'
) {
  docNumXG5.save();

  if (
    production == 'Acta (New)' ||
    production == 'Documento X' ||
    production == 'Solicitação Pagamento' ||
    production == 'Quitações (Requerimentos)'
  ) {
    pagesApp.activate();
    delay(d0p3);

    if (production == 'Solicitação Pagamento') {
      saApp.setTheClipboardTo(invoicingNumbers);
      dAlert('COPIADO\n\n' + invoicingNumbers, ``);
    }
  }
}

// ------------------------------------------ FUNCTIONS

// --------------- FUNCTIONS GLOBAL5

function global5EnsureSpaceAfterCommaInStr(string) {
  return string.replace(/, /g, ',').replace(/,/g, ', ');
}

function global5ContractDetailsForEventAndFolderAndSubscricoes(
  company,
  action,
  invoiceNumberEdition,
  p5PathStrWithSuffixP5,
  dueAmountAndTotalWithPrefix,
  disciplines,
  consultancyCategs,
  yearY4,
  whatReturn,
  typeOfInvoicingC1,
  numberOfYearsToRead
) {
  var disciplinesStr = disciplines.toString();
  var consultancyCategsStr = consultancyCategs.toString();

  if (disciplinesStr == 'All') {
    var disciplines = ['Arquitectura', 'Design', 'Simplitask', 'Urbanismo'];
  }

  if (consultancyCategsStr == 'All') {
    var consultancyCategs = ['Projecto', 'Construção', 'Empreitada', 'Fiscalização', 'Técnica'];
  }

  try {
    if (action.includes('Read')) {
      if (action.includes('ReadFolderName')) {
        var filterInputStrs = dDialog(`Filtros\n\n—\nAdicione "-3", <filtro-3> 3 são anos a ler`, `magai, hercu`);

        if (filterInputStrs.includes('-')) {
          var filterInputStrs = filterInputStrs.replace(/" "/g, '');

          var filterInputStrsItems = filterInputStrs.split('-');

          var filterStrs = filterInputStrsItems[0];

          var numberOfYearsToRead = Number(filterInputStrsItems[1]);
        } else {
          var filterStrs = filterInputStrs;
        }
      }

      // filterStrs == "n" and filterStrs == "s" USED IN EVENT
      if (filterStrs == 'n') {
        // New work
        return 'NEW';
      } else if (filterStrs == 's') {
        // Select old Object
        return 'SELECTINOLDPROJECTS';
      } else {
        var xproj5xbuild5FoldersNames = [];
        var contractsInfo = [];

        try {
          for (var g = 0; g < disciplines.length; g++) {
            var discipline = disciplines[g];
            var disciplineUpperCase = discipline.toUpperCase();

            var p5PathStrWithSuffixP5InCateg = p5PathStrWithSuffixP5 + disciplineUpperCase[0] + ' ' + disciplineUpperCase;

            for (var h = 0; h < consultancyCategs.length; h++) {
              var consultancyCateg = consultancyCategs[h];

              if (consultancyCateg == 'Projecto') {
                try {
                  var xproj5PathStr = p5PathStrWithSuffixP5InCateg + '/P5' + discipline[0].toUpperCase() + 'P PROJECTO';

                  var xproj5Years = [];

                  // xproj5Years // -1 para a lista ter número de anos igual a numberOfYearsToRead
                  for (var i = numberOfYearsToRead - 1; i >= 0; i--) {
                    xproj5Years.push(yearY4 - i);
                  }

                  // Ano
                  for (var i = 0; i < xproj5Years.length; i++) {
                    var xproj5Year = 'P' + disciplineUpperCase[0] + xproj5Years[i];

                    try {
                      var xproj5Provinces = seApp.folders.byName(xproj5PathStr + '/' + xproj5Year).folders.name();

                      // Província
                      for (var j = 0; j < xproj5Provinces.length; j++) {
                        var xproj5Province = xproj5Provinces[j];

                        // Projectos
                        var xproj5Folders = seApp.folders.byName(xproj5PathStr + '/' + xproj5Year + '/' + xproj5Province).folders;

                        for (var k = 0; k < xproj5Folders.length; k++) {
                          var folderName = xproj5Folders[k].name();
                          var folderNameItems = folderName.split(` ${ND} `);
                          var folderNameItemsL = folderNameItems.length;

                          if (folderNameItems[0] == 'Y' && folderNameItemsL == 6) {
                            var customer4Folders = folderName.split(` ${ND} `)[2];

                            var csAndCustomerAndObjItems = global5WhatReturnCsAndCustomerAndObj(
                              folderName,
                              folderNameItems,
                              whatReturn
                            ).split(' | ');

                            var cs = csAndCustomerAndObjItems[0];

                            if (action == 'ReadInvoiceInfoAndUpdateJSON') {
                              var xproj5ProjectFolders = seApp.folders.byName(
                                xproj5PathStr + '/' + xproj5Year + '/' + xproj5Province + '/' + folderName
                              ).folders;

                              if (cs[3] == 'C') {
                                for (var m = 0; m < xproj5ProjectFolders.length; m++) {
                                  var xproj5ProjectXd5Folder = xproj5ProjectFolders[m].name();

                                  if (xproj5ProjectXd5Folder.includes('P&C')) {
                                    var folderPAndCItems = xproj5ProjectXd5Folder.split(' | ');
                                    var dateInfo = folderPAndCItems[1];
                                    var invoicingInfo = folderPAndCItems[2];

                                    contractsInfo.push(`${cs} | ${customer4Folders} | ${invoicingInfo} | ${dateInfo}`);
                                  }
                                }
                              } else if (cs[3] == 'F') {
                                for (var l = 0; l < xproj5ProjectFolders.length; l++) {
                                  var xproj5ProjectFolder = xproj5ProjectFolders[l].name();

                                  if (xproj5ProjectFolder.includes('XD5')) {
                                    var xproj5ProjectXd5Folders = seApp.folders.byName(
                                      xproj5PathStr +
                                        '/' +
                                        xproj5Year +
                                        '/' +
                                        xproj5Province +
                                        '/' +
                                        folderName +
                                        '/' +
                                        xproj5ProjectFolder
                                    ).folders;

                                    for (var m = 0; m < xproj5ProjectXd5Folders.length; m++) {
                                      var xproj5ProjectXd5Folder = xproj5ProjectXd5Folders[m].name();

                                      if (xproj5ProjectXd5Folder.includes('P&C')) {
                                        var folderPAndCItems = xproj5ProjectXd5Folder.split(' | ');
                                        var dateInfo = folderPAndCItems[1];
                                        var invoicingInfo = folderPAndCItems[2];

                                        contractsInfo.push(`${cs} | ${customer4Folders} | ${invoicingInfo} | ${dateInfo}`);
                                      }
                                    }
                                  }
                                }
                              }
                            } else if (action == 'ReadFolderName') {
                              var csAndCustomerAndObj = csAndCustomerAndObjItems[1];

                              if (global5IsCs(cs)) {
                                xproj5xbuild5FoldersNames.push(csAndCustomerAndObj);
                              }
                            }
                          }
                        }
                      }
                    } catch (e) {
                      // Desactivado para não Alertar se não apanhar o Ano
                      //dAlert(`${e.message}❗️`, `Talvez não apanhou o ano ""${xproj5Year}""`)
                    }
                  }
                } catch (e) {
                  // Desactivado para não Alertar se não apanhar o Ano
                  //dAlert(`${e.message}❗️`, `Processando Projecto - Processando "${folderName}"`)
                }
              } else if (
                consultancyCateg == 'Construção' ||
                consultancyCateg == 'Empreitada' ||
                consultancyCateg == 'Fiscalização' ||
                consultancyCateg == 'Técnica'
              ) {
                try {
                  //var xo5PathStr = p5PathStrWithSuffixP5 + "/P5" + discipline[0].toUpperCase() + consultancyCateg[0] + " " + consultancyCateg.toUpperCase()

                  var xo5PathStr =
                    p5PathStrWithSuffixP5InCateg +
                    '/P5' +
                    discipline[0].toUpperCase() +
                    consultancyCateg[0] +
                    ' ' +
                    consultancyCateg.toUpperCase();

                  // Obras
                  var xo5Folders = seApp.folders.byName(xo5PathStr).folders;

                  for (var k = 0; k < xo5Folders.length; k++) {
                    var folderName = xo5Folders[k].name();
                    var folderNameItems = folderName.split(` ${ND} `);
                    var folderNameItemsL = folderNameItems.length;

                    if (folderNameItems[0] == 'Y' && folderNameItemsL == 6) {
                      var customer4Folders = folderName.split(` ${ND} `)[2];

                      var csAndCustomerAndObjItems = global5WhatReturnCsAndCustomerAndObj(
                        folderName,
                        folderNameItems,
                        whatReturn
                      ).split(' | ');

                      var cs = csAndCustomerAndObjItems[0];

                      if (action == 'ReadInvoiceInfoAndUpdateJSON') {
                        var xobras5ProjectFolders = seApp.folders.byName(xo5PathStr + '/' + folderName).folders;

                        if (cs[3] == 'C') {
                          for (var m = 0; m < xobras5ProjectFolders.length; m++) {
                            var xobras5ProjectXd5Folder = xobras5ProjectFolders[m].name();

                            if (xobras5ProjectXd5Folder.includes('P&C')) {
                              var folderPAndCItems = xobras5ProjectXd5Folder.split(' | ');
                              var dateInfo = folderPAndCItems[1];
                              var invoicingInfo = folderPAndCItems[2];

                              contractsInfo.push(`${cs} | ${customer4Folders} | ${invoicingInfo} | ${dateInfo}`);
                            }
                          }
                        } else if (cs[3] == 'F') {
                          for (var l = 0; l < xobras5ProjectFolders.length; l++) {
                            var xobras5ProjectFolder = xobras5ProjectFolders[l].name();

                            if (xobras5ProjectFolder.includes('XD5')) {
                              var xobras5ProjectXd5Folders = seApp.folders.byName(
                                xo5PathStr + '/' + folderName + '/' + xobras5ProjectFolder
                              ).folders;

                              for (var m = 0; m < xobras5ProjectXd5Folders.length; m++) {
                                var xobras5ProjectXd5Folder = xobras5ProjectXd5Folders[m].name();

                                if (xobras5ProjectXd5Folder.includes('P&C')) {
                                  var folderPAndCItems = xobras5ProjectXd5Folder.split(' | ');
                                  var dateInfo = folderPAndCItems[1];
                                  var invoicingInfo = folderPAndCItems[2];

                                  contractsInfo.push(`${cs} | ${customer4Folders} | ${invoicingInfo} | ${dateInfo}`);
                                }
                              }
                            }
                          }
                        }
                      } else if (action == 'ReadFolderName') {
                        var csAndCustomerAndObj = csAndCustomerAndObjItems[1];

                        if (global5IsCs(cs)) {
                          xproj5xbuild5FoldersNames.push(csAndCustomerAndObj);
                        }
                      }
                    }
                  }
                } catch (e) {
                  // Desactivado para não Alertar se não apanhar o Ano
                  //dAlert(`${e.message}❗️`, `Processando Obras - Processando "${folderName}"`)
                }
              }
            }
          }
        } catch (e) {
          // Desactivado para não Alertar se não apanhar o Ano
          //dAlert(`${e.message}!`)
        }

        if (action == 'ReadFolderName') {
          var filters = global5EnsureSpaceAfterCommaInStr(filterStrs).split(', ');

          var xproj5xbuild5FoldersNamesFiltered = [];
          for (var i = 0; i < filters.length; i++) {
            var filter = filters[i];

            for (var j = 0; j < xproj5xbuild5FoldersNames.length; j++) {
              var xproj5xbuild5FoldersName = xproj5xbuild5FoldersNames[j];

              var xproj5xbuild5FoldersNamesFilteredStr = xproj5xbuild5FoldersNamesFiltered.toString();

              if (
                xproj5xbuild5FoldersName.toLowerCase().includes(filter.toLowerCase()) &&
                !xproj5xbuild5FoldersNamesFilteredStr.includes(xproj5xbuild5FoldersName)
              ) {
                xproj5xbuild5FoldersNamesFiltered.push(xproj5xbuild5FoldersName);
              }
            }
          }

          // FILTERS BY XDIMW & XDIMX & BY INVOICING TYPE CHARECTER 1 (C - Cotação ou F - Factura)

          // 🔴 typOfInvoicingC1 se for "" inclui Cotações e Facturas
          //if (typeOfInvoicingC1 != "") {

          /*
					if (typeOfInvoicingC1 == "C" || typeOfInvoicingC1 == "F") {

						var xproj5xbuild5FoldersNames = xproj5xbuild5FoldersNames.filter(

							function(name) {
								var cs = name.split(" ").slice(-1).toString()

								if (company == "") {

									return cs[3] == typeOfInvoicingC1

								} else if (company == "X-DIM W") {

									return cs.slice(1,3).includes("DW") && cs[3] == typeOfInvoicingC1

								} else if (company == "X-DIM X") {

									return !cs.slice(1,3).includes("DW") && cs[3] == typeOfInvoicingC1
								}
							}
						)
					}
					*/

          var xproj5xbuild5FoldersNames = xproj5xbuild5FoldersNames.filter(function (name) {
            var cs = name.split(' ').slice(-1).toString();

            if (company == '') {
              if (typeOfInvoicingC1 == '') {
                return cs;
              } else if (typeOfInvoicingC1 == 'C' || typeOfInvoicingC1 == 'F') {
                return cs[3] == typeOfInvoicingC1;
              }
            } else if (company == 'X-DIM W') {
              if (typeOfInvoicingC1 == '') {
                return cs.slice(1, 3).includes('DW');
              } else if (typeOfInvoicingC1 == 'C' || typeOfInvoicingC1 == 'F') {
                return cs.slice(1, 3).includes('DW') && cs[3] == typeOfInvoicingC1;
              }
            } else if (company == 'X-DIM X') {
              if (typeOfInvoicingC1 == '') {
                return !cs.slice(1, 3).includes('DW');
              } else if (typeOfInvoicingC1 == 'C' || typeOfInvoicingC1 == 'F') {
                return !cs.slice(1, 3).includes('DW') && cs[3] == typeOfInvoicingC1;
              }
            }
          });

          var collator = new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' });
          xproj5xbuild5FoldersNames.sort(collator.compare);
          xproj5xbuild5FoldersNamesFiltered.sort(collator.compare);

          if (xproj5xbuild5FoldersNamesFiltered.length == 0 || filterStrs == '') {
            if (xproj5xbuild5FoldersNamesFiltered.length == 0) {
              var filterInfo = 'Filtros não encontrados ' + '(' + filterStrs + ')';
            }
            if (filterStrs == '') {
              var filterInfo = 'Filtro vazio';
            }

            var xproj5xbuild5FoldersNameselected = cfl2Str(
              xproj5xbuild5FoldersNames,
              'Lista de CSs Cliente | Lista completa | ' + xproj5xbuild5FoldersNames.length + '\n—\n' + filterInfo + '\n',
              xproj5xbuild5FoldersNames[xproj5xbuild5FoldersNames.length - 1],
              'm'
            );
          } else {
            var xproj5xbuild5FoldersNameselected = cfl2Str(
              xproj5xbuild5FoldersNamesFiltered,
              'Lista de CSs Cliente | Filtros (' + filterStrs + ') | ' + xproj5xbuild5FoldersNamesFiltered.length,
              xproj5xbuild5FoldersNamesFiltered[xproj5xbuild5FoldersNamesFiltered.length - 1],
              'm'
            );
          }

          return xproj5xbuild5FoldersNameselected.replace(/,/g, ', ');
        }

        // ----------------------

        try {
          var text = [];

          for (var i = 0; i < contractsInfo.length; i++) {
            var contractInfo = contractsInfo[i];
            var contractInfoItems = contractInfo.split(' | ');

            var id = i + 1;
            var cs = contractInfoItems[0];
            var customer = contractInfoItems[1];

            var invoicingInfo = contractInfoItems[2];

            var percentage = invoicingInfo.match(/[A-Z0-9.]*%/)[0];

            var dateInfoItems = contractInfoItems[3].split('-');
            var date = dateInfoItems[0].slice(0, 4) + '.' + dateInfoItems[0].slice(4, 6) + '.' + dateInfoItems[0].slice(-2);
            var dueDate = dateInfoItems[1].slice(0, 4) + '.' + dateInfoItems[1].slice(4, 6) + '.' + dateInfoItems[1].slice(-2);

            if (cs[3] == 'C') {
              var amount = invoicingInfo.match(/C([0-9,.]*)/)[1];

              text.push(
                `{"id":${id}, "cs":"${cs}", "customer":"${customer}", "amount":"${amount}", "percentage":"${percentage}", "date":"${date}", "dueDate":"${dueDate}"}`
              );
            } else if (cs[3] == 'F') {
              var amount = invoicingInfo.match(/F([0-9,.]*)/)[1];
              var dueAmount = invoicingInfo.match(/R([0-9,.]*)/)[1];

              text.push(
                `{"id":${id}, "cs":"${cs}", "customer":"${customer}", "amount":"${amount}", "dueAmount":"${dueAmount}", "percentage":"${percentage}", "date":"${date}", "dueDate":"${dueDate}"}`
              );
            }
          }
        } catch (e) {
          dAlert(
            `${e.message}❗️\n\nPreparando contractsInfo para gravar em JSON!`,
            `Talvez seja o item "${cs} ${customer} ${invoicingInfo}"`
          );
        }

        try {
          // 🔴 NAOTAR
          // Precisa de JSON.Stringfy para situação de text2
          //var text = JSON.stringify(text2)

          // Text já vem com aspas devidamente por não precisa de JSON.Stringfy
          var text = `[` + text.join(',\n') + `]`;

          /*
					var desktopString = currentApp.pathTo("desktop").toString()
					var file = `${desktopString}/MY JSON FILE.json`
					*/

          var file = '/Users/xd5-wmac/Dropbox/SWIFTUITEMPORAY/JSONInfoA5.json';

          // Converting to UTF8 to accept accents
          var outputStr = $.NSString.alloc.initWithUTF8String(text);
          // WRITING TO FILE
          outputStr.writeToFileAtomically(file, true);
        } catch (e) {
          dAlert(`${e.message}❗️`, `Gravando no ficheiro JSON!`);
        }
      }
    } else if (action == 'UpdateP&CFolderName') {
      var cs = invoiceNumberEdition;

      // if (cs[5] == "A") {
      if (cs[4] == 'A') {
        var xproj5PathStr = p5PathStrWithSuffixP5 + '/P5AA ARQUITECTURA';

        var xproj5Year = cs.slice(5, 7);

        var xproj5folderPathsObjByYear = seApp.folders.byName(xproj5PathStr).folders;
        var xproj5folderPathsObjByYearL = xproj5folderPathsObjByYear.length;

        for (var i = 0; i < xproj5folderPathsObjByYearL; i++) {
          // XFER01

          var folderNameYear = xproj5folderPathsObjByYear[i].name();

          if (folderNameYear.includes(xproj5Year)) {
            var folderNameYearFound = folderNameYear;
            break;
          }
        }

        var xproj5Province = cs.slice(7, 9);

        var xproj5folderPathsObjByProvince = seApp.folders.byName(xproj5PathStr + '/' + folderNameYearFound).folders;
        var xproj5folderPathsObjByProvinceL = xproj5folderPathsObjByProvince.length;

        for (var i = 0; i < xproj5folderPathsObjByProvinceL; i++) {
          // XFER01

          var folderNameProvince = xproj5folderPathsObjByProvince[i].name();

          if (folderNameProvince.includes(xproj5Province)) {
            var folderNameProvinceFound = folderNameProvince;
            break;
          }
        }
      } else if (cs[5] == 'A' || cs[5] == 'C' || cs[5] == 'E' || cs[5] == 'F') {
        if (cs[5] == 'A') {
          var xproj5PathStr = p5PathStrWithSuffixP5 + '/P5AA ASSISTÊNCIA';
        } else if (cs[5] == 'C') {
          var xproj5PathStr = p5PathStrWithSuffixP5 + '/P5AC CONSTRUÇÃO';
        } else if (cs[5] == 'E') {
          var xproj5PathStr = p5PathStrWithSuffixP5 + '/P5AE EMPREITADA';

          /* 🔴🔴🔴 DESACTIVADO PORQUE É DIRECTO NAS PROPOSTAS

				} else if (cs[5] == "F") {

					var xproj5PathStr = p5PathStrWithSuffixP5 + "/P5AF FISCALIZAÇÃO"
					*/
        }
      }

      // if (cs[5] == "A") {
      if (cs[4] == 'A') {
        var folderPathProjectStr = xproj5PathStr + '/' + folderNameYearFound + '/' + folderNameProvinceFound;
      } else {
        var folderPathProjectStr = xproj5PathStr;
      }

      var folderPathsObjByProject = seApp.folders.byName(folderPathProjectStr).folders;
      var folderPathsObjByProjectL = folderPathsObjByProject.length;

      for (var i = 0; i < folderPathsObjByProjectL; i++) {
        // XFER01

        var projectFolder = folderPathsObjByProject[i].name();

        if (projectFolder.includes(cs)) {
          var projectFolderFound = projectFolder;
          break;
        }
      }

      var folderPathStr = folderPathProjectStr + '/' + projectFolderFound;
      var foldersInProject = seApp.folders.byName(folderPathStr).folders;

      if (cs[3] == 'C') {
        // Cotação

        for (var i = 0; i < foldersInProject.length; i++) {
          // XFER01

          var folderInProject = foldersInProject[i].name();

          if (folderInProject.includes('P&C')) {
            var folderPAndC = folderInProject;
            break;
          }
        }

        var folderAlias = seApp.aliases.byName(folderPathStr + '/' + folderPAndC);

        var folderNameNew = folderPAndC.replace(/C\d[0-9,.]*\s[0-9.]*/, 'C' + quoteTotal + ' ' + chargedPercentage);
      } else if (cs[3] == 'F') {
        // Factura

        for (var i = 0; i < foldersInProject.length; i++) {
          // XFER01

          var folderInProject = foldersInProject[i].name();

          if (folderInProject.includes('XD5')) {
            var folderXd5 = folderInProject;

            var projectFolderXd5Folders = seApp.folders.byName(folderPathStr + '/' + folderInProject).folders;

            for (var j = 0; j < projectFolderXd5Folders.length; j++) {
              var folderInXD5 = projectFolderXd5Folders[j].name();

              if (folderInXD5.includes('P&C')) {
                var folderPAndC = folderInXD5;
                break;
              }
            }
          }
        }

        var folderAlias = seApp.aliases.byName(folderPathStr + '/' + folderXd5 + '/' + folderPAndC);

        var folderNameNew = folderPAndC
          .replace(/\d{8}-\d{8}/, dateAndDueDate)
          .replace(/R[0-9,.]*-F[0-9,.]*/, dueAmountAndTotalWithPrefix);
      }

      folderAlias.name = folderNameNew;
    }
  } catch (e) {
    dAlert(`${e.message}❗️`, ``);
  }
}

function global5WhatReturnCsAndCustomerAndObj(folderName, folderNameItems, whatReturn) {
  var cs = folderNameItems[1];
  var customerItems = folderNameItems[2].split(' ');
  var obj = folderNameItems[3];

  var customerFName = customerItems[0];
  var customerLName = customerItems[customerItems.length - 1];

  if (customerFName == customerLName) {
    if (whatReturn == 'csAndCustomerAndObj') {
      // Not Used
      var csAndCustomerAndObj = `${cs} ${customerFName} ${ND} ${obj}`;
    } else if (whatReturn == 'csAndCustomer') {
      // For Event

      var csAndCustomerAndObj = cs + ' ' + customerFName;
    } else if (whatReturn == 'customerAndCsNoBullet') {
      // For Subscrições
      var csAndCustomerAndObj = customerFName + ' ' + cs;
    }
  } else {
    //
    if (whatReturn == 'csAndCustomerAndObj') {
      // Not Used
      var csAndCustomerAndObj = cs + ' ' + customerFName + ' ' + customerLName + ` ${ND} ` + obj;
    } else if (whatReturn == 'csAndCustomer') {
      // For Event

      var csAndCustomerAndObj = cs + ' ' + customerFName + ' ' + customerLName;
    } else if (whatReturn == 'customerAndCsNoBullet') {
      var csAndCustomerAndObj = customerFName + ' ' + customerLName + ' ' + cs;
    }
  }

  return cs + ' | ' + csAndCustomerAndObj;
}

function global5IsCs(csToTest) {
  alert(`Use projectLib for global5ContractDetailsForEventAndFolderAndSubscricoes`, ``);

  // XDWFPA200902: String "XDWFPA", Number "200902"
  var csStringPart = csToTest.slice(0, 6);
  var csNumberPart = csToTest.slice(6, 12);

  if (isNaN(csStringPart) && csStringPart.length == 6 && !isNaN(csNumberPart) && csNumberPart.length == 6) {
    return true;
  } else {
    return false;
  }
}

// ---------------

function processSelectedObjectsStr(selectedObjectsStr) {
  return `${selectedObjectsStr ? ` - ${selectedObjectsStr}` : ''}`;
}

function fillWorkSchedule(docPages, workPhasesNameAndWeeks, scheduleDurationUnit) {
  var workScheduleTableName = 'projectPlanInPages'; //"workScheduleTable"
  var workScheduleTable = docPages.tables[workScheduleTableName];

  workScheduleTable.cells['B1'].value = scheduleDurationUnit;

  // Long dash "—"
  var workPhaseNames = workPhasesNameAndWeeks.map(workInfo => workInfo.split(' — ')[0]);
  var workPhaseWeekNumbers = workPhasesNameAndWeeks.map(workInfo => Number(workInfo.split(' — ')[1]));

  var workScheduleTableWeeks = sumAllByReduce(workPhaseWeekNumbers);

  var columnWidthCoeficient = 1 + 1 / workScheduleTableWeeks;

  var workPhasesWithEmptyWeekNumbers = [];
  var workWeekNumbers = [];
  for (var i = 0; i < workPhaseNames.length; i++) {
    var workPhase = workPhaseNames[i];
    var workPhaseAndEmptyWeek = [workPhase];
    var workWeekNumbersByPhase = [];

    for (var j = 0; j < workScheduleTableWeeks; j++) {
      if (i == 0) {
        workWeekNumbersByPhase.push((j + 1).toString());
      } else {
        workWeekNumbersByPhase.push('');
      }
      workPhaseAndEmptyWeek.push('');
    }

    workPhasesWithEmptyWeekNumbers.push(workPhaseAndEmptyWeek);
    workWeekNumbers.push(workWeekNumbersByPhase);
  }

  pagesApp.activate(); // 🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴 TEMPORAY

  selectionRange(workScheduleTable, 'A3:A3');
  menuLib.copyPaste(workPhasesWithEmptyWeekNumbers.join('\n'));

  selectionRange(workScheduleTable, 'B2:B2');
  menuLib.copyPaste(workWeekNumbers.join('\n'));
  delay(d0p3);

  var workScheduleTableUpdated = docPages.tables[workScheduleTableName];

  var workScheduleTableColumnsL = workScheduleTableUpdated.columnCount();
  var workScheduleTableColumnsLastLetter = appLib.letterFromLetterAndNumberPairs(workScheduleTableColumnsL);

  if (workScheduleTableColumnsL - 1 != 1) {
    // If is not one week, merge
    mergeCells(workScheduleTableUpdated, 'B1:' + workScheduleTableColumnsLastLetter + 1);
  }

  // 🔴🔴🔴 ------------------------------------------ FORMAT TABLE

  // -------------- COLUMNS

  for (var i = 0; i < workScheduleTableUpdated.columnCount(); i++) {
    if (i == 0) {
      workScheduleTableUpdated.columns[i].width = 200 * columnWidthCoeficient;
    } else {
      workScheduleTableUpdated.columns[i].width = 20 * columnWidthCoeficient;
    }
  }

  // -------------- TEXT

  var rangeName4Horizontal =
    'B3:' + appLib.letterFromLetterAndNumberPairs(workScheduleTableWeeks + 1) + (workPhaseNames.length + 2);

  alignHorizontal(workScheduleTableUpdated, rangeName4Horizontal, 'center');

  var rangeName4Vertical =
    'A3:' + appLib.letterFromLetterAndNumberPairs(workScheduleTableWeeks + 1) + (workPhaseNames.length + 2);

  alignVertical(workScheduleTableUpdated, rangeName4Vertical, 'center');

  // 🔴🔴🔴 ------------------------------------------  FILL THE WORK WEEKS

  var workWeekNumberStartColumn = 1;

  for (var i = 0; i < workPhaseNames.length; i++) {
    var workPhaseWeekNumber = workPhaseWeekNumbers[i];

    if (i == 0) {
      var columnsFirstLetter = 'B';
    } else {
      // Para a letra a seguir
      var columnsFirstLetter = appLib.letterFromLetterAndNumberPairs(workWeekNumberLastColumn + 1);
    }

    var workWeekNumberLastColumn = workWeekNumberStartColumn + workPhaseWeekNumber;

    var columnsLastLetter = appLib.letterFromLetterAndNumberPairs(workWeekNumberLastColumn);

    var startCell = columnsFirstLetter + (i + 3);

    workScheduleTable.ranges[startCell + ':' + columnsLastLetter + (i + 3)].backgroundColor = 'red';

    workScheduleTable.cells[startCell].value = workPhaseWeekNumber;

    workWeekNumberStartColumn += workPhaseWeekNumber;
  }
}

function moveFile(dischargePathStr, pathStrTo, dischargeInstitutionShortName) {
  var fileNames = seApp.folders.byName(dischargePathStr).files.name();

  var collator = new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' });
  fileNames.sort(collator.compare);

  var fileNameToMove = fileNames.filter(fileName => fileName.includes(dischargeInstitutionShortName))[0];

  var pathStrToMove = dischargePathStr + '/' + fileNameToMove;

  finderApp.move(Path(pathStrToMove), { to: Path(pathStrTo) });
}

function activityReimbursementsOrMiscellaneousExpenses(propSheetName, tableName) {
  var propSheet = docNumXG5.sheets[propSheetName];
  var table = propSheet.tables[tableName];

  var tableRowsL = table.rowCount() - 1;

  var tableInfo = [];

  for (var i = 2; i < tableRowsL; i++) {
    var iNum = i + 1;

    var quantity = table.cells['C' + iNum].value();

    if (quantity > 0) {
      var activity = table.cells['A' + iNum].value();
      var unit = table.cells['B' + iNum].value();
      var unitAmount = table.cells['D' + iNum].value();
      var amount = formatNumber(table.cells['E' + iNum].value());

      tableInfo.push(activity + '\t' + unit + '\t' + quantity + '\t' + unitAmount + '\t' + amount);
    }
  }

  return tableInfo;
}

function deleteEmptyRowsInPagesTable(tableToDeleteRows) {
  // ----- Get empty ROWS
  var tableColumnL = tableToDeleteRows.columnCount();

  var rowCountToDelete = 0;

  for (var i = 0; i < tableToDeleteRows.rowCount(); i++) {
    // Coluna A
    var cellEmptyCheck = tableToDeleteRows.rows[i].cells[0].value();

    // Última coluna a direita
    var cellTotalCheck = tableToDeleteRows.rows[i].cells[tableColumnL - 1].value();

    if (cellEmptyCheck == null && cellTotalCheck == null) {
      rowCountToDelete += 1;
    }

    if (rowCountToDelete == 1) {
      var rowIndexToDeleteStart = i;
    }
  }

  // ----- Delete empty ROWS
  for (var i = 0; i < rowCountToDelete; i++) {
    tableToDeleteRows.rows[rowIndexToDeleteStart].delete();
  }
}

function tableTeamForWagesOrTasks(propSheetName, tableName) {
  var propSheet = docNumXG5.sheets[propSheetName];
  var table = propSheet.tables[tableName];

  var teamTasks = [];
  var teamWages = [];

  for (var i = 0; i < table.rowCount(); i++) {
    var iNum = i + 1;

    var memberCheck = table.cells['H' + iNum].value();

    if (memberCheck == 1) {
      // Estas variáveis incluem o cabeçalho
      var memberName = table.cells['A' + iNum].value();
      var position = table.cells['B' + iNum].value();
      var task = table.cells['C' + iNum].value();
      var period = table.cells['D' + iNum].value();

      var standadWages = table.cells['E' + iNum].value();
      var wages = table.cells['F' + iNum].value();

      if (i > 0) {
        var standadWages = formatNumber(standadWages);
        var wages = formatNumber(wages);
      }

      teamTasks.push(memberName + '\t' + position + '\t' + task);
      teamWages.push(memberName + '\t' + position + '\t' + task + '\t' + period + '\t' + standadWages + '\t' + wages);
    }
  }

  return {
    teamTasks: teamTasks,
    teamWages: teamWages,
  };
}

function copyAndPasteTables(tableNamesToCopyAndOPaste) {
  var paragraphs = docPagesInProposta.bodyText.paragraphs; // Whole document
  pagesApp.activate();

  var tableNamesToCopyAndOPasteL = tableNamesToCopyAndOPaste.length;

  for (var h = 0; h < tableNamesToCopyAndOPasteL; h++) {
    var tableNameToCopyAndOPaste = tableNamesToCopyAndOPaste[h];

    delay(d0p1);
    menuLib.selectAll();
    delay(d0p1);
    seApp.keyCode(124);
    delay(d0p1);
    seApp.keyCode(126, { using: 'shift down' }); // Selection one line / table
    delay(d0p1);
    seApp.keyCode(126, { using: 'shift down' }); // Selection one line / table
    delay(d0p1);
    seApp.keystroke('x', { using: 'command down' });

    for (var i = 0; i < paragraphs.length; i++) {
      var paragraph = paragraphs()[i];

      if (paragraph == tableNameToCopyAndOPaste) {
        delay(d0p1);
        paragraphs[i].set(tableNameToCopyAndOPaste);
        delay(d0p1);
        seApp.keyCode([76, 76]); // Press Enter
        delay(d0p1);
        seApp.keystroke('v', { using: 'command down' });

        break;
      }
    }

    // Se for última tabela apagar a última página de tabelas feita com com Page Break

    if (h == tableNamesToCopyAndOPasteL - 1) {
      delay(d3);
      menuLib.selectAll();
      delay(d3);
      seApp.keyCode(124);
      seApp.keyCode(51); // Delete
    }
  }
}

function ptOptionsLists(tableName, rowStart) {
  var table = propSheet.tables[tableName];
  var tableRowsL = table.rowCount();
  var specsOptions = [];

  for (var i = rowStart; i < tableRowsL; i++) {
    var infoColumnD = table.cells['D' + (i + 1)].value();

    if (infoColumnD != undefined) {
      specsOptions.push(infoColumnD);
    }
  }

  return specsOptions;
}

function pageBreaking() {
  var paragraphs = docPagesInProposta.bodyText.paragraphs; // Whole document
  pagesApp.activate();

  for (var i = 0; i < paragraphs.length; i++) {
    var paragraph = paragraphs()[i];

    if (paragraph == 'pageBreak') {
      delay(d0p1);
      paragraphs[i].set('');
      delay(d0p1);

      menuLib.doMenu('Pages', 'Insert', 'Page Break');
      delay(d0p1);

      seApp.keyCode(124);
      delay(d0p1);
      seApp.keyCode(51); // Delete
    }
  }
}

function ptInfoLists(tableName, optionsSel, scheduleDurationUnit) {
  numbersApp.activate();
  var table = propSheet.tables[tableName];
  var tableRowsL = table.rowCount();

  selectionRange(table, 'E1:E' + tableRowsL);
  delay(d0p3);
  seApp.keyCode(51); // Delete
  delay(d0p3);

  var infoLines = [];
  var heading1List = [];
  var heading2List = [];
  var heading3List = [];

  var workPhasesNameAndWeeks = [];

  for (var i = 0; i < tableRowsL; i++) {
    var iNum = i + 1;
    var trackIdInfoLine = table.cells['B' + iNum].value();

    for (var j = 0; j < optionsSel.length; j++) {
      var trackIdCurrent = optionsSel[j].split(' - ')[0];

      if (trackIdInfoLine == trackIdCurrent) {
        var workScheduleTrack = table.cells['A' + iNum].value();

        var infoLine = table.cells['D' + iNum].value();

        table.cells['E' + iNum].value = '•';

        var workPhaseWeekNumber = table.cells['A' + iNum].value();

        if (workPhaseWeekNumber > 0) {
          // null é zero

          // Long dash "—"
          var workPhaseWeekNumberWithPrefix = ' — ' + workPhaseWeekNumber;

          var infoLine4WorkSchedule = infoLine.split(' / ')[0];

          workPhasesNameAndWeeks.push(infoLine4WorkSchedule + workPhaseWeekNumberWithPrefix);
        }

        // PARA IMPEDIR 2 pageBreaks seguidos
        if (infoLine == 'pageBreak') {
          if (infoLines[infoLines.length - 1] != 'pageBreak') {
            infoLines.push(infoLine);
          }
        } else {
          if (workPhaseWeekNumber > 0) {
            // workPhaseWeekNumber == 1 ? weekUnit = "Semana" : weekUnit = "Semanas"

            // D Dias, S Semanas
            if (scheduleDurationUnit[0] === 'd') {
              workPhaseWeekNumber == 1 ? (weekUnit = 'dia') : (weekUnit = 'dias');
            } else if (scheduleDurationUnit[0] === 'm') {
              workPhaseWeekNumber == 1 ? (weekUnit = 'mês') : (weekUnit = 'meses');
            } else if (scheduleDurationUnit[0] === 's') {
              workPhaseWeekNumber == 1 ? (weekUnit = 'semana') : (weekUnit = 'semanas');
            }

            var infoLineWithWeekNumber = infoLine.replace(' / ', workPhaseWeekNumberWithPrefix + ` ${weekUnit} / `);

            infoLines.push(infoLineWithWeekNumber);
          } else {
            infoLines.push(infoLine);
          }
        }

        var trackIdHeading = table.cells['C' + iNum].value();

        try {
          // Por que tem empty "null" para trackIdHeading onde não tem numeração
          var trackIdHeadingItems = trackIdHeading.split('.');
          var trackIdHeadingItemsL = trackIdHeadingItems.length;

          if (trackIdHeadingItemsL == 1) {
            heading1List.push(infoLine);
          } else if (trackIdHeadingItemsL == 2) {
            heading2List.push(infoLine);
          } else if (trackIdHeadingItemsL == 3) {
            if (workPhaseWeekNumber > 0) {
              heading3List.push(infoLineWithWeekNumber);
            } else {
              heading3List.push(infoLine);
            }
          }
        } catch {
          //
        }
      }
    }
  }
  return [infoLines, heading1List, heading2List, heading3List, workPhasesNameAndWeeks];
}

function numberingHeadings(headingList, headingNumber) {
  var paragraphs = docPagesInProposta.bodyText.paragraphs; // Whole document
  pagesApp.activate();

  for (var i = 0; i < paragraphs.length; i++) {
    var paragraph = paragraphs()[i];
    var paragraphSixCharacters = paragraph.slice(0, 6);

    for (var h = 0; h < headingList.length; h++) {
      var heading = headingList[h];

      if (paragraph.includes(heading)) {
        if (heading.includes(' / IDENTIFIER')) {
          paragraphs[i].set(paragraph.replace(' / IDENTIFIER', ''));
        } else {
          paragraphs[i].set(heading);
        }
        delay(d0p1);

        // Selecionar um caracter é suficiente para aplicar Paragrapgh Styles
        seApp.keyCode(123, { using: 'shift down' });

        delay(d0p1);

        if (headingNumber == 'H1') {
          seApp.keyCode(122); // F1
        } else if (headingNumber == 'H2') {
          //seApp.keyCode(120) // F2

          if (!xd5DocumentsStr.includes(paragraphSixCharacters)) {
            seApp.keyCode(120); // F2
          }
        } else if (headingNumber == 'H3') {
          seApp.keyCode(99); // F3
        }
        delay(d0p1);

        seApp.keyCode(96); // F5 Numbered
        delay(d1); // Era d0p3

        // delay(3)

        systemLib.arrowRight(1); // 20230713 Added to activate button which was not availbel in this version at this stage.
        delay(d0p3);

        //pagesAppControllerP.windows[0].splitterGroups[0].scrollAreas[1].groups.at(3).radioGroups[0].radioButtons.byName("Continue from previous")

        pagesAppControllerP.windows[0].splitterGroups[0].scrollAreas[1].groups[3].radioGroups[0].radioButtons
          .byName('Continue from previous')
          .click();

        delay(d0p1);

        if (headingNumber == 'H2') {
          seApp.keyCode(48); // Tab
          delay(d0p1);
        } else if (headingNumber == 'H3') {
          seApp.keyCode(48); // Tab
          delay(d0p1);
          seApp.keyCode(48); // Tab
          delay(d0p1);
        }

        // PASTE TABLES IN MEMORY
        if (heading.toLowerCase().includes('programa de necessidades')) {
          seApp.keyCode(124);
          delay(d0p1);
          seApp.keyCode(76);
          delay(d0p1);
          seApp.keystroke('v', { using: 'command down' });
        }

        break;
      }
    }
  }
}

function pdfText(pathStr) {
  var pdfURL = $.NSURL.fileURLWithPath(pathStr);
  var pdfDoc = $.PDFDocument.alloc.initWithURL(pdfURL);
  var pdfPage1 = pdfDoc.pageAtIndex(0);
  return $(pdfPage1.string).js; // Returns " " is scanned PDF
}

function previousTabPathStr() {
  finderApp.activate();
  delay(d1);

  seApp.keyCode(48, { using: ['shift down', 'control down'] });
  delay(d1);

  var itemListSelection = finderApp.selection();

  try {
    if (itemListSelection[0].kind() == 'Folder') {
      return decodeURI(itemListSelection[0].url()).slice(7).replace(/\/$/, '');
    } else {
      return decodeURI(itemListSelection[0].container().url()).slice(7).replace(/\/$/, '');
    }
  } catch (error) {
    dAlert(`${error.name}`, `${error.message}\n\n—\nTalvez não selecionou nenhuma pasta ou ficheiro!`);

    //currentApp.displayAlert("Seleciona uma pasta ou ficheiro!", {buttons: "Cancel", cancelButton: 1})
  }
}

function dAlert(theTitle, message, theButtons, theDefaultButton, theCancelButton) {
  if (theButtons == undefined) {
    currentApp.displayAlert(theTitle, { message: message });
  } else {
    currentApp.displayAlert(theTitle, {
      message: message,
      buttons: theButtons,
      defaultButton: theDefaultButton,
      cancelButton: theCancelButton,
    });
  }
}

function dDialog(theTitle, theDefaultAnswer, theButtons, theDefaultButton, theCancelButton) {
  if (theButtons == undefined) {
    return currentApp.displayDialog(theTitle, { defaultAnswer: theDefaultAnswer }).textReturned;
  } else {
    return currentApp.displayDialog(theTitle, {
      defaultAnswer: theDefaultAnswer,
      buttons: theButtons,
      defaultButton: theDefaultButton,
      cancelButton: theCancelButton,
    }).textReturned;
  }
}

function cfl(theList, thePrompt, theDefaultItems, multipleStatus) {
  if (multipleStatus == undefined) {
    return currentApp.chooseFromList(theList, { withPrompt: thePrompt, defaultItems: theDefaultItems });
  } else if (multipleStatus == 'm') {
    return currentApp.chooseFromList(theList, {
      withPrompt: thePrompt,
      defaultItems: theDefaultItems,
      multipleSelectionsAllowed: true,
    });
  }
}

function cfl2Str(theList, thePrompt, theDefaultItems, multipleStatus) {
  if (multipleStatus == undefined) {
    return currentApp.chooseFromList(theList, { withPrompt: thePrompt, defaultItems: theDefaultItems }).toString();
  } else if (multipleStatus == 'm') {
    return currentApp
      .chooseFromList(theList, { withPrompt: thePrompt, defaultItems: theDefaultItems, multipleSelectionsAllowed: true })
      .toString();
  }
}

function processSave(docPages, destinyFolderStr, fileName) {
  const filePath = appLib.saveDoc(docPages, destinyFolderStr, `${dateY4M2D2__H2M2S2}-V1`, fileName, `pages`, true, 'dateAtStart');

  return filePath;
}

function getURL() {
  return safariApp.windows[0].currentTab.url();
}

function openURL(urlInput) {
  const firstWindow = safariApp.windows[0];
  const tab = safariApp.Tab({ url: urlInput });
  firstWindow.tabs.push(tab);
  firstWindow.currentTab = tab;
  delay(d1);

  var urlSubscriptionCurrentTab = getURL();

  // "favorites://" is link of blank page
  if (urlSubscriptionCurrentTab == 'favorites://') {
    delay(d0p3);

    // Open Location - garantir que que barra de endereço esteja activa (Spend activa imediatamente mas Create Invoice não)
    seApp.keystroke('l', { using: 'command down' });
    delay(d0p3);

    saApp.setTheClipboardTo(urlInput);
    delay(d1);

    seApp.keystroke('v', { using: 'command down' });
    delay(d1);

    seApp.keyCode(76); // Press Enter
    delay(d1);
  }
}

// --------------------- MENSAGEM

// GET GROUPS / MENSAGEM
function messageGroupsArraysNames() {
  var theGroups = contactsApp.groups.whose({ name: { _contains: arrayGroupIdentifier } });

  var theGroupsLength = theGroups.length;

  var accounts = [];
  for (var i = 0; i <= theGroupsLength - 1; ++i) {
    // -1 para coincidir a indexação <= condiciona

    accounts[i] = i + 1 + '. ' + theGroups[i].name(); // Numeração e nome
  }
  return accounts;
}

// GET PEOPLE & PHONE NUMBERS / MENSAGEM
function peopleAndPhonesArraysValues() {
  var peopleArrayLength = filteredGroup.people().length;
  var accounts = [];
  for (var i = 0; i <= peopleArrayLength - 1; ++i) {
    // -1 para coincidir a indexação <= condiciona

    accounts[i] = filteredGroup.people()[i].name();

    try {
      accounts[i] = filteredGroup.people()[i].phones()[1].value() + ' • ' + accounts[i];
    } catch {
      accounts[i] = filteredGroup.people()[i].phones()[0].value() + ' • ' + accounts[i];
    }
  }
  return accounts;
}

// ------- NEW DATE

function createListFromLoop(listInput, subItem) {
  var theItems = []; // Edited accounts to theItems

  for (var i = 0; i < listInput.length; ++i) {
    //theItems[i] = (i + 1) + ". " + listInput[i][subItem]; // Adicionamos mais 1 para numeração correcta na listagem e depois vamos subtrair 1 acima para indexação corrrecta;
    theItems[i] = listInput[i][subItem];
  }

  return theItems;
}
