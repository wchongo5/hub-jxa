        for (var i = 2; i < tableWagesFormBySpeciality.rowCount() - 3; i++) {
          var iNum = i + 1;

          var consultancyCheck = tableWagesFormBySpeciality.cells['E' + iNum].value();

          if (consultancyCheck == 1) {
            // Estas variáveis incluem o cabeçalho
            var specialityName = tableWagesFormBySpeciality.cells['B' + iNum].value();
            var amount = tableWagesFormBySpeciality.cells['G' + iNum].value();

            if (i > 2) {
              var amount = formatNumber(amount);
            }

            wagesBySpeciality.push(specialityName + '\t0.00\t0.00\t0.00\t0.00\t' + amount);
          }
        }

        saApp.setTheClipboardTo(wagesBySpeciality.join('\n'));
