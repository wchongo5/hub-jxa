            placeHolderTexts_.whose({ tag: thisTag })[0].set(dateAndDueDateAndDuration);
          } else if (thisTag == 'objAndCustomer') {
            placeHolderTexts_.whose({ tag: thisTag })[0].set(objAndCustomer);
          } else if (thisTag == 'constructorTypeAndName') {
            placeHolderTexts_.whose({ tag: thisTag })[0].set(constructorTypeAndName);
          } else if (thisTag == 'constructorName') {
            placeHolderTexts_.whose({ tag: thisTag })[0].set(constructorName);
          }
        }

        pagesApp.activate();
        delay(d0p1);

        var docPages = docPagesInContract;

        processSave(
          docPages,
          destinyFolderStr,
          `XG5${invoiceCs[4]} ${ND} CONTRATO OBRA ${ND} ${formatNumber(
            totalAmount
          )} ${ND} ${constructorTypeAndName.toUpperCase()}`
        );
      }
    }
  }
} else if (production == 'Mensagem') {
