          }

          if (intervention == 'As Built') {
            var ptOptionsSel = ['A5PAB'].concat(ptOptionsSel);
          }
        } else if (consultancyCode == 'U5P') {
          var ptOptionsSel = ['U5P'].concat(ptOptionsSel);
        }
      } else if (consultancyCode == 'A5F') {
        var ptOptionsSel = ['A5F'].concat(ptOptionsSel);

        if (intervention == 'Construção') {
          var ptOptionsSel = ['A5FCO'].concat(ptOptionsSel);
        }
      }

