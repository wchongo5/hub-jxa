        var creditCode = dDialog('Código da recarga', '');

        var theOperator = cfl2Str(['Mcel', 'Movitem', 'Vodacom'], 'Operadora', 'Vodacom');

        var theMessageString = `Olá minha filha,\nAqui está crédito de ${creditAmount} da ${theOperator}:\n${creditCode}`;

        var message = dDialog('Mensagem (Edição)', theMessageString);
      } else {
        var message = dDialog('Mensagem (Edição)', '\n');
      }
    } else if (groupsNamesSelected.includes('WalterTest5')) {
      var message = 'Test5 WalterOnlyMcel - MapOut!';
    }

    messagesApp.activate();

    for (var i = 0; i < contactsOfSelected.length; i++) {
