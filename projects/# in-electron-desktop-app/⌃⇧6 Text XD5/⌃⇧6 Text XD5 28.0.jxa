      // tablePFPTInfoInPages
      tablePFPTInfoInPages.cells['A3'].value = proposalType + '\n' + quoteCs;

      tablePFPTInfoInPages.cells['A9'].value = `Referência: ${
        proposal === 'Manifestação de Interesse' ? referenceNumber1 : referenceNumber2
      }`;
    }

    tablePFPTInfoInPages.cells['A4'].value = lot;
    tablePFPTInfoInPages.cells['A5'].value = dateAlert;
    tablePFPTInfoInPages.cells['A6'].value = localAndDate;

    if (proposal == 'Manifestação de Interesse' || proposal == 'Proposta Técnica') {
      // Esta info só usa tabela em PT
