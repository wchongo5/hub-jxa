        multipleSelectionsAllowed: true,
      }); // Array
    }

    var contactsOfSelected = selectedPeopleArray.map(function (newVariable) {
      return newVariable.split(' • ')[0];
    });

    if (groupsNamesSelected.includes('Dia Inter dos Trabalhadores')) {
      var message = 'Feliz 1º de Maio,\n' + 'O Dia Internacional dos Trabalhadores.\n\n' + yearY4 + ' X-DIM';
    } else if (groupsNamesSelected.includes('Dia da Mulher Moçambicana')) {
      var message = 'Feliz 7 de Abril,\nO dia da Mulher Moçambicana!\n\n' + yearY4;
    } else if (groupsNamesSelected.includes('Dia da X-DIM')) {
      var message =
        'Feliz 19 de Setembro,\nO Dia da X-DIM.\n\n' +
        'Os ' +
        TimeYYXDIM +
        ' anos de existência oficial.\n\n' +
        yearY4 +
        ' X-DIM';
    } else if (groupsNamesSelected.includes('Azaldo')) {
      var theVariable = cfl2Str(
        ['Hi, How are you with family?', 'Viva, Reforcei a C90 com 10,000.00 (X para operações) transferido para BIM. Abraços!'],
        'Referência',
        'Viva, Reforcei a C90 com 10,000.00 (X para operações) transferido para BIM. Abraços!'
      );

      var theMessageSelection = dDialog('Mensagem', theMessageSelection);
    } else if (groupsNamesSelected.includes('Melindo')) {
      var theMessageSelection = cfl2Str(
        [
          'Energia',
          'Transferência - Rancho',
          'Transferência - X',
          '---------------',
          greeting + ' Como estão?',
          'Manda cumprimentos a todos!',
          'Ok. Manda cumprimentos a família!',
        ],
        'Referência',
        'Transferência - Rancho'
      );

      var theGreetingSend = 'Manda cumprimentos!';

      if (theMessageSelection == 'Ok. Manda cumprimentos a família!' || theMessageSelection == 'Manda cumprimentos a todos!') {
        var message = dDialog('Mensagem', theMessageSelection);
      } else {
        if (theMessageSelection == 'Energia') {
          var theCredelecValue = dDialog('Valor da Energia', '');
          var theCredelecCode = dDialog('Código da Energia', '');

          var message = dDialog(
            'Referência',
            greeting + '\nEnergia de ' + formatNumber(theCredelecValue) + ' — ' + theCredelecCode + '\n\nManda cumprimentos!'
          );
        } else if (theMessageSelection == 'Transferência - Rancho') {
          var iw1AndIa5MonthBuying = dDialog('Valor para IW1 + IA5', '7420.00');
          var theIA5MonthBuying = dDialog('Valor para IA5 - Chiconela', '1000.00');

          var message = dDialog(
            'Referência',
            greeting +
              '\nTransferi ' +
              formatNumber(iw1AndIa5MonthBuying) +
              ' dos quais ' +
              formatNumber(theIA5MonthBuying) +
              ' para mamã Izabel.\n\n' +
              theGreetingSend
          );
        } else if (theMessageSelection == 'Transferência - X') {
          var message = dDialog('Referência', greeting + '\nTransferi 0.00\n\n' + theGreetingSend);
        }
      }
    } else if (groupsNamesSelected.includes('Tancya')) {
      var theEmojiList = ['💋', '🌹', '🌺', '💐', '❤️', '🌸', '🌼'];

      var theMessageSelection =
