    {
      referenceNumberWithDate: referenceNumber2WithDate,
      referenceNumberIncrement: referenceNumberIncrement2,
    },
  ];

  numbersApp.activate();
  docNumXG5.activeSheet.set(docNumXG5.sheets[propSheetName]);

  for (var b = 0; b < proposals.length; b++) {
