    // --------------- PAGES

    pagesApp.activate();

    var placeHolderTexts_ = docPagesInProposta.placeholderTexts;
    var theseTags = placeHolderTexts_.tag();

    var uniqueTags = [];

    for (var i = 0; i < theseTags.length; i++) {
      var thisTag = theseTags[i];
      uniqueTags.push(thisTag);
    }

    //PFPT - TableInfo
    tablePFPTInfoInPages.cells['A1'].value = customer;
    tablePFPTInfoInPages.cells['A2'].value = obj;

    if (proposal == 'Proposta Financeira') {
