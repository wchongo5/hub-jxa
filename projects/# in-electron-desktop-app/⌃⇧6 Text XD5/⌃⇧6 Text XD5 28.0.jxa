      var tableInvoicingDetails = docPages.tables['tableInvoicingDetails'];

      // 🔴 As células com merge aplicavam inofrmação nas duas células desactivado o merge automaticamente. Já usei em Numbers sem problemas considerando o nome da primeira célula.

      tableInvoicingDetails.cells['A1'].value = dateWithDateStr;
