      var tableWagesFormBySpeciality = propSheet.tables['V1-Por especialidade'];

      // Usa Loop não set value to cell para ter possibilidade de escrevr o valor da proposta por Extenso.

      for (var i = 0; i < uniqueTags.length; i++) {
        var thisTag = uniqueTags[i];

        if (thisTag == 'requestType') {
          placeHolderTexts_.whose({ tag: thisTag })[0].set(requestType);
        } else if (thisTag == 'requestDate') {
          placeHolderTexts_.whose({ tag: thisTag })[0].set(requestDate);
        }
      }

      if (theWageType == 'V1-Por especialidade') {
