    if (proposal == 'Proposta Financeira') {
      var proposalTrack = proposal;
    }

    // -------------- PAGES

    // ----- PF
    pagesApp.activate();

    if (proposal == 'Proposta Financeira') {
      var docPagesInProposta = pagesApp.Document({ documentTemplate: pagesApp.templates['PropostaF'] }).make();
    } else if (proposal == 'Manifestação de Interesse' || proposal == 'Proposta Técnica') {
      var ptOptions = ptOptionsLists('Proposta Técnica - Opções', 1);

      // Projecto (A5P, U5P) e não Fiscalização (A5F)
      if (consultancyCode[2] == 'P') {
        /*
				if (consultancyCode == "A5P") {
					var commentsAndSuggestionsCode =
				} else if (consultancyCode == "U5P") {

				}
				*/

        //var ptOptions = ptOptions.concat("---------------", "A5CS - Comentários e Sugestões TdR")

        // A5P // A5P

        var ptOptions = ptOptions.concat('---------------', consultancyCode.slice(0, 2) + 'CS - Comentários e Sugestões TdR');
      }

      if (allowTecnicalBaseDocsSelection) {
        currentApp.activate();
        var ptOptionsSel = cfl(
          ptOptions,
          'Proposta Técnica',
          [
            'PE5 - Perfil da Empresa',
            'CA5 - Cartas Abonatórias',
            'RE5 - Referências da Empresa',
            consultancyCode.slice(0, 2) + 'CS - Comentários e Sugestões TdR',
          ],
          'm'
        );
      } else {
        var ptOptionsSel = ptOptions;
      }

      if (consultancyCode == 'A5P' || consultancyCode == 'U5P') {
        // PX - Projecto visto que P5 é plataforma 5
        //var ptOptionsSel = ["PX"].concat(ptOptionsSel) // NÃO USADO AGORA

        if (consultancyCode == 'A5P') {
