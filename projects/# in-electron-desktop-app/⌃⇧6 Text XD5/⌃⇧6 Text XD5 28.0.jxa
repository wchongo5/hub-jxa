          ],
          'Mensagem',
          'Amora, Transferi 13,000.00 para BIM, o valor para rancho.'
        ) +
        ' ' +
        theEmojiList[Math.floor(Math.random() * theEmojiList.length)];

      var message = dDialog('Mensagem (Edição)', theMessageSelection);
    } else if (groupsNamesSelected.includes('RKA')) {
      var theMessageSelection = cfl2Str(['Escrever', '---------------', 'Crédito'], 'Mensagem', 'Crédito');

      if (theMessageSelection == 'Crédito') {
