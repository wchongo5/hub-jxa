    var proposalCode = `${proposalItemsFiltered[0][0]}${proposalItemsFiltered[1][0]}`;
    var proposalNameWithQuoteCs = `${proposal.toUpperCase()} ${quoteCs}`;

    var docPages = docPagesInProposta;

