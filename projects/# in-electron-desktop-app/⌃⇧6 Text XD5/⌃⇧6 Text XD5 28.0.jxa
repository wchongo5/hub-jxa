  var chargedPercentage = numbersQuoteChargedPercentage(tableInputs1);

  var tableHeaderInfo = propSheet.tables['HeaderInfo'];
  var scheduleDurationUnit = tableHeaderInfo.cells['C4'].value().split(' ')[1];

  var tableProposalInfo = propSheet.tables['Table - ProposalInfo'];
  var tableCustomerAndObjectInfo = propSheet.tables['Table - CustomerAndObjectInfo'];

  // ----- Comum
  var consultancyCode = tableProposalInfo.cells['A1'].value();
  var intervention = tableProposalInfo.cells['A2'].value();
  // var quoteCs = tableProposalInfo.cells["B1"].value()
  var theWageType = tableProposalInfo.cells['A3'].value();

  // const objectAndNumberOfStories = tableProposalInfo.cells['B2'].value();

  // More
  var technicalProposalOrInterestExpression = tableProposalInfo.cells['A4'].value();
  var commentsAndSuggestions = tableProposalInfo.cells['A6'].value();
  var serviceMethodology = tableProposalInfo.cells['A7'].value();

  var lot = tableProposalInfo.cells['A9'].value().toUpperCase();
  if (lot == '—') {
    var lot = ' ';
  } // Se for "", célula que busca info aqui será "0", não ""

  // ----- Proposta Técnica/Financeira
  var requestType = tableProposalInfo.cells['A5'].value();
  var requestDate = tableProposalInfo.cells['B5'].value();

  if (requestDate == null) {
    var requestDate = '';
  }

  // --------------- CUSTOMER & OBJECT INFO
  var customer = tableCustomerAndObjectInfo.cells['A1'].value();
  var customerShortName = tableCustomerAndObjectInfo.cells['A11'].value();
  var obj = tableCustomerAndObjectInfo.cells['A2'].value();
  var dateAlert = tableCustomerAndObjectInfo.cells['A6'].value();
  var localAndDate = tableCustomerAndObjectInfo.cells['A8'].value();

  // CP Concurso Público
  var dateToUpdateInPropostasInCP = tableCustomerAndObjectInfo.cells['B8'].value();
  var proposalTypeEnvelope = tableCustomerAndObjectInfo.cells['A4'].value();
  var proposalType = tableCustomerAndObjectInfo.cells['A5'].value();

  if (technicalProposalOrInterestExpression == 'Manifestação de Interesse') {
    var proposals = ['Manifestação de Interesse'];
  } else if (technicalProposalOrInterestExpression == 'Proposta Técnica') {
    var proposals = ['Proposta Financeira', 'Proposta Técnica'];
  }

