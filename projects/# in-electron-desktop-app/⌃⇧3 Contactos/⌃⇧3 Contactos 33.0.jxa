    if (contactDetails.includes('Email')) {
      var theEmail = dialog('Email', '');
      var email = contactsApp.Email({ label: 'Work', value: theEmail });
      person.emails.push(email);
    }

    if (contactDetails.includes('URL')) {
      var theUrl = dialog('URL', '');
      var url = contactsApp.Url({ label: 'home page', value: theUrl });
      person.urls.push(url);
    }

    if (contactDetails.includes('Telefone')) {
      var telephoneNumbers = documentLib
        .ensureSpaceAfterCommaInStr(dialog(`Números separados por vírgula e com ou sem prefixos, se for nacionais`, ''))
        .split(', ');

      for (var i = 0; i < telephoneNumbers.length; i++) {
        var telephoneNumber = telephoneNumbers[i].replace(/ /g, '');

        if ((telephoneNumber.startsWith('+258') && telephoneNumber.length === 12) || telephoneNumber.length === 8) {
          var operator = 'Fixo';

          if (telephoneNumber.startsWith('+258')) {
            var telephoneNumber = telephoneNumber.replace('+258', '');
          }

          var phone = contactsApp.Phone({ label: operator, value: '+258' + telephoneNumber });
        } else {
          if (telephoneNumber.startsWith('+258')) {
            var telephoneNumber = telephoneNumber.replace('+258', '');
          }

          // Mozambican mobile operators
          // telephoneNumber.slice(0,2). Exclude international numbers beacuse they start with "+"
          if (['82', '83', '84', '85', '86', '87'].includes(telephoneNumber.slice(0, 2))) {
            if (telephoneNumber.slice(0, 2) == '82' || telephoneNumber.slice(0, 2) == '83') {
              var operator = 'Mcel';
            } else if (telephoneNumber.slice(0, 2) == '84' || telephoneNumber.slice(0, 2) == '85') {
              var operator = 'Vodacom';
            } else if (telephoneNumber.slice(0, 2) == '86' || telephoneNumber.slice(0, 2) == '87') {
              var operator = 'Movitel';
            }

            var phone = contactsApp.Phone({ label: operator, value: '+258' + telephoneNumber });
          } else {
            var operator = cfl(['Angola', 'RSA', 'Swaziland'], 'Seleciona operadora', 'RSA');

            var phone = contactsApp.Phone({ label: operator, value: telephoneNumber });
          }
        }

        person.phones.push(phone);
      }
    }

