} else if (operation == 'Delete - All Groups') {
  while (contactsApp.groups.length > 0) {
    contactsApp.groups[0].delete();
  }

  contactsApp.save();
} else if (operation == 'Modify') {
  var lastNameOldAndNew = dialog('Nomes - Serão copiado!', 'oldLastName | newLastNameEMPRESAouSINGULAR');

  saApp.setTheClipboardTo(lastNameOldAndNew);

  var theOldLastName = lastNameOldAndNew.split(' | ')[0];
  var theNewLastName = lastNameOldAndNew.split(' | ')[1];

  var peopleToChange = contactsApp.people.whose({ lastName: theOldLastName })();

  var peopleToChangeList = [];

  for (var i = 0; i < peopleToChange.length; i++) {
    peopleToChangeList.push(i + 1 + ' ' + peopleToChange[i].lastName() + ' ' + peopleToChange[i].firstName());
  }

  currentApp.displayAlert(
    peopleToChange.length + ' contactos — Last Name de ' + theOldLastName + ' para ' + theNewLastName + '?',
    { message: peopleToChangeList.join('\n'), buttons: ['Cancel', 'OK'], defaultButton: 2, cancelButton: 1 }
  );

  peopleToChange.forEach(person => {
    let lastName_ = person.lastName();

    //if(lastName.startsWith("Test5Last")) {
    if (lastName_ == theOldLastName) {
      person.lastName = theNewLastName;
    }
  });
  contactsApp.save();
} else if (operation == 'Update/Create Groups') {
  var startDateTime = new Date();

  // var groupsInfoSelected = [
  // 	["P1F - Banco •", ["P1F", "SB"], "and"],
  // 	// ["P1F - Fornecedor •", ["P1F"], ""],
  // 	// ["P1F - Graphisoft - ACBuy & Support", ["Note", ["GraphisoftSupportXD5", "ArchicadBuyXD5"]], ""],
  // 	// ["P1F - Graphisoft - ACBuy & Support", ["Note", ["GraphisoftSupportXD5"]], ""],
  // 	// ["P5A - #Empresa", ["P5A01AE"], ""],
  // 	// ["P5A - #Individual", ["P5A01A"], ""],
  // ]

  var groupsInfo = contactLib.getGroupsInfo();

  /*
	const groupNames = groupsInfo.map(item => item[0])
	const groupNamesD = groupNames.filter(
		name => name.includes("P5") && (name.includes("#Empresa"))
	)

	var groupNamesSelected = cfl(groupNames, "Seleciona operadora", groupNamesD, "m")

	const groupsInfoSelected = groupsInfo.filter(group => groupNamesSelected.includes(group[0]));
	*/

  const groupsInfoSelected = contactLib.getGroupsInfoSelected(groupsInfo);

  const _groups = contactsApp.groups;
  const groupNamesSet = new Set(_groups.name()); // Use a Set for O(1) lookup
  const _people = contactsApp.people();

  _people.forEach(person => {
    groupsInfoSelected.forEach(([groupNameInput, filters, filtersRelation]) => {
      updateGroups(contactsApp, groupNamesSet, person, groupNameInput, filters, filtersRelation);
    });
  });

  contactsApp.save();

  const groupsInfoTxt = groupsInfoSelected
    .map((item, index, array) => {
      return `${index + 1}. Nome: ${item[0]} | Filtros: ${item[1].join(', ')} | Relação de filtros: ${item[2]}`;
    })
    .join('\n');

  var endDateTime = new Date();
  var processTimeElapsed = timeElapsed(startDateTime, endDateTime);

  const { dateY4M2D2__H2M2S2: end_dateY4M2D2__H2M2S2 } = formatDateV3(endDateTime).formats;

  // ARCHIVE "Update/Create Groups" PROCCESSED groupsInfoSelected
  objCLib.writeToFile(
    `${inboxPathStr}/LOG - CONTACTOS - PROCCESSED GROUPSINFO ${end_dateY4M2D2__H2M2S2} (${groupsInfoSelected.length}) (${processTimeElapsed}).txt`,
    groupsInfoTxt
  );

  // ------------ Check "Contacts App" has names that "groupsInfo" does not have and vice-versa

  const groupsInfoNames = groupsInfo.map(item => item[0]);

  const groupNames = sortArray(contactsApp.groups.name());

  const groupNamesNotInContactsApp = groupsInfoNames.filter(item => !groupNames.includes(item));

  if (groupNamesNotInContactsApp.length > 0) {
    alert(`Nomes que estão em "groupsInfo" mas não estão em "Contacts App":`, `${groupNamesNotInContactsApp.join('\n')}`);
  }

  const groupNamesNotInGroupsInfo = groupNames.filter(item => !groupsInfoNames.includes(item));

  if (groupNamesNotInGroupsInfo.length > 0) {
    alert(`Nomes que estão em "Contacts App" mas não estão em "groupsInfo":`, `${groupNamesNotInGroupsInfo.join('\n')}`);
  }
}

// ------------------------------------------ FUNCTIONS
// ------------ NEW
function updateGroups(contactsApp, groupNamesSet, person, groupNameInput, filters, filtersRelation) {
  try {
    // Extract person information once
    let personInfoToTrack = extractPersonInfo(person, filters);

    if (filters[0] === 'Note') {
      var filters = filters[1];
    }

    if (shouldProcessPerson(personInfoToTrack, filters, filtersRelation)) {
      processPerson(contactsApp, groupNamesSet, person, person.name(), groupNameInput);
    }
  } catch (error) {
    //   console.error('Error processing person:', error);

    alert(`Error processing person:`, `${error.message}`);
  }
}

function extractPersonInfo(person, filters) {
  if (filters[0] === 'Note') {
    return person.note() || ''; // Fallback to empty string if note is null or undefined
  } else {
    // Check if lastName exists and is not null or undefined
    const lastName = person.lastName();
    if (lastName) {
      var filter1Items = filters[0].split(' ');

      if (filter1Items.length > 1) {
        // For ["P1F10BTS GRAPHISOFT"] from ["P1F - Graphisoft", ["P1F10BTS GRAPHISOFT"], ""],
        return lastName;
      } else {
        // For ["P1F", "SB"] from ["P1F - Banco •", ["P1F", "SB"], "and"]
        return lastName.split(' ')[0];
      }
    } else {
      return ''; // Fallback to empty string if lastName is null or undefined
    }
  }
}

function shouldProcessPerson(personInfoToTrack, filters, filtersRelation) {
  // Check if personInfoToTrack is null or undefined
  if (personInfoToTrack == null) {
    return false;
  }

  if (filtersRelation === 'or') {
    // Ensure the filter is not an empty string
    return filters.some(filter => filter && personInfoToTrack.includes(filter));
  } else if (filtersRelation === 'and') {
    // Ensure the filter is not an empty string
    return filters.every(filter => filter && personInfoToTrack.includes(filter));
  } else {
    // Check for empty string filter
    return filters[0] && personInfoToTrack.includes(filters[0]);
  }
}

function processPerson(contactsApp, groupNamesSet, person, personName, groupNameInput) {
  if (groupNamesSet.has(groupNameInput)) {
    let existingGroup = contactsApp.groups[groupNameInput];
    let existingGroupNames = existingGroup.people.name();

    if (!existingGroupNames.includes(personName)) {
      contactsApp.add(person, { to: existingGroup });
    }
  } else {
    let newGroup = contactsApp.Group({ name: groupNameInput });
    contactsApp.groups.push(newGroup);
    contactsApp.add(person, { to: newGroup });
    groupNamesSet.add(groupNameInput); // Update the set
  }
}

// ------------

function extraNoteStatus(prompt) {
  return cfl2Str(['Não', 'Sim'], prompt, 'Não');
}

function peopleAll() {
  var peopleAll = [];
  var peopleArray = contactsApp.people();

  for (var i = 0; i < peopleArray.length; ++i) {
    peopleAll.push(peopleArray[i].name());
  }
  return peopleAll;
}

// peopleInGroup
function peopleInGroup() {
  var peopleInGroup = [];
  var theGroups = contactsApp.groups();

  for (var i = 0; i < theGroups.length; ++i) {
    var thePeople = theGroups[i].people();
    for (var j = 0; j < thePeople.length; ++j) {
      peopleInGroup.push(theGroups[i].name() + ' | ' + thePeople[j].name());
    }
  }
  return peopleInGroup;
}

// peopleWithEmails
function peopleWithEmails() {
  var peopleWithEmails = [];
  var peopleArray = contactsApp.people();

  for (var i = 0; i < peopleArray.length; ++i) {
    try {
      if (peopleArray[i].emails()[0].value()) {
        peopleWithEmails.push(peopleArray[i].name() + '	•	' + peopleArray[i].emails()[0].value());
      }
    } catch {
      //
    }
  }
  return peopleWithEmails;
}

// peopleWithOutEmails
function peopleWithOutEmails() {
  var peopleWithOutEmails = [];
  var peopleArray = contactsApp.people();

  for (var i = 0; i < peopleArray.length; ++i) {
    try {
      if (peopleArray[i].emails()[0].value()) {
        // If error, does not have email
        //
      }
    } catch {
      peopleWithOutEmails.push(peopleArray[i].name());
    }
  }
  return peopleWithOutEmails;
}

function getPartnerOption() {
  var cooperatorStatus = cfl2Str(['Não', 'Sim'], 'Parceiro', 'Não');

  if (cooperatorStatus == 'Sim') {
    return 'P';
  } else {
    return '';
  }
}
