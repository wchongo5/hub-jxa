  );

  if (contactsOption == 'Contactos') {
    //peopleAll

    var peopleAll = peopleAll().sort();
    var theReference = cfl2Str(peopleAll, contactsOption + ' ' + peopleAll.length, peopleAll[0]);
  } else if (contactsOption == 'Contactos por Grupo') {
    // peopleInGroup

    var peopleInGroup = peopleInGroup().sort();

    var theReference = cfl2Str(peopleInGroup, contactsOption + ' ' + peopleInGroup.length, peopleInGroup[0]);
  } else if (contactsOption == 'Contactos com Emails') {
    //peopleWithEmails

    var peopleWithEmails = peopleWithEmails().sort();
    var theReference = cfl2Str(peopleWithEmails, contactsOption + ' ' + peopleWithEmails.length, peopleWithEmails[0]);
  } else if (contactsOption == 'Contactos sem Emails') {
    //peopleWithOutEmails

    var peopleWithOutEmails = peopleWithOutEmails().sort();
