];

const nowFormatted = formatDateV3(new Date());

if (!nowFormatted) {
  throw new Error(`"Data" inválida`);
}

const {
  components: {
    year: { Y4: yearY4 },
    month: { M1: monthM1, M2: monthM2, long: monthLong },
  },
  formats: { dateY4M2D2, dateY4M2D2__H2M2S2 },
} = nowFormatted;

var operation = cfl2Str(
  ['Create - Contact', 'Contactos & Grupos', 'Delete - All Groups', 'Modify', '---------------', 'Update/Create Groups'],
  'Operação',
  'Create - Contact'
);

if (operation == 'Create - Contact') {
  var timesByContact = dialog('Quantos contactos?\n\n— Actualiza automaticamente contactos em JSON (não inclui Notas)', '1');

  for (var h = 0; h < timesByContact; h++) {
    var { ddEntryPadded: ddEntryStart } = ddEntryWithPreviousAndOrNext30DaysDisplay(
      `Anteriores`,
      `Contacto ${
        h + 1
      }/${timesByContact}\n\nPessoa - Dia do conhecimento\n\n—\nSe o contacto for "P5I Beneficiário Indefinido ou Novo ou Todos", a data é da compra da propriedade.`
    );

    //var mmNumTrack = monthSelector("Mês", monthM1, monthLong, "returnMm")
    var mmNumTrack = monthSelector('Mês', monthM1, monthLong, 'auto_mm');

    if (Number(mmNumTrack) > Number(monthM2)) {
      // >= em Extrato Start Date
      var yyyyTrack = Number(yearY4) - 1;
    } else {
      var yyyyTrack = yearY4;
    }

    var personKnewDate = dialog('Pessoa - Data do conhecimento', yyyyTrack + mmNumTrack + ddEntryStart);

    var personIntermediaryStatus = cfl2Str(['Não', 'Sim'], 'Tem Pessoa Intermediária?', 'Não');

    if (personIntermediaryStatus == 'Não') {
      var personIntermediary = '';
    } else if (personIntermediaryStatus == 'Sim') {
      var contactFilter2Input = dialog('Filtro para encontrar o contacto!', '');
      var contactFilter1Auto = 'personIntermediary';
      var newContactDescrip = ''; // Sem efeito mas necessário para posição de "NoFilters"

      // NO NEED TO UPDATE contactFinder DEL5 IN FUTURE
      var personIntermediary = contactLib.contactFinderToCreate(
        contactFilter1Auto,
        contactFilter2Input,
        'Pessoa Intermediária - Em P5I inclui Walter (Eu)',
        newContactDescrip,
        'NoFilters'
      );
    }

    var contactPlataform = cfl2Str(['1. P1', '3. P3', '5. P5'], 'Plataforma', '5. P5');

    if (contactPlataform == '1. P1') {
      var contactCategory = cfl2Str(
        ['1. P1M - Ministério & Plus', '---------------', '2. P1FB - Bens', '3. P1FS - Serviços'],
        'Operação',
        '2. P1FB - Bens'
      );

      var { provinceNumberPadded } = spaceLib.getProvinceInfo([''], 'Maputo (Cidade)');

      var contactCategoryCode = contactCategory.split(' ')[1];

      if (contactCategory == '1. P1M - Ministério & Plus') {
        var contactCategSub = cfl2Str(
          [
            '0 Instituto Nacional de Estatística / INE',
            '---------------',
            '1 Ministério da Saúde / MISAU',
            '2 Ministério da Educação e Desenvolvimento Humano / MINED',
            '3 Ministério do Trabalho,  Emprego e Segurança Social / MITESS',
            '4 Ministério da Economia e Finanças / MEF',
            '5 Ministério das Obras Públicas, Habitação e Recursos Hídricos / MOPHRH',
            '6 Ministério do Interior / MINT',
            '7 Ministério da Defesa Nacional / MDN',
            '8 Ministériostério da Administração Estatal e Função Pública / MAEFP',
            '9 Ministério da Ciência e Tecnologia, Ensino Superior e Técnico Profissional / MCTESTP',
            '10 Ministério dos Negócios Estrangeiros e Cooperação / MINEC',
            '11 Ministério da Indústria e Comércio / MIC',
            '12 Ministério da Justiça e Assuntos Constitucionais e Religiosos / MJCR',
            '13 Ministério da Terra, Ambiente e Desenvolvimento Rural / MITADER',
            '14 Ministério da Agricultura e Segurança Alimentar / MASA',
            '15 Ministério da Juventude e Desportos / MJD',
            '16 Ministério da Cultura e Turismo / MICULTUR',
            '17 Ministério dos Transportes e Comunicações / MTC',
            '18 Ministério do Mar, Águas Interiores e Pescas / MIMAIP',
            '19 Ministério dos Recursos Minerais e Energia / MIREME',
            '20 Ministério do Género, Criança e Acção Social / MGCAS',
            '21 Ministério dos Combatentes / MICO',
          ],
          'Ministério & Plus',
          '2 Ministério da Educação e Desenvolvimento Humano / MINED'
        );

        var contactCategorySubCode = cfl2Str(
          ['Próprio Ministério & Plus', 'Secção do Ministério / Funcionário'],
          'Opção',
          'Secção do Ministério / Funcionário'
        );

        var contactCategorySubCodeTrack = contactCategorySubCode;

        var categPosition = numberLib.addZero(contactCategSub.split(' ')[0]);

        if (contactCategorySubCode == 'Próprio Ministério & Plus') {
          var contactCategorySubCode = contactCategSub.split(' / ')[1];
        } else if (contactCategorySubCode == 'Secção do Ministério / Funcionário') {
          var contactFilter2Input = dialog('Segundo filtro - Ignore para não usá-lo!', '');

          var contactFilter1Auto = contactCategoryCode + provinceNumberPadded + categPosition;

          var contactCategorySubCode = contactLib.contactFinderToCreate(
            contactFilter1Auto,
            contactFilter2Input,
            contactFilter1Auto + ' | Contactos desta categoria + 2º filtro',
            'NOVA SECÇÃO',
            'WithFilters'
          );

          var contactCategorySubCode = contactCategorySubCode.split(/P[1-5]\w+\s/)[1];

          if (contactCategorySubCode == 'NOVA SECÇÃO') {
            var contactCategorySubCode = dialog('NOVA SECÇÃO', '');
          }
        }

        var contactCategoryCodeFinal = contactCategoryCode + provinceNumberPadded + categPosition + ' ' + contactCategorySubCode;
      } else if (contactCategory == '2. P1FB - Bens' || contactCategory == '3. P1FS - Serviços') {
        var contactGroup = cfl2Str(['Empresa', 'Individual'], 'Tipo', 'Empresa');

        if (contactCategory == '2. P1FB - Bens') {
          var goodsList = [
            'Água',
            'Carro',
            'Escritório',
            'Gráfica (Facturas, Recibos)',
            'Interiores - Desenhados, Prontos - (Iluminação, Equipamento sanitário, Mobiliário, Etc)',
            'Material - Betão, Cofragem, Electricidade, Geral, Inertes, Prefabricado, Solares, Tinta, Vidro e Alumínio',
            'Óptica',
            'Peças',
            'Tecnologia — Equipamento - (Aparelhagem, Computador, Geleira, Etc), Software, Multiservices',
            'Vestuário',
          ];

          // COPY goodsList
          //saApp.setTheClipboardTo(goodsList.join("\n"))

          var contactCategSub = documentLib.replaceAccentC1(
            cfl2Str(
              goodsList,
              'Bens',
              'Material - Betão, Cofragem, Electricidade, Geral, Inertes, Prefabricado, Solares, Tinta, Vidro e Alumínio'
            )
          );

          if (contactCategSub.includes('Interiores')) {
            var contactCategSubExtra1 = cfl2Str(['Desenhados', 'Prontos'], 'Tipo', 'Prontos');
          } else if (contactCategSub.includes('Material')) {
            var contactCategSubExtra1 = cfl2Str(
              ['Betão', 'Cofragem', 'Electricidade', 'Geral', 'Inertes', 'Prefabricado', 'Solares', 'Tinta', 'Vidro e Alumínio'],
              'Tipo',
              'Geral'
            );
          } else if (contactCategSub.includes('Tecnologia')) {
            var contactCategSubExtra1 = cfl2Str(['Equipamento', 'Software', 'Multiservices'], 'Tipo', 'Software');
          }
        } else if (contactCategory == '3. P1FS - Serviços') {
          // COPY servicesList
          //saApp.setTheClipboardTo(servicesList.join("\n"))

          var contactCategSub = cfl2Str(servicesList, 'Serviços', manutencaoItem);

          if (contactCategSub.includes('Alimentação')) {
            var contactCategSubExtra1 = cfl2Str(alimentacaoList, 'Tipo de ' + contactCategSub, 'Comida');
          } else if (contactCategSub.includes('Comunicação')) {
            var contactCategSubExtra1 = cfl2Str(comunicacaoList, 'Tipo de ' + contactCategSub, 'Informação');
          } else if (contactCategSub.includes('Formação')) {
            var contactCategSubExtra1 = cfl2Str(formacaoList, 'Tipo de ' + contactCategSub, 'Archicad');
          } else if (contactCategSub.includes('Gestão')) {
            var contactCategSubExtra1 = cfl2Str(gestaoList, 'Tipo de ' + contactCategSub, 'Geral');

            if (contactCategSubExtra1 == 'Compra') {
              var contactCategSubExtra2 = cfl2Str(gestaoCompraList, 'Tipo de ' + contactCategSubExtra1, 'Viatura');
            }
          } else if (contactCategSub.includes('Higienização')) {
            var contactCategSubExtra1 = cfl2Str(higienizacaoList, 'Tipo de ' + contactCategSub, 'Cabeleireiro');
          } else if (contactCategSub.includes('Locação')) {
            var contactCategSubExtra1 = cfl2Str(locacaoList, 'Tipo de ' + contactCategSub, 'Equipamento');
          } else if (contactCategSub.includes('Informática')) {
            var contactCategSubExtra1 = cfl2Str(informaticaList, 'Tipo de ' + contactCategSub, 'Impressão');
          } else if (contactCategSub.includes('Protecção')) {
            var contactCategSubExtra1 = cfl2Str(proteccaoList, 'Tipo de ' + contactCategSub, 'Guarda');
          } else if (contactCategSub.includes('Manutenção')) {
            var contactCategSubExtra1 = cfl2Str(manutencaoList, 'Tipo de ' + contactCategSub, 'Viatura');

            if (contactCategSubExtra1 == 'Eletrodoméstico') {
              var contactCategSubExtra2 = cfl2Str(manutencaoElectrodomesticosList, 'Tipo de ' + contactCategSubExtra1, 'TV');
            }
            if (contactCategSubExtra1 == 'Tecnologias') {
              var contactCategSubExtra2 = cfl2Str(manutencaoTecologiasList, 'Tipo de ' + contactCategSubExtra1, 'Mac');
            }
            if (contactCategSubExtra1 == 'Viatura') {
              var contactCategSubExtra2 = cfl2Str(manutencaoViaturaList, 'Tipo de ' + contactCategSubExtra1, 'Mecânica');
            }
          } else if (contactCategSub.includes('Transporte')) {
            var contactCategSubExtra1 = cfl2Str(transporteList, 'Tipo de ' + contactCategSub, 'Terrestre');

            var contactCategSubExtra2 = cfl2Str(
              ['Encomnda', 'Material', 'Passageiros'],
              'Tipo de Mercadoria' + `\n\n—\n🔴 Taxista está em "Passageiros"!\n`,
              'Material'
            );

            var contactCategSubExtra2TrackPassengers = contactCategSubExtra2;
          }
        }

        if (contactGroup == 'Empresa') {
          var contactFilter2Input = dialog('Segundo filtro - Ignore para não usá-lo!', '');

          var contactFilter1Auto = contactCategory.slice(3, 6) + provinceNumberPadded + contactCategory[6] + contactCategSub[0];

          var contactCompanyName = contactLib.contactFinderToCreate(
            contactFilter1Auto,
            contactFilter2Input,
            contactFilter1Auto + ' | Contactos desta categoria + 2º filtro',
            'NOVA EMPRESA',
            'WithFilters'
          );

          var contactCompanyName = contactCompanyName.split(/P[1-5]\w+\s/)[1];

          if (contactCompanyName == 'NOVA EMPRESA') {
            var contactCompanyName = dialog('NOVA EMPRESA', '');
          }
        } else {
          var contactCompanyName = 'INDIVIDUAL';
        }

        // contactCategSubExtra1 == "" é usado no loop 2º contacto pois vem com variável contactCategSubExtra1 = ""
        if (contactCategSubExtra1 == undefined || contactCategSubExtra1 == '') {
          var contactCategSubExtra1 = '';
        } else {
          var contactCategSubExtra1 = contactCategSubExtra1[0];
        }

        // contactCategSubExtra2 == "" é usado no loop 2º contacto pois vem com variável contactCategSubExtra2 = ""
        if (contactCategSubExtra2 == undefined || contactCategSubExtra2 == '') {
          var contactCategSubExtra2 = '';
        } else {
          var contactCategSubExtra2 = contactCategSubExtra2[0];
        }

        // P1FB
        var contactCategoryCodeFinal =
          contactCategoryCode.slice(0, 3) +
          provinceNumberPadded +
          contactCategoryCode[3] +
          contactCategSub[0] +
          contactCategSubExtra1 +
          contactCategSubExtra2 +
          ' ' +
          contactCompanyName;
      }
    } else if (contactPlataform == '3. P3') {
      var contactCategory = cfl2Str(
        [
          '1. P3C - Consultoria',
          '2. P3E - Empreiteiro',
          '3. P3F - Familiar',
          '4. P3O - Obra',
          '5. P3P - Parceria',
          '6. P3T - Técnicos',
          '9. P3X - X-DIM (Ainda)',
        ],
        'Secção',
        '6. P3T - Técnicos'
      );

      // 🔴 "9. P3X - X-DIM (Ainda)" deverão contemplar "Recrutamento R18.2"

      var { provinceNumberPadded } = spaceLib.getProvinceInfo([''], 'Maputo (Cidade)');
      var contactCategoryCode = contactCategory.split(' ')[1];

      if (
        contactCategory == '1. P3C - Consultoria' ||
        contactCategory == '2. P3E - Empreiteiro' ||
        contactCategory == '5. P3P - Parceria' ||
        contactCategory == '6. P3T - Técnicos'
      ) {
        if (
          contactCategory == '1. P3C - Consultoria' ||
          contactCategory == '2. P3E - Empreiteiro' ||
          contactCategory == '5. P3P - Parceria'
        ) {
          if (contactCategory == '1. P3C - Consultoria') {
            var contactCategSub = cfl2Str(['Ambiental', 'Construção', 'Topografia', 'Urbanismo'], 'Especialização', 'Construção');
          } else if (contactCategory == '2. P3E - Empreiteiro') {
            var contactCategSub = cfl2Str(
              ['E - Edifícios', 'P - Estradas e Pontes', 'T - Tudo (Edifícios, Estradas e Pontes)'],
              'Especialização',
              'E - Edifícios'
            );
          }

          if (contactCategSub) {
            var contactCategSubC1 = contactCategSub[0];
          }

          var contactFilter2Input = dialog('Segundo filtro - Ignore para não usá-lo!', '');
          var contactFilter1Auto = contactCategory.slice(3, 6);

          var newContactDescrip =
            'NOV' + contactCategory.substr(-1).toUpperCase() + ' ' + contactCategory.split(' ')[3].toUpperCase();

          var contactCompanyName = contactLib.contactFinderToCreate(
            contactFilter1Auto,
            contactFilter2Input,
            contactFilter1Auto + ' | Contactos desta categoria + 2º filtro',
            newContactDescrip,
            'WithFilters'
          );

          var contactCompanyNameTrack = contactCompanyName.split(/P[1-5]\w+\s/)[1];

          if (contactCompanyNameTrack == newContactDescrip) {
            if (
              contactCategory == '1. P3C - Consultoria' ||
              contactCategory == '2. P3E - Empreiteiro' ||
              contactCategory == '6. P3T - Técnicos'
            ) {
              var partnerOption = getPartnerOption();
            }

            var contactCompanyName = dialog(newContactDescrip, '');

            if (contactCategory == '2. P3E - Empreiteiro') {
              var contractorLevel = '-C' + dialog(`Classe do empreiteiro`, `3`);
            }
          } else {
            // P3C10C NOME // Parceiro: P3C10CP NOME
            // P3E10E-C7 NOME // Parceiro: P3E10EP-C7 NOME

            // P de Parceiria é sempre caracter 7
            if (contactCompanyName[6] == 'P') {
              var partnerOption = 'P';
            }

            if (contactCategory == '2. P3E - Empreiteiro') {
              var contractorLevel = contactCompanyName.match(/-C\w/)[0];
              var contactCompanyName = contactCompanyName.split(contractorLevel + ' ')[1];
            } else {
              var contactCompanyName = contactCompanyName.split(/P[1-5]\w+\s/)[1];
            }
          }

          if (contractorLevel === undefined) {
            contractorLevel = '';
          }
          if (contactCategSubC1 === undefined) {
            contactCategSubC1 = '';
          }
          if (partnerOption === undefined) {
            partnerOption = '';
          }

          var contactCategoryCodeFinal =
            contactCategoryCode +
            provinceNumberPadded +
            contactCategSubC1 +
            partnerOption +
            contractorLevel +
            ' ' +
            documentLib.changeCase(contactCompanyName, 'UPPER');
        } else if (contactCategory == '6. P3T - Técnicos') {
          var contactCategSub = cfl2Str(
            [
              'Ambiental',
              'Arquitecto',
              'Biólogo',
              'Civil',
              'Contabilista',
              'Electrotécnico',
              'Electrotécnico & Som',
              'Geólogo',
              'Geotécnico',
              'Hidráulico',
              'Médico',
              'Mecânico',
              'Paisagista',
              'Topógrafo',
              '---------------',
              'Medidor',
              'Projectista',
            ],
            'Técnico',
            'Civil'
          );

          if (
            contactCategSub == 'Civil' ||
            contactCategSub.includes('Electrotécnico') ||
            contactCategSub == 'Topógrafo' ||
            contactCategSub == 'Medidor' ||
            contactCategSub == 'Projectista'
          ) {
            var technicianDegree = cfl2Str(['01 Superior', '02 Médio', '03 Abaixo de Médio'], 'Nível', '01 Superior');

            var contactCategSub = contactCategSub + technicianDegree.split(' ')[0];
          }

          var partnerOption = getPartnerOption();

          var contactCategoryCodeFinal =
            contactCategoryCode + provinceNumberPadded + partnerOption + ' ' + documentLib.changeCase(contactCategSub, 'UPPER');
        }
      } else if (contactCategory == '3. P3F - Familiar') {
        var contactCategSub = cfl2Str(['Anastância', 'Walter', '---------------', 'Casal'], 'Parceiro ou Casal', 'Walter');

        if (contactCategSub == 'Casal') {
          var contactCategSubExtra1 = cfl2Str(['Afilhado', 'Comadre', 'Friend', 'Padrinhos'], 'Tipo', 'Comadre');

          var contactCategoryCodeFinal =
            contactCategoryCode +
            provinceNumberPadded +
            contactCategSub[0] +
            ' ' +
            documentLib.changeCase(contactCategSubExtra1, 'UPPER');
        } else {
          var contactCategorySubExtra1Gender = cfl2Str(['Feminino', 'Masculino'], 'Género', 'Masculino');

          if (contactCategorySubExtra1Gender == 'Feminino') {
            var GLC = 'a'; // Gender Last Character
            var brotherGender = 'Irmã';
          } else {
            var GLC = 'o';
            var brotherGender = 'Irmão';
          }

          // Ilustre é designação para "CONHECIDA/CONHECIDO"

          var contactCategSubExtra1 = cfl2Str(
            [
              'Ilustre',
              '---------------',
              'Cunhad' + GLC,
              'Escolar',
              'Friend',
              brotherGender,
              'Kid',
              'Mãe',
              'Prim' + GLC,
              'Sobrinh' + GLC,
              'Ti' + GLC,
              'Vovo',
            ],
            'Tipo\n\n—\nIlustre é Conhecido\n',
            'Prim' + GLC
          );

          if (contactCategSubExtra1 == 'Escolar') {
            var contactCategorySubExtra1School = cfl2Str(
              ['Primária', 'Secundária', 'Pré-Universitária', 'Universidade'],
              'Referência',
              'Secundária'
            );

            if (contactCategorySubExtra1School == 'Pré-Universitária') {
              var contactCategorySubExtra1SchoolID = 'PU';
            } else {
              var contactCategorySubExtra1SchoolID = contactCategorySubExtra1School[0];
            }

            var contactCategSubExtra1 = contactCategSubExtra1 + '-' + contactCategorySubExtra1SchoolID;
          }

          if (
            contactCategSubExtra1 == 'Cunhad' + GLC ||
            contactCategSubExtra1 == 'Friend' ||
            contactCategSubExtra1 == 'Mãe' ||
            contactCategSubExtra1 == 'Prim' + GLC ||
            contactCategSubExtra1 == 'Sobrinh' + GLC ||
            contactCategSubExtra1 == 'Ti' + GLC ||
            contactCategSubExtra1 == 'Vovo'
          ) {
            if (contactCategSubExtra1 == 'Mãe') {
              var contactCategSubExtra2 = 'Indirecta';
            } else {
              var contactCategSubExtra2 = cfl2Str(['Direct' + GLC, 'Indirect' + GLC], 'Tipo', 'Indirect' + GLC);
            }

            var contactCategoryCodeFinal =
              contactCategoryCode +
              provinceNumberPadded +
              contactCategSub[0] +
              contactCategSubExtra1[0] +
              contactCategSubExtra2[0] +
              ' ' +
              documentLib.changeCase(contactCategSubExtra1, 'UPPER');
          } else {
            var contactCategoryCodeFinal =
              contactCategoryCode +
              provinceNumberPadded +
              contactCategSub[0] +
              ' ' +
              documentLib.changeCase(contactCategSubExtra1, 'UPPER');
          }
        }
