var imagePathStr = `${pathLib.getP1PathStr()}/P1T TEMPLATES/P1T5P XA5 ${ND} GCPUP/00X00I ${ND} CLIENTE ${ND} IMAGENS XDXXXXXXXXXX ${ND} DATAVS.afpub`;

// ---------------

var pageImagesLenOptions = '10 ou 15 ou 18 ou 21 ou 24 ou 27 ou 30';

