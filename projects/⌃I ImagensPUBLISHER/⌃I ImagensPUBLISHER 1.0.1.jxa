function dAlert(theTitle, theMessage, theButtons, theDefaultButton, theCancelButton) {
  if (theButtons == undefined) {
    currentApp.displayAlert(theTitle, { message: theMessage });
  } else {
    currentApp.displayAlert(theTitle, {
      message: theMessage,
      buttons: theButtons,
      defaultButton: theDefaultButton,
      cancelButton: theCancelButton,
    });
  }
}

function cfl2Str(theList, thePrompt, theDefaultItems, multipleStatus) {
  if (multipleStatus == undefined) {
    return currentApp.chooseFromList(theList, { withPrompt: thePrompt, defaultItems: theDefaultItems }).toString();
  } else if (multipleStatus == 'm') {
    return currentApp
      .chooseFromList(theList, { withPrompt: thePrompt, defaultItems: theDefaultItems, multipleSelectionsAllowed: true })
      .toString();
  }
}

function doMenu(appName, menuName, menuItem) {
  var frontApp = Application(appName);

  frontApp.activate();

  var frontAppSE = seApp.processes.byName(appName);

  var menuName = frontAppSE.menuBars[0].menuBarItems.byName(menuName);
  delay(d0p3);

  menuName.menus[0].menuItems.byName(menuItem).click();
}

function addZero(i) {
  if (i < 10) {
    i = '0' + i;
  }
  return i.toString();
}

function deletePages(pageStart1, pagesToDelete1, pageStart2, pagesToDelete2) {
  doMenu('Affinity Publisher', 'Document', 'Delete Pages…');
  delay(d0p3);

  // ----- RANGE 1
  // Delete Pages Start
  seApp.keyCode(48);
  delay(d0p3);
  saApp.setTheClipboardTo(pageStart1);
  delay(d0p3);
  seApp.keystroke('v', { using: 'command down' });
  delay(d0p3);

  // Number o pages to delete
  seApp.keyCode(48);
  delay(d0p3);
  saApp.setTheClipboardTo(pagesToDelete1);
  delay(d1);
  seApp.keystroke('v', { using: 'command down' });
  delay(d1);

  seApp.keyCode(76); // Press Enter
  delay(d0p3);
  seApp.keyCode(76); // Press Enter

  delay(d3);

  if (pageStart2 != '0') {
    doMenu('Affinity Publisher', 'Document', 'Delete Pages…');
    delay(d0p3);

    // ----- RANGE 2
    // Delete Pages Start
    seApp.keyCode(48);
    delay(d0p3);
    saApp.setTheClipboardTo(pageStart2);
    delay(d0p3);
    seApp.keystroke('v', { using: 'command down' });
    delay(d0p3);

    // Number o pages to delete
    seApp.keyCode(48);
    delay(d0p3);
    saApp.setTheClipboardTo(pagesToDelete2);
    delay(d1);
    seApp.keystroke('v', { using: 'command down' });
    delay(d1);

    seApp.keyCode(76); // Press Enter
    delay(d0p3);
    seApp.keyCode(76); // Press Enter
  }
}
