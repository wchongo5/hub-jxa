                  // ----------------- SLABS
                  /*
									barsSlabWriteSubtotal(estimateByMTable, iSum,  slabBars6QuantitiesPartial, slabBars8QuantitiesPartial, slabBars10QuantitiesPartial,slabBars12QuantitiesPartial, slabBarsSubTotalAndTotalColor)
									*/

                  slabBars6QuantitiesTotal += slabBars6QuantitiesPartial;
                  slabBars8QuantitiesTotal += slabBars8QuantitiesPartial;
                  slabBars10QuantitiesTotal += slabBars10QuantitiesPartial;
                  slabBars12QuantitiesTotal += slabBars12QuantitiesPartial;

                  shoeQuantityTotal += shoeQuantityPartial;
                  columnQuantityTotal += columnQuantityPartial;
                  beamQuantityTotal += beamQuantityPartial;

                  // ---------------------------------- TOTAL
                  var slabBarsList = [
                    slabBars6QuantitiesTotal,
                    slabBars8QuantitiesTotal,
                    slabBars10QuantitiesTotal,
                    slabBars12QuantitiesTotal,
                  ];

                  var shoesColumnsBeamsStrTotal = getShoesColumnsBeamsStrPartialAndTotal(
                    shoeQuantityTotal,
                    columnQuantityTotal,
                    beamQuantityTotal
                  );

                  var barsKilogramsInfo = getBarsKilogramsInfo(quantitiesBarsTotal, slabBarsList);

                  //

                  var barsKilogramsQuantity = barsKilogramsInfo.match(/(\d[0-9,.]*)\sKG/)[1].replace(/,/g, '');

                  var estimateInfoToFill = { 'Aço A400': barsKilogramsQuantity };

                  // ---------------

                  const barsTotalStr = barsWriteTotal(
                    estimateByMTable,
                    iSum,
                    quantitiesBarsTotal,
                    barsKilogramsInfo,
                    shoeColumnBeamBarsTotalColor,
                    shoesColumnsBeamsStrTotal
                  );

                  // ----------------- SLABS
                  /* // 🔴🔴🔴 DESACTIVADO NOT NECESSARY BECAUSE WAS INCLUDED IN TOTAL
									barsSlabWriteTotal(estimateByMTable, iSum,  slabBarsList, slabBarsSubTotalAndTotalColor)
									*/

                  // ----------------- BARS COST
                  // var slabBarsList = [slabBars6QuantitiesTotal, slabBars8QuantitiesTotal, slabBars10QuantitiesTotal, slabBars12QuantitiesTotal]

                  if (includeCost) {
                    var barsCostInfo = barsCost(
                      estimateByMTable,
                      buildingNameAndGroupID,
                      iSum,
                      quantitiesBarsTotal,
                      stirrupCoecientCost,
                      bar6Cost,
                      bar8Cost,
                      bar10Cost,
                      bar12Cost,
                      slabBarsList,
                      costRowsColor
                    );

                    processedBuildingsInfo.push(barsCostInfo);
                  }

                  // -----------------

                  // Apply white backgroundColor in row before GRAND TOTAL
                  applyBackgroundColor(estimateByMTable, 'A' + (iSum + 1) + ':K' + (iSum + 1), 'white');

                  // ----------------- WRITE SUMMARY
                  estimateByMSummaryTable.cells['B3'].value = barsTotalStr;
                }
              }
            } else if (sheetName.includes('VOLUMES')) {
              // 🔴🔴🔴 DELETE Coluna de Elemento, vem no Export e no Archicad vem apenas em Header
              deleteColumns(estimateByMTable, 1, 1);

              alignVertical(estimateByMTable, 'A7:H' + estimateByMTableRowsL2, 'center');

              var estimateByMTableRowsL3 = estimateByMTable.rowCount();

              setDecimals(numbersAppControllerP, estimateByMTable, 'C7:H' + estimateByMTableRowsL3, 1, 'Up');

              thousandsSeparator(numbersAppControllerP, estimateByMTable, 'C7:H' + estimateByMTableRowsL3, 'Number');

              var [
                subtotalLineSumNamesCement,
                subtotalLineSumNamesGrossSand,
                subtotalLineSumNamesFineSand,
                subtotalLineSumNamesStone,
                subtotalLineSumNamesWater,
              ] = [[], [], [], [], []];

              var [
                subtotalLevelSumNamesCement,
                subtotalLevelSumNamesGrossSand,
                subtotalLevelSumNamesFineSand,
                subtotalLevelSumNamesStone,
                subtotalLevelSumNamesWater,
              ] = [[], [], [], [], []];

              var levelNames = [];
              var elementNames = [];

              // NEW, HIDE DETAILS
              var hideRowDetailsStartNum = 7;
              // var numOfRowsToHideCollection = 0

              var rowPrimaryColorsIndex = 0;
              var quantitiesNoProcessPartial = {};
              var volumeQuantitiesTotal = {};

              for (var i = 6; i < estimateByMTableRowsL3; i++) {
                var iSum = i + 1;
                var columnA_Track = estimateByMTable.cells['A' + iSum].value();
                var columnB_Track = estimateByMTable.cells['B' + iSum].value();
                var columnC_Track = estimateByMTable.cells['C' + iSum].value();

                if (columnC_Track != null) {
                  estimateByMTable.cells['C' + iSum].value = '=' + columnC_Track + '*' + marginOfError;

                  var columnC_Track = columnC_Track * marginOfError;
                }

                if (columnA_Track != null) {
                  // A - Fundação, Pilar 200x200 / Estribo 160x160

                  var columnA_TrackItems = columnA_Track.split(', ');
                  // G301 B Piso 1
                  var levelName = columnA_TrackItems.slice(0, 2).join(' ');

                  var elementName = columnA_TrackItems[2];

                  // Remove G301
                  estimateByMTable.cells['A' + iSum].value = columnA_TrackItems.slice(1, columnA_TrackItems.length).join(', ');

                  // Não no primeiro columnA_Track
                  if (i > 6 && levelNames[0] != levelName) {
                    estimateByMTable.cells['A' + i].addRowBelow();

                    i += 1;
                    estimateByMTableRowsL3 += 1;

                    // ----------------- FUNCTION
                    var subtotalLineSumNames = [
                      subtotalLineSumNamesCement,
                      subtotalLineSumNamesGrossSand,
                      subtotalLineSumNamesFineSand,
                      subtotalLineSumNamesStone,
                      subtotalLineSumNamesWater,
                    ];

                    volumeWriteSubtotal(
                      estimateByMTable,
                      estimateByMTableRowsL3,
                      i,
                      levelNames,
                      subtotalLineSumNames,
                      rowPrimaryColorsAlternate,
                      rowPrimaryColorsIndex,
                      quantitiesNoProcessPartial,
                      hideRowDetailsStartNum,
                      hideBarsSurfacesVolumesDetails
                    );
                    // -----------------

                    // Cimento
                    var subtotalLevelSumNameCement = estimateByMTable.cells['D' + iSum].name();
                    subtotalLevelSumNamesCement.push(subtotalLevelSumNameCement);

                    // Areia Grossa
                    var subtotalLevelSumNameGrossSand = estimateByMTable.cells['E' + iSum].name();
                    subtotalLevelSumNamesGrossSand.push(subtotalLevelSumNameGrossSand);

                    // Areia Fina
                    var subtotalLevelSumNameFineSand = estimateByMTable.cells['F' + iSum].name();
                    subtotalLevelSumNamesFineSand.push(subtotalLevelSumNameFineSand);

                    // Pedra
                    var subtotalLevelSumNameStone = estimateByMTable.cells['G' + iSum].name();
                    subtotalLevelSumNamesStone.push(subtotalLevelSumNameStone);

                    // Água
                    var subtotalLevelSumNameWater = estimateByMTable.cells['H' + iSum].name();
                    subtotalLevelSumNamesWater.push(subtotalLevelSumNameWater);

                    var [
                      subtotalLineSumNamesCement,
                      subtotalLineSumNamesGrossSand,
                      subtotalLineSumNamesFineSand,
                      subtotalLineSumNamesStone,
                      subtotalLineSumNamesWater,
                    ] = [[], [], [], [], []];

                    var levelNames = [];
                    var elementNames = [];

                    var quantitiesNoProcessPartial = {};

                    if (rowPrimaryColorsIndex == 0) {
                      var rowPrimaryColorsIndex = 1;
                    } else if (rowPrimaryColorsIndex == 1) {
                      var rowPrimaryColorsIndex = 0;
                    }

                    var hideRowDetailsStartNum = iSum + 1;

                    // Bold row
                    bold(estimateByMTable, 'A' + (iSum + 1) + ':H' + (iSum + 1));

                    applyBackgroundColor(
                      estimateByMTable,
                      'A' + (iSum + 1) + ':H' + (iSum + 1),
                      rowPrimaryColorsAlternate[rowPrimaryColorsIndex]
                    );
                  } else {
                    // Bold row
                    bold(estimateByMTable, 'A' + iSum + ':H' + iSum);
                    applyBackgroundColor(
                      estimateByMTable,
                      'A' + iSum + ':H' + iSum,
                      rowPrimaryColorsAlternate[rowPrimaryColorsIndex]
                    );
                  }

                  if (!levelNames.includes(levelName)) {
                    levelNames.push(levelName);
                  }

                  if (!elementNames.includes(elementName)) {
                    elementNames.push(elementName);
                  }
                }

                if (columnB_Track != null) {
                  if (
                    columnB_Track.includes('Areia') ||
                    columnB_Track.includes('Enrocamento') ||
                    columnB_Track.includes('Escavação') ||
                    columnB_Track.includes('Solo')
                  ) {
                    applyBackgroundColor(estimateByMTable, 'B' + iSum + ':C' + iSum, rowSecondaryColor);
                  }

                  var quantity = Number(formatNumber(columnC_Track, 2, 2).replace(/,/g, ''));

                  if (
                    columnB_Track.includes('Betão armado') ||
                    columnB_Track.includes('Betão simples') ||
                    columnB_Track.includes('Enrocamento')
                  ) {
                    //var elementNameCurrent = elementNames[0]

                    var elementNameCurrent = elementNames[elementNames.length - 1];

                    if (elementNameCurrent.includes('Sapata')) {
                      // var elementNameSimple = "Sapata"

                      if (columnB_Track.includes('Enrocamento')) {
                        var elementNameSimple = 'Leito Fundações';
                      } else {
                        var elementNameSimple = 'Sapata';
                      }
                    } else if (elementNameCurrent.includes('Pilar')) {
                      var elementNameSimple = 'Pilar';
                    } else if (elementNameCurrent.includes('Viga')) {
                      var elementNameSimple = 'Viga';
                    } else if (elementNameCurrent.includes('Laje')) {
                      if (columnB_Track.includes('Enrocamento')) {
                        var elementNameSimple = 'Leito Piso Térreo';
                      } else if (elementNameCurrent.includes('Laje') && elementNameCurrent.includes('Piso Térreo')) {
                        var elementNameSimple = 'Laje Piso Térreo';
                      } else {
                        var elementNameSimple = 'Laje';
                      }
                    }

                    if (elementNameSimple) {
                      columnB_Track += ` (${elementNameSimple})`;
                    }
                  }

                  if (quantitiesNoProcessPartial[columnB_Track] === undefined) {
                    quantitiesNoProcessPartial[columnB_Track] = quantity;
                  } else {
                    quantitiesNoProcessPartial[columnB_Track] += quantity;
                  }

                  if (volumeQuantitiesTotal[columnB_Track] === undefined) {
                    volumeQuantitiesTotal[columnB_Track] = quantity;
                  } else {
                    volumeQuantitiesTotal[columnB_Track] += quantity;
                  }

                  if (
                    columnB_Track.includes('Betonilha') ||
                    columnB_Track.includes('Betão') ||
                    columnB_Track.includes('Reboco')
                  ) {
                    // NOTE QUE ARCHICAD COLOCA "Betonilha" antes de "Betão"

                    if (columnB_Track.includes('Betão armado')) {
                      var volumeCalculationsQuotients = [
                        reinforcedConcreteK_CementBy1m3,
                        reinforcedConcreteK_SandBy1m3,
                        reinforcedConcreteK_StoneBy1m3,
                        reinforcedConcreteK_WaterBy1m3,
                      ];

                      volumeCalculationsSubtotal(estimateByMTable, iSum, volumeCalculationsQuotients, rowSecondaryColor);
                    } else if (
                      columnB_Track.includes('Betonilha de regularização') ||
                      columnB_Track.includes('Betão de limpeza') ||
                      columnB_Track.includes('Betão simples')
                    ) {
                      var volumeCalculationsQuotients = [
                        concretK_CementBy1m3,
                        concretK_GrossSandBy1m3,
                        concretK_StoneBy1m3,
                        concretK_WaterBy1m3,
                      ];

                      volumeCalculationsSubtotal(estimateByMTable, iSum, volumeCalculationsQuotients, rowSecondaryColor);
                    } else if (columnB_Track.includes('Reboco')) {
                      var volumeCalculationsQuotients = [plasterK_CementBy1m3, plasterK_FineSandBy1m3, plasterK_WaterBy1m3];

                      volumeCalculationsSubtotal_Plaster(estimateByMTable, iSum, volumeCalculationsQuotients, rowSecondaryColor);
                    }

                    // Cimento
                    var subTotalLineSumNameCement = estimateByMTable.cells['D' + iSum].name();
                    subtotalLineSumNamesCement.push(subTotalLineSumNameCement);

                    // Areia Grossa
                    var subTotalLineSumNameGrossSand = estimateByMTable.cells['E' + iSum].name();
                    subtotalLineSumNamesGrossSand.push(subTotalLineSumNameGrossSand);

                    // Areia Fina
                    var subTotalLineSumNameFineSand = estimateByMTable.cells['F' + iSum].name();
                    subtotalLineSumNamesFineSand.push(subTotalLineSumNameFineSand);

                    // Pedra
                    var subTotalLineSumNameStone = estimateByMTable.cells['G' + iSum].name();
                    subtotalLineSumNamesStone.push(subTotalLineSumNameStone);

                    // Água
                    var subTotalLineSumNameWater = estimateByMTable.cells['H' + iSum].name();
                    subtotalLineSumNamesWater.push(subTotalLineSumNameWater);
                  }
                }

                if (i == estimateByMTableRowsL3 - 1) {
                  estimateByMTable.cells['A' + (i + 1)].addRowBelow();
                  estimateByMTable.cells['A' + (i + 1)].addRowBelow();
                  estimateByMTable.cells['A' + (i + 1)].addRowBelow();

                  i += 3;
                  estimateByMTableRowsL3 += 3;

                  // ----------------- FUNCTION / SUBTOTAL
                  var subtotalLineSumNames = [
                    subtotalLineSumNamesCement,
                    subtotalLineSumNamesGrossSand,
                    subtotalLineSumNamesFineSand,
                    subtotalLineSumNamesStone,
                    subtotalLineSumNamesWater,
                  ];

                  volumeWriteSubtotal(
                    estimateByMTable,
                    estimateByMTableRowsL3,
                    i,
                    levelNames,
                    subtotalLineSumNames,
                    rowPrimaryColorsAlternate,
                    rowPrimaryColorsIndex,
                    quantitiesNoProcessPartial,
                    hideRowDetailsStartNum,
                    hideBarsSurfacesVolumesDetails
                  );

                  // ----------------- FUNCTION / TOTAL
                  var subtotalLevelSumNames = [
                    subtotalLevelSumNamesCement,
                    subtotalLevelSumNamesGrossSand,
                    subtotalLevelSumNamesFineSand,
                    subtotalLevelSumNamesStone,
                    subtotalLevelSumNamesWater,
                  ];

                  const volumesMaterialStr = volumeWriteTotal(
                    estimateByMTable,
                    estimateByMTableRowsL3,
                    volumeQuantitiesTotal,
                    subtotalLevelSumNames,
                    grandTotalRangeColor
                  );

                  if (includeCost) {
                    var volumeCostInfo = volumeCost(
                      estimateByMTable,
                      buildingNameAndGroupID,
                      iSum,
                      volumeQuantitiesTotal,
                      priceCementUnit,
                      priceGrossSandM3,
                      priceRockfill,
                      priceStoneM3,
                      priceFineSandM3,
                      priceRedSandM3,
                      priceWaterL,
                      costRowsColor
                    );

                    processedBuildingsInfo.push(volumeCostInfo);
                  }
                  // ----------------- WRITE SUMMARY
                  estimateByMSummaryTable.cells['B4'].value = volumesMaterialStr;
                }
              }

              var estimateInfoToFill = volumeQuantitiesTotal;
            }

            var tableHeight = estimateByMTable.height();
            positionY += tableHeight + 75; //100

            // ----------------- APPLY FORMULA RESULTS

            if (sheetName.includes('PAREDES')) {
              var rangeNameToApplyFormulaResults = 'B7:J' + estimateByMTableRowsL3;
            } else if (sheetName.includes('VOLUMES')) {
              var rangeNameToApplyFormulaResults = 'C7:H' + estimateByMTableRowsL3;
            } else if (sheetName.includes('SUPERF')) {
              var rangeNameToApplyFormulaResults = 'C7:C' + estimateByMTableRowsL3;
            } else if (sheetName.includes('VAR')) {
              // 🔴🔴🔴 NO FORMULAS
            }

            if (sheetName.includes('PAREDES') || sheetName.includes('VOLUMES') || sheetName.includes('SUPERF')) {
              applyFormulaResults(estimateByMTable, rangeNameToApplyFormulaResults);
            }

            delay(d0p3); // Era d1

            if (
              sheetName.includes('PAREDES') ||
              sheetName.includes('VOLUMES') ||
              sheetName.includes('VAR') ||
              sheetName.includes('SUPERF')
            ) {
              updateGrandSummary(estimateByMSummaryTable);
            }

            // -------------- UPDATE TABLE NAME

            estimateByMTable.name = buildingNameAndGroupID;

            // ---------------------------- WRITE QUANTITIES IN ESTIMATE BY QUANTITY DOCNUM

            if (writeQuantitiesInEstimateByQ) {
              if (filteredBuildingsToWriteQuantitiesInEstimateByQ) {
                if (!filteredBuildingsToWriteQuantitiesInEstimateByQ.includes(buildingNum)) {
                  continue;
                }
              }

              var invoiceCs = invoiceCs.slice(0, 12);

              var docsNum = numbersApp.documents();

              var estimateByQDocNum = docsNum.filter(
                document => document.name().includes(invoiceCs) && document.name().includes('ESTIMATIVA DE CUSTO ')
              )[0];

              if (!estimateByQDocNum) {
                var estimateByQDocNum = numbersApp.open(Path(estimateByQPathStr));
                delay(d3);
              }

              var estimateByQDocNumName = estimateByQDocNum.name();

              delay(d0p3);
              doMenu('Numbers', 'Window', estimateByQDocNumName);
              delay(d0p3);

              var sheetsNamesEstimateByQ = estimateByQDocNum.sheets.name();
              var sheetNameEstimateByQ = sheetsNamesEstimateByQ.filter(name => name.includes(buildingGroupId))[0];
              var estimateByQSheet = estimateByQDocNum.sheets[sheetNameEstimateByQ];

              var estimateByQTable = estimateByQSheet.tables[0];
              estimateByQTable.columns[6].textColor = 'black';

              var estimateByQTableRowsL = estimateByQTable.rowCount();

              // VOLUMES PAISAGISMO
              if (sheetName.includes('VOLUMES') && buildingGroupId[1] == '1') {
                var estimateInfoToFillVolumesLandscape = Object.entries(estimateInfoToFill).map(item => [
                  item[0] + ' | m3',
                  item[1],
                ]);

                var generalItemsToWriteCollection = [
                  ['GeralVolumes', 'GeralSuperfícies', 'GERALSUPERFÍCIES', estimateInfoToFillVolumesLandscape],
                ];

                writeEstimateByQArray(estimateByQTable, generalItemsToWriteCollection, estimateByQTableRowsL);
              } else if (sheetName.includes('VAOS')) {
                var generalItemsToWriteCollection = [
                  ['Janelas', 'Portas', 'Fornecimento e colocação de portas', windowsInfo],
                  ['Portas', 'Total Parcial', 'Total Parcial', doorsInfo],
                ];

                writeEstimateByQArray(estimateByQTable, generalItemsToWriteCollection, estimateByQTableRowsL);
              } else if (
                sheetName.includes('AREAS') ||
                sheetName.includes('PAREDES') ||
                sheetName.includes('SUPERF') ||
                sheetName.includes('VAR') ||
                sheetName.includes('VOLUMES')
              ) {
                writeEstimateByQDict(estimateByQTable, estimateInfoToFill, estimateByQTableRowsL);
              }

              if (sheetName.includes('COBERTURA') || sheetName.includes('ESPECIALIDADES') || sheetName.includes('SUPERF')) {
                if (sheetName.includes('ESPECIALIDADES')) {
                  if (buildingGroupId[1] == '1') {
                    // PAISAGISMO G101

                    var generalQuantities01PAI = Object.fromEntries(
                      Object.entries(generalQuantities).filter(([key]) => key.includes('01PAI'))
                    );

                    var estimateInfoToFillGeneral01PAI = Object.entries(generalQuantities01PAI);

                    var generalItemsToWriteCollection = [
                      ['GeralEspecialidade01PAI', 'Total Parcial', 'Total Parcial', estimateInfoToFillGeneral01PAI],
                    ];
                  } else {
                    var generalQuantities00MOB = Object.fromEntries(
                      Object.entries(generalQuantities).filter(([key]) => key.includes('00MOB'))
                    );

                    var estimateInfoToFillGeneral00MOB = Object.entries(generalQuantities00MOB);

                    var generalQuantities02ARQ = Object.fromEntries(
                      Object.entries(generalQuantities).filter(([key]) => key.includes('02ARQ'))
                    );

                    var estimateInfoToFillGeneral02ARQ = Object.entries(generalQuantities02ARQ);

                    var generalQuantities03HID = Object.fromEntries(
                      Object.entries(generalQuantities).filter(([key]) => key.includes('03HID'))
                    );

                    var estimateInfoToFillGeneral03HID = Object.entries(generalQuantities03HID);

                    var generalQuantities05ELE = Object.fromEntries(
                      Object.entries(generalQuantities).filter(([key]) => key.includes('05ELE'))
                    );

                    var estimateInfoToFillGeneral05ELE = Object.entries(generalQuantities05ELE);

                    var generalQuantities06CLI = Object.fromEntries(
                      Object.entries(generalQuantities).filter(([key]) => key.includes('06CLI'))
                    );

                    var estimateInfoToFillGeneral06CLI = Object.entries(generalQuantities06CLI);

                    var generalQuantities07GAS = Object.fromEntries(
                      Object.entries(generalQuantities).filter(([key]) => key.includes('07GAS'))
                    );

                    var estimateInfoToFillGeneral07GAS = Object.entries(generalQuantities07GAS);

                    var generalItemsToWriteCollection = [
                      ['GeralEspecialidade00MOB', 'Total Parcial', 'Total Parcial', estimateInfoToFillGeneral00MOB],
                      [
                        'GeralEspecialidade02ARQ',
                        'GeralEspecialidade00MOB',
                        'GeralEspecialidade00MOB',
                        estimateInfoToFillGeneral02ARQ,
                      ],
                      ['GeralEspecialidade03HID', 'Total Parcial', 'Total Parcial', estimateInfoToFillGeneral03HID],
                      ['GeralEspecialidade05ELE', 'Total Parcial', 'Total Parcial', estimateInfoToFillGeneral05ELE],
                      ['GeralEspecialidade06CLI', 'Total Parcial', 'Total Parcial', estimateInfoToFillGeneral06CLI],
                      ['GeralEspecialidade07GAS', 'Total Parcial', 'Total Parcial', estimateInfoToFillGeneral07GAS],
                    ];
                  }
                } else if (sheetName.includes('COBERTURA') || sheetName.includes('SUPERF')) {
                  if (sheetName.includes('COBERTURA')) {
                    var fillIdStart = 'GeralCobertura';
                    var fillIdEnd = 'Total Parcial';

                    var columnB_Track2ID = 'Total Parcial';

                    var estimateInfoToFillGeneral = Object.entries(generalQuantities);
                  } else if (sheetName.includes('SUPERF')) {
                    var fillIdStart = 'GeralSuperfícies';

                    if (buildingGroupId[1] == '1') {
                      var fillIdEnd = 'GeralEspecialidade01PAI';
                      var columnB_Track2ID = 'GERALESPECIALIDADE01PAI';
                    } else if (buildingGroupId[1] == '2') {
                      var fillIdEnd = 'Pavimentos';
                      var columnB_Track2ID = 'PAVIMENTOS';
                    } else if (buildingGroupId[1] == '3') {
                      var fillIdEnd = 'Pavimentos';
                      var columnB_Track2ID = 'PAVIMENTOS';
                    }

                    var estimateInfoToFillGeneral = Object.entries(estimateInfoToFillGeneral);
                  }

                  var generalItemsToWriteCollection = [[fillIdStart, fillIdEnd, columnB_Track2ID, estimateInfoToFillGeneral]];
                }

                writeEstimateByQArray(estimateByQTable, generalItemsToWriteCollection, estimateByQTableRowsL);
              }
            }
          }
        }

        if (savePdfAndMoveAndRenameTXT) {
          if (writeQuantitiesInEstimateByQ) {
            delay(d0p3);
            estimateByQDocNum.save();
          }

          delay(d0p3); // Era d1

          try {
            doMenu('Numbers', 'Window', estimateByMDocNumName);
          } catch (error) {
            // File with extension unhidden

            doMenu('Numbers', 'Window', `${estimateByMDocNumName}.numbers`);
          }
          delay(d0p3); // Era d1

          populateProcessedBuildingsInfo(headerTable, processedBuildingsInfo, includeCost);

          deteleExtraTables(estimateByMSheet, buildingsNamesAndGroupID);

          delay(d0p3); // Era d2
          estimateByMDocNum.save();
          delay(d0p3); // Era d2

          // -------------- TIMESTAMP AND RENAME
          const endDateTime = new Date();
          const processTimeElapsed = timeElapsed(startDateTime, endDateTime);

          const { dateY4M2D2__H2M2S2: end_dateY4M2D2__H2M2S2 } = formatDateV3(endDateTime).formats;

          // ---------------------------- SAVE PDFS
          if (saveEstimateByMPdf) {
            var sheetNames = [`${sheetName} _ ${end_dateY4M2D2__H2M2S2}`];

            for (var i = 0; i < sheetNames.length; i++) {
              var formatedPdfNewName = sheetNames[i];
              var sheetNameItems = sheetName.split(' _ ');
              var sheetName = sheetNameItems[0];

              numbersSaveAsPDF(
                numbersAppControllerP,
                estimateByMDocNum,
                i,
                sheetNames,
                sheetName,
                materialPathStr,
                formatedPdfNewName
              );
            }
          }

          var txtFileNameNew = txtFileName.replace('.txt', ` _ ${end_dateY4M2D2__H2M2S2} (${processTimeElapsed})`);

          var filePathStrNew = filePathStrItems.join('/') + `/TF 00 ${ND} WF_ESTIMATE A5E - InPROCESS/` + txtFileName;

          // ----- Move to PROJECT ORIGINAIS
          finderApp.move(Path(filePathStrNew), { to: Path(originalsPathStr + '/' + orifinalsDel5FolderStr) });
          delay(d3);

          // renameItem(originalsPathStr + "/" + orifinalsDel5FolderStr + "/" + txtFileName, txtFileNameNew, "noReveal")
          renameItem(
            originalsPathStr + '/' + orifinalsDel5FolderStr + '/' + txtFileName,
            txtFileNameNew,
            'reveal-activatePreviousTab'
          );
        }
      } catch (error) {
        alert(
          `${error.name}`,
          `❗️${error.message}❗️\n\n\n—\nTalvez não encontrou o Numbers de "00X00EM" para ${customerName} ${invoiceCs}!`
        );
      }
    }
  } else {
    // 🔴🔴🔴 Desacriva alerta para não atrapalhar em cada verificação do número de ficheiros a processar
    // alert(`Check in Numbers if "filePathStrsFromWfEstimateA5PathStrL == numberOfTxtFilesToProcess"`, ``)
  }
}

// ------------------------------------------ FUNCTIONS

function getArrayOfSumOfUniqueBarsNames(barsShoesColumnsBeamsSlabArray) {
  let sumByBarsNames = {};
  barsShoesColumnsBeamsSlabArray.forEach(item => {
    let parts = item.split(': ');
    let barName = parts[0];
    let barQuantity = parseInt(parts[1]);

    if (!sumByBarsNames[barName]) {
      sumByBarsNames[barName] = barQuantity;
    } else {
      sumByBarsNames[barName] += barQuantity;
    }
  });

  // Convert the object to an barsShoesColumnsBeamsSlabArray of strings
  let summedBarsShoesColumnsBeamsSlabArray = [];
  for (let barName in sumByBarsNames) {
    if (sumByBarsNames[barName] !== 0) {
      // summedBarsShoesColumnsBeamsSlabArray.push(barName + ': ' + sumByBarsNames[barName]);
      summedBarsShoesColumnsBeamsSlabArray.push(barName + ': ' + formatNumber(sumByBarsNames[barName], 0, 0));
    }
  }

  // Now perform the mapping operation
  return summedBarsShoesColumnsBeamsSlabArray.map(item => item.replace('Varão ', ''));
}

function getPreviousColumnA_WithElementName(estimateByMTable, currentCellNum) {
  var columnA_WithElementName = '';

  for (var i = currentCellNum; i < estimateByMTable.rowCount(); i--) {
    var columnA_Track = estimateByMTable.cells['A' + i].value();

    if (columnA_Track) {
      columnA_WithElementName = columnA_Track;
      break;
    }
  }

  return columnA_WithElementName;
}
