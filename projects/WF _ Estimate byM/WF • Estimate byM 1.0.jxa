	.filter(item => item[0].includes("Varão"))
	
	// ---------------
	var barsQuantitiesArray = barsQuantitiesArrayOnly
	.map(item => Number(item[1]))
	
	var barsQuantitiesTotal = formatNumber(sumAllByReduce(barsQuantitiesArray), 0, 0)
	
	
	
	estimateByMTable.cells["B" + (iSum + 2)].value = quantitiesBarsTotalArrayTxt + `\n\n—\n` + barsKilogramsInfo + `\n\n—\n• Estribos (Pilares e Vigas): ${stirrupsQuantitiesTotal}\n• Varão (Sapatas, Pilares e Vigas): ${barsQuantitiesTotal}\n\n—\n${shoesColumnsBeamsStrTotal}`
	*/

  // --------------- SIMPLIFIED SUMMARY

  estimateByMTable.cells['A' + (iSum + 2)].value = 'TOTAL (TODOS NÍVEIS)';

  var stirrupsArrayTxt = quantitiesBarsTotalArray
    .filter(item => item[0].includes('Estribo'))
    .map(item => '• ' + item[0] + ': ' + formatNumber(item[1], 0, 0))
    .sort()
    .join('\n');

  const barsTotalStr = stirrupsArrayTxt + `\n\n—\n` + barsKilogramsInfo;

  estimateByMTable.cells['B' + (iSum + 2)].value = barsTotalStr;

  // Withe background
  applyBackgroundColor(estimateByMTable, 'B' + (iSum + 2) + ':K' + (iSum + 2), 'white');

  applyBackgroundColor(estimateByMTable, 'B' + (iSum + 2) + ':G' + (iSum + 2), shoeColumnBeamBarsTotalColor);

  bold(estimateByMTable, 'A' + (iSum + 2) + ':G' + (iSum + 2));

  return barsTotalStr;
}

