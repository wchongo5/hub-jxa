var objCLib = Library('objCLib');

const { getUniqueItems, sortArray } = Library('appLib');
const { formatDateV3, timeElapsed } = Library('datetimeLib');
const { alert } = Library('displayLib');
const { getColors } = Library('colorsLib');
const { getND, getPathStrsFromPathStr, moveItems, renameItem } = Library('finderLib');
const {
  alignHorizontal,
  alignVertical,
  applyBackgroundColor,
  applyFontSize,
  applyFormulaResults,
  bold,
  clearRange,
  deleteColumns,
  deleteRows,
  deleteTablesByName,
  getCellNamePartColumnOrRow,
  hideRows,
  hideRowsRange,
  numbersSaveAsPDF,
  mergeCells,
  rowPopulateItems,
  rowsSelectionNumInColumn,
  selectionRange,
  setDecimals,
  sumFromSelectionRange,
  tableDelimeterUpdate,
  thousandsSeparator,
  thousandsSeparatorWithCopyPaste,
} = Library('iWorkLib');
const { copy, doMenu, paste, setClipboard } = Library('menuLib');
const { addZero, formatNumber, sumAllByReduce } = Library('numberLib');
const { getNumXA5PathStr, getP5PathStr, getP5PathStrWithSuffixP5, getXa5TemporayPathStr } = Library('pathLib');
const { getBuildingsGroupIDAndNames, getConsultancyPathStrs, getProjectInProcessInfo, getEstimatesPathStrs } =
  Library('projectLib');
const { pressDelete } = Library('systemLib');

var currentApp = Application.currentApplication();
//currentApp.includeStandardAdditions = true
var saApp = ((currentApp.includeStandardAdditions = true), currentApp);
var seApp = Application('System Events');

var finderApp = Application('Finder');
var numbersApp = Application('Numbers');
var numbersAppControllerP = seApp.processes['Numbers'];

// ---------------------------------------
const ND = getND();
// --------------------------------------- DELAYS

var d0p3 = 0.3;
var d1 = 1;
var d2 = 2;
//var d1p5 = 1.5
var d3 = 3;
var d5 = 5;
//var d7 = 7
var d10 = 10;

// ---------------------------------------

function run(input, parameters) {
  var orifinalsDel5FolderStr = '+ DEL5';
  var onlyTotalsStr = 'Apenas totais. Detalhes de cálculos disponíveis, solicite se necessário.';

  var xa5TemporayPathStr = getXa5TemporayPathStr();
  var wfEstimateA5PathStr = `${xa5TemporayPathStr}/TF 00 ${ND} WF_ESTIMATE A5E`;
  var wfEstimateA5InProcessPathStr = `${xa5TemporayPathStr}/TF 00 ${ND} WF_ESTIMATE A5E - InPROCESS`;

  var p5PathStrWithSuffixP5 = getP5PathStrWithSuffixP5();
  var numXA5PathObj = Path(getNumXA5PathStr());

  var docNumXA5 = numbersApp.open(numXA5PathObj);

  var {
    customerName,
    invoiceCs,
    numberOfTxtFilesToProcess,
    includeCost,
    savePdf,
    hideBarsSurfacesVolumesDetails,
    filteredBuildingsToProcessInEstimateByM,
    writeQuantitiesInEstimateByQ,
    filteredBuildingsToWriteQuantitiesInEstimateByQ,
  } = getProjectInProcessInfo(docNumXA5);

  var filePathStrsFromWfEstimateA5PathStr = getPathStrsFromPathStr(wfEstimateA5PathStr, 'files');

  var filePathStrsFromWfEstimateA5PathStrL = filePathStrsFromWfEstimateA5PathStr.length;

  // alert(`${filePathStrsFromWfEstimateA5PathStrL}\n\n${numberOfTxtFilesToProcess}`, ``);

  if (filePathStrsFromWfEstimateA5PathStrL == numberOfTxtFilesToProcess) {
    moveItems(filePathStrsFromWfEstimateA5PathStr, wfEstimateA5InProcessPathStr);

    numbersApp.activate();
    delay(d1);

    var filePathStrsFromFolderInProcess = getPathStrsFromPathStr(wfEstimateA5InProcessPathStr, 'files');

    for (var f = 0; f < filePathStrsFromFolderInProcess.length; f++) {
      var startDateTime = new Date();

      // --------------------------------------- COLORS
      const {
        // ----- COST ROWS
        orangeLight: costRowsColor,

        // ----- GRAND TOTAL - PAREDES
        cyanLight,
        greenLight,
        magentaLight,
        redLight,
        yellowLight,
        grayLight1,
      } = getColors();

      var rowPrimaryColor = redLight;
      var rowSecondaryColor = grayLight1;

      var rowPrimaryColorsAlternate = [redLight, greenLight]; // Light red

      var grandTotalRangeColor_General = cyanLight; //"cyan"
      var grandTotalRangeColor_Cement = greenLight; // "green"

      var grandTotalRangeColor_Sand = yellowLight; //"yellow"

      var grandTotalRangeColor_Water = magentaLight; //"magenta"

      // ----- GRAND TOTAL - VOLUMES AND SURFACES
      var grandTotalRangeColor = yellowLight; // "yellow"

      // ----- GRAND TOTAL - PAREDES
      var slabBarsSubTotalAndTotalColor = cyanLight; // "cyan"
      var shoeColumnBeamBarsTotalColor = yellowLight; // "yellow"

      // --------------------------------------- COSTS (METICAIS)

      // ----- GENERAL
      var priceCementUnit = 350.0;
      var priceGrossSandM3 = 1050.0;
      var priceWaterL = 0.65; // 0.45 considerarndo MZN10.00 25L

      // ----- OPENINGS

      // 🔴🔴🔴 Qual é o vão mais caro - de alumínio ou madeira?????
      /// Abaxio assumi que madeira é mais cara

      var openingPriceK = 1.0; // 1.00

      // 12750.37 is price for door of 1.89m2 (0.90x2.10)
      var doorAluminium900By2100Price = (22779.79 / 1.89) * openingPriceK;
      var doorWood900By2100Price = (24779.79 / 1.89) * openingPriceK;

      var windowAluminium2000By1200Price = (35124.52 / 2.4) * openingPriceK;
      var windowWood2000By1200Price = (37124.52 / 2.4) * openingPriceK;

      // Substituir 0.00 com preço
      var gridConcrete1000By1000Price = (0.0 / 1.0) * openingPriceK;
      var ventilatorPVC300By300Price = (0.0 / 0.09) * openingPriceK;

      var openningPricesKByMaterial = {
        'Grelha Betão': gridConcrete1000By1000Price,
        'Janela Alumínio': windowAluminium2000By1200Price,
        'Janela Madeira': windowWood2000By1200Price,
        'Porta Alumínio': doorAluminium900By2100Price,
        'Porta Madeira': doorWood900By2100Price,
        'Ventilador PVC': ventilatorPVC300By300Price,
      };

      // ----- VOLUMES
      var priceRockfill = 1400.0;
      var priceStoneM3 = 1650.0;
      var priceFineSandM3 = 1350.0;
      var priceRedSandM3 = 130.0;

      // ----- SURFACES
      var priceStoneCoatingM2 = 355.0;
      var pricePaintExteriorM2 = 215.0;
      var pricePaintInteriorM2 = 175.0;
      var pricePaintCeilingM2 = 195.0;

      var priceFloorTilesM2 = 1500.0;
      var priceWallTilesM2 = 1350.0;
      var priceSkirtingML = 423.32; // Em ml, antes era 1350.00 para m2

      // ----- BARS
      // --- COEFICIENTE PARA VALOR DE STRIBOS
      // 0.64 (160x160) está para MZN7.50 / 0.84 (160x260) está para X
      // X = (7.50*0.84)/0.64 o mesmo que (7.50/0.64) * 0.84
      // O mesmo que multiplicar qualquer comprimento do estribo por 11.72 (7.50/0.64)
      var stirrup160By160Cost = 7.5;
      var stirrupCoecientCost = stirrup160By160Cost / 0.64; // 0.64 (160x160) de stirrup160By160Cost
      // ---
      var bar6Cost = 120.0;
      var bar8Cost = 210.0;
      var bar10Cost = 280.0;
      var bar12Cost = 320.0;

      // ----- WALL
      var priceBrick100 = 12.0;
      var priceBrick150 = 17.0;
      var priceBrick200 = 25.0;
      // var priceCementUnit = 350.00
      // var priceGrossSandM3 = 1350.00
      // var priceWaterL = 0.65 // 0.45 considerarndo MZN10.00 25L

      // --------------------------------------- QUOCIENTS

      // ----- MARGEM DE ERRO
      // 🔴🔴🔴 Because I sue conditional statement before apply it I was forced to put it inside run(input, parameters) function
      var marginOfError = 1.1; // 10%

      // --------------- INFO FROM #P51A _ DESENHO & ESPECIFICAÇÕES > PROGRAMAÇÃO
      // // ----- SCREED
      // var screedK_CementBy1m3 = 5.93 // E18
      // var screedK_SandBy1m3 = 0.42 // E20
      // var screedK_StoneBy1m3 = 0.85 // E22
      // var screedK_WaterBy1m3 = 222.46 // E23

      // ----- PLASTER
      var plasterK_CementBy1m3 = 11.81; // B33
      var plasterK_FineSandBy1m3 = 1.05; // B35
      var plasterK_WaterBy1m3 = 221.52; // B37

      // ----- LIGHT CONCRET
      var concretK_CementBy1m3 = 5.93; // E18
      var concretK_GrossSandBy1m3 = 0.42; // E20
      var concretK_StoneBy1m3 = 0.85; // E22
      var concretK_WaterBy1m3 = 222.46; // E23

      // ----- REINFORCED CONCRET
      var reinforcedConcreteK_CementBy1m3 = 5.87; // E33
      var reinforcedConcreteK_SandBy1m3 = 0.52; // E35
      var reinforcedConcreteK_StoneBy1m3 = 0.73; // E37
      var reinforcedConcreteK_WaterBy1m3 = 220.13; // E39

      // --------------------------------------- BOOLEAN

      var hideRows = true; // true

      // ---------------------------------------

      var filePathStr = filePathStrsFromFolderInProcess[f];
      var filePathStrItems = filePathStr.split('/');
      var txtFileName = filePathStrItems.pop();
      var folderActionName = filePathStrItems.pop();

      // saveEstimateByMPdf
      if (invoiceCs[2] == 'W') {
        var saveEstimateByMPdf = true;
      } else {
        var saveEstimateByMPdf = savePdf;
      }

      // Use marginOfError 1.00
      if (invoiceCs[2] != 'W') {
        var marginOfError = 1.0; // 1.100
      }

      var buildingsGroupIDAndNames = getBuildingsGroupIDAndNames(invoiceCs);

      var buildingsGroupIDAndNamesL = buildingsGroupIDAndNames.length;

      var { consultancyPathStr, originalsPathStr, materialPathStr } = getConsultancyPathStrs(p5PathStrWithSuffixP5, invoiceCs);

      // var originalsPathStr = consultancyPathStr + '/00A5D ORIGINAIS iWORK';

      try {
        var { estimateByMPathStr, estimateByQPathStr } = getEstimatesPathStrs(originalsPathStr, invoiceCs);

        var estimateByMDocNumName = estimateByMPathStr.split('/').slice(-1)[0].replace('.numbers', '');

        var estimateByMDocNum = numbersApp.open(Path(estimateByMPathStr));

        var quantityGroupIDAndName = txtFileName.match(/(00X00\w*\s.*).txt/)[1].toUpperCase(); //[1]

        // .slice(0, 10) para SUPERFÍCIES, VARÃO sem acentuação
        var quantityGroupIDAndNameSliced13 = quantityGroupIDAndName.slice(0, 10);

        var sheetsNames = estimateByMDocNum.sheets.name();

        // name.slice(0,13) => "Superf" para contornar acentuação em Superfícies, …
        var sheetName = sheetsNames.filter(
          name => name.slice(0, 13).includes(quantityGroupIDAndNameSliced13) && !name.includes('CYPECAD')
        )[0];

        // 00X00E VAR

        // 🔴🔴🔴🔴 -------------- EXCLUDE COST IN SHEETS DON'T HAVE CALCULATIONS YET

        if (
          sheetName.includes('AREAS') ||
          sheetName.includes('COBERTURA') ||
          sheetName.includes('ESPECIALIDADES') ||
          sheetName.includes('VAOS')
        ) {
          var includeCost = false;
        }

        const estimateByMSummaryTable = estimateByMDocNum.sheets['00X00 RESUMO'].tables['TODOS GRUPOS'];

        var estimateByMSheet = estimateByMDocNum.sheets[sheetName];
        var headerTable = estimateByMSheet.tables['TableHeader'];

        headerTable.position = { x: 0, y: 75 };

        if (sheetName.includes('VOLUMES') || sheetName.includes('SUPERF') || sheetName.includes('VAR')) {
          if (hideBarsSurfacesVolumesDetails) {
            headerTable.cells['E5'].value = onlyTotalsStr;
          } else {
            headerTable.cells['E5'].value = '';
          }
        }

        // -------------- DELETE COST ROWS IF includeCost IS FALSE
        if (!includeCost) {
          deleteBuildingCostEstimateInfo(headerTable);
        }

        // .replace(/## /g, "") SUPERFICIES TEM NOMES COM INCICAIAS ##
        // 🔴🔴🔴 SE ACTUALIZAR NO ARCHICAD, VIR ACTUALIZAR AQUI

        var buildingsText = objCLib
          .readFile(filePathStr)
          .replace(/### |## |# /g, '')
          .replace(/---|, ---|, -/g, '');

        // finderApp.move(Path(filePathStr), {to: Path(wfEstimateA5InProcessPathStr)})

        /*         var buidingGroupTypes = buildingsText.match(/G\d{3}/g).map(item => item.slice(0, 2) + '00');

        var buidingGroupTypesUniques = getUniqueItems(buidingGroupTypes); */

        var processedBuildingsInfo = [];
        var buildingsNamesAndGroupID = [];

        var savePdfAndMoveAndRenameTXT = false;

        // -------------- FIXING ERROR

        // TODO:

        // var buidingGroupTypesUniquesL = buidingGroupTypesUniques.length;

        if (filteredBuildingsToProcessInEstimateByM) {
          var buidingGroupTypes = filteredBuildingsToProcessInEstimateByM.map(item => `G${item.slice(0, 2)}00`);

          var buidingGroupTypesUniques = getUniqueItems(buidingGroupTypes);

          var buidingGroupTypesUniquesL = filteredBuildingsToProcessInEstimateByM.length;
        } else {
          var buidingGroupTypes = buildingsText.match(/G\d{3}/g).map(item => item.slice(0, 2) + '00');

          var buidingGroupTypesUniques = getUniqueItems(buidingGroupTypes);

          var buidingGroupTypesUniquesL = buidingGroupTypesUniques.length;
        }

        // --------------

        var positionX = 0;
        // 330 position of first table without any row estimate summary
        // 21 is row height
        // buildingsGroupIDAndNamesL number os buildings (menos 1 row, last empty never used)
        // var positionY = 330 + (includeCost ? 21 * (buildingsGroupIDAndNamesL - 1) : 0)
        var positionY = 330 + (includeCost ? 21 * buildingsGroupIDAndNamesL : 0);

        for (var g = 0; g < buidingGroupTypesUniquesL; g++) {
          var buidingGroupTypeUnique = buidingGroupTypesUniques[g];

          // 99 Limite de G399, parece que vai aceitar mais G3120
          for (var h = 1; h < 99; h++) {
            var buildingGroupId = buidingGroupTypeUnique.slice(0, 2) + addZero(h);

            var buildingNum = buildingGroupId.replace('G', '');

            var re_buildingGroupId = new RegExp(`${buildingGroupId}`, `g`);
            var re_buildingGroupIds = buildingsText.match(re_buildingGroupId);

            if (!re_buildingGroupIds) {
              if (!re_buildingGroupIds && g == buidingGroupTypesUniquesL - 1) {
                var savePdfAndMoveAndRenameTXT = true;
                break;
              } else {
                continue;
              }
            }

            // ----------- NEW THANKS GOD!
            if (filteredBuildingsToProcessInEstimateByM) {
              if (!filteredBuildingsToProcessInEstimateByM.includes(buildingNum)) {
                continue;
              }
            }
            // -----------

            //
            // 🔴🔴🔴 Não pode estar acima de <if (!re_buildingGroupIds) {>, pois deve obedecer os 99 LOOPS se for objectos não existes (se não existir, G102, G103, G104, …), que geralmente o <continue> acima faz skip e acelera

            // Used when comes from DocNum Estimate byQ
            delay(d1);
            try {
              doMenu('Numbers', 'Window', estimateByMDocNumName);
            } catch (error) {
              // File with extension unhidden

              doMenu('Numbers', 'Window', `${estimateByMDocNumName}.numbers`);
            }
            delay(d1);

            // var buildingGroupIDAndNameItems = buildingsGroupIDAndNames.filter(name => name.includes(buildingGroupId))[0].split(" ")

            var buildingGroupIDAndName = buildingsGroupIDAndNames.filter(name => name.includes(buildingGroupId));

            if (buildingGroupIDAndName.length == 1) {
              var buildingGroupIDAndNameItems = buildingGroupIDAndName[0].split(' ');
            } else {
              alert(`Erro — o ficheiro TXT "EDIFICAÇÕES" não inclui "${buildingGroupId}"!`, ``);

              break;
            }

            var buildingNameAndGroupID = buildingGroupIDAndNameItems.slice(1).join(' ') + ` (${buildingGroupIDAndNameItems[0]})`;

            buildingsNamesAndGroupID.push(buildingNameAndGroupID);

            var tablesNames = estimateByMSheet.tables.name();

            var tableName = tablesNames.filter(name => name.includes(buildingGroupId))[0];

            if (g == 0 && h == 1) {
              var tablesNamesOfBuildings = getTablesNamesOfBuildings(tablesNames);

              distributeTablesRightVertically(estimateByMSheet, tablesNamesOfBuildings, '2000');
            }

            if (tableName == undefined) {
              var estimateByMTableRefToCreateNew = getTablesOfBuildings(estimateByMSheet.tables())[0];

              selectionRange(estimateByMTableRefToCreateNew, 'A6');
              doMenu('Numbers', 'Edit', 'Duplicate Selection');

              var tableNameNew = getTablesNamesOfBuildings(estimateByMSheet.tables.name()).filter(item =>
                item.includes(')-1')
              )[0];

              var tableName = tableNameNew;
            }

            var estimateByMTable = estimateByMSheet.tables[tableName];

            estimateByMTable.position = { x: positionX, y: positionY };

            if (sheetName.includes('AREAS')) {
              var buildingText = getBuildingTextType2(buildingsText, buildingGroupId);
            } else if (sheetName.includes('PAREDES')) {
              var buildingText = getBuildingTextType1(buildingsText, buildingGroupId);

              var textInfoItems1 = buildingText.split('\n');

              var textInfoBeforeLast = textInfoItems1[textInfoItems1.length - 2];

              // REMOVE TOTAL ROW IF IS LAST BUILDING THAT INCLUDES IT
              if (textInfoBeforeLast.includes('m')) {
                // "m" from "m²"
                textInfoItems1.pop();
                var buildingText = textInfoItems1.join('\n');
              }

              // ADD ROW TOTAL BY BUILDING
              var textInfoItems2 = buildingText.split('\n');
              var textInfoItemsTotals = textInfoItems2.filter(item => item.includes('m²'));

              var wallTotal = getWallTotals(textInfoItemsTotals, 2);
              var wallAreaTotal = getWallTotals(textInfoItemsTotals, 3);
              var bricksTotal = getWallTotals(textInfoItemsTotals, 4);
              var cementLayingTotal = getWallTotals(textInfoItemsTotals, 5);
              var cementFillingTotal = getWallTotals(textInfoItemsTotals, 6);
              var sandLayingTotal = getWallTotals(textInfoItemsTotals, 7);
              var sandFillingTotal = getWallTotals(textInfoItemsTotals, 8);
              var waterLayingTotal = getWallTotals(textInfoItemsTotals, 9);
              var waterFillingTotal = getWallTotals(textInfoItemsTotals, 10);

              // O primeiro \t é de edificação "G301"
              var totalRow = `\t\t${wallTotal}\t${wallAreaTotal} m²\t${bricksTotal}\t${cementLayingTotal}\t${cementFillingTotal}\t${sandLayingTotal}\t${sandFillingTotal}\t${waterLayingTotal}\t${waterFillingTotal}`;

              textInfoItems2.push(totalRow);
              var buildingText = textInfoItems2.join('\n');

              // } else if (sheetName.includes("COBERTURA") ||  sheetName.includes("SUPERF") || sheetName.includes("VOLUMES")) {

              // 🔴🔴🔴 ADDED NOW TO FIX ERRROR
              // "ESPECIALIDADES"
              // "VAOS"
            } else if (
              sheetName.includes('COBERTURA') ||
              sheetName.includes('ESPECIALIDADES') ||
              sheetName.includes('SUPERF') ||
              sheetName.includes('VAOS') ||
              sheetName.includes('VOLUMES')
            ) {
              var buildingText = getBuildingTextType1(buildingsText, buildingGroupId);
            } else if (sheetName.includes('VAR')) {
              var buildingText = getBuildingTextType1(buildingsText, buildingGroupId);

              var textInfoItems1 = buildingText.split('\n');

              var textInfoLast = textInfoItems1[textInfoItems1.length - 1];
              var textInfoLastItems = textInfoLast.split('\t');

              textInfoLastItems[2];

              // REMOVE TOTAL ROW IF IS LAST BUILDING THAT INCLUDES IT
              if (textInfoLastItems[2] == '') {
                // "m" from "m²"
                textInfoItems1.pop();
                var buildingText = textInfoItems1.join('\n');
              }

              // 🔴🔴🔴 ADD ROW TOTAL BY BUILDING BUT WILL BE DELETE BEFORE PROCESS. KEET IT!
              var textInfoItems2 = buildingText.split('\n');

              var shoeBarsTotal = getBarsTotals(textInfoItems2, 4);

              var columnBarsTotal = getBarsTotals(textInfoItems2, 5);
              var columnStirrupsTotal = getBarsTotals(textInfoItems2, 6);

              var beamBarsTotal = getBarsTotals(textInfoItems2, 7);
              var beamStirrupsTotal = getBarsTotals(textInfoItems2, 8);

              var slabBars6Total = getBarsTotals(textInfoItems2, 9);
              var slabBars8Total = getBarsTotals(textInfoItems2, 10);
              var slabBars10Total = getBarsTotals(textInfoItems2, 11);
              var slabBars12Total = getBarsTotals(textInfoItems2, 12);

              // "\t" coluns before
              var totalRow = `\t\t\t${shoeBarsTotal}\t${columnBarsTotal}\t${columnStirrupsTotal}\t${beamBarsTotal}\t${beamStirrupsTotal}\t${slabBars6Total}\t${slabBars8Total}\t${slabBars10Total}\t${slabBars12Total}`;

              // var totalRow = `			${shoeBarsTotal}	${columnBarsTotal}	${columnStirrupsTotal}	${beamBarsTotal}	${beamStirrupsTotal}	${slabBars6Total}	${slabBars8Total}	${slabBars10Total}	${slabBars12Total}`

              textInfoItems2.push(totalRow);

              var buildingText = textInfoItems2.join('\n');
            }

            setClipboard(buildingText); // ---

            var estimateByMTableRowsL1 = estimateByMTable.rowCount();

            if (estimateByMTableRowsL1 > 6) {
              // Table with info
              selectionRange(estimateByMTable, 'A7:A' + estimateByMTableRowsL1);
              doMenu('Numbers', 'Table', 'Delete Rows');
            }

            estimateByMTable.cells['A6'].addRowBelow();

            selectionRange(estimateByMTable, 'A7:A7');

            // 🔴🔴🔴 INSERIR Coluna de Nível, vem no Export e no Archicad vem apenas em Header

            if (sheetName.includes('AREAS')) {
              estimateByMTable.cells['A7'].addColumnBefore();
            } else if (
              sheetName.includes('COBERTURA') ||
              sheetName.includes('ESPECIALIDADES') ||
              sheetName.includes('PAREDES') ||
              sheetName.includes('SUPERF') ||
              sheetName.includes('VAOS') ||
              sheetName.includes('VAR') ||
              sheetName.includes('VOLUMES')
            ) {
              estimateByMTable.cells['B7'].addColumnBefore();
            }

            if (sheetName.includes('VAR') || sheetName.includes('SUPERF') || sheetName.includes('VOLUMES')) {
              estimateByMTable.cells['B7'].addColumnBefore();

              if (sheetName.includes('SUPERF')) {
                estimateByMTable.cells['B7'].addColumnBefore();
              }
            }

            selectionRange(estimateByMTable, 'A7:A7');
            doMenu('Numbers', 'Edit', 'Paste and Match Style');

            // UPDATE TABLE DELIMETERS
            if (sheetName.includes('PAREDES') || sheetName.includes('VAR') || sheetName.includes('VOLUMES')) {
              if (sheetName.includes('PAREDES')) {
                var wallTableDelimeterTrack = estimateByMTable.cells['K8'].value();
              } else if (sheetName.includes('VAR')) {
                var barsTableDelimeterTrack = estimateByMTable.cells['A8'].value();
              } else if (sheetName.includes('VOLUMES')) {
                var volumeTableDelimeterTrack = estimateByMTable.cells['F8'].value();
              }

              if (
                (sheetName.includes('PAREDES') && wallTableDelimeterTrack == null) ||
                (sheetName.includes('VAR') && barsTableDelimeterTrack != null) ||
                (sheetName.includes('VOLUMES') && volumeTableDelimeterTrack != null)
              ) {
                // If this cell is null, update
                tableDelimeterUpdate(numbersAppControllerP, estimateByMTable);
              }
            }

            var estimateByMTableRowsL2 = estimateByMTable.rowCount();

            if (sheetName.includes('AREAS')) {
              // First colum of G09
              deleteColumns(estimateByMTable, 1, 0);
            } else if (
              sheetName.includes('COBERTURA') ||
              sheetName.includes('ESPECIALIDADES') ||
              sheetName.includes('PAREDES') ||
              sheetName.includes('SUPERF') ||
              sheetName.includes('VAOS') ||
              sheetName.includes('VAR') ||
              sheetName.includes('VOLUMES')
            ) {
              // 🔴🔴🔴 DELETE Coluna de Nível, vem no Export e no Archicad vem apenas em Header
              deleteColumns(estimateByMTable, 1, 1);
            }

            if (sheetName.includes('AREAS')) {
              var rowSecondaryColorForAreas = greenLight;

              // Delete last Empty Column
              // deleteColumns(estimateByMTable, 1, 7) // Era 5 no 7
              deleteColumns(estimateByMTable, 1, 7); // Era 5 no 7

              alignVertical(estimateByMTable, 'A7:G' + estimateByMTableRowsL2, 'center');

              var estimateByMTableRowsL3 = estimateByMTable.rowCount();

              thousandsSeparatorWithCopyPaste(numbersAppControllerP, estimateByMTable, 'B7:G' + estimateByMTableRowsL3, 1);

              for (var i = 6; i < estimateByMTableRowsL3; i++) {
                var iSum = i + 1;
                var columnA_Track = estimateByMTable.cells['A' + iSum].value();

                if (columnA_Track == 'Cabouco' || columnA_Track == 'Implantação Obra' || columnA_Track == 'Limpeza Terreno') {
                  applyBackgroundColor(estimateByMTable, 'A' + iSum, rowSecondaryColorForAreas);

                  if (columnA_Track == 'Cabouco') {
                    applyBackgroundColor(estimateByMTable, 'C' + iSum, rowSecondaryColorForAreas);
                  } else if (columnA_Track == 'Implantação Obra') {
                    applyBackgroundColor(estimateByMTable, 'F' + iSum, rowSecondaryColorForAreas);
                  } else if (columnA_Track == 'Limpeza Terreno') {
                    applyBackgroundColor(estimateByMTable, 'G' + iSum, rowSecondaryColorForAreas);
                  }
                } else if (columnA_Track == 'Laje Cobertura' || columnA_Track == 'Laje Piso') {
                  applyBackgroundColor(estimateByMTable, 'A' + iSum + ':B' + iSum, rowSecondaryColorForAreas);

                  if (columnA_Track == 'Laje Cobertura') {
                    applyBackgroundColor(estimateByMTable, 'D' + iSum, rowSecondaryColorForAreas);
                  }
                } else if (columnA_Track == 'Laje Piso Térreo') {
                  applyBackgroundColor(estimateByMTable, 'A' + iSum + ':E' + iSum, rowSecondaryColorForAreas);
                } else if (columnA_Track == 'Pilar' || columnA_Track == 'Sapata' || columnA_Track == 'Viga') {
                  applyBackgroundColor(estimateByMTable, 'A' + iSum + ':B' + iSum, rowSecondaryColorForAreas);
                }

                var letters = ['B', 'C', 'D', 'E', 'F', 'G'];

                for (var j = 0; j < letters.length; j++) {
                  var quantity = estimateByMTable.cells[letters[j] + iSum].value();

                  if (quantity == 0 || quantity == null) {
                    estimateByMTable.cells[letters[j] + iSum].value = '';
                  } else {
                    estimateByMTable.cells[letters[j] + iSum].value = formatNumber(quantity * marginOfError, 2, 2);
                  }
                }
              }

              estimateByMTable.cells['A' + iSum].addRowBelow();

              var estimateByMTableRowsL3 = estimateByMTable.rowCount();

              estimateByMTable.cells['C' + (iSum + 1)].value = '=SUM(C7:C' + iSum + ')';
              estimateByMTable.cells['E' + (iSum + 1)].value = '=SUM(E7:E' + iSum + ')';
              estimateByMTable.cells['F' + (iSum + 1)].value = '=SUM(F7:F' + iSum + ')';
              estimateByMTable.cells['G' + (iSum + 1)].value = '=SUM(G7:G' + iSum + ')';

              applyBackgroundColor(estimateByMTable, 'A' + (iSum + 1) + ':D' + (iSum + 1), 'white');

              applyBackgroundColor(estimateByMTable, 'C' + (iSum + 1), rowPrimaryColor);

              applyBackgroundColor(estimateByMTable, 'E' + (iSum + 1), rowPrimaryColor);

              applyBackgroundColor(estimateByMTable, 'F' + (iSum + 1) + ':G' + (iSum + 1), rowPrimaryColor);

              var areasQuantities = {};

              for (var i = 6; i < estimateByMTableRowsL3; i++) {
                var iSum = i + 1;
                var elementName = estimateByMTable.cells['A' + iSum].value();
                var quantity = estimateByMTable.cells['B' + iSum].value();

                if (quantity != null) {
                  var elementName = 'Cofragem ' + elementName;

                  if (elementName.includes('Laje')) {
                    var elementName = 'Cofragem Laje';
                  }

                  if (areasQuantities[elementName] === undefined) {
                    areasQuantities[elementName] = quantity;
                  } else {
                    areasQuantities[elementName] += quantity;
                  }
                }
              }

              // ------------- Tratamento Anti-Térmitas
              var antiTermitesQuantity = estimateByMTable.cells['C' + estimateByMTableRowsL3].value();

              areasQuantities['Tratamento Anti-Térmitas'] = antiTermitesQuantity;

              // ------------- Malhassol
              var meshIronQuantity = estimateByMTable.cells['E' + estimateByMTableRowsL3].value();

              areasQuantities['Malhassol'] = meshIronQuantity;

              // ------------- Implantação
              var implantationQuantity = estimateByMTable.cells['F' + estimateByMTableRowsL3].value();

              areasQuantities['Implantação Obra'] = implantationQuantity;

              // ------------- Limpeza do Terreno
              var cleaningTerrainQuantity = estimateByMTable.cells['G' + estimateByMTableRowsL3].value();

              areasQuantities['Limpeza Terreno'] = cleaningTerrainQuantity;

              for (var i = 6; i < estimateByMTableRowsL3; i++) {
                var iSum = i + 1;
                var elementName = estimateByMTable.cells['A' + iSum].value();
                var quantity = estimateByMTable.cells['D' + iSum].value();

                if (quantity != null) {
                  var elementName = 'Impermeabilização ' + elementName;

                  if (areasQuantities[elementName] === undefined) {
                    areasQuantities[elementName] = quantity;
                  } else {
                    areasQuantities[elementName] += quantity;
                  }
                }
              }

              var estimateInfoToFill = areasQuantities;
            } else if (sheetName.includes('COBERTURA') || sheetName.includes('ESPECIALIDADES')) {
              if (sheetName.includes('COBERTURA')) {
                var rowsToDelete = 1;
              } else if (sheetName.includes('ESPECIALIDADES')) {
                var rowsToDelete = 3;
              }

              alignVertical(estimateByMTable, 'A7:D' + estimateByMTableRowsL2, 'center');

              alignHorizontal(estimateByMTable, 'C7:C' + estimateByMTableRowsL2, 'center');

              // deleteRows(estimateByMTable, 2, 6)

              var estimateByMTableRowsL3 = estimateByMTable.rowCount();

              thousandsSeparatorWithCopyPaste(numbersAppControllerP, estimateByMTable, 'D7:D' + estimateByMTableRowsL3, 3);

              var generalQuantities = {};

              for (var i = 6; i < estimateByMTableRowsL3; i++) {
                var iSum = i + 1;
                var columnA_Track = estimateByMTable.cells['A' + iSum].value();
                var elementName = estimateByMTable.cells['B' + iSum].value();
                var elementUnit = estimateByMTable.cells['C' + iSum].value();
                var quantityTrack = estimateByMTable.cells['D' + iSum].value();

                if (columnA_Track) {
                  var columnA_Track = columnA_Track.replace(/G\d{3},\s/g, '');
                  estimateByMTable.cells['A' + iSum].value = columnA_Track;

                  applyBackgroundColor(estimateByMTable, 'A' + iSum + ':D' + iSum, rowPrimaryColor);

                  if (sheetName.includes('ESPECIALIDADES')) {
                    var specialityId = columnA_Track.match(/\((\d\w*)\)/)[1];
                  }
                }

                if (quantityTrack != null) {
                  if (elementUnit == 'un' || elementName.includes('ApplyInDocNumProcess_UN')) {
                    // Quantidades unitárias sem margem de erro
                    var marginOfErrorLocal = 1.0;
                  } else {
                    var marginOfErrorLocal = marginOfError;
                  }

                  var quantity = quantityTrack * marginOfErrorLocal;

                  //estimateByMTable.cells["D" + iSum].value = "=" + quantityTrack + "*" + marginOfErrorLocal
                  estimateByMTable.cells['D' + iSum].value = quantity;

                  if (sheetName.includes('ESPECIALIDADES')) {
                    // if (elementUnit == "m2" || elementUnit == "ml") {

                    if (elementUnit == 'ml') {
                      // if (sheetName.includes("ESPECIALIDADES")) { // Only ml
                      // 	var quantityToMoveToRowC_Track = estimateByMTable.cells["E" + iSum].value()

                      // }

                      if (elementName.includes('ApplyInDocNumProcess_UN')) {
                        var elementName = elementName.replace(' // ApplyInDocNumProcess_UN', '');
                        var elementUnit = 'un'; // was "ml"

                        estimateByMTable.cells['B' + iSum].value = elementName;
                        estimateByMTable.cells['C' + iSum].value = elementUnit;
                      } else {
                        var quantityToMoveToRowC_Track = estimateByMTable.cells['E' + iSum].value();

                        var areaToMoveToRowC = quantityToMoveToRowC_Track * marginOfErrorLocal;

                        estimateByMTable.cells['D' + iSum].value = areaToMoveToRowC;

                        var quantity = areaToMoveToRowC;
                      }
                    }
                  }

                  if (sheetName.includes('ESPECIALIDADES')) {
                    var elementNameWithUnit = `${specialityId} | ${elementName} | ${elementUnit}`;
                  } else {
                    var elementNameWithUnit = `${elementName} | ${elementUnit}`;
                  }

                  if (generalQuantities[elementNameWithUnit] === undefined) {
                    generalQuantities[elementNameWithUnit] = quantity;
                  } else {
                    generalQuantities[elementNameWithUnit] += quantity;

                    // -------------- 🔴🔴🔴 THIS IS ONLY USEFUL FOR COBERTURA THAT DOES NOT ACCPET MERGE ITEMS IN ARCHICAD BECAUSE QUANTITY COMES FROM EXPRESSION (has not in TXT file)

                    estimateByMTable.cells['D' + (iSum - 1)].value = generalQuantities[elementNameWithUnit];

                    deleteRows(estimateByMTable, 1, i);

                    i -= 1;

                    estimateByMTableRowsL3 -= 1;
                  }
                }
              }

              // Delete last Empty Column
              // Delelte after process to move Area quantities during process
              deleteColumns(estimateByMTable, rowsToDelete, 4);
            } else if (sheetName.includes('PAREDES')) {
              // 🔴🔴🔴 DELETE Coluna de Nível, vem no Export e no Archicad vem apenas em Header
              //deleteColumns(estimateByMTable, 1, 1)

              deleteColumns(estimateByMTable, 1, 10); // Delete last Empty Column

              alignVertical(estimateByMTable, 'A7:J' + estimateByMTableRowsL2, 'center');

              // 🔴🔴🔴 No ROWS to delete in new version
              // deleteRows(estimateByMTable, 3, 6)

              // // 🔴🔴🔴 ADD ROW IN LAST ROW in new VERSION
              // estimateByMTable.cells["A" + estimateByMTableRowsL2].addRowBelow()

              var estimateByMTableRowsL3 = estimateByMTable.rowCount();

              // Numbers 12.2 não aceita Thousands se for "Automatic" por isso mudei para "Number"
              // Tive que criar funcão thousandsSeparatorWithCopyPaste
              //thousandsSeparator(numbersAppControllerP, estimateByMTable, "C7:J" + estimateByMTableRowsL3, "Number")

              // 🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴 POR VEZES DÁ ERRO AINDA NAO PERCEBIDO, FECHANDO NUMBERS E ABRIR RESOLVE
              // Acho que o error mencionado acima já foi resolvido em thousandsSeparatorWithCopyPaste, tendo aumentado delay em pressDelete de d0p1 apar d0p3

              thousandsSeparatorWithCopyPaste(numbersAppControllerP, estimateByMTable, 'C7:J' + estimateByMTableRowsL3, 1);

              alignHorizontal(estimateByMTable, 'C7:C' + estimateByMTableRowsL3, 'right');

              alignHorizontal(estimateByMTable, 'B7:B' + estimateByMTableRowsL3, 'left');

              var [subtotalLineSumNamesCement, subtotalLineSumNamesGrossSand, subtotalLineSumNamesWater] = [[], [], []];

              // var wallThicknesses = []
              var wallThicknessesToHideSubtotal2 = [];
              var bricksQuantityByThickness = {};

              var rowStartNumToHide = 0;

              var letters = ['C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'];
              // var marginOfError = 1.10

              for (var i = 6; i < estimateByMTableRowsL3; i++) {
                var iSum = i + 1;

                // APPLY marginOfError
                for (var j = 0; j < letters.length; j++) {
                  var letter = letters[j];
                  var quantity_Track = estimateByMTable.cells[letter + iSum].value();

                  if (quantity_Track == 0) {
                    estimateByMTable.cells[letter + iSum].value = '';
                  }

                  var columnC_Track = estimateByMTable.cells['C' + iSum].value();

                  if (quantity_Track) {
                    // var columnC_TrackStr = columnC_Track.toString()

                    var quantity_TrackStr = quantity_Track.toString();

                    if (quantity_TrackStr.includes('m')) {
                      var quantity = Number(quantity_TrackStr.split('m')[0].replace(/,/g, ''));
                    } else {
                      var quantity = quantity_Track;
                    }

                    var quantityWithMarginOfError = quantity * marginOfError;

                    if (quantity_TrackStr.includes('m')) {
                      var quantityWithMarginOfError = formatNumber(quantityWithMarginOfError, 2, 2) + ' m²';
                    }

                    // Change Cells info, only if marginOfError is not 1.00 obviuosly
                    if (marginOfError != 1.0) {
                      estimateByMTable.cells[letter + iSum].value = quantityWithMarginOfError;
                    }

                    // if (iSum > 7 && letter == "F") {
                    // 	alert(`${quantityWithMarginOfError}`, `quantityWithMarginOfError`)
                    // }
                  }
                }

                var columnA_Track = estimateByMTable.cells['A' + iSum].value();
                var columnB_Track = estimateByMTable.cells['B' + iSum].value();
                var columnF_Track = estimateByMTable.cells['F' + iSum].value();

                if (columnB_Track != null) {
                  if (rowStartNumToHide == 0) {
                    var rowStartNumToHide = iSum;
                  }

                  var bricksQuantity = estimateByMTable.cells['D' + iSum].value();

                  if (columnC_Track && !columnC_Track.toString().includes('m')) {
                    var columnB_TrackStr = 'Bloco ' + columnB_Track;

                    if (columnF_Track > 0) {
                      columnB_TrackStr += ` (Amaciçados)`;
                    }

                    if (bricksQuantityByThickness[columnB_TrackStr] === undefined) {
                      bricksQuantityByThickness[columnB_TrackStr] = bricksQuantity;
                    } else {
                      bricksQuantityByThickness[columnB_TrackStr] += bricksQuantity;
                    }
                  }
                }

                if (columnA_Track != null) {
                  var columnA_TrackItems = columnA_Track.split(', ');

                  // Remove G301
                  estimateByMTable.cells['A' + iSum].value = columnA_TrackItems.slice(1, columnA_TrackItems.length).join(', ');

                  if (i > 6) {
                    // Não no primeiro columnA_Track

                    estimateByMTable.cells['A' + i].addRowBelow();

                    i += 1;
                    estimateByMTableRowsL3 += 1;

                    // ----------------- FUNCTION
                    var subtotalLineSumNames = [
                      subtotalLineSumNamesCement,
                      subtotalLineSumNamesGrossSand,
                      subtotalLineSumNamesWater,
                    ];

                    wallCalculationsSubtotal2(estimateByMTable, iSum, subtotalLineSumNames, wallThicknessesToHideSubtotal2);

                    // Reset
                    var wallThicknessesToHideSubtotal2 = [];

                    // Bold row
                    bold(estimateByMTable, 'A' + (iSum + 1) + ':J' + (iSum + 1));
                    applyBackgroundColor(estimateByMTable, 'A' + (iSum + 1) + ':J' + (iSum + 1), rowPrimaryColor);
                  } else {
                    // Bold row
                    bold(estimateByMTable, 'A' + iSum + ':J' + iSum);
                    applyBackgroundColor(estimateByMTable, 'A' + iSum + ':J' + iSum, rowPrimaryColor);
                  }

                  // Reseting
                  var [subtotalLineSumNamesCement, subtotalLineSumNamesGrossSand, subtotalLineSumNamesWater] = [[], [], []];
                }

                try {
                  // columnC_Track.includes("m") raise error if is null
                  if (columnC_Track.includes('m')) {
                    estimateByMTable.cells['A' + iSum].addRowBelow();

                    i += 1;
                    estimateByMTableRowsL3 += 1;

                    // Cimento
                    var subTotalLineSumNameCement = estimateByMTable.cells['E' + (iSum + 1)].name();
                    subtotalLineSumNamesCement.push(subTotalLineSumNameCement);

                    // Areia Grossa
                    var subTotalLineSumNameGrossSand = estimateByMTable.cells['G' + (iSum + 1)].name();
                    subtotalLineSumNamesGrossSand.push(subTotalLineSumNameGrossSand);

                    // Água
                    var subTotalLineSumNameWater = estimateByMTable.cells['I' + (iSum + 1)].name();
                    subtotalLineSumNamesWater.push(subTotalLineSumNameWater);

                    // ----------------- FUNCTION
                    wallCalculationsSubtotal1(estimateByMTable, estimateByMTableRowsL3, i, iSum, rowSecondaryColor, hideRows);

                    // ----- HIDE ROWS

                    var thisWallThikness = estimateByMTable.cells['B' + (iSum - 1)].value();

                    if (hideRows) {
                      var numOfRowsToHide = estimateByMTable.cells['B' + iSum].value();
                      var rowEndNumToHide = rowStartNumToHide + numOfRowsToHide - 1;

                      hideRowsRange(estimateByMTable, numOfRowsToHide, 'A' + rowStartNumToHide + ':A' + rowEndNumToHide);

                      // In Numbers replace Quantity (numOfRowsToHide) of Walls with its thickness
                      // var thisWallThikness = estimateByMTable.cells["B" + (iSum - 1)].value()
                      estimateByMTable.cells['B' + iSum].value = thisWallThikness;

                      // Reseting
                      var rowStartNumToHide = 0;
                    }

                    if (thisWallThikness) {
                      wallThicknessesToHideSubtotal2.push(thisWallThikness);
                    }
                  }
                } catch {}

                if (i == estimateByMTableRowsL3 - 1) {
                  // 🔴🔴🔴 IN OLD VERSION
                  estimateByMTable.cells['A' + (i - 1)].addRowBelow();

                  // // 🔴🔴🔴 IN NEW VERSION
                  // estimateByMTable.cells["A" + (i)].addRowBelow()

                  i += 1;
                  estimateByMTableRowsL3 += 1;

                  // ----------------- FUNCTION / TOTAL
                  var subtotalLineSumNamesAndColors = [
                    [subtotalLineSumNamesCement, grandTotalRangeColor_Cement],
                    [subtotalLineSumNamesGrossSand, grandTotalRangeColor_Sand],
                    [subtotalLineSumNamesWater, grandTotalRangeColor_Water],
                  ];

                  var bricksQuantityByThicknessArrayProcessed = Object.entries(bricksQuantityByThickness).map(item =>
                    item.join(': ')
                  );

                  const wallMatetialStr = wallWriteTotal(
                    estimateByMTable,
                    estimateByMTableRowsL3,
                    iSum,
                    subtotalLineSumNamesAndColors,
                    grandTotalRangeColor_General,
                    rowPrimaryColor,
                    hideRows,
                    bricksQuantityByThicknessArrayProcessed,
                    wallThicknessesToHideSubtotal2
                  );

                  if (includeCost) {
                    var wallCostInfo = wallCost(
                      estimateByMTable,
                      buildingNameAndGroupID,
                      iSum,
                      bricksQuantityByThicknessArrayProcessed,
                      priceBrick100,
                      priceBrick150,
                      priceBrick200,
                      priceCementUnit,
                      priceGrossSandM3,
                      priceWaterL,
                      costRowsColor
                    );

                    processedBuildingsInfo.push(wallCostInfo);
                  }

                  // ----------------- WRITE SUMMARY
                  estimateByMSummaryTable.cells['B2'].value = wallMatetialStr;
                }
              }

              var estimateInfoToFill = bricksQuantityByThickness;
            } else if (sheetName.includes('SUPERF')) {
              // 🔴🔴🔴 DELETE Coluna de Elemento, vem no Export e no Archicad vem apenas em Header
              //deleteColumns(estimateByMTable, 1, 1)
              deleteColumns(estimateByMTable, 2, 1);

              // // 🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴 OUTRA SOLUÇÃO SERIA USAR O CONCEITO DE ELIMINAR A ÚLTIMA COLUNA QUE ESTÁ EM Tex A5 Programa de Necessidades - USA REMOVE LAST TAB - 🔴🔴🔴 PARECE QUE É MELHOR DEIXAR ASSIM AQUI
              // deleteColumns(estimateByMTable, 1, 3) // Empty Column

              alignVertical(estimateByMTable, 'A7:C' + estimateByMTableRowsL2, 'center');

              // deleteRows(estimateByMTable, 2, 6)

              var estimateByMTableRowsL3 = estimateByMTable.rowCount();

              setDecimals(numbersAppControllerP, estimateByMTable, 'C7:C' + estimateByMTableRowsL3, 1, 'Up');

              thousandsSeparator(numbersAppControllerP, estimateByMTable, 'C7:C' + estimateByMTableRowsL3, 'Number');

              var levelNames = [];

              var rowPrimaryColorsIndex = 0;
              var hideRowDetailsStartNum = 7;
              //var quantitiesNoProcessPartial = {};
              var surfaceQuantitiesTotal = {};

              for (var i = 6; i < estimateByMTableRowsL3; i++) {
                var iSum = i + 1;
                var columnA_Track = estimateByMTable.cells['A' + iSum].value();
                var columnB_Track = estimateByMTable.cells['B' + iSum].value();
                var columnC_Track = estimateByMTable.cells['C' + iSum].value();

                var columnD_Track = estimateByMTable.cells['D' + iSum].value();
                var columnE_Track = estimateByMTable.cells['E' + iSum].value();

                if (columnC_Track != null) {
                  if (columnE_Track) {
                    // 01P description colum

                    // 🔴🔴🔴 columnC_Track is quantity
                    // columnD_Track is 01P quantity
                    var columnC_Track = columnD_Track;
                    estimateByMTable.cells['B' + iSum].value = columnE_Track;
                    var columnB_Track = columnE_Track;
                  }

                  estimateByMTable.cells['C' + iSum].value = '=' + columnC_Track + '*' + marginOfError;

                  var columnC_Track = columnC_Track * marginOfError;
                }

                if (columnA_Track != null) {
                  var columnA_TrackItems = columnA_Track.split(', ');
                  var levelName = columnA_TrackItems.slice(0, 2).join(' '); // G301 B Piso 1
                  var spaceName = columnA_TrackItems[columnA_TrackItems.length - 1];

                  // Remove G301
                  estimateByMTable.cells['A' + iSum].value = columnA_TrackItems.slice(1, columnA_TrackItems.length).join(', ');

                  // Não no primeiro columnA_Track
                  if (i > 6 && levelNames[0] != levelName) {
                    var levelNames = [];

                    if (rowPrimaryColorsIndex == 0) {
                      var rowPrimaryColorsIndex = 1;
                    } else if (rowPrimaryColorsIndex == 1) {
                      var rowPrimaryColorsIndex = 0;
                    }
                  }

                  applyBackgroundColor(
                    estimateByMTable,
                    'A' + iSum + ':C' + iSum,
                    rowPrimaryColorsAlternate[rowPrimaryColorsIndex]
                  );

                  if (!levelNames.includes(levelName)) {
                    levelNames.push(levelName);
                  }
                }

                if (columnB_Track != null) {
                  var quantity = Number(formatNumber(columnC_Track, 2, 2).replace(/,/g, ''));

                  if (columnB_Track.includes('Tijoleira') && !columnB_Track.includes('Rodapé')) {
                    columnB_Track += ' - ' + spaceName;
                  }

                  // CONVERSÃO DE ÁREA PARA METRO LINEAR DE RODAPÉ
                  if (columnB_Track.includes('Rodapé')) {
                    columnB_Track += ` (ml)`;
                    // 0.10 altura de rodapé no Archicad
                    var quantity = quantity / 0.1;

                    estimateByMTable.cells['B' + iSum].value = columnB_Track;
                    estimateByMTable.cells['C' + iSum].value = quantity;
                  }

                  if (surfaceQuantitiesTotal[columnB_Track] === undefined) {
                    surfaceQuantitiesTotal[columnB_Track] = quantity;
                  } else {
                    surfaceQuantitiesTotal[columnB_Track] += quantity;
                  }
                }

                if (i == estimateByMTableRowsL3 - 1) {
                  estimateByMTable.cells['A' + (i + 1)].addRowBelow();
                  estimateByMTable.cells['A' + (i + 1)].addRowBelow();

                  i += 2;
                  estimateByMTableRowsL3 += 2;

                  estimateByMTable.cells['A' + estimateByMTableRowsL3].value = 'TOTAL';

                  var surfaceQuantitiesTotalArray = Object.entries(surfaceQuantitiesTotal);

                  // Sem formatNumber cria deciamis estranhas (313.15000000000003) mesmo com form antes de somar para dictionary

                  // var surfaceQuantitiesTotalArrayProcessed = surfaceQuantitiesTotalArray.map(item => "• " + item[0] + ": " + formatNumber(item[1], 2, 2))
                  var surfaceQuantitiesTotalArrayProcessed = surfaceQuantitiesTotalArray.map(
                    item => '• ' + item[0] + ': ' + formatNumber(Math.ceil(item[1]), 0, 0)
                  );

                  var surfaceQuantitiesTotalArrayTxt = surfaceQuantitiesTotalArrayProcessed.sort().join('\n');

                  estimateByMTable.cells['B' + estimateByMTableRowsL3].value = surfaceQuantitiesTotalArrayTxt;

                  bold(estimateByMTable, 'A' + estimateByMTableRowsL3);

                  applyBackgroundColor(
                    estimateByMTable,
                    'A' + estimateByMTableRowsL3 + ':C' + estimateByMTableRowsL3,
                    grandTotalRangeColor
                  );

                  // ----- NEW

                  if (hideBarsSurfacesVolumesDetails) {
                    var numOfRowsToHide = i + 1 - hideRowDetailsStartNum;

                    hideRowsRange(estimateByMTable, numOfRowsToHide, 'A' + hideRowDetailsStartNum + ':A' + i);
                  }

                  if (includeCost) {
                    var surfaceCostInfo = surfaceCost(
                      estimateByMTable,
                      buildingNameAndGroupID,
                      iSum,
                      surfaceQuantitiesTotalArrayProcessed,
                      priceStoneCoatingM2,
                      pricePaintExteriorM2,
                      pricePaintInteriorM2,
                      pricePaintCeilingM2,
                      priceFloorTilesM2,
                      priceWallTilesM2,
                      priceSkirtingML,
                      costRowsColor
                    );

                    processedBuildingsInfo.push(surfaceCostInfo);
                  }

                  // ----------------- WRITE SUMMARY
                  estimateByMSummaryTable.cells['B5'].value = surfaceQuantitiesTotalArrayTxt;
                }
              }

              // NEW POSITIO

              // 🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴🔴 OUTRA SOLUÇÃO SERIA USAR O CONCEITO DE ELIMINAR A ÚLTIMA COLUNA QUE ESTÁ EM Tex A5 Programa de Necessidades - USA REMOVE LAST TAB - 🔴🔴🔴 PARECE QUE É MELHOR DEIXAR ASSIM AQUI
              deleteColumns(estimateByMTable, 3, 3); // Empty Column

              var estimateInfoToFillArray = Object.entries(surfaceQuantitiesTotal);

              var estimateInfoToFillNormal = {};
              var estimateInfoToFillGeneral = {};

              for (var i = 0; i < estimateInfoToFillArray.length; i++) {
                var item = estimateInfoToFillArray[i];
                var element = item[0];
                var quantity = Number(item[1]);

                if (
                  element.includes('Pintura') &&
                  (element.includes('Tecto') || element.includes('Exterior') || element.includes('Interior'))
                ) {
                  var elementItems = element.split(' - ');

                  var element = elementItems[0] + ' - ' + elementItems.slice(2, 4).join(' - ');
                }

                if (element.includes('Tijoleira') && element.includes('Laje')) {
                  var elementItems = element.split(' - ');

                  // var element = elementItems[0].split(" ")[0] + " - " + elementItems[1].split(" ")[1]
                  var element = elementItems[0] + ' - Piso Térreo'; //+ elementItems[1].split(" ")[1]
                }

                if (element.includes('Pintura') || element.includes('Rodapé')) {
                  if (estimateInfoToFillNormal[element] === undefined) {
                    estimateInfoToFillNormal[element] = quantity;
                  } else {
                    estimateInfoToFillNormal[element] += quantity;
                  }
                } else {
                  element += ' | m2';

                  if (estimateInfoToFillGeneral[element] === undefined) {
                    estimateInfoToFillGeneral[element] = quantity;
                  } else {
                    estimateInfoToFillGeneral[element] += quantity;
                  }
                }
              }

              // var fillIdStart = "GeralSuperfícies"
              // var fillIdEnd = "Pavimentos"
              // var columnB_Track2ID = "PAVIMENTOS"

              var estimateInfoToFill = estimateInfoToFillNormal;
              // var estimateInfoToFillGeneral = Object.entries(estimateInfoToFillGeneral)
            } else if (sheetName.includes('VAOS')) {
              if (openingPriceK != 1.0) {
                alert(`O coeficiente de preço de "Vãos" é diferente de 1.00 (${openingPriceK})!`, ``);

                numbersApp.activate();
              }

              deleteColumns(estimateByMTable, 1, 4); // Delete last Empty Column

              alignHorizontal(estimateByMTable, 'C7:C' + estimateByMTableRowsL2, 'center');

              alignVertical(estimateByMTable, 'A7:D' + estimateByMTableRowsL2, 'center');

              var estimateByMTableRowsL3 = estimateByMTable.rowCount();

              thousandsSeparatorWithCopyPaste(numbersAppControllerP, estimateByMTable, 'D7:D' + estimateByMTableRowsL3, 3);

              var openingType = '';
              var windowsInfo = [];
              var doorsInfo = [];

              for (var i = 6; i < estimateByMTableRowsL3; i++) {
                var iSum = i + 1;
                var columnA_Track = estimateByMTable.cells['A' + iSum].value();
                var columnB_Track = estimateByMTable.cells['B' + iSum].value();

                if (columnB_Track && columnB_Track.includes(' ##')) {
                  var columnB_Track = columnB_Track.replace(' ##', '');
                  estimateByMTable.cells['B' + iSum].value = columnB_Track;
                }

                if (columnA_Track != null) {
                  var columnA_Track = columnA_Track.replace(/G\d{3},\s/g, '');
                  estimateByMTable.cells['A' + iSum].value = columnA_Track;

                  var openingType = columnA_Track;

                  applyBackgroundColor(estimateByMTable, 'A' + iSum + ':D' + iSum, rowPrimaryColor);
                }

                if (columnB_Track) {
                  var openingDimensions = columnB_Track
                    .match(/(\d[0-9,.]*)\sx\s(\d[0-9,.]*)/)
                    .slice(1)
                    // 1000 para metros
                    .map(item => Number(item.replace(/,/g, '')) / 1000);

                  var openingArea = openingDimensions[0] * openingDimensions[1];

                  var material = columnB_Track.split(', ')[1].split(' ')[0];
                  var openingTypeAndMaterial = `${openingType} ${material}`;

                  var openningPriceKByMaterial = openningPricesKByMaterial[openingTypeAndMaterial];

                  if (!openningPriceKByMaterial) {
                    var openningPriceKByMaterial = 0;
                  }

                  estimateByMTable.cells['D' + iSum].value = formatNumber(openingArea * openningPriceKByMaterial, 2, 2);

                  // --------------- COLLECT INFO
                  var quantity = estimateByMTable.cells['C' + iSum].value();
                  var priceUnit = estimateByMTable.cells['D' + iSum].value();

                  if (
                    openingType == 'Bloco de Vidro' ||
                    openingType == 'Grade Janela' ||
                    openingType == 'Grelha' ||
                    openingType == 'Janela' ||
                    openingType == 'Ventilador'
                  ) {
                    // windowsInfo.push(["Janela", columnB_Track, quantity, priceUnit])

                    windowsInfo.push([columnB_Track + ' | ' + priceUnit, quantity]);
                  } else if (openingType == 'Grade Porta' || openingType == 'Porta' || openingType == 'Portão') {
                    // doorsInfo.push(["Porta", columnB_Track, quantity, priceUnit])

                    doorsInfo.push([columnB_Track + ' | ' + priceUnit, quantity]);
                  }
                }
              }

              // var estimateInfoToFill = windowsInfo.concat(doorsInfo)
            } else if (sheetName.includes('VAR')) {
              deleteColumns(estimateByMTable, 1, 12); // Delete last Empty Column

