                      slabBarsQuantitiesObj,
                      hideRowDetailsStartNum,
                      numOfRowsToHideCollection,
                      hideBarsSurfacesVolumesDetails
                    );

                    // ----------------- SLABS
                    /*
										barsSlabWriteSubtotal(estimateByMTable, iSum,  slabBars6QuantitiesPartial, slabBars8QuantitiesPartial, slabBars10QuantitiesPartial,slabBars12QuantitiesPartial, slabBarsSubTotalAndTotalColor)
										*/

                    // var slabBarsPartialList = [slabBars6QuantitiesPartial, slabBars8QuantitiesPartial, slabBars10QuantitiesPartial, slabBars12QuantitiesPartial]

                    // -----------------

                    if (rowPrimaryColorsIndex == 0) {
                      var rowPrimaryColorsIndex = 1;
                    } else if (rowPrimaryColorsIndex == 1) {
                      var rowPrimaryColorsIndex = 0;
                    }

                    var numOfRowsToHideCollection = 0;
                    var hideRowDetailsStartNum = iSum + 1;

                    applyBackgroundColor(
                      estimateByMTable,
                      'A' + (iSum + 1) + ':K' + (iSum + 1),
                      rowPrimaryColorsAlternate[rowPrimaryColorsIndex]
                    );

                    var levelNames = [];
                    var quantitiesBarsPartial = {};
                    var stirrupsNameStr = '';

                    slabBars6QuantitiesTotal += slabBars6QuantitiesPartial;
                    var slabBars6QuantitiesPartial = 0;

                    slabBars8QuantitiesTotal += slabBars8QuantitiesPartial;
                    var slabBars8QuantitiesPartial = 0;

                    slabBars10QuantitiesTotal += slabBars10QuantitiesPartial;
                    var slabBars10QuantitiesPartial = 0;

                    slabBars12QuantitiesTotal += slabBars12QuantitiesPartial;
                    var slabBars12QuantitiesPartial = 0;

                    // ---------------
                    shoeQuantityTotal += shoeQuantityPartial;
                    var shoeQuantityPartial = 0;

                    columnQuantityTotal += columnQuantityPartial;
                    var columnQuantityPartial = 0;

                    beamQuantityTotal += beamQuantityPartial;
                    var beamQuantityPartial = 0;
                  } else {
                    applyBackgroundColor(
                      estimateByMTable,
                      'A' + iSum + ':K' + iSum,
                      rowPrimaryColorsAlternate[rowPrimaryColorsIndex]
                    );
                  }

                  if (!levelNames.includes(levelName)) {
                    levelNames.push(levelName);
                  }
                }

                if (columnB_Track != null) {
                  if (levelAndElement.includes('Sapata') && columnB_Track.includes('Var')) {
                    var quantity = estimateByMTable.cells['C' + iSum].value();

                    estimateByMTable.cells['C' + iSum].value = Math.ceil(quantity * marginOfError);

                    applyBackgroundColor(estimateByMTable, 'B' + iSum + ':C' + iSum, rowSecondaryColor);
                  } else if (
                    (levelAndElement.includes('Pilar') || levelAndElement.includes('Viga')) &&
                    columnB_Track.includes('Var')
                  ) {
                    applyBackgroundColor(estimateByMTable, 'B' + iSum + ':B' + iSum, rowSecondaryColor);

                    var stirrupsNameStr = levelAndElement.split(' / ')[1];

                    if (levelAndElement.includes('Pilar')) {
                      stirrupsNameStr += ' (Pilar)';

                      var quantity = estimateByMTable.cells['D' + iSum].value();
                      estimateByMTable.cells['D' + iSum].value = Math.ceil(quantity * marginOfError);

                      // 🔴🔴🔴 NOT USED YET
                      var quantityStirrups = estimateByMTable.cells['E' + iSum].value();
                      estimateByMTable.cells['E' + iSum].value = Math.ceil(quantityStirrups * marginOfError);

                      applyBackgroundColor(estimateByMTable, 'D' + iSum + ':E' + iSum, rowSecondaryColor);
                    } else if (levelAndElement.includes('Viga')) {
                      stirrupsNameStr += ' (Viga)';

                      var quantity = estimateByMTable.cells['F' + iSum].value();
                      estimateByMTable.cells['F' + iSum].value = Math.ceil(quantity * marginOfError);

                      // 🔴🔴🔴 NOT USED YET
                      var quantityStirrups = estimateByMTable.cells['G' + iSum].value();
                      estimateByMTable.cells['G' + iSum].value = Math.ceil(quantityStirrups * marginOfError);

                      applyBackgroundColor(estimateByMTable, 'F' + iSum + ':G' + iSum, rowSecondaryColor);
                    }

                    var quantityStirrupsWithMarginOfError = Math.ceil(quantityStirrups * marginOfError);

                    if (quantitiesBarsPartial[stirrupsNameStr] === undefined) {
                      quantitiesBarsPartial[stirrupsNameStr] = quantityStirrupsWithMarginOfError;
                    } else {
                      quantitiesBarsPartial[stirrupsNameStr] += quantityStirrupsWithMarginOfError;
                    }

                    if (quantitiesBarsTotal[stirrupsNameStr] === undefined) {
                      quantitiesBarsTotal[stirrupsNameStr] = quantityStirrupsWithMarginOfError;
                    } else {
                      quantitiesBarsTotal[stirrupsNameStr] += quantityStirrupsWithMarginOfError;
                    }
                  }

                  var quantityWithMarginOfError = Math.ceil(quantity * marginOfError);

                  if (quantitiesBarsPartial[columnB_Track] === undefined) {
                    quantitiesBarsPartial[columnB_Track] = quantityWithMarginOfError;
                  } else {
                    quantitiesBarsPartial[columnB_Track] += quantityWithMarginOfError;
                  }

                  if (quantitiesBarsTotal[columnB_Track] === undefined) {
                    quantitiesBarsTotal[columnB_Track] = quantityWithMarginOfError;
                  } else {
                    quantitiesBarsTotal[columnB_Track] += quantityWithMarginOfError;
                  }

                  if (rowStartNumToHide == 0) {
                    // + 1 para considerar a fila a seguir pois a corrente é necessária para introduzir os resumos
                    var rowStartNumToHide = iSum + 1;
                  }

                  barsQuantities.push(quantityWithMarginOfError);
                  stirrupsQuantities.push(quantityStirrupsWithMarginOfError);
                } else {
                  // Is SLAB
                  if (levelAndElement.includes('Laje') && slabBars12Track != null) {
