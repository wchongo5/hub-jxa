              deleteColumns(estimateByMTable, 1, 1);

              alignHorizontal(estimateByMTable, 'C7:K' + estimateByMTableRowsL2, 'center');

              alignVertical(estimateByMTable, 'A7:K' + estimateByMTableRowsL2, 'center');

              // Delete Last Rows - is for TOTALS from Schedules
              deleteRows(estimateByMTable, 1, estimateByMTableRowsL2 - 1);

              // NOT NECESSARY IN NEW VERSION
              // deleteRows(estimateByMTable, 3, 6)

              var estimateByMTableRowsL3 = estimateByMTable.rowCount();

              setDecimals(numbersAppControllerP, estimateByMTable, 'C7:K' + estimateByMTableRowsL3, 1, 'Up');

              thousandsSeparator(numbersAppControllerP, estimateByMTable, 'C7:K' + estimateByMTableRowsL3, 'Number');

              // NEW, HIDE DETAILS
              var hideRowDetailsStartNum = 7;
              var numOfRowsToHideCollection = 0;

              // -----
              var rowPrimaryColorsIndex = 0;

              var rowStartNumToHide = 0;
              var barsQuantities = [];
              var stirrupsQuantities = [];
              var barNameAndQuantityTrack = '';

              var levelNames = [];

              var levelAndElement = '';
              var levelsAndElementsTrack = [];
              var stirrupsNameStr = '';

              var quantitiesBarsPartial = {};
              var quantitiesBarsTotal = {};

              var slabBars6QuantitiesPartial = 0;
              var slabBars6QuantitiesTotal = 0;

              var slabBars8QuantitiesPartial = 0;
              var slabBars8QuantitiesTotal = 0;

              var slabBars10QuantitiesPartial = 0;
              var slabBars10QuantitiesTotal = 0;

              var slabBars12QuantitiesPartial = 0;
              var slabBars12QuantitiesTotal = 0;

              // --------------- QUANTITIES: SHOES, COLUMNS AND BEAMS
              var shoeQuantityPartial = 0;
              var columnQuantityPartial = 0;
              var beamQuantityPartial = 0;

              var shoeQuantityTotal = 0;
              var columnQuantityTotal = 0;
              var beamQuantityTotal = 0;
              // ---------------

              for (var i = 6; i < estimateByMTableRowsL3; i++) {
                var iSum = i + 1;
                var columnA_Track = estimateByMTable.cells['A' + iSum].value();
                var columnB_Track = estimateByMTable.cells['B' + iSum].value();

                var slabBars12Track = estimateByMTable.cells['K' + iSum].value();

                // --------------- HIDE ROWS

                if (columnA_Track != null) {
                  var levelAndElement = columnA_Track;

                  levelsAndElementsTrack.push(levelAndElement);
                }

                if (hideRows) {
                  // 🔴🔴🔴 (columnB_Track == null && columnA_Track == null) — SITUAÇÃO FIM DA TABELA, ANTES DE RESUMOS GRAND TOTAL
                  // Vide no Finder o Screen que mostra onde deve permitir HIDE
                  // Vide aplicação no ELSE, ABAIXO

                  if (columnB_Track != null || columnA_Track != null || (columnB_Track == null && columnA_Track == null)) {
                    if (barNameAndQuantityTrack == '' && columnB_Track != null) {
                      var barNameAndQuantityTrack = columnB_Track;
                    } else if (barNameAndQuantityTrack != '') {
                      if (barNameAndQuantityTrack != columnB_Track || (columnA_Track == null && columnB_Track == null)) {
                        var barsQuantitiesL = barsQuantities.length;

                        var barsQuantitiesTotal = sumAllByReduce(barsQuantities);

                        var rowEndNameToHide = estimateByMTable.cells['B' + iSum].name();

                        // - 1 para usar fila anterior a corrente que é novo barNameAndQuantityTrack
                        var rowEndNumToHide = getCellNamePartColumnOrRow(rowEndNameToHide, 'rowName') - 1;

                        // + 1 para compatibilizar o número de numOfRowsToHide
                        var numOfRowsToHide = rowEndNumToHide - rowStartNumToHide + 1;

                        if (columnA_Track == null) {
                          // "hideInChangeBarName"
                          var levelAndElementToUse = levelsAndElementsTrack[levelsAndElementsTrack.length - 1];
                        } else if (columnB_Track == null) {
                          // "hideInSummary"
                          var levelAndElementToUse = levelsAndElementsTrack[levelsAndElementsTrack.length - 2];
                        }

                        var rowStartNumToHideMinus1 = rowStartNumToHide - 1;

                        var barName = estimateByMTable.cells['B' + rowStartNumToHideMinus1].value();

                        if (levelAndElementToUse.includes('Sapata')) {
                          var elementName = barsQuantitiesL > 1 ? 'Sapatas' : 'Sapata';

                          shoeQuantityPartial += barsQuantitiesL;
                        } else if (levelAndElementToUse.includes('Pilar')) {
                          var elementName = barsQuantitiesL > 1 ? 'Pilares' : 'Pilar';

                          columnQuantityPartial += barsQuantitiesL;
                        } else if (levelAndElementToUse.includes('Viga')) {
                          var elementName = barsQuantitiesL > 1 ? 'Vigas' : 'Viga';

                          beamQuantityPartial += barsQuantitiesL;
                        }

                        estimateByMTable.cells[
                          'B' + rowStartNumToHideMinus1
                        ].value = `${barName} (${barsQuantitiesL} ${elementName})`;

                        if (levelAndElementToUse.includes('Sapata')) {
                          estimateByMTable.cells['C' + rowStartNumToHideMinus1].value = barsQuantitiesTotal;
                        } else if (levelAndElementToUse.includes('Pilar') || levelAndElementToUse.includes('Viga')) {
                          var stirrupsQuantitiesTotal = sumAllByReduce(stirrupsQuantities);

                          if (levelAndElementToUse.includes('Pilar')) {
                            estimateByMTable.cells['D' + rowStartNumToHideMinus1].value = barsQuantitiesTotal;

                            estimateByMTable.cells['E' + rowStartNumToHideMinus1].value = stirrupsQuantitiesTotal;
                          } else if (levelAndElementToUse.includes('Viga')) {
                            estimateByMTable.cells['F' + rowStartNumToHideMinus1].value = barsQuantitiesTotal;

                            estimateByMTable.cells['G' + rowStartNumToHideMinus1].value = stirrupsQuantitiesTotal;
                          }
                        }

                        if (numOfRowsToHide > 0) {
                          hideRowsRange(estimateByMTable, numOfRowsToHide, 'A' + rowStartNumToHide + ':A' + rowEndNumToHide);

                          numOfRowsToHideCollection += numOfRowsToHide;

                          // var numOfRowsToHide = 0; // Reset NEW20240102
                        }

                        var rowStartNumToHide = 0;
                        var barsQuantities = [];
                        var stirrupsQuantities = [];

                        if (columnB_Track == null) {
                          var barNameAndQuantityTrack = '';
                        } else {
                          // 🔴🔴🔴 This to get in <if (barNameAndQuantityTrack != "") {> above to write " (1 pilar)" in Varão 6 “Varão 6 (1 pilare)” and include in quantity if is last column that is only one - see screenshot in Finder
                          var barNameAndQuantityTrack = columnB_Track;
                        }
                      }
                    }
                  }
                }

                if (columnA_Track != null) {
                  var columnA_TrackItems = columnA_Track.split(', ');
                  var levelName = columnA_TrackItems.slice(0, 2).join(' '); // G301 B Piso 1

                  // Remove G301
                  estimateByMTable.cells['A' + iSum].value = columnA_TrackItems.slice(1, columnA_TrackItems.length).join(', ');

                  // Não no primeiro columnA_Track
                  if (i > 6 && levelNames[0] != levelName) {
                    estimateByMTable.cells['A' + i].addRowBelow();

                    i += 1;
                    estimateByMTableRowsL3 += 1;

                    const slabBarsQuantitiesObj = {
                      slabBars6QuantitiesPartial,
                      slabBars8QuantitiesPartial,
                      slabBars10QuantitiesPartial,
                      slabBars12QuantitiesPartial,
