                      columnLetter + iSumStart + ':' + columnLetter + iSumEnd
                    );

                    estimateByMTable.cells[columnLetter + (rowStartNumToHide - 1)].value = barsQuantities.toString();

                    if (elementName.includes('Pilar')) {
                      var columnsStirrupsQuantities = sumFromSelectionRange(estimateByMTable, 'E' + iSumStart + ':E' + iSumEnd);

                      estimateByMTable.cells['E' + (rowStartNumToHide - 1)].value = columnsStirrupsQuantities.toString();
                    } else if (elementName.includes('Viga')) {
                      var beamsStirrupsQuantities = sumFromSelectionRange(estimateByMTable, 'G' + iSumStart + ':G' + iSumEnd);

                      estimateByMTable.cells['G' + (rowStartNumToHide - 1)].value = beamsStirrupsQuantities.toString();
                    }

                    hideRowsRange(estimateByMTable, numOfRowsToHide, 'A' + rowStartNumToHide + ':A' + rowEndNumToHide);

                    // var numOfRowsToHideCollection = numOfRowsToHide

                    numOfRowsToHideCollection += numOfRowsToHide;
                  }

                  // ---------------------------------- SUBTOTAL

                  const slabBarsQuantitiesObj = {
                    slabBars6QuantitiesPartial,
                    slabBars8QuantitiesPartial,
                    slabBars10QuantitiesPartial,
                    slabBars12QuantitiesPartial,
