                  estimateByMTable.cells['A' + (i + 1)].addRowBelow();
                  estimateByMTable.cells['A' + (i + 1)].addRowBelow();

                  iSum += 1;
                  i += 2;
                  estimateByMTableRowsL3 += 2;
                  var rowEndNumToHide = i - 1;

