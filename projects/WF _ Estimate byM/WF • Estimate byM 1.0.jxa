  barsKilogramsInfo,
  shoeColumnBeamBarsTotalColor,
  shoesColumnsBeamsStrTotal
) {
  // ---------------
  var quantitiesBarsTotalArray = Object.entries(quantitiesBarsTotal);

  /* // COMPLEX SUMMARY

	var quantitiesBarsTotalArrayProcessed = barsShoesColumnsBeamsWriteTotalToArrayProcess(quantitiesBarsTotal)


	var quantitiesBarsTotalArrayTxt = quantitiesBarsTotalArrayProcessed.join("\n")
	
	// --------------- GET TOTAL OF ESTRIBOS
	var stirrupsQuantitiesArray = quantitiesBarsTotalArray
