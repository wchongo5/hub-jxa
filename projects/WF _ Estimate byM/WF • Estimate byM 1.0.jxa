        estimateByQPathStr ? 'Sim' : 'Não'
      }`;
    }

    alert(`Há erro na busca de "EstimatesPathStrs". Encontrado?`, errorMessage);
  }

  return {
    estimateByMPathStr,
    estimateByQPathStr,
  };
}
 */
function deteleExtraTables(estimateByMSheet, tablesNamesOfBuildingsProcessed) {
  var tablesOfBuildings = getTablesOfBuildings(estimateByMSheet.tables());

  var tablesNamesToDelete = [];
  for (var i = 0; i < tablesOfBuildings.length; i++) {
    var tableOfBuilding = tablesOfBuildings[i];
    var tableOfBuildingName = tableOfBuilding.name();

    if (!tablesNamesOfBuildingsProcessed.includes(tableOfBuildingName)) {
      // tableOfBuilding.delete()

      tablesNamesToDelete.push(tableOfBuildingName);
    }
  }

  deleteTablesByName(estimateByMSheet, tablesNamesToDelete);
}

function getTablesOfBuildings(tables) {
  return tables.filter(item => item.name().includes('(G'));
}

function getTablesNamesOfBuildings(tablesNames) {
  return tablesNames
    .filter(item => item.includes('(G'))
    .sort(function (x, y) {
      // var xp = x.substr(18, 2);
      var xp = x.match(/G(\d{3})/)[1];
      // var yp = y.substr(18, 2);

      var yp = y.match(/G(\d{3})/)[1];
      return xp == yp ? 0 : xp < yp ? -1 : 1;
    });
}

function distributeTablesRightVertically(sheet, tablesNames, distanceBetweenTopLeftCorners_Input) {
  var positionX = 1250;
  var positionY = 75; // Start position

  for (var i = 0; i < tablesNames.length; i++) {
    var tableName = tablesNames[i];
    var table = sheet.tables[tableName];

    if (distanceBetweenTopLeftCorners_Input == 'auto') {
      // var tablePosition = table.position()
      var tableHeight = table.height();
    } else {
      var tableHeight = Number(distanceBetweenTopLeftCorners_Input);
    }

    table.position = { x: positionX, y: positionY };
    positionY += tableHeight + 100;
  }
}

function getBuildingTextType1(buildingsText, buildingGroupId) {
  var re = new RegExp(`${buildingGroupId}.*(\n\t.*)*`, `gm`);
  return buildingsText.match(re).join('\n');
}

function getBuildingTextType2(buildingsText, buildingGroupId) {
  var re = new RegExp(`${buildingGroupId}.*`, `g`);
  return buildingsText.match(re).join('\n');
}

function getBarsTotals(list, indexToReturn) {
  var quantities = list.map(item => {
    var itemItems = item.split('\t');
    var itemItem = itemItems[indexToReturn];

    if (itemItem.includes('-')) {
      return 0.0;
    } else {
      return Number(itemItem);
    }
  });
  return sumAllByReduce(quantities);
}

function getWallTotals(list, indexToReturn) {
  var quantities = list.map(item => Number(item.split('\t')[indexToReturn].replace(' m²', '').replace(/,/, '')));

  if (indexToReturn == 2) {
    // Wall quantity does not need decimals
    return sumAllByReduce(quantities);
  } else {
    return formatNumber(sumAllByReduce(quantities), 2, 2);
  }
}

// -------------------------------- COST ESTIMATE

function deleteBuildingCostEstimateInfo(table) {
  while (table.rowCount() > 9) {
    table.rows[7].delete();
  }
  clearRange(table, 'A8:B8');
}

// ---------------- COST

function populateProcessedBuildingsInfo(headerTable, processedBuildingsInfo, includeCost) {
  var rowIndexStart = 7;
  // 1 is last empty row to ensure SUM() function include new row
  var rowsLWithoutBuilding = rowIndexStart + 1;

  if (includeCost) {
    var processedBuildingsInfoL = processedBuildingsInfo.length;
    var headerTableRowsL = headerTable.rowCount();

    var finalRowsL = rowsLWithoutBuilding + processedBuildingsInfoL;

    if (headerTableRowsL > finalRowsL) {
      while (headerTable.rowCount() > finalRowsL) {
        headerTable.rows[7].delete();
      }
    } else if (headerTableRowsL < finalRowsL) {
      while (headerTable.rowCount() < finalRowsL) {
        headerTable.rows[7].addRowBelow();
      }
    } // else if is headerTableRowsL == finalRowsL // Do nothing

    for (var i = 0; i < processedBuildingsInfo.length; i++) {
      var rowIndex = rowIndexStart + i;
      var itemsToPopulate = processedBuildingsInfo[i];
      rowPopulateItems(headerTable, itemsToPopulate, rowIndex);
    }
  }

  // else { // Delete rows and clear row before last one
  //    while (headerTable.rowCount() > 9) {
  //       headerTable.rows[7].delete();
  //    }

  //    clearRange(headerTable, "A8:B8")
  // }
}

// ---------------- VOLUME COST

function volumeCost(
  estimateByMTable,
  buildingNameAndGroupID,
  iSum,
  volumeQuantitiesTotal,
  priceCementUnit,
  priceGrossSandM3,
  priceRockfill,
  priceStoneM3,
  priceFineSandM3,
  priceRedSandM3,
  priceWaterL,
  costRowsColor
) {
  estimateByMTable.cells['A' + (iSum + 3)].addRowBelow();
  estimateByMTable.cells['A' + (iSum + 3)].addRowBelow();
  estimateByMTable.cells['A' + (iSum + 3)].addRowBelow();

  var volumeQuantitiesTotalArrayProcessed = volumeQuantitiesTotalArrayProcess(volumeQuantitiesTotal);

  var priceVolumeItems = volumeQuantitiesTotalArrayProcessed
    .filter(item => !item.includes('Escavação') && !item.includes('Solo'))
    .map(function (item) {
      var itemItems = item.split(': ');
      var quantity = itemItems[1].replace(/,/g, '');

      if (item.includes('Areia - Vermelha')) {
        var priceSubtotal = quantity * priceRedSandM3;
      } else if (item.includes('Enrocamento')) {
        var priceSubtotal = quantity * priceRockfill;
      } else {
        var priceSubtotal = 0.0;
      }

      // return itemItems[0] + ': ' + formatNumber(priceSubtotal.toString(), 2, 2);
      return itemItems[0] + ': ' + formatNumber(priceSubtotal, 2, 2);
    });

  applyBackgroundColor(estimateByMTable, 'A' + (iSum + 4) + ':' + 'H' + (iSum + 6), costRowsColor);

  applyBackgroundColor(estimateByMTable, 'A' + (iSum + 4) + ':' + 'C' + (iSum + 4), 'white');

  estimateByMTable.cells['A' + (iSum + 5)].value = 'ESTIMATIVA DE CUSTO';
  estimateByMTable.cells['B' + (iSum + 5)].value = priceVolumeItems.filter(item => item.split(': ')[1] != '0.00').join('\n');

  var priceVolumeQuantitiesNoProcesTotal = sumAllByReduce(
    priceVolumeItems.map(item => Number(item.split(': ')[1].replace(/,/g, '')))
  );

  var letters = ['D', 'E', 'F', 'G', 'H'];
  var pricesCimentGrossSandFineSandStoneWater = [priceCementUnit, priceGrossSandM3, priceFineSandM3, priceStoneM3, priceWaterL];

  var priceCimentGrossSandFineSandStoneWaterCollection = [];

  for (var i = 0; i < letters.length; i++) {
    var quantity = estimateByMTable.cells[letters[i] + (iSum + 3)].value();
    // var quantity = Number(formatNumber(estimateByMTable.cells[letters[i] + (iSum + 3)].value()), 2, 2)

    var cost = quantity * pricesCimentGrossSandFineSandStoneWater[i];
    estimateByMTable.cells[letters[i] + (iSum + 4)].value = cost;

    priceCimentGrossSandFineSandStoneWaterCollection.push(cost);
  }

  var priceCimentGrossSandFineSandStoneWaterTotal = sumAllByReduce(priceCimentGrossSandFineSandStoneWaterCollection);

  estimateByMTable.cells['D' + (iSum + 5)].value = formatNumber(priceCimentGrossSandFineSandStoneWaterTotal, 2, 2);

  var rangeNameToFormat1 = 'D' + (iSum + 5) + ':' + 'H' + (iSum + 5);
  alignHorizontal(estimateByMTable, rangeNameToFormat1, 'center');

  mergeCells(estimateByMTable, rangeNameToFormat1);

  var priceVolumeTotal = priceVolumeQuantitiesNoProcesTotal + priceCimentGrossSandFineSandStoneWaterTotal;

  estimateByMTable.cells['A' + (iSum + 6)].value = formatNumber(priceVolumeTotal, 2, 2);

  var rangeNameToFormat2 = 'A' + (iSum + 6) + ':' + 'H' + (iSum + 6);
  alignHorizontal(estimateByMTable, rangeNameToFormat2, 'center');
  applyFontSize(estimateByMTable, rangeNameToFormat2, 15);
  mergeCells(estimateByMTable, rangeNameToFormat2);

  return [buildingNameAndGroupID, priceVolumeTotal];
}

// ---------------- BARS COST

function barsCost(
  estimateByMTable,
  buildingNameAndGroupID,
  iSum,
  quantitiesBarsTotal,
  stirrupCoecientCost,
  bar6Cost,
  bar8Cost,
  bar10Cost,
  bar12Cost,
  slabBarsList,
  costRowsColor
) {
  estimateByMTable.cells['A' + (iSum + 2)].addRowBelow();
  estimateByMTable.cells['A' + (iSum + 2)].addRowBelow();
  estimateByMTable.cells['A' + (iSum + 2)].addRowBelow();

  var quantitiesBarsTotalArrayProcessed = barsShoesColumnsBeamsWriteTotalToArrayProcess(quantitiesBarsTotal);

  var priceBarsItems = quantitiesBarsTotalArrayProcessed.map(function (item) {
    var itemItems = item.split(': ');
    var quantity = itemItems[1].replace(/,/g, '');

    if (item.includes('Estribo')) {
      var stirrupLengthWithListStrs = item.match(/(\d*)x(\d*)/).slice(-2);

      // 1000 para metros
      var stirrupLengthWithList = stirrupLengthWithListStrs.map(num => Number(num) / 1000);
      var stirrupLengthLinear = sumAllByReduce(stirrupLengthWithList) * 2;
      var priceSubtotal = quantity * stirrupLengthLinear * stirrupCoecientCost;
    } else if (item.includes('Varão 6')) {
      var priceSubtotal = quantity * bar6Cost;
    } else if (item.includes('Varão 8')) {
      var priceSubtotal = quantity * bar8Cost;
    } else if (item.includes('Varão 10')) {
      var priceSubtotal = quantity * bar10Cost;
    } else if (item.includes('Varão 12')) {
      var priceSubtotal = quantity * bar12Cost;
    }

    // return itemItems[0] + ': ' + formatNumber(priceSubtotal.toString(), 2, 2);
    return itemItems[0] + ': ' + formatNumber(priceSubtotal, 2, 2);
  });

  applyBackgroundColor(estimateByMTable, 'A' + (iSum + 3) + ':' + 'K' + (iSum + 5), costRowsColor);

  applyBackgroundColor(estimateByMTable, 'A' + (iSum + 3) + ':' + 'G' + (iSum + 3), 'white');

  estimateByMTable.cells['A' + (iSum + 4)].value = 'ESTIMATIVA DE CUSTO';
  estimateByMTable.cells['B' + (iSum + 4)].value = priceBarsItems.join('\n');

  var priceBarsShoesColumnsBeamsTotal = sumAllByReduce(priceBarsItems.map(item => Number(item.split(': ')[1].replace(/,/g, ''))));

  var letters = ['H', 'I', 'J', 'K'];
  var bars_6_8_10_12_Costs = [bar6Cost, bar8Cost, bar10Cost, bar12Cost];

  var priceBarsSlabTotalCollection = [];

  for (var i = 0; i < letters.length; i++) {
    var costByBarType = slabBarsList[i] * bars_6_8_10_12_Costs[i];
    estimateByMTable.cells[letters[i] + (iSum + 3)].value = costByBarType;

    priceBarsSlabTotalCollection.push(costByBarType);
  }

  var priceBarsSlabTotal = sumAllByReduce(priceBarsSlabTotalCollection);

  estimateByMTable.cells['H' + (iSum + 4)].value = formatNumber(priceBarsSlabTotal, 2, 2);

  mergeCells(estimateByMTable, 'H' + (iSum + 4) + ':' + 'K' + (iSum + 4));

  var priceBarsTotal = priceBarsShoesColumnsBeamsTotal + priceBarsSlabTotal;

  estimateByMTable.cells['A' + (iSum + 5)].value = formatNumber(priceBarsTotal, 2, 2);

  var rangeNameToFormat2 = 'A' + (iSum + 5) + ':' + 'K' + (iSum + 5);
  alignHorizontal(estimateByMTable, rangeNameToFormat2, 'center');
  applyFontSize(estimateByMTable, rangeNameToFormat2, 15);
  mergeCells(estimateByMTable, rangeNameToFormat2);

  return [buildingNameAndGroupID, priceBarsTotal];
}

// ---------------- WALL COST

function wallCost(
  estimateByMTable,
  buildingNameAndGroupID,
  iSum,
  bricksQuantityByThicknessArrayProcessed,
  priceBrick100,
  priceBrick150,
  priceBrick200,
  priceCementUnit,
  priceGrossSandM3,
  priceWaterL,
  costRowsColor
) {
  estimateByMTable.cells['A' + (iSum + 2)].addRowBelow(); // Subcost1
  estimateByMTable.cells['A' + (iSum + 2)].addRowBelow(); // Subcost1
  estimateByMTable.cells['A' + (iSum + 2)].addRowBelow(); // Total Cost

  var letters = [
    ['E', 'F'],
    ['G', 'H'],
    ['I', 'J'],
  ]; // Cimento, Areia, Água
  var pricesCimentSandWaterList = [priceCementUnit, priceGrossSandM3, priceWaterL];
  var pricesCimentSandWaterSum = 0;

  for (var i = 0; i < letters.length; i++) {
    var totalQuantity = estimateByMTable.cells[letters[i][0] + (iSum + 2)].value();
    var priceSubtotal = totalQuantity * pricesCimentSandWaterList[i];
    estimateByMTable.cells[letters[i][0] + (iSum + 3)].value = priceSubtotal;

    var rangeNameToFormat = letters[i][0] + (iSum + 3) + ':' + letters[i][1] + (iSum + 3);

    mergeCells(estimateByMTable, rangeNameToFormat);

    pricesCimentSandWaterSum += priceSubtotal;
  }

  estimateByMTable.cells['G' + (iSum + 4)].value = pricesCimentSandWaterSum;
  mergeCells(estimateByMTable, 'E' + (iSum + 4) + ':' + 'J' + (iSum + 4));

  applyBackgroundColor(estimateByMTable, 'A' + (iSum + 3) + ':' + 'J' + (iSum + 5), costRowsColor);

  applyBackgroundColor(estimateByMTable, 'A' + (iSum + 2) + ':' + 'D' + (iSum + 3), 'white');

  // --------------- BRICKS

  // var bricksQuantityByThicknessArray = Object.entries(bricksQuantityByThickness)

  var priceTotalBricksItems = bricksQuantityByThicknessArrayProcessed
    //.map(item => "Bloco " + item.join(": "))
    // .map(item => item.join(": "))
    .map(function (item) {
      var itemItems = item.split(': ');
      var thickness = itemItems[0].split(' ')[1];
      var quantity = itemItems[1];

      if (thickness == '100') {
        var priceSubtotal = Number(quantity) * priceBrick100;
      } else if (thickness == '150') {
        var priceSubtotal = Number(quantity) * priceBrick150;
      } else if (thickness == '200') {
        var priceSubtotal = Number(quantity) * priceBrick200;
      }

      // return itemItems[0] + ': ' + formatNumber(priceSubtotal.toString(), 2, 2);
      return itemItems[0] + ': ' + formatNumber(priceSubtotal, 2, 2);
    });

  estimateByMTable.cells['A' + (iSum + 4)].value = 'ESTIMATIVA DE CUSTO';
  estimateByMTable.cells['B' + (iSum + 4)].value = priceTotalBricksItems.join('\n');

  // --------------- WRITE SUMMARY
  var bricksCosts = priceTotalBricksItems.map(item => Number(item.split(': ')[1].replace(/,/g, '')));

  var bricksCost = sumAllByReduce(bricksCosts);
  var wallCost = pricesCimentSandWaterSum + bricksCost;

  estimateByMTable.cells['A' + (iSum + 5)].value = formatNumber(wallCost, 2, 2);

  var rangeNameToFormat2 = 'A' + (iSum + 5) + ':' + 'J' + (iSum + 5);
  alignHorizontal(estimateByMTable, rangeNameToFormat2, 'center');
  applyFontSize(estimateByMTable, rangeNameToFormat2, 15);
  mergeCells(estimateByMTable, rangeNameToFormat2);

  return [buildingNameAndGroupID, wallCost];
}

// ---------------- SURFACE COST

function surfaceCost(
  estimateByMTable,
  buildingNameAndGroupID,
  iSum,
  quantitiesNoProcessTotalArrayProcessed,
  priceStoneCoatingM2,
  pricePaintExteriorM2,
  pricePaintInteriorM2,
  pricePaintCeilingM2,
  priceFloorTilesM2,
  priceWallTilesM2,
  priceSkirtingML,
  costRowsColor
) {
  estimateByMTable.cells['A' + (iSum + 2)].addRowBelow(); // Subcost1
  estimateByMTable.cells['A' + (iSum + 2)].addRowBelow(); // Subcost1
  //estimateByMTable.cells["A" + (iSum + 2)].addRowBelow() // Total Cost

  var priceSurfaceItems = quantitiesNoProcessTotalArrayProcessed.map(function (item) {
    var itemItems = item.split(': ');
    var quantity = itemItems[1].replace(/,/g, '');

    if (item.includes('Pedra')) {
      var priceSubtotal = quantity * priceStoneCoatingM2;
    } else if (item.includes('Pintura') && item.includes('Exterior')) {
      var priceSubtotal = quantity * pricePaintExteriorM2;
    } else if (item.includes('Pintura') && item.includes('Interior')) {
      var priceSubtotal = quantity * pricePaintInteriorM2;
    } else if (item.includes('Pintura') && item.includes('Tecto')) {
      var priceSubtotal = quantity * pricePaintCeilingM2;

      // 🔴🔴🔴 MUST COME BEFORE "Tijoelira", not to use Tijoleira's price because Rodapé's item has Tijoleira in name "• Rodapé - Tijoleira (ml): 1,206.30"
    } else if (item.includes('Rodapé')) {
      var priceSubtotal = quantity * priceSkirtingML;
    } else if (item.includes('Tijoleira') && item.includes('Piso Térreo')) {
      var priceSubtotal = quantity * priceFloorTilesM2;
    } else if (item.includes('Tijoleira')) {
      var priceSubtotal = quantity * priceWallTilesM2;
    } else {
      var priceSubtotal = 0.0;
    }

    // return itemItems[0] + ': ' + formatNumber(priceSubtotal.toString(), 2, 2);
    return itemItems[0] + ': ' + formatNumber(priceSubtotal, 2, 2);
  });

  applyBackgroundColor(estimateByMTable, 'A' + (iSum + 3) + ':' + 'C' + (iSum + 4), costRowsColor);

  estimateByMTable.cells['A' + (iSum + 3)].value = 'ESTIMATIVA DE CUSTO';
  estimateByMTable.cells['B' + (iSum + 3)].value = priceSurfaceItems.join('\n');

  var priceSurfaceTotal = sumAllByReduce(priceSurfaceItems.map(item => Number(item.split(': ')[1].replace(/,/g, ''))));

  estimateByMTable.cells['A' + (iSum + 4)].value = formatNumber(priceSurfaceTotal, 2, 2);

  var rangeNameToFormat = 'A' + (iSum + 4) + ':' + 'C' + (iSum + 4);
  alignHorizontal(estimateByMTable, rangeNameToFormat, 'center');
  applyFontSize(estimateByMTable, rangeNameToFormat, 15);
  mergeCells(estimateByMTable, rangeNameToFormat);

  return [buildingNameAndGroupID, priceSurfaceTotal];
}

function getSubtotalNameUpperCFromLevelNames(levelNames) {
  return ('Subtotal de ' + levelNames[0].split(' ').slice(3, 20).join(' ')).toUpperCase();
}

// ---------------- WALL

function wallCalculationsSubtotal1(estimateByMTable, estimateByMTableRowsL3, i, iSum, rowSecondaryColor, hideRows) {
  var letters = [
    ['E', 'E', 'F'],
    ['G', 'G', 'H'],
    ['I', 'I', 'J'],
  ]; // Cimento, Areia, Água

  var iSumPlus1 = iSum + 1;

  for (var j = 0; j < letters.length; j++) {
    estimateByMTable.cells[letters[j][0] + iSumPlus1].value = '=SUM(' + letters[j][1] + iSum + ':' + letters[j][2] + iSum + ')';

    var rangeNameToFormat = letters[j][1] + (iSum + 1) + ':' + letters[j][2] + (iSum + 1);

    mergeCells(estimateByMTable, rangeNameToFormat);
    alignHorizontal(estimateByMTable, rangeNameToFormat, 'center');

    bold(estimateByMTable, letters[j][0] + iSumPlus1 + ':' + letters[j][0] + iSumPlus1);
  }

  if (!hideRows) {
    // Bold row
    bold(estimateByMTable, 'A' + iSum + ':J' + iSum);
  }

  if (i != estimateByMTableRowsL3 - 1) {
    // Se não for última coluna
    applyBackgroundColor(estimateByMTable, 'B' + iSum + ':J' + iSum, rowSecondaryColor);
  }
}

function wallCalculationsSubtotal2(estimateByMTable, iSum, subtotalLineSumNames, wallThicknessesToHideSubtotal2) {
  var letters = ['E', 'G', 'I']; // Cimento, Areia, Água

  for (var j = 0; j < subtotalLineSumNames.length; j++) {
    estimateByMTable.cells[letters[j] + iSum].value = '=' + subtotalLineSumNames[j].join('+');

    if (letters[j] == 'E') {
      var rangeNameToFormat = 'E' + iSum + ':F' + iSum;
    } else if (letters[j] == 'G') {
      var rangeNameToFormat = 'G' + iSum + ':H' + iSum;
    } else if (letters[j] == 'I') {
      var rangeNameToFormat = 'I' + iSum + ':J' + iSum;
    }

    mergeCells(estimateByMTable, rangeNameToFormat);
    alignHorizontal(estimateByMTable, rangeNameToFormat, 'center');
  }

  bold(estimateByMTable, 'A' + iSum + ':J' + iSum);

  hideSubtotal2IfOneWallType(estimateByMTable, iSum, wallThicknessesToHideSubtotal2);
}

function hideSubtotal2IfOneWallType(estimateByMTable, iSum, wallThicknessesToHideSubtotal2) {
  // HIDE Subtotal2 IF IS ONLY ONE WALL THICKNESS
  if (wallThicknessesToHideSubtotal2.length == 1) {
    // + 2 para fila a fazer hide
    hideRows(estimateByMTable, 1, iSum);
  }
}

function wallWriteTotal(
  estimateByMTable,
  estimateByMTableRowsL3,
  iSum,
  subtotalLineSumNamesAndColors,
  grandTotalRangeColor_General,
  rowPrimaryColor,
  hideRows,
  bricksQuantityByThicknessArrayProcessed,
  wallThicknessesToHideSubtotal2
) {
  // Dados comuns
  applyBackgroundColor(
    estimateByMTable,
    'A' + (estimateByMTableRowsL3 - 1) + ':D' + (estimateByMTableRowsL3 - 1),
    grandTotalRangeColor_General
  );
  applyBackgroundColor(estimateByMTable, 'A' + estimateByMTableRowsL3 + ':D' + estimateByMTableRowsL3, rowPrimaryColor);

  // 🔴🔴🔴 DESACTVADO, ESTE TOTAL ESTÁ CONTEMPLADO NO RESUMO

  //var letters = [["G", "E", "I"], ["K", "J", "M"], ["O", "N", "J"]] // Cimento, Areia, Água
  var letters = [
    ['E', 'E', 'F'],
    ['G', 'G', 'H'],
    ['I', 'I', 'J'],
  ]; // Cimento, Areia, Água

  for (var j = 0; j < subtotalLineSumNamesAndColors.length; j++) {
    var subtotalLineSumNames = subtotalLineSumNamesAndColors[j][0];
    var grandTotalRangeColor = subtotalLineSumNamesAndColors[j][1];

    // Cimento – pop to remove GRAND TOTAL FROM ARCHICAD
    var subTotalLineSumNameCementFromAC_GrandTotal = subtotalLineSumNames.pop();

    // G61,G63
    estimateByMTable.cells[letters[j][0] + iSum].value = '=' + subtotalLineSumNames.join('+');

    var rangeNameToFormat = letters[j][1] + (estimateByMTableRowsL3 - 2) + ':' + letters[j][2] + (estimateByMTableRowsL3 - 2);

    mergeCells(estimateByMTable, rangeNameToFormat);
    alignHorizontal(estimateByMTable, rangeNameToFormat, 'center');

    applyBackgroundColor(
      estimateByMTable,
      letters[j][1] + (estimateByMTableRowsL3 - 1) + ':' + letters[j][2] + estimateByMTableRowsL3,
      grandTotalRangeColor
    );
  }

  // ---- Round to zero decimals
  // setDecimals(numbersAppControllerP, estimateByMTable, `D${estimateByMTableRowsL3 - 1}:J${estimateByMTableRowsL3}`, 2, "Down")

  const cement_brickPlacement = estimateByMTable.cells['E' + (estimateByMTableRowsL3 - 1)].value();

  const cement_brickFill = estimateByMTable.cells['F' + (estimateByMTableRowsL3 - 1)].value();
  const cementTotal = formatNumber(cement_brickPlacement + cement_brickFill, 0, 0);

  const sand_brickPlacement = estimateByMTable.cells['G' + (estimateByMTableRowsL3 - 1)].value();
  const sand_brickFill = estimateByMTable.cells['H' + (estimateByMTableRowsL3 - 1)].value();
  const sandTotal = formatNumber(sand_brickPlacement + sand_brickFill, 0, 0);

  const water_brickPlacement = estimateByMTable.cells['I' + (estimateByMTableRowsL3 - 1)].value();
  const water_brickFill = estimateByMTable.cells['J' + (estimateByMTableRowsL3 - 1)].value();
  const waterTotal = formatNumber(water_brickPlacement + water_brickFill, 0, 0);

  const cementSandWaterStr = `• Sacos de Cimento: ${cementTotal}\n• Areia Grossa: ${sandTotal}\n• Água: ${waterTotal}`;

  let wallMatetialStr = '';

  if (hideRows) {
    // estimateByMTable.cells["B" + (estimateByMTableRowsL3 - 1)].value = appGeneralLib

    // Empty number of bick line like "110"
    estimateByMTable.cells['B' + (estimateByMTableRowsL3 - 1)].value = '';
    estimateByMTable.cells['A' + estimateByMTableRowsL3].value = 'TOTAL (TODOS NÍVEIS)';

    wallMatetialStr =
      sortArray(
        bricksQuantityByThicknessArrayProcessed.map(function (item) {
          var itemItems = item.split(': ');
          // return itemItems[0] + ": " + formatNumber(itemItems[1], 2, 2)
          return '• ' + itemItems[0] + ': ' + formatNumber(Math.ceil(Number(itemItems[1]), 0, 0));
        })
      ).join('\n') + `\n-----\n${cementSandWaterStr}`;

    estimateByMTable.cells['B' + estimateByMTableRowsL3].value = wallMatetialStr;
  }

  hideSubtotal2IfOneWallType(estimateByMTable, iSum, wallThicknessesToHideSubtotal2);

  // BOLD GRAND TOTAL ROW
  bold(estimateByMTable, 'A' + (iSum + 2) + ':J' + (iSum + 2));

  // ------------- Delete Totals in Summary Row and change background to white
  const rangeToclear = 'E' + (iSum + 2) + ':J' + (iSum + 2);
  clearRange(estimateByMTable, rangeToclear);
  applyBackgroundColor(estimateByMTable, rangeToclear, 'white');

  return wallMatetialStr;
}

// ---------------- VOLUMES

function volumeQuantitiesTotalArrayProcess(volumeQuantitiesTotal) {
  var quantitiesNoProcessTotalArray = Object.entries(volumeQuantitiesTotal);

  // Sem formatNumber cria deciamis estranhas (313.15000000000003) mesmo com form antes de somar para dictionary
  return quantitiesNoProcessTotalArray.map(item => '• ' + item[0] + ': ' + formatNumber(Math.ceil(item[1]), 0, 0)).sort();
}

function volumeCalculationsSubtotal(estimateByMTable, iSum, volumeCalculationsQuotients, rowSecondaryColor) {
  applyBackgroundColor(estimateByMTable, 'B' + iSum + ':E' + iSum, rowSecondaryColor);

  applyBackgroundColor(estimateByMTable, 'G' + iSum + ':H' + iSum, rowSecondaryColor);

  var letters = ['D', 'E', 'G', 'H']; // Cimento, Areia, Pedra, Água

  for (var j = 0; j < volumeCalculationsQuotients.length; j++) {
    estimateByMTable.cells[letters[j] + iSum].value = '=C' + iSum + '*' + volumeCalculationsQuotients[j];
  }
}

function volumeCalculationsSubtotal_Plaster(estimateByMTable, iSum, volumeCalculationsQuotients, rowSecondaryColor) {
  applyBackgroundColor(estimateByMTable, 'B' + iSum + ':D' + iSum, rowSecondaryColor);

  applyBackgroundColor(estimateByMTable, 'F' + iSum, rowSecondaryColor);
  applyBackgroundColor(estimateByMTable, 'H' + iSum, rowSecondaryColor);

  var letters = ['D', 'F', 'H']; // Cimento, Areia, Pedra, Água

  for (var j = 0; j < volumeCalculationsQuotients.length; j++) {
    estimateByMTable.cells[letters[j] + iSum].value = '=C' + iSum + '*' + volumeCalculationsQuotients[j];
  }
}

function volumeWriteSubtotal(
  estimateByMTable,
  estimateByMTableRowsL3,
  i,
  levelNames,
  subtotalLineSumNames,
  rowPrimaryColorsAlternate,
  rowPrimaryColorsIndex,
  quantitiesNoProcessPartial,
  hideRowDetailsStartNum,
  hideBarsSurfacesVolumesDetails
) {
  if (i == estimateByMTableRowsL3 - 1) {
    var cellNum = i - 1;
  } else {
    var cellNum = i;
  }
  // G301 B Piso 1, Sapata
  // G301 B - Piso 1, Sapata
  // Escrita "Resumo + Nível"
  // 20 para que seja qual for o nome esteja dentro de número de items
  estimateByMTable.cells['A' + cellNum].value = getSubtotalNameUpperCFromLevelNames(levelNames);

  /* // DESACTIVATO
	applyTextColor(estimateByMTable, "A" + cellNum + ":A" + cellNum, rowPrimaryColorsAlternate[rowPrimaryColorsIndex])
	*/

  // var letters = ["D", "E", "G", "H"] // Cimento, Areia, Pedra, Água
  var letters = ['D', 'E', 'F', 'G', 'H']; // Cimento, Areia, Pedra, Água

  for (var j = 0; j < subtotalLineSumNames.length; j++) {
    if (subtotalLineSumNames[j].length > 0) {
      estimateByMTable.cells[letters[j] + cellNum].value = '=' + subtotalLineSumNames[j].join('+');
    }
  }

  if (!hideBarsSurfacesVolumesDetails) {
    bold(estimateByMTable, 'A' + cellNum + ':H' + cellNum);
  }

  applyBackgroundColor(estimateByMTable, 'B' + cellNum + ':H' + cellNum, rowPrimaryColorsAlternate[rowPrimaryColorsIndex]);

  var quantitiesNoProcessPartialArray = Object.entries(quantitiesNoProcessPartial);

  // Sem formatNumber cria deciamis estranhas (313.15000000000003) mesmo com form antes de somar para dictionary

  /*
	var quantitiesNoProcessPartialArrayTxt = quantitiesNoProcessPartialArray.map(item => "• " + item[0] + ": " + formatNumber(Math.ceil(item[1]), 0, 0)).sort().join("\n")
	*/
  var quantitiesNoProcessPartialArraySorted = quantitiesNoProcessPartialArray
    .map(item => '• ' + item[0] + ': ' + formatNumber(Math.ceil(item[1]), 0, 0))
    .sort(); //.join("\n")

  const quantitiesNoProcessPartialArrayTxt = getSeparatedVolumesByUsingOrNotCement(quantitiesNoProcessPartialArraySorted);

  estimateByMTable.cells['B' + cellNum].value = quantitiesNoProcessPartialArrayTxt;

  // ----- NEW

  if (hideBarsSurfacesVolumesDetails) {
    var numOfRowsToHide = cellNum - hideRowDetailsStartNum;

    if (numOfRowsToHide > 0) {
      hideRowsRange(estimateByMTable, numOfRowsToHide, 'A' + hideRowDetailsStartNum + ':A' + (cellNum - 1));
    }
  }
}

function volumeWriteTotal(
  estimateByMTable,
  estimateByMTableRowsL3,
  volumeQuantitiesTotal,
  subtotalLevelSumNames,
  grandTotalRangeColor
) {
  estimateByMTable.cells['A' + estimateByMTableRowsL3].value = 'TOTAL (TODOS NÍVEIS)';

  // var quantitiesNoProcessTotalArray = Object.entries(volumeQuantitiesTotal)

  // // Sem formatNumber cria deciamis estranhas (313.15000000000003) mesmo com form antes de somar para dictionary
  // var quantitiesNoProcessTotalArrayTxt = quantitiesNoProcessTotalArray.map(item => "• " + item[0] + ": " + formatNumber(item[1], 2, 2)).sort().join("\n")

  var volumeQuantitiesTotalArrayProcessed = volumeQuantitiesTotalArrayProcess(volumeQuantitiesTotal);

  /*

	// ------------ Filter by Composites With and Without Cement
	const cementComposites = ["Betonilha", "Betão", "Reboco"];

	const arrayWithCementComposites = volumeQuantitiesTotalArrayProcessed.filter(item =>
		cementComposites.some(keyword => item.includes(keyword))
	);

	const arrayWithoutCementComposites = volumeQuantitiesTotalArrayProcessed.filter(item =>
		!cementComposites.some(keyword => item.includes(keyword))
	);
	*/

  // const arrayWithCementComposites = separatedVolumesByUsingOrNotCement.
  // const arrayWithoutCementComposites =

  // var quantitiesNoProcessTotalArrayTxt = volumeQuantitiesTotalArrayProcessed.join("\n")

  /*
	var quantitiesNoProcessTotalArrayTxt = arrayWithoutCementComposites.join("\n") + "\n---------\n" + arrayWithCementComposites.join("\n")
		*/

  /*
	const quantitiesNoProcessTotalArrayTxt = getSeparatedVolumesByUsingOrNotCement(volumeQuantitiesTotalArrayProcessed)

	estimateByMTable.cells["B" + estimateByMTableRowsL3].value = quantitiesNoProcessTotalArrayTxt
	*/

  var letters = ['D', 'E', 'F', 'G', 'H']; // Cimento, Areia Grossa, Areia Fina, Pedra, Água

  for (var j = 0; j < subtotalLevelSumNames.length; j++) {
    var subtotalLevelSumName = estimateByMTable.cells[letters[j] + (estimateByMTableRowsL3 - 2)].name();

    estimateByMTable.cells[letters[j] + estimateByMTableRowsL3].value =
      '=' + subtotalLevelSumNames[j].join('+') + '+' + subtotalLevelSumName;
  }

  bold(estimateByMTable, 'A' + estimateByMTableRowsL3 + ':H' + estimateByMTableRowsL3);

  // White backgroundColor for Previous em ROW
  applyBackgroundColor(estimateByMTable, 'A' + (estimateByMTableRowsL3 - 1) + ':H' + (estimateByMTableRowsL3 - 1), 'white');

  pressDelete(1);

  // Color Grand TOTAL
  applyBackgroundColor(estimateByMTable, 'A' + estimateByMTableRowsL3 + ':H' + estimateByMTableRowsL3, grandTotalRangeColor);

  const cementTotal = formatNumber(estimateByMTable.cells['D' + estimateByMTableRowsL3].value(), 0, 0);
  const sandGrossTotal = formatNumber(estimateByMTable.cells['E' + estimateByMTableRowsL3].value(), 0, 0);
  const sandFineTotal = formatNumber(estimateByMTable.cells['F' + estimateByMTableRowsL3].value(), 0, 0);
  const stoneTotal = formatNumber(estimateByMTable.cells['G' + estimateByMTableRowsL3].value(), 0, 0);
  const waterTotal = formatNumber(estimateByMTable.cells['H' + estimateByMTableRowsL3].value(), 0, 0);

  const cementSandGrossSandFineStoneWaterStr = `• Sacos de Cimento: ${cementTotal}\n• Areia Grossa: ${sandGrossTotal}\n• Areia Fina: ${sandFineTotal}\n• Brita: ${stoneTotal}\n• Água: ${waterTotal}`;

  const quantitiesNoProcessTotalArrayTxt = getSeparatedVolumesByUsingOrNotCement(volumeQuantitiesTotalArrayProcessed);

  const volumesMaterialStr = cementSandGrossSandFineStoneWaterStr + '\n-----\n' + quantitiesNoProcessTotalArrayTxt;

  estimateByMTable.cells['B' + estimateByMTableRowsL3].value = volumesMaterialStr;

  // ------------- Delete Totals in Summary Row and change background to white
  const rangeToclear = 'D' + estimateByMTableRowsL3 + ':H' + estimateByMTableRowsL3;
  clearRange(estimateByMTable, rangeToclear);
  applyBackgroundColor(estimateByMTable, rangeToclear, 'white');

  // .split("\n---------")[0] Excude volues of elements

  return volumesMaterialStr
    .split('\n---------')[0]
    .split('\n')
    .filter(item => !item.includes('Escavação') && !item.includes('Solo - Natural'))
    .join('\n');
}

function getSeparatedVolumesByUsingOrNotCement(volumeQuantities) {
  // ------------ Filter by Composites With and Without Cement
  const cementComposites = ['Betonilha', 'Betão', 'Reboco'];

  const arrayWithoutCementComposites = volumeQuantities.filter(item => !cementComposites.some(keyword => item.includes(keyword)));

  const arrayWithCementComposites = volumeQuantities.filter(item => cementComposites.some(keyword => item.includes(keyword)));

  const arrayWithoutAndWithCementCompositesTxt =
    arrayWithoutCementComposites.join('\n') + '\n---------\n' + arrayWithCementComposites.join('\n');

  return arrayWithoutAndWithCementCompositesTxt;

  // return {
  //    arrayWithoutCementComposites,
  //    arrayWithCementComposites
  // }
}

// ---------------- VARÃO

function getBarsKilogramsInfo(quantitiesBarsTotal, slabBarsList) {
  // --------------- GET BARS KG
  var quantitiesBarsTotalArray = Object.entries(quantitiesBarsTotal);

  // ------ GET TOTAL OF VARÃO
  var barsQuantitiesArrayOnly = quantitiesBarsTotalArray.filter(item => item[0].includes('Varão'));

  // --------------- GET ALL KILOGRAMS OF barsShoesColumnsBeamsSlab

  // var theVariable = cflLib.cfl2Str(barsQuantitiesArrayOnly[0], "Referência", barsQuantitiesArrayOnly[0][0])

  // ----- ORGANIZE slabBarsList By Name section
  var slabBarsListByName = [
    'Varão 6: ' + slabBarsList[0],
    'Varão 8: ' + slabBarsList[1],
    'Varão 10: ' + slabBarsList[2],
    'Varão 12: ' + slabBarsList[3],
  ];

  var barsShoesColumnsBeamsSlabArray = barsQuantitiesArrayOnly.map(item => item[0] + ': ' + item[1]).concat(slabBarsListByName);

  var barsKilograms = 0;
  // var barsNamesSetcions = []

  for (var i = 0; i < barsShoesColumnsBeamsSlabArray.length; i++) {
    var barItems = barsShoesColumnsBeamsSlabArray[i].split(': ');
    var barNameSection = barItems[0].split(' ')[1];
    var barQuantity = Number(barItems[1]);

    if (barQuantity > 0) {
      // if (!barsNamesSetcions.includes(barNameSection)) {
      // 	barsNamesSetcions.push(barNameSection)
      // }

      // Comprimento de varão 5.8 m calculado em "#P51A • DESENHO & ESPECIFICAÇÕES > 04-FERRO"
      if (barNameSection == '6') {
        barsKilograms += barQuantity * 1.29; // Varão 6 (de 5.8m) são 1.29 KG
      }
      if (barNameSection == '8') {
        barsKilograms += barQuantity * 2.29;
      }
      if (barNameSection == '10') {
        barsKilograms += barQuantity * 3.09;
      }
      if (barNameSection == '12') {
        barsKilograms += barQuantity * 5.15;
      }
    }
  }

  // var barsNamesSetcionsSorted = sortArray(barsNamesSetcions)
  var barsNamesSetcionsSorted = sortArray(getArrayOfSumOfUniqueBarsNames(barsShoesColumnsBeamsSlabArray));

  return `Varão ${barsNamesSetcionsSorted.join(', ') + ' — ' + formatNumber(barsKilograms, 2, 2)} KG`;
}

function getShoesColumnsBeamsStrPartialAndTotal(shoeQuantity, columnQuantity, beamQuantity) {
  return `Sapatas: ${formatNumber(shoeQuantity, 0, 0)}\nPilares (Segmentos): ${formatNumber(
    columnQuantity,
    0,
    0
  )}\nVigas (Segmentos): ${formatNumber(beamQuantity, 0, 0)}`;
}

function barsWritePartial(
  estimateByMTable,
  iSum,
  levelNames,
  quantitiesBarsPartial,
  shoeColumnBeamBarsTotalColor,
  shoesColumnsBeamsStrPartial,
  slabBarsQuantitiesObj,
  hideRowDetailsStartNum,
  numOfRowsToHideCollection,
  hideBarsSurfacesVolumesDetails
) {
  // -------------- SLAB
  const {
    slabBars6QuantitiesPartial,
    slabBars8QuantitiesPartial,
    slabBars10QuantitiesPartial,
    slabBars12QuantitiesPartial,
    slabBarsSubTotalAndTotalColor,
  } = slabBarsQuantitiesObj;

  const hasBarsSlab =
    slabBars6QuantitiesPartial > 0 ||
    slabBars8QuantitiesPartial > 0 ||
    slabBars10QuantitiesPartial > 0 ||
    slabBars12QuantitiesPartial > 0;

  if (hasBarsSlab) {
    estimateByMTable.cells['H' + iSum].value = slabBars6QuantitiesPartial;
    estimateByMTable.cells['I' + iSum].value = slabBars8QuantitiesPartial;
    estimateByMTable.cells['J' + iSum].value = slabBars10QuantitiesPartial;
    estimateByMTable.cells['K' + iSum].value = slabBars12QuantitiesPartial;

    applyBackgroundColor(estimateByMTable, 'H' + iSum + ':K' + iSum, slabBarsSubTotalAndTotalColor);
  }

  // --------------

  var subtotalNameUpperC = getSubtotalNameUpperCFromLevelNames(levelNames);

  var quantitiesBarsPartialPartialArray = Object.entries(quantitiesBarsPartial);

  var quantitiesBarsPartialPartialArrayTxt = quantitiesBarsPartialPartialArray
    .map(item => '• ' + item[0] + ': ' + formatNumber(item[1], 0, 0))
    .sort()
    .join('\n');

  // Se quantitiesBarsPartialPartialArrayTxt disponível então pode correr
  // Lajes de Pisos e Cobertura quantitiesBarsPartialPartialArrayTxt é undefined não tendo info
  /// 🔴🔴🔴 E não inclui a Laje de Piso Térreo, pois esta faz parte de Level Fundação
  // Resultado é string "undefined" devido ao join mas aceita if (quantitiesBarsPartialPartialArrayTxt) { e negou if (quantitiesBarsPartialPartialArrayTxt != undefined) { e ainda não percebi porque negou visto que devia aceitar

  if (quantitiesBarsPartialPartialArrayTxt || hasBarsSlab) {
    estimateByMTable.cells['A' + iSum].value = subtotalNameUpperC;
  }

  if (quantitiesBarsPartialPartialArrayTxt) {
    // estimateByMTable.cells["A" + iSum].value = subtotalNameUpperC
    estimateByMTable.cells['B' + iSum].value = `${quantitiesBarsPartialPartialArrayTxt}\n\n—\n${shoesColumnsBeamsStrPartial}`;

    if (!hideBarsSurfacesVolumesDetails) {
      bold(estimateByMTable, 'A' + iSum + ':G' + iSum);
    }

    applyBackgroundColor(estimateByMTable, 'B' + iSum + ':G' + iSum, shoeColumnBeamBarsTotalColor);
  }

  // ----- NEW

  if (hideBarsSurfacesVolumesDetails) {
    var numOfRowsToHide = iSum - hideRowDetailsStartNum - numOfRowsToHideCollection;

    if (numOfRowsToHide > 0) {
      hideRowsRange(estimateByMTable, numOfRowsToHide, 'A' + hideRowDetailsStartNum + ':A' + (iSum - 1));
    }
  }
}

function barsShoesColumnsBeamsWriteTotalToArrayProcess(quantitiesBarsTotal) {
  var quantitiesBarsTotalArray = Object.entries(quantitiesBarsTotal);

  return quantitiesBarsTotalArray.map(item => '• ' + item[0] + ': ' + formatNumber(item[1], 0, 0)).sort();
}

