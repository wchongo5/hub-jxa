function writeEstimateByQDict(estimateByQTable, estimateInfoToFillDict, estimateByQTableRowsL) {
  for (var i = 1; i < estimateByQTableRowsL; i++) {
    var iSum = i + 1;
    var fillId = estimateByQTable.cells['D' + iSum].value();

    if (fillId) {
      var quantity = estimateInfoToFillDict[fillId];

      if (quantity) {
        // CONVERSÕES

        if (fillId.includes('Bloco')) {
          quantity /= 12.5; // 12.5 blocos por m2
        }

        if (fillId.includes('Betonilha de regularização')) {
          quantity /= 0.03; // 30 mm de espessura de betonilha de regularização
        }

        if (fillId.includes('Reboco')) {
          quantity /= 0.025; // 25 mm de espessura de reboco
        }

        estimateByQTable.cells['G' + iSum].value = quantity;
        estimateByQTable.cells['G' + iSum].textColor = 'blue';
        estimateByQTable.cells['D' + iSum].textColor = 'blue';
      }
    }
  }
}

function writeEstimateByQArray(estimateByQTable, generalItemsToWriteCollectionArrayNested, estimateByQTableRowsL) {
  for (var h = 0; h < generalItemsToWriteCollectionArrayNested.length; h++) {
    var fillIdStart = generalItemsToWriteCollectionArrayNested[h][0];
    var fillIdEnd = generalItemsToWriteCollectionArrayNested[h][1];
    var columnB_Track2ID = generalItemsToWriteCollectionArrayNested[h][2];
    var generalItemsToWrite = generalItemsToWriteCollectionArrayNested[h][3];

    var isToWrite = false;
    var j = 0;

    for (var i = 1; i < estimateByQTableRowsL; i++) {
      var iSum1 = i + 1;
      // var columnB_Track1 = estimateByQTable.cells["B" + iSum1].value()
      var fillId1_Track = estimateByQTable.cells['D' + iSum1].value();

      try {
        // Para fim da tabela visto que
        var columnB_Track2 = estimateByQTable.cells['B' + (iSum1 + 1)].value();
        var fillId2_Track = estimateByQTable.cells['D' + (iSum1 + 1)].value();
      } catch (error) {
        //
      }

      try {
        //if (generalItemToWrite) { // Para se generalItemToWrite[0] não tiver info

        var generalItemToWrite = generalItemsToWrite[j];

        if (generalItemsToWrite.length > j) {
          var openingIdentifier = 'Preencher';
        } else {
          var openingIdentifier = 'Fim';
        }

        if (fillId1_Track == fillIdStart) {
          var isToWrite = true;
          var started = true;
        } else if (fillId1_Track == fillIdEnd) {
          var isToWrite = false;
        }

        if (openingIdentifier == 'Preencher' && isToWrite) {
          var generalItemToWrite1Items = generalItemToWrite[0].split(' | ');

          if (generalItemToWrite1Items.length == 2) {
            var elementName = generalItemToWrite1Items[0];

            if (fillIdStart == 'Janelas' || fillIdStart == 'Portas') {
              var openingUnitPrice = generalItemToWrite1Items[1];
            } else {
              var elementUnit = generalItemToWrite1Items[1];
            }
          } else if (generalItemToWrite1Items.length == 3) {
            var elementName = generalItemToWrite1Items[1];
            var elementUnit = generalItemToWrite1Items[2];
          }

          var elementQuantity = generalItemToWrite[1];

          if (columnB_Track2 == columnB_Track2ID) {
            estimateByQTable.cells['B' + iSum1].addRowBelow();

            selectionRange(estimateByQTable, 'A' + iSum1 + ':K' + iSum1);

            delay(d0p3); // Acrescido depois que falhou Copy Paste do item anterior

            copy();
            delay(d0p3); // Acrescido depois que falhou Copy Paste do item anterior

            selectionRange(estimateByQTable, 'A' + (iSum1 + 1) + ':K' + (iSum1 + 1));

            delay(d0p3); // Acrescido depois que falhou Copy Paste do item anterior

            paste();

            estimateByQTable.cells['B' + (iSum1 + 1)].value = elementName;
            estimateByQTable.cells['B' + (iSum1 + 1)].textColor = 'blue';

            if (elementUnit) {
              estimateByQTable.cells['E' + (iSum1 + 1)].value = elementUnit;
              estimateByQTable.cells['E' + (iSum1 + 1)].textColor = 'blue';
            }

            estimateByQTable.cells['G' + (iSum1 + 1)].value = elementQuantity;
            estimateByQTable.cells['G' + (iSum1 + 1)].textColor = 'blue';

            if (openingUnitPrice) {
              estimateByQTable.cells['I' + (iSum1 + 1)].value = openingUnitPrice;
              estimateByQTable.cells['I' + (iSum1 + 1)].textColor = 'blue';
            }
          } else {
            estimateByQTable.cells['B' + (iSum1 + 1)].value = elementName;
            estimateByQTable.cells['B' + (iSum1 + 1)].textColor = 'blue';

            // estimateByQTable.cells["E" + (iSum1 + 1)].value = elementUnit
            // estimateByQTable.cells["E" + (iSum1 + 1)].textColor = "blue"
            if (elementUnit) {
              estimateByQTable.cells['E' + (iSum1 + 1)].value = elementUnit;
              estimateByQTable.cells['E' + (iSum1 + 1)].textColor = 'blue';
            }

            estimateByQTable.cells['G' + (iSum1 + 1)].value = elementQuantity;
            estimateByQTable.cells['G' + (iSum1 + 1)].textColor = 'blue';

            if (openingUnitPrice) {
              estimateByQTable.cells['I' + (iSum1 + 1)].value = openingUnitPrice;
              estimateByQTable.cells['I' + (iSum1 + 1)].textColor = 'blue';
            }
          }

          j++;
        } else if (openingIdentifier == 'Fim' && isToWrite && fillId2_Track != fillIdEnd) {
          estimateByQTable.rows[i + 1].delete();

          i -= 1;
          estimateByQTableRowsL -= 1; // Não percebi por que 2 e nega
        }
      } catch (error) {
        // alert(`${error.name}`, `${error.message}\n\n—\nTalvez …`)
      }
    }
  }
}

// --------------

function updateGrandSummary(estimateByMSummaryTable) {
  const wallMatetialStr = estimateByMSummaryTable.cells['B2'].value();

  let barsTotalStr = estimateByMSummaryTable.cells['B3'].value();

  const volumesMaterialStr = estimateByMSummaryTable.cells['B4'].value();
  let surfaceQuantitiesTotalArrayTxt = estimateByMSummaryTable.cells['B5'].value();

  if (barsTotalStr === null) {
    barsTotalStr = '';
  }

  if (surfaceQuantitiesTotalArrayTxt === null) {
    surfaceQuantitiesTotalArrayTxt = '';
  }

  let wallMatetialStrItems = [];

  if (wallMatetialStr) {
    wallMatetialStrItems = wallMatetialStr.split('\n').filter(item => item[0] != '-');
  }

  let volumesMaterialStrItems = [];
  let volumeWithoutCementComposites = '';

  if (volumesMaterialStr) {
    volumesMaterialStrItems = volumesMaterialStr.split(`\n-----\n`);
    volumeWithoutCementComposites = volumesMaterialStrItems[1];
  }

  let itemsToProcessGoup1 = wallMatetialStrItems;

  // const itemsToProcessGoup1 = wallMatetialStrItems.concat(volumesMaterialStrItems[0].split("\n"))

  if (volumesMaterialStrItems[0]) {
    itemsToProcessGoup1 = itemsToProcessGoup1.concat(volumesMaterialStrItems[0].split('\n'));
  }

  // console.log("volumesMaterialStrItems[0]: " + volumesMaterialStrItems[0])

  const itemsToProcessGoup2 = volumeWithoutCementComposites.split('\n');

  const uniqueGrandSummaryGroup1 = makeUniqueGrandSummaryItems(itemsToProcessGoup1);
  const uniqueGrandSummaryGroup2 = makeUniqueGrandSummaryItems(itemsToProcessGoup2);

  const grandSummaryGroup1AndGroup2 = `${uniqueGrandSummaryGroup1.join('\n')}\n-----\n${uniqueGrandSummaryGroup2.join('\n')}`;

  const grandSummary = `${grandSummaryGroup1AndGroup2}\n-----\n${barsTotalStr}\n-----\n${surfaceQuantitiesTotalArrayTxt}`;

  const grandSummaryWithUnits = grandSummary
    .split('\n')
    .map(function (item) {
      if (item.includes(' (ml):')) {
        return item;
      } else if (item.includes('Água')) {
        return `${item} (l)`;
      } else if (item.includes('Pedra') || item.includes('Pintura') || item.includes('Tijoleira')) {
        return `${item} m2`;
      } else if (item.includes('Areia') || item.includes('Brita') || item.includes('Enrocamento')) {
        return `${item} m3`;
      } else {
        return item;
      }
    })
    .join('\n');

  estimateByMSummaryTable.cells['B11'].value = grandSummaryWithUnits;
}

function makeUniqueGrandSummaryItems(itemsToProcess) {
  var itemsProcessedObj = {};

  for (var i = 0; i < itemsToProcess.length; i++) {
    const itemItems = itemsToProcess[i].split(': ');

    let itemName = itemItems[0];
    let itemQuantityMultipleDelimeter = itemItems[1];

    if (itemName && itemQuantityMultipleDelimeter) {
      const itemQuantity = Number(itemQuantityMultipleDelimeter.replace(/,/g, ''));

      if (itemName.includes('Bloco')) {
        itemName = itemName.split(' ').slice(0, 3).join(' ');
      }

      if (itemName.includes('Enrocamento')) {
        itemName = itemName.split(' ').slice(0, 2).join(' ');
      }

      if (itemsProcessedObj[itemName] === undefined) {
        itemsProcessedObj[itemName] = itemQuantity;
      } else {
        itemsProcessedObj[itemName] += itemQuantity;
      }
    }
  }
  // itemName

  var itemsProcessed = Object.entries(itemsProcessedObj);

  const itemsProcessedMapped = itemsProcessed.map(item => item[0] + ': ' + formatNumber(item[1], 0, 0));

  return sortArray(itemsProcessedMapped);
}

