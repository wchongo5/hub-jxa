                    // 🔴🔴🔴 USE THIS FOR SLABS
                    var slabBars6Quantity = estimateByMTable.cells['H' + iSum].value();
                    var slabBars6QuantityWithMarginOfError = Math.ceil(slabBars6Quantity * marginOfError);
                    estimateByMTable.cells['H' + iSum].value = slabBars6QuantityWithMarginOfError;

                    var slabBars8Quantity = estimateByMTable.cells['I' + iSum].value();
                    var slabBars8QuantityWithMarginOfError = Math.ceil(slabBars8Quantity * marginOfError);
                    estimateByMTable.cells['I' + iSum].value = slabBars8QuantityWithMarginOfError;

                    var slabBars10Quantity = estimateByMTable.cells['J' + iSum].value();
                    var slabBars10QuantityWithMarginOfError = Math.ceil(slabBars10Quantity * marginOfError);
                    estimateByMTable.cells['J' + iSum].value = slabBars10QuantityWithMarginOfError;

                    var slabBars12Quantity = estimateByMTable.cells['K' + iSum].value();
                    var slabBars12QuantityWithMarginOfError = Math.ceil(slabBars12Quantity * marginOfError);
                    estimateByMTable.cells['K' + iSum].value = slabBars12QuantityWithMarginOfError;

                    slabBars6QuantitiesPartial += slabBars6QuantityWithMarginOfError;
                    slabBars8QuantitiesPartial += slabBars8QuantityWithMarginOfError;
                    slabBars10QuantitiesPartial += slabBars10QuantityWithMarginOfError;
                    slabBars12QuantitiesPartial += slabBars12QuantityWithMarginOfError;
                  }
                }

                if (i == estimateByMTableRowsL3 - 1) {
                  // var quantitiesBarsPartialL = Object.keys(quantitiesBarsPartial).length

