                  delay(d1);

                  // 🔴🔴🔴🔴🔴🔴 ERROR TESTING — Sem pilares na cobertura não entra AQUI
                  if (numOfRowsToHide > 0 && rowStartNumToHide > 0) {
                    // numOfRowsToHide: Used only to get in then is overwritten

                    var numOfRowsToHide = rowsSelectionNumInColumn(
                      estimateByMTable,
                      'A' + rowStartNumToHide + ':A' + rowEndNumToHide
                    );

                    var barsQuantitiesL = numOfRowsToHide + 1;

                    // Manter a linha abaixo de …[4], projecto Magaia exigiu [3]
                    // var elementName = getPreviousColumnA_WithElementName(estimateByMTable, rowStartNumToHide-1).split(" ")[4]
                    var elementName = getPreviousColumnA_WithElementName(estimateByMTable, rowStartNumToHide - 1).split(' ')[3];

                    var barName = estimateByMTable.cells['B' + (rowStartNumToHide - 1)].value();

                    var elementName =
                      barsQuantitiesL > 0 ? (elementName.includes('Pilar') ? elementName + 'e' : elementName) + 's' : elementName;

                    estimateByMTable.cells[
                      'B' + (rowStartNumToHide - 1)
                    ].value = `${barName} (${barsQuantitiesL} ${elementName})`;

                    var iSumStart = rowStartNumToHide - 1;
                    var iSumEnd = iSum - 1;

                    // 🔴🔴🔴🔴🔴🔴 AQUI CHEGA NOME ERRADO "200x300s" por isso gera erro por issso não apanha "columnLetter"

                    if (elementName.includes('Sapata')) {
                      var columnLetter = 'C';
                    } else if (elementName.includes('Pilar')) {
                      var columnLetter = 'D';
                    } else if (elementName.includes('Viga')) {
                      var columnLetter = 'F';
                    }

                    var barsQuantities = sumFromSelectionRange(
