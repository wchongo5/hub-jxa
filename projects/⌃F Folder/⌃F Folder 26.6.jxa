            var estimateFolder = xa5SpecialitySelected;

            var xa5SpecialitiesSelectedStr = xa5SpecialitiesSelected.toString().toUpperCase();

            // 🔴 ESTIMATE CIVIL AQUI, O RESTO DAS ESPECIALIDADES ABAIXO NO LOOP

            if (xa5SpecialitySelectedName == `00 QUANTIDADES CIVIL`) {
              if (xa5SpecialitiesSelectedStr.includes('ESTRUTURA')) {
