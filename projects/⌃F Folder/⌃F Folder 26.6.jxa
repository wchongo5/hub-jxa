  const base = makeFolder(
    Path(ctx.selection.destPathStr),
    `Y ${ctx.ND} ${invoiceCs} ${ctx.ND} ${customer4Folders} ${ctx.ND} ${otherInfo4Folders}`
  );

  for (var i = 0; i < subNameList.length; i++) {
    const folderName = subNameList[i];
    const {
      folder: thisFolder,
