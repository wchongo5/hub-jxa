  if (invoiceCs[invoiceCsL - 2] == 'A' || invoiceCs[invoiceCsL - 2] == 'T') {
    makeAlias(base.folderPathObj, Path(mainFolderStr), '# ' + base.name());
  }

  // -------------- FICHEIRO "00 NOTAS"

  writeToFile(`${base.folderPathStr}/00 NOTAS.txt`, '1. Sem notas');
  // -------------- XA5-TEMPORARY5
  // TF 20230707 _ XDWFAP231103 _ TOP LOGÍSTICA

  // var dateAndCsAndCustomer4Folders = dateFoldersAndDocuments + " " + customer4Folders + " " + invoiceCs
  var dateAndCsAndCustomer4Folders = `${dateFoldersAndDocumentsBasicDatetime} ${ctx.ND} ${invoiceCs} ${ctx.ND} ${customer4Folders}`;

  var temporayFolderName = 'TF ' + dateAndCsAndCustomer4Folders;

  // 🔴 var to access tempFolderPathObj in <if (option == '2. Projecto' || option == '3. Obra') {>
