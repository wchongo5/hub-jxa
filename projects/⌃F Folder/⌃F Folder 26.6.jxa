        makeFolder(thisFolderPathObj, dateY4M2D2__H2M2S2_3daysAfter + ' GARANTIA DEFINITIVA');
      }
    }

    if (folderName.includes(originalsName) && (managerId == 'J5X' || managerId == 'X5X')) {
