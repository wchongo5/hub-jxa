      partner + ' ' + percentageStr + ' | F' + partnerPrice,
    ];
  }

  if ((flow.partnerId == 'J' && managerId == 'J5C') || flow.partnerId == 'N') {
    var subNameList = subNameListPartnership;
  } else {
    var xd5Folder = 'XD5' + consultancyManagerIdToFolder + ' ' + dateFoldersAndDocumentsBasicDatetime + obfuscatedAmount;

    if (discipline == 'Arquitectura' || discipline == 'Urbanismo') {
      var originalsName = `ORIGINAIS iWORK`;

      var subNameList = [originalsName, xd5Folder];

      // PASTA AKERTA PARA "+ 🔴 SOLICITAR CONTRATO ASSINADO & VISADO PELO TA"
      if (invoiceCs[2] != 'W') {
        var subNameList = subNameList.concat('+ 🔴 SOLICITAR CONTRATO ASSINADO & VISADO PELO TA');
      }
    } else {
      // Design, Simplitask
      var subNameList = [xd5Folder];
    }
  }

  // if (!isHerd && (flow.partnerId == 'X' || (flow.partnerId == 'J' && managerId == 'J5X'))) {
  if (
    !isHerd &&
    (invoiceCs.slice(4, 6) === 'AP' || invoiceCs.slice(4, 6) === 'UP') &&
    (flow.partnerId == 'X' || (flow.partnerId == 'J' && managerId == 'J5X'))
  ) {
    // XDXFDP251101

