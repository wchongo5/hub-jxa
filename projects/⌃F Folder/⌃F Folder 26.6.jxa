    var consultancyManagerIdToFolder = ' ' + managerId;
  } else {
    var consultancyManagerIdToFolder = '';
  }

  if (flow.partnerId == 'J' || flow.partnerId == 'N') {
    var subNameListPartnership = [
      'FACTURA' +
