        var estimatesFileAlias = ctx.apps.seApp.aliases.byName(originalsPathStr + '/' + estimateFileName);

        var estimateFileNameNew = `00X00E ${ctx.ND} ${customer4Folders} ${ctx.ND} ESTIMATIVA DE CUSTO ${invoiceCs} ${ctx.ND} ${deliveryDateYyyyMmDd}-XXXXXX-V1.numbers`;

        estimatesFileAlias.name = estimateFileNameNew;
