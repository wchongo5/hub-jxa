      var needsHMTLStr = `${sellingAnimalReazon} ***NewLine/ MZN${quoteAmountApproved}/${otherInfo4Folders}`;
    } else {
      var needsHMTLStr = 'null';
    }

    if (flow.partnerId == 'J' || flow.partnerId == 'N') {
      var partnershipItems = partnership('Factura', quoteAmountApproved).split(' | ');

      var partner = partnershipItems[0];
      var partnerPrice = partnershipItems[1];
      var xdimPrice = partnershipItems[2]; // Igual a quoteAmountApproved
      var percentageStr = partnershipItems[3];
    }

    if (isHerd) {
      var chargedPercentageWithSymbol = 'X%';
      var chargedPercentageWithSymbolAndSpace = ' X%';
    } else {
      var {
        chargedPercentage,
        percentageWithSymbol: chargedPercentageWithSymbol,
        chargedPercentageWithSymbolAndSpace,
      } = chargePercentage(quoteCs, flow.partnerId, managerId);
    }

    var customer4Xero = generateCustomerForXero(customer4Folders, customer4Documents);

    // var object4FoldersAndExtrasUpper = generateObjectNameForNeedsInXero(otherInfo4Folders);
  } else {
    var company = getCompanyFromCs(invoiceCs);
    // --------------- GET QUOTE DATE & AMOUNT

    var quoteFolderName = folderListInfoItems[1];
    var selectedFolderStr = folderListInfoItems[2];

    var quoteFolderStr = selectedFolderStr + '/' + quoteFolderName;

    var xdimAndPartnerQuoteFolderNamesItems = xdimAndpartnerQuoteFolderNames(ctx, flow, originType, quoteFolderStr).split(' / ');

    var xdimQuoteFolder = xdimAndPartnerQuoteFolderNamesItems[0];
    var quoteDate = xdimQuoteFolder.match(/\d{8}/)[0];

    var quoteAmountApproved = xdimQuoteFolder.match(/C(\d[,.0-9]*)/)[1];

    if (flow.partnerId == 'J' || flow.partnerId == 'N') {
      var partnerQuoteFolder = xdimAndPartnerQuoteFolderNamesItems[1];
      var percentageStr = partnerQuoteFolder.match(/\s(\d\d?%.*)\s\|/)[1];
      var partner = partnerQuoteFolder.split(' ' + percentageStr)[0].split(' S1Q ')[1];
      var partnerPrice = partnerQuoteFolder.split(percentageStr + ' | C')[1];

      var xdimPrice = quoteAmountApproved;
    }

    // ---------------

    var quoteFolderItems = folderListInfoItems[1].split(` ${ctx.ND} `);

    var quoteCs = quoteFolderItems[1];

    var customer4Folders = quoteFolderItems[2];
    var otherInfo4Folders = quoteFolderItems.slice(3, 6).join(` ${ctx.ND} `);

    customerAndObjectInfo = getCustomerAndObject(docNumXG5, quoteCs, invoiceCs, dateFoldersAndDocumentsBasicDatetime);

    var {
      customer4Documents,
      customer4SheetOrBimCloud: customer4SheetOrBimCloudOrNote,
      objectOptions: {
        object4Documents,
        object4ImagesAndVideoAndDrawings,
        object4FoldersAndExtras,
        object4FoldersAndExtrasUpper,
        object4DocumentsAndImagesAndFolderAndExtras,
      },
      projectSite,
      siteID,
      genderOptionsStr,
      genderOptions,
      intervention,
      customerGroup,
      contractManager,
      propLocal,
      needsHMTLStr,
      buildingObjectsStr,
      deadlineWithUnit,
      customer4Xero,
      // object4FoldersAndExtrasUpper,
    } = customerAndObjectInfo;

