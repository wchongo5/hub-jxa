      materialFileAlias.name = `00X00EM ${ctx.ND} ${customer4Folders} ${ctx.ND} MATERIAL ${invoiceCs} ${ctx.ND} ${deliveryDateYyyyMmDd}-XXXXXX-V1.numbers`;
    }
  }

  // --------------- MOVE QUOTE INFO TO WORK FOLDER

  if (folderListInfoTrackESCREVER != 'ESCREVER') {
    if ((flow.partnerId == 'J' && managerId == 'J5C') || flow.partnerId == 'N') {
