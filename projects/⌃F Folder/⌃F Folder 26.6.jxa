            makeFolder(thisFolder1PathObj, folderName2);
          }
        }
      }

      if (managerId == 'J5X') {
        // Excludes "FACTURA" because its name info is in XD5 J5X (xd5Folder)
        var subNameListPartnershipFiltered = subNameListPartnership.filter(item => !item.includes('FACTURA'));

        for (var j = 0; j < subNameListPartnershipFiltered.length; j++) {
          makeFolder(thisFolderPathObj, subNameListPartnershipFiltered[j]);
        }
      }

