    }

    alert('THANKS GoD - 2');

    for (var i = 0; i < subTemporayFolderList.length; i++) {
      const { folderPathObj: thisFolder1PathObj, folderPathStr: thisFolder1PathStr } = makeFolder(
        temp.folderPathObj,
