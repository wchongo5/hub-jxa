function writeprojectInfoInCoverEstimate(
  ctx,
  estimatePathStr,
  customer4Documents,
  object4Documents,
  contractManager,
  endMmStrInPTAndEndYyyy
) {
  var docNumEstimateByQ = ctx.apps.numbersApp.open(Path(estimatePathStr));

  var tableCover = docNumEstimateByQ.sheets['00 CAPA'].tables[0];

  tableCover.cells['A1'].value = `${customer4Documents}\n${contractManager.toUpperCase()}`;
  tableCover.cells['A2'].value = object4Documents.toUpperCase();
  tableCover.cells['A5'].value = endMmStrInPTAndEndYyyy;

  docNumEstimateByQ.save();
  delay(ctx.delays.d1);
  docNumEstimateByQ.close();
}

function writeSiteDimensions(projSheet, siteDimensions) {
  var tableDescription02ARQ = projSheet.tables['Memória 02ARQ'];

  var tableRowsL = tableDescription02ARQ.rowCount();
  for (var i = 0; i < tableRowsL; i++) {
    var iNum = i + 1;

    var infoLine = tableDescription02ARQ.cells['C' + iNum].value();

    if (infoLine.toLowerCase().includes('área do projecto')) {
      if (siteDimensions == 'LxC') {
        tableDescription02ARQ.cells['C' + (iNum + 1)].value = '—';
      } else {
        var siteDimensionsItems = siteDimensions.split('x');

        tableDescription02ARQ.cells['C' + (iNum + 1)].value =
          formatNumber(siteDimensionsItems[0], 2, 2) + 'mx' + formatNumber(siteDimensionsItems[1], 2, 2) + 'm';
      }
      break;
    }
  }
}

function generateBuildingsTemporayFunc(
  object4Documents,
  buildingObjectsStr,
  floorsCount,
  startStory,
  circulationPercentage = 30
) {
  const buildingLines = buildingObjectsStr
    .split(',')
    .map(line => line.trim())
    .filter(line => line.startsWith('G3'));

  const buildindsTyped = [];

  return buildingLines.map(line => {
    const [code, ...nameParts] = line.split(' ');
    const name = nameParts.join(' ');

    const nameLowerCase = name.toLowerCase();
    const object4DocumentsLowerCase = object4Documents.toLowerCase();

    const prompt = `${object4Documents}\n-----\nSelecione o tipo para o edifício ${code} (${name})${
      buildindsTyped.length > 0 ? `\n\nEdificações tipificadas:\n${buildindsTyped.map(b => `• ${b}`).join('\n')}` : ``
    }`;

    const defaultTypeValue = 'Residential';
    let defaultTypeLabel = 'Residencial';
    let buildingType;

    if (
      (object4Documents.includes('Residência Unifamiliar') || object4Documents.includes('Veraneio')) &&
      nameLowerCase.includes('principal')
    ) {
      buildingType = defaultTypeValue;
    } else {
      if (object4DocumentsLowerCase.includes('escritório')) {
        defaultTypeLabel = 'Escritório';
      }

      const buildingTypes = getBuildingTypes();
      const labels = buildingTypes.map(t => t.label);

      const buildingTypeLabel = cfl2Str(labels, prompt, defaultTypeLabel);

      buildingType = buildingTypes.find(t => t.label === buildingTypeLabel).value;

      if (!buildingType) {
        alert(`Tipo de construção em EN não encontrado para "${buildingTypeLabel}".`);
      }
    }

    buildindsTyped.push(`${name}: ${buildingType}`);

    return {
      id: generateUUID(),
      code,
      type: buildingType, // Default type, you can modify this as needed
      name,
      floors: floorsCount,
      startStory,
      circulationPercentage,
      stories: [
        {
          id: generateUUID(),
          number: startStory,
          name: `Piso`,
          typologyGroups: [
            {
              name: 'Tipologia',
              number: 1,
              label: 'Editar (para T3)',
              unitsPerStory: 1,
              circulationPercentage: 30,
              rooms: [],
            },
          ],
        },
      ],
    };
  });
}

function obfuscateAmount(monetaryValue, isReverse) {
  if (isReverse) {
    // Deobfuscate: Replace "Y" back to the decimal point and "X" back to commas
    return monetaryValue.replace(/Y/g, '.').replace(/X/g, ',');
  } else {
    // Obfuscate: Replace commas with "X" and the decimal point with "Y"
    return monetaryValue.replace(/,/g, 'X').replace(/\./g, 'Y');
  }
}
