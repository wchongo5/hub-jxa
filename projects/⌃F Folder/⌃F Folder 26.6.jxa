      var specialityD = specialities.filter(speciality => !speciality.includes('7'));

      var xa5SpecialitiesSelected = cfl(specialities, 'Especialidades para pasta X-Produção', specialityD, 'm');
      var xa5SpecialitiesSelected = xa5SpecialitiesSelected.map(speciality => '0' + speciality);

      if (folderListInfoTrackESCREVER != 'ESCREVER') {
        var buildingObjectsStr = dialog(`Objectos\n\n—\nVerificar os objectos escritos na Cotação`, buildingObjectsStr);
      }

      var buildingObjects = ensureSpaceAfterCommaInStr(buildingObjectsStr).split(', ');
    }
  }

  // ----------------------------------

  // START DATE
  var startDate = new Date(mmDateFoldersAndDocuments + '/' + ddDateFoldersAndDocuments + '/' + yyyyDateFoldersAndDocuments);

  var startMm = startDate.toLocaleString('en', {
    month: '2-digit',
  });
  var startMmStr = startDate.toLocaleString('en', {
    month: 'long',
  });
  var startMmStrInPT = capitalizeText(mmEnglishToPortuguese(startMmStr), 'NoExclusions');
  var startDd = addZero(startDate.getDate());
  var startYyyy = startDate.getFullYear();

  // DELIVERY TIME // CHECK02
  // END DATE

  /*    var endDateNumItems = offsetDateByInput(invoiceCs, startDate, 'Duração', durationInputWithUnit, 'No').split(' | ');
    var endDateNum = Number(endDateNumItems[0]);
    var duration = endDateNumItems[1];
    var durationUnit = endDateNumItems[2]; */

  var {
    newDateNumStr,
    offset: duration,
    offsetUnit: durationUnit,
  } = offsetDateByInput(invoiceCs, startDate, 'Duração', durationInputWithUnit, 'No');

  var endDateNum = Number(newDateNumStr);

  var startDateTextAndDeliveryTime =
    startDd +
    ' ' +
    startMmStrInPT +
    ' ' +
    startYyyy +
    ' / ' +
    duration +
    ' ' +
    durationUnit.replace('d', 'dias').replace('m', 'meses');

  var endDate = new Date(endDateNum);

  // For Xero Invoice and DeliveryTerm
  var endMm = endDate.toLocaleString('en', { month: '2-digit' });

  var endMmStr = endDate.toLocaleString('en', {
    month: 'long',
  });
  var endMmStrInPT = capitalizeText(mmEnglishToPortuguese(endMmStr), 'NoExclusions');
  var endDd = addZero(endDate.getDate());
  var endYyyy = endDate.getFullYear();

  var deliveryDateYyyyMmDd = endYyyy + endMm + endDd;

  //var issueDateAndDueDate = dateFoldersAndDocuments + "-" + endYyyy + endMm + endDd

  var issueDateAndDueDate = dateFoldersAndDocuments + '-' + deliveryDateYyyyMmDd;

