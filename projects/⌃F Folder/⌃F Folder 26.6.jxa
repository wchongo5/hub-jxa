    } = makeFolder(base.folderPathObj, folderName);

    // if (folderName.includes('XD5')) {
    if (folderName === xd5Folder) {
      var folder4QuoteFolder = thisFolder; // Se for Factura a partir da seleção da Cotação

      var xx5DigitalProjectName = `${deliveryDateYyyyMmDd}-HHMMSS XX5 ${ctx.ND} ${
        discipline[0] == 'A' ? 'PROJECTO' : 'PLANO'
      } DIGITAL ${ctx.ND} ${customer4Folders} ${ctx.ND} ${object4FoldersAndExtrasUpper} ${ctx.ND} ${invoiceCs}`;

      var xx5DigitalList = [xx5DigitalProjectName, '202XXXXX-HHMMSS REL1 LEVANTAMENTO', '202XXXXX-HHMMSS REL2 ANTEPROJECTO'];

