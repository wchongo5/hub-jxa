// xdim-core-logger.scpt (JXA Script Library)

function log(msg) {
  try {
    $.NSLog(`ℹ️ ${msg}`);
  } catch (e) {}
}
function warn(msg) {
  try {
    $.NSLog(`⚠️ ${msg}`);
  } catch (e) {}
}
function fail(msg) {
  throw new Error(msg);
}

// xdim-core-errors.scpt (JXA Script Library)
function withGuard(fn) {
  try {
    fn();
  } catch (e) {
    try {
      Library('displayLib').alert('Erro', String(e && e.message ? e.message : e));
    } catch (_) {}
    throw e;
  }
}

// xdim-core-ctx.scptd (JXA Script Library)

function AppCtx_bootstrap(deps) {
  const currentApp = Application.currentApplication();
  // currentApp.includeStandardAdditions = true;

  const saApp = ((currentApp.includeStandardAdditions = true), currentApp);

  const seApp = Application('System Events');
  const finderApp = Application('Finder');
  const numbersApp = Application('Numbers');
  const numbersAppControllerP = seApp.processes['Numbers'];
  const safariApp = Application('Safari');
  const safariAppControllerP = seApp.processes['Safari'];
  const archicadApp = Application('ARCHICAD 25');

  const delays = deps.datetimeLib.getDelays();

  const sel = finderApp.selection();
  if (!sel || sel.length === 0) throw new Error('Nenhuma seleção no Finder');
  const it = sel[0];
  const destFolder = it.kind() === 'Folder' || it.kind() === 'Alias' ? it : it.container();

  const ND = deps.finderLib.getND();
  const destPathStr = deps.finderLib.getPathStrsFromPathObjs([destFolder])[0];
  const provinceInfo = deps.spaceLib.getProvinceInfoByPathObj(destFolder);

  const nowFmt = deps.datetimeLib.formatDateV3(new Date());
  if (!nowFmt) throw new Error('Data inválida');

  // ADDDED AFTER

  const { isDisciplineAndServicePath, discipline, service } = getDisciplineAndServiceFromPath(destPathStr);

  const {
    year: { Y4: yearY4 },
    month: { M2: monthM2, long: monthLong },
    day: { D2: dayD2 },
  } = nowFmt.components;

  return {
    ...deps,
    apps: {
      currentApp,
      saApp,
      seApp,
      finderApp,
      numbersApp,
      numbersAppControllerP,
      safariApp,
      safariAppControllerP,
      archicadApp,
    },
    mission: { isDisciplineAndServicePath, discipline, service },
    ND,
    delays,
    selection: { destFolder, destPathStr, provinceInfo },
    dates: {
      now: {
        all: nowFmt,
        yearY4,
        monthM2,
        monthLong,
        dayD2,
      },
      generated: {},
    },

    names: buildNamesAndPaths(deps, ND).names,
    paths: buildNamesAndPaths(deps, ND).paths,
    content: {
      centralInfo02Qgis: deps.spaceLib.getCentralInfo02Qgis(),
      sellingAnimalReazon: `Razões da venda: Necessidade de dinheiro ou Problema do animal (problema)\n • Divisão de dinheiro\n\n—\nIncluir na Factura Xero`, //
    },
  };
}

function buildNamesAndPaths(deps, ND) {
  // ------------ Names
  const helpCustomerFolderName = `AAP`;
  const qgisPackackageP5TemplateNameWtihExt = 'P5TEMPLATE_TERRAIN.gpkg';
  const controlSchedulesFileNameWithExt = `YYYYDDMM-HHMMSS-V1 _ MAPAS DE CONTROLO XDXXXXXXXXXX - XDXXXXXXXXXX.numbers`;
  const estimateFileName = `00X00E ${ND} CLIENTE ${ND} ESTIMATIVA DE CUSTO E DURAÇÃO XDXXXXXXXXXX ${ND} 20XXXXXX-XXXXXX-V1.numbers`;
  const materialFileName = `00X00EM ${ND} CLIENTE ${ND} MATERIAL XDXXXXXXXXXX ${ND} 20XXXXXX-XXXXXX-V1.numbers`;
  const xa5VideoName = `00X00V ${ND} CLIENTE ${ND} VÍDEO PROJECTO_OR_PLANO XDXXXXXXXXXX ${ND} 20XXXXXX-XXXXXX-V1.motn`;

  // ------------ Paths

  const pathLib = deps.pathLib;
  const plataformsPathStr = pathLib.getPlataformsPathStr();
  const p4SP5AQGISPathStr = pathLib.getP4SP5AQGISPathStr();
  const inboxPathStr = pathLib.getInboxPathStr();

  return {
    names: {
      helpCustomerFolderName,
      qgisPackackageP5TemplateNameWtihExt,
      controlSchedulesFileNameWithExt,
      estimateFileName,
      materialFileName,
      xa5VideoName,
      // ---------- Resultants
      helpCustomerFolderNameS1Q: `S1Q ${helpCustomerFolderName}`,
      helpCustomerFolderNameS1Q0: `S1Q0 ${helpCustomerFolderName}`,
    },

    paths: {
      // ----------- QUOTATIONS
      // ----------- PROJECTS

      numXA5PathObj: Path(pathLib.getNumXA5PathStr()),
      numXG5PathObj: Path(pathLib.getNumXG5PathStr()),
      xa5XProdutionPathObj: Path(pathLib.getXa5XProdutionPathStr() + '/PROJECTOS'),
      p5PathStrWithSuffixP5: Path(pathLib.getP5PathStrWithSuffixP5()),
      plataformsPathStr,
      inboxPathStr,
      p4SP5AQGISPathStr,
      x5AliasQuotesPathStr: inboxPathStr + '/X5-QUOTES-ALIAS',
      qgisPackageTemplateTerrainPathStr: `${p4SP5AQGISPathStr}/SPACEXD5DB/${qgisPackackageP5TemplateNameWtihExt}`,
      controlSchedulesFilePathStr: `/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Plataformas/P1/P1T TEMPLATES/P1T5P XO5 _ GCPUP/+ MAPAS DE CONTROLO/${controlSchedulesFileNameWithExt}`,
      estimatesPathObj: Path(
        `${plataformsPathStr}/P1/P1T TEMPLATES/P1T5P XA5 ${ND} GCPUP/A555 ${ND} ORÇAMENTOS & DERIVADOS/${estimateFileName}`
      ),
      materialFileNamePathObj: Path(
        `${plataformsPathStr}/P1/P1T TEMPLATES/P1T5P XA5 ${ND} GCPUP/A555 ${ND} ORÇAMENTOS & DERIVADOS/${materialFileName}`
      ),
      temporayPathObj: Path(`${inboxPathStr}/XA5-TEMPORARY5`),
      xa5TemporayOfflinePathObj: Path(`/Users/xd5-wmac/P51A XA5-TEMPORARY5 OFFLINE`),
      xa5VideoPathObj: Path(`${plataformsPathStr}/P5/P5M MULTIMÉDIA/P552 VÍDEO/VIDEO PROJECTO/${xa5VideoName}`),
      xa5XmlProjInfoTemplatePathStr: Path(
        `${plataformsPathStr}/P1/P1T TEMPLATES/P1T5P XA5 ${ND} GCPUP/X5 - PROJECT INFO TEMPLATE.xml`
      ),

      // ----------- BUILDINGS
      xo5AliasObrasPathObj: Path(`${inboxPathStr}/XO5-ALIAS`),
    },
  };
}

