// xdim-core-options.scpt (JXA Script Library)

function chooseMainFlow(ctx) {
  // const { cfl } = Library('cflLib');
  // const { alert } = Library('displayLib');

  alert('/////// CREATE TF01Q FOLDER, and RENAME TF to TF02I - FREEZES AFTER TRIGER-2');

  const { yearY4, monthM2 } = ctx.dates.now;

  const opts = cfl(
    [
      '1. Cotação',
      '2. Projecto',
      '3. Obra',
      '-----',
      '• JointVenture (J5)*',
      '• Negociação (N5)*',
      '---------------',
      '4. Projecto - Subpastas',
      '5. Projecto - Extrapastas',
      '6. Obra - Subpastas',
      '---------------',
      'Q. Anual Projectos',
      'A. Província',
    ],
    'Seleciona o tipo da pasta\n\n—\n* J5 ou N5 deve ser selecionado com: Cotação ou Projecto ou Obra',
    '1. Cotação',
    'm'
  );

  if (!opts || opts.length === 0) throw new Error('Nenhuma opção selecionada');

  const normalized = _normalizeCombo(opts);
  if (!normalized) {
    alert('Erro nas opções', 'Selecione no máximo 2 opções e combine-as corretamente.');
    throw new Error('Opção inválida');
  }

  alert('TRIGER-1');

  const generated = generateDateFoldersAndDocuments(yearY4, monthM2, normalized);

  alert('TRIGER-2');

  var originType = getOriginType([''], 'Ajuste Directo (DW)');

  alert('TRIGER-3');

  let discipline = ctx.mission.discipline;
  let service = ctx.mission.service;

  if (!ctx.mission.isDisciplineAndServicePath) {
    discipline = getDiscipline([''], 'Arquitectura');

    alert('TRIGER-4');

    if (normalized.kind.en === 'QUOTATION') {
      // if (discipline == 'Rebanho') {
      //   service = 'Projecto';
      // } else {

      alert('TRIGER-5');

      if (originType == 'Ajuste Directo (DW)') {
        // "4. Fiscalização" para Negociação e Jointventure

        alert('TRIGER-6');

        service = getService([''], 'Projecto');
        alert('TRIGER-7');
      } else if (originType == 'Ajuste Directo (DX)') {
        service = getService(['Assistência'], 'Projecto');
      } else if (originType.includes('Concurso')) {
        service = getService(['Assistência', 'Construção'], 'Projecto');
      }
      // }
    } else if (normalized.kind.en === 'PROJECT') {
      service = 'Projecto';
    } else if (normalized.kind.en === 'BUILDING') {
      if (originType == 'Ajuste Directo (DW)') {
        // "4. Fiscalização" para Negociação e Jointventure
        service = getService(['Projecto'], 'Assistência');
      } else {
        service = getService(['Assistência', 'Construção', 'Projecto'], 'Fiscalização');
      }
    }
  }

  alert('TRIGER-8');

  const isHerd = discipline === 'Rebanho';
  const disciplineC1 = discipline[0];
  const serviceC1 = isHerd
    ? 'A' // Rebanho WRA, WRB, WRC, WRD
    : service[0];

  return {
    flow: normalized,
    updatedCtx: {
      ...ctx,
      mission: {
        ...ctx.mission, //
        originType,
        discipline,
        service,
        isHerd,
        disciplineC1,
        serviceC1,
      },
      dates: { ...ctx.dates, generated },
    },
  };
}

function _normalizeCombo(opts) {
  const main = opts.find(o => /^\d\./.test(o));
  const partner = opts.find(o => /^•\s/.test(o));
  const partnerId = !partner ? 'X' : partner.includes('JointVenture') ? 'J' : 'N';

  let managerId = 'X5X'; // Gestão X-DIM

  if (partnerId == 'J') {
    managerId = cfl2Str(['J5C', 'J5X'], 'Gestão de JointVenture no Parceiro (J5C) ou X-DIM (J5X)?\n', 'J5X');
  }

  const collected = {};

  switch (main) {
    case '1. Cotação':
      // return { kind: 'COTACAO', partner: partnerId };
      // return { kind: 'QUOTATION', partner: partnerId };
      return { kind: { en: 'QUOTATION', pt: 'COTAÇÃO' }, managerId, partnerId, collected };
    case '2. Projecto':
      return { kind: { en: 'PROJECT', pt: 'PROJECTO' }, managerId, partnerId, collected };
    case '3. Obra':
      return { kind: { en: 'BUILDING', pt: 'OBRA' }, managerId, partnerId, collected };

    // -------- UPDATE LATER
    /*  case '4. Projecto - Subpastas':
      return { kind: 'PROJECTO_SUBPASTAS', managerId, partnerId, collected };
    case '5. Projecto - Extrapastas':
      return { kind: 'PROJECTO_EXTRAPASTAS', managerId, partnerId, collected };
    case '6. Obra - Subpastas':
      return { kind: 'OBRA_SUBPASTAS', managerId, partnerId, collected };
    case 'Q. Anual Projectos':
      return { kind: 'ANUAL_PROJECTOS', managerId, partnerId, collected };
    case 'A. Província':
      return { kind: 'PROVINCIA', managerId, partnerId, collected }; */
    default:
      return null;
  }
}

// xdim-core-codes.scpt (JXA Script Library)

function serviceCodeForQuotation(partner, originShort, disciplineC1, serviceC1) {
  return partner + originShort + 'C' + disciplineC1 + serviceC1; // e.g., X + DW + C + A + P
}

function serviceCodeForProject(partner, originShort, disciplineC1, serviceC1) {
  return partner + originShort + 'F' + disciplineC1 + serviceC1; // e.g., X + DW + F + A + P
}

function provinceCodeFrom(provinceInfo) {
  const numberPart = provinceInfo.includes(' | ') ? provinceInfo.split(' | ')[0] : provinceInfo;
  const n = Number(numberPart.split('. ')[0]);
  return Library('numberLib').addZero(n);
}

// xdim-core-dates.scpt (JXA Script Library)

function generateDateFoldersAndDocuments(yearY4, monthM2, flow) {
  if (flow.kind.en === 'QUOTATION') {
    var descriptionInvoicingStage = 'Data Cotação';
  } else if (flow.kind.en === 'PROJECT' || flow.kind.en === 'BUILDING') {
    var descriptionInvoicingStage = 'Data Contrato ou Data Cotação Aprovada (Factura)';
  }

  alert('TRIGER-1.1');

  const { ddEntryPadded } = ddEntryWithPreviousAndOrNext30DaysDisplay(`Anteriores`, 'Dia');

  alert('TRIGER-1.2');

  // Get the current date and time
  const currentDate = new Date();
  // const currentYear = currentDate.getFullYear();
  // const currentMonth = String(currentDate.getMonth() + 1).padStart(2, '0');
  // const currentDay = String(currentDate.getDate()).padStart(2, '0');
  const currentHours = String(currentDate.getHours()).padStart(2, '0');
  const currentMinutes = String(currentDate.getMinutes()).padStart(2, '0');
  const currentSeconds = String(currentDate.getSeconds()).padStart(2, '0');

  // Combine yearY4, monthM2, ddEntryPadded with the current date and time
  // const combinedDate = `${yearY4}${monthM2}${ddEntryPadded}${currentYear}${currentMonth}${currentDay}T${currentHours}${currentMinutes}${currentSeconds}`;
  const combinedDate = `${yearY4}${monthM2}${ddEntryPadded}T${currentHours}:${currentMinutes}:${currentSeconds}`;

  alert('TRIGER-1.3');

  const dateFoldersAndDocumentsWithTime = dialog(`Data (Pastas & Documentos)\n\n—\n• ${descriptionInvoicingStage}`, combinedDate);

  // 2024 07 09 2024 07 09 T181006

  const [dateFoldersAndDocuments, time] = dateFoldersAndDocumentsWithTime.split('T');

  const ddDateFoldersAndDocuments = dateFoldersAndDocuments.slice(-2);
  const mmDateFoldersAndDocuments = dateFoldersAndDocuments.slice(4, 6);
  const yyyyDateFoldersAndDocuments = dateFoldersAndDocuments.slice(0, 4);
  const yyDateFoldersAndDocuments = yyyyDateFoldersAndDocuments.slice(2, 4);

  const dateFoldersAndDocumentsISO8601 = `${yyyyDateFoldersAndDocuments}-${mmDateFoldersAndDocuments}-${ddDateFoldersAndDocuments}T${time}`;

  const dateFoldersAndDocumentsBasicDatetime = dateFoldersAndDocumentsISO8601
    .replace(/-/g, '')
    .replace('T', '-')
    .replace(/:/g, '');

  return {
    dateFoldersAndDocumentsBasicDatetime,
    dateFoldersAndDocumentsISO8601,
    dateFoldersAndDocuments,
    ddDateFoldersAndDocuments,
    mmDateFoldersAndDocuments,
    yyyyDateFoldersAndDocuments,
    yyDateFoldersAndDocuments,
  };
}

// xdim-core-folderSpec.scpt (JXA Script Library)

function buildTree(finderLib, rootPathObj, specNodes, ctx) {
  const created = [];
  for (var i = 0; i < specNodes.length; i++) {
    var node = specNodes[i];
    if (node.when && !node.when(ctx)) continue;
    const name = _render(node.name, ctx);
    const mk = finderLib.makeFolder(rootPathObj, name);
    created.push({ name, folderPathObj: mk.folderPathObj, folderPathStr: mk.folderPathStr });
    if (node.children && node.children.length) {
      buildTree(finderLib, mk.folderPathObj, node.children, ctx);
    }
  }
  return created;
}

function _render(tpl, ctx) {
  return tpl.replace(/\$\{([^}]+)\}/g, function (_, k) {
    return '' + _get(ctx, k.trim());
  });
}
function _get(o, path) {
  return path.split('.').reduce(function (a, k) {
    return a && a[k] !== undefined ? a[k] : '';
  }, o);
}

// xdim-commands-quotation.scptd (JXA Script Library)
// Phase 1: Cotação flow — creates folders, duplicates Numbers sheet, fills key cells.

function runQuotation({ ctx, flow }) {
  const { datetimeLib, spaceLib } = ctx;

  const { originType, discipline, service, isHerd, disciplineC1, serviceC1 } = ctx.mission;
  const { yearY4, monthM2, monthLong, dayD2 } = ctx.dates.now;

  const { sellingAnimalReazon } = ctx.content;

  const provinceInfo = ctx.selection.provinceInfo;
  const provinceInfoItems = provinceInfo.split(' | ');

  const {
    dateFoldersAndDocumentsBasicDatetime,
    dateFoldersAndDocumentsISO8601,
    dateFoldersAndDocuments,
    ddDateFoldersAndDocuments,
    mmDateFoldersAndDocuments,
    yyyyDateFoldersAndDocuments,
    yyDateFoldersAndDocuments,
  } = ctx.dates.generated;

  const { numXG5PathObj, x5AliasQuotesPathStr } = ctx.paths;

  const { helpCustomerFolderName: _helpCustomerFolderName, helpCustomerFolderNameS1Q, helpCustomerFolderNameS1Q0 } = ctx.names;

  let helpCustomerFolderName = _helpCustomerFolderName;

  var vatCodeType = flow.partnerId + originType.match(/\((\w*)\)/)[1];

  // ------------- Table - ProposalInfo

  if (originType == 'Ajuste Directo (DW)') {
    var wagesFormD = 'V1-Por especialidade';
    var serviceMethodologyD = 'Sem — Metodologia';
  } else {
    var wagesFormD = 'V2-Por profissional';
    var serviceMethodologyD = 'Com — Metodologia';
  }

  var serviceC1AndDisciplineC1And5 = disciplineC1 + '5' + serviceC1;

  let managerId = flow.managerId;

  if (vatCodeType == 'XCP') {
    var proposalRequestTypeD = 'do Anúncio Jornal Notícias datado';
  } else {
    var proposalRequestTypeD = 'da solicitação de proposta';
  }

  var propOptions1 = ['V1-Por especialidade', 'V2-Por profissional'];
  var propOptions2 = [
    '---------------',
    'Manifestação de Interesse',
    'Proposta Técnica',
    '---------------',
    'da solicitação de proposta',
    'da Carta de solicitação de proposta datada',
    'do Anúncio Jornal Notícias datado',
    '---------------',
    'Com — Comentários & Sugestões',
    'Sem — Comentários & Sugestões',
    '---------------',
    'Com — Metodologia',
    'Sem — Metodologia',
    '---------------',
    'Com — Não Abrir Antes …',
    'Sem — Não Abrir Antes …',
    '---------------',
    'Com — Lote',
    'Sem — Lote',
  ];

  if (isHerd) {
    var propOptions = ['—', '—', '—', '—', '—', '—', 'Sem — Lote'];
  } else {
    var propOptions = cfl(
      propOptions1.concat(propOptions2),
      'Selecione uma opção em cada secção — ' + serviceC1AndDisciplineC1And5,
      [
        serviceC1 + '5',
        'Construção',
        wagesFormD,
        'Manifestação de Interesse',
        proposalRequestTypeD,
        'Sem — Comentários & Sugestões',
        serviceMethodologyD,
        'Sem — Não Abrir Antes …',
        'Sem — Lote',
      ],
      'm'
    );
  }

  var lotStatus = propOptions[6];

  if (lotStatus == 'Com — Lote') {
    var lot = 'Lote ' + cfl2Str(['1', 'I', '2', 'II', '3', 'III', '4', 'IV', '5', 'V'], 'Lote', '3');
  } else if (lotStatus == 'Sem — Lote') {
    var lot = '—';
  }

  var propOptionsStr = propOptions.toString();

  if (
    propOptionsStr.includes('da Carta de solicitação de proposta datada') ||
    propOptionsStr.includes('do Anúncio Jornal Notícias datado')
  ) {
    var requestDateWithPreposition = dialog(
      'Data de solicitação de Propostas (no Jornal Notícias ou Outro Meio).',
      ' de ' + dayD2 + '/' + monthM2 + '/' + yearY4
    );
  } else {
    var requestDateWithPreposition = '';
  }

  var propDateStr = dayD2 + '/' + capitalizeText(mmEnglishToPortuguese(monthLong), 'NoExclusions') + '/' + yearY4 + '/15:30';

  if (originType == 'Ajuste Directo (DW)') {
    var propDateItems = propDateStr.split('/');
  } else {
    var propDateItems = dialog('Data de submissão de Propostas.', propDateStr).split('/');
  }

  // "XDXFAF" NEW 20221001

  /*   if (isHerd) {
    var serviceC1 = 'A'; // serviceC1 fica WRA, WRB, WRC, …
  } */

  // XDWCR1220903 // Rebanho (R1 Rebanho 1)
  // XDWCAP220901
  var serviceCode = vatCodeType + 'C' + discipline[0] + serviceC1;

  // var provinceInfoItems = provinceInfo.split(' | ');

  /* if (provinceInfoItems.length > 1) {
    var provinceNumbered = provinceInfo.split(' | ')[0];
  } else {
    var provinceNumbered = provinceInfo;
  } */

  const provinceNumbered = provinceInfoItems[0];

  // var provCode = addZero(Number(provinceNumbered.split('. ')[0]));

  const provCode = provinceCodeFrom(ctx.selection.provinceInfo);

  var provAndNumberAndSiteAndFoldersItems = provAndNumberAndSiteAndFolders(
    ctx.selection.destPathStr,
    serviceCode,
    provCode,
    'Cotação',
    yyDateFoldersAndDocuments
  ).split(' / ');

  var quoteCs = provAndNumberAndSiteAndFoldersItems[0];
  var folderListInfo = provAndNumberAndSiteAndFoldersItems[1]; // ANTES 2
  var folderListInfoItems = folderListInfo.split(' | ');

  var quoteCsL = quoteCs.length;

  // "A" Adenda e "T" trabalhos adicionais
  if (quoteCs[quoteCsL - 2] == 'A' || quoteCs[quoteCsL - 2] == 'T') {
    var mainFolderName4ExtraWorkCs = folderListInfoItems[1];
    var selectedFolderStr = folderListInfoItems[2];
    var mainFolderStr = selectedFolderStr + '/' + mainFolderName4ExtraWorkCs;
  }

  // var { isValidUseThisSiteForProjectStr, projectSite, propLocal, siteInfoForMinistries } = getProjectSite(provinceInfoItems);

  const {
    isValidUseThisSiteForProjectStr,
    projectSite: _projectSite,
    propLocal,
    siteInfoForMinistries,
  } = spaceLib.getProjectSite(provinceInfoItems, originType);

  let projectSite = _projectSite;

  var siteID = getSiteID(projectSite, flow);

  var intervention = getIntervention(quoteCs);

  var { serviceGroup, durationC1, workPhasesNumbers: workDurationNumbers } = getWorkDurationNumbersWithUnit(quoteCs);

  const animals = null;

  const customerAndObjectInfo = customerAndObject(serviceCode, siteInfoForMinistries, isHerd, intervention, animals);

  var {
    customerType,
    ministryOrProvinceAndOrPrivateCustomer,
    provDirOrNatServiceOrEmpty4PrivateCustomer,
    customer4Documents,
    objectOptions: {
      object4Documents,
      object4ImagesAndVideoAndDrawings,
      object4FoldersAndExtras,
      object4FoldersAndExtrasUpper,
      object4DocumentsAndImagesAndFolderAndExtras,
    },
    customer4Folders,
    customer4SheetOrBimCloudOrNote,
  } = customerAndObjectInfo;

  var buildingObjectsStr = getBuildingObjectsStr(quoteCs, flow, object4Documents);

  // var customerType = customerAndObjectItems[0]

  if (customerType == 'Estado') {
    // var ministryOrProvince = customerAndObjectItems[1]
    // var provincialDirectorateOrNationalService = customerAndObjectItems[2]
    var ministryOrProvince = ministryOrProvinceAndOrPrivateCustomer;
    var provincialDirectorateOrNationalService = provDirOrNatServiceOrEmpty4PrivateCustomer;
  } else if (customerType == 'Empresa Privada' || customerType == 'Individual') {
    // var privateCustomer = customerAndObjectItems[1]
    var privateCustomer = ministryOrProvinceAndOrPrivateCustomer;
  }

  if (originType.includes('Concurso')) {
    var biddingNum = dialog('Número do concurso.\n\n—\nSe não tiver número, ignore.', '');
    if (biddingNum == '') {
      var biddingNum = 'CONCURSO SEM NÚMERO';
    }
  } else {
    // "Ajuste Directo (DW)"
    var biddingNum = '';
  }

  if (service == 'Projecto' && discipline == 'Arquitectura') {
    if (customerType == 'Individual') {
      var customerGroup = 'Individual';
    } else {
      // "Estado" or "Empresa Privada"
      var customerGroup = 'Empresa';
    }
  } else {
    var customerGroup = '—';
  }

  // 🔴🔴🔴🔴 KEEP THIS IS USED TO GET Folder INFO to Use in HyperXD5

  // var customer4Documents = customerAndObjectItems[3]
  // var object4DocumentsAndImagesAndFolderAndExtras = customerAndObjectItems[4]

  // var object4DocumentsAndImagesAndNoteItems = object4DocumentsAndImagesAndFolderAndExtras.split(" / ")
  // var object4Documents = object4DocumentsAndImagesAndNoteItems[0]
  // var object4FoldersAndExtras = object4DocumentsAndImagesAndNoteItems[2]

  // var customer4Folders = customerAndObjectItems[5]
  // var customer4SheetOrBimCloudOrNote = customerAndObjectItems[6]
  // var object4FoldersAndExtrasUpper = customerAndObjectItems[7]

  // alert(`object4Documents: ${object4Documents}`, ``)
  // alert(`object4FoldersAndExtras: ${object4FoldersAndExtras}`, ``)
  // alert(`object4DocumentsAndImagesAndFolderAndExtras: ${object4DocumentsAndImagesAndFolderAndExtras}`, ``);

  /*     if (customer4Folders.includes('&')) {
      var customer4Xero = capitalizeText(customer4Folders, 'WithExclusions'); // Era NoExclusions
    } else {
      var customer4Xero = capitalizeText(customer4Documents, 'WithExclusions'); // Era NoExclusions
    } */

  var customer4Xero = generateCustomerForXero(customer4Folders, customer4Documents);

  var otherInfo4Folders = workInfo(object4FoldersAndExtrasUpper, isValidUseThisSiteForProjectStr, projectSite, quoteCs, ctx);

  if (customerType == 'Estado') {
    var contractManager = contractManagerFunc(ministryOrProvince, customer4Documents);
  } else if (customerType == 'Empresa Privada' || customerType == 'Individual') {
    var contractManager = '—';
  }

  if (originType == 'Concurso Limitado (CL)') {
    var manage3QuotesStatus = getManage3QuotesStatus();

    if (manage3QuotesStatus == 'Sim') {
      var otherInfo4Folders = otherInfo4Folders + ' (3Q)';
    }
  }

  if (isHerd) {
    var needsHMTLStr = `${sellingAnimalReazon} ***NewLine/ MZN0.00/${otherInfo4Folders}`;
  } else {
    var needsHMTLStr = 'null'; // Was "—" before 20230302
  }

  if (originType == 'Concurso Limitado (CL)' || originType == 'Concurso Público (CP)') {
    var helpCustomerStatus = getHelpCustomerStatus();
  }

  jointVentureDwJ5XAlert(quoteCs, 'Cotação', flow);

  // GENDER OPTIONS
  var genderOptionsStr = getGenderOptions(
    service,
    discipline,
    customer4Folders,
    object4Documents,
    projectSite,
    customerType,
    customer4Documents
  );

  if (isHerd) {
    var chargedPercentageWithSymbol = 'X%';
    var chargedPercentageWithSymbolAndSpace = ' X%';
    var isAppliedAmount = true;
  } else {
    var {
      chargedPercentage,
      percentageWithSymbol: chargedPercentageWithSymbol,
      chargedPercentageWithSymbolAndSpace,
      isAppliedAmount,
    } = chargePercentage(quoteCs, flow);
  }

  ctx.apps.numbersApp.activate();
  var docNumXG5 = ctx.apps.numbersApp.open(numXG5PathObj);

  numbersSheetsUpdatePrefixNumbers(docNumXG5);

  const propSheetName = numbersSheetDuplicateAndUpdatePrefixNumber(
    ctx.apps.numbersAppControllerP,
    docNumXG5,
    `${customer4Folders} ${quoteCs}`
  );

  // var serviceTypeFolder = dateFoldersAndDocuments + ' S1Q P&C';
  var serviceTypeFolder = dateFoldersAndDocumentsBasicDatetime + ' S1Q P&C';

  // START DATE
  var startDate = new Date(mmDateFoldersAndDocuments + '/' + ddDateFoldersAndDocuments + '/' + yyyyDateFoldersAndDocuments);

  const durationD = customerType === 'Estado' ? '90d' : '7d';

  // END DATE
  /*     var endDateNumItems = offsetDateByInput(quoteCs, startDate, 'Duração', durationD, 'No').split(' | ');
    var endDateNum = Number(endDateNumItems[0]);
    var duration = endDateNumItems[1];
    var durationUnit = endDateNumItems[2]; */

  var {
    newDateNumStr,
    offset: duration,
    offsetUnit: durationUnit,
  } = offsetDateByInput(quoteCs, startDate, 'Duração', durationD, 'No');

  var endDateNum = Number(newDateNumStr);

  var durationInputWithUnit = duration + ' ' + durationUnit;
  var endDate = new Date(endDateNum);

  var endMm = endDate.toLocaleString('en', { month: '2-digit' });
  var endDd = addZero(endDate.getDate());
  var endYyyy = endDate.getFullYear();

  var issueDateAndDueDate = dateFoldersAndDocuments + '-' + endYyyy + endMm + endDd;

  if (flow.partnerId == 'J' || flow.partnerId == 'N') {
    var quoteAmountApproved = ''; // Empty because does not exist yet

    var partnershipItems = partnership('Cotação', quoteAmountApproved).split(' | ');
    var partner = partnershipItems[0];
    var partnerPrice = partnershipItems[1];
    var xdimPrice = partnershipItems[2];
    var percentageStr = partnershipItems[3];

    const managerIdString = flow.partnerId == 'J' ? ' ' + managerId : '';

    var partnerSubNameList = [
      serviceTypeFolder +
        managerIdString +
        ' | ' +
        issueDateAndDueDate +
        ' | C' +
        xdimPrice +
        chargedPercentageWithSymbolAndSpace,
      dateFoldersAndDocuments + ' S1Q ' + partner + ' ' + percentageStr + ' | C' + partnerPrice,
    ];

    var subNameList = partnerSubNameList;
  } else if (originType == 'Concurso Público (CP)') {
    // "99*" it's placeholder for Day. * shows that 99 it's not normal
    // var dateY4M2D2__H2M2S2_20daysAfterAsterisk = dateFoldersAndDocuments.slice(0, 6) + '99*';

    var offsetDate20DaysAfter = formatDateV3(
      new Date(
        offsetDateByComponents(new Date(dateFoldersAndDocumentsISO8601), {
          days: 20,
        }).newDateNumStr
      )
    );

    var dateY4M2D2__H2M2S2_20daysAfterAsterisk = offsetDate20DaysAfter.formats.dateY4M2D2__H2M2S2 + '*';

    var subNameList = [
      `${dateFoldersAndDocuments}-HHMMSS S1Q1 JORNAL + CADERNO DE ENCARGOS + TdR`,
      `${dateFoldersAndDocuments}-HHMMSS S1Q2 M-INTERESSE`,
      `${dateY4M2D2__H2M2S2_20daysAfterAsterisk} S1Q3.1 P&C | ${issueDateAndDueDate} | C0,000.00 ${chargedPercentageWithSymbol}`,
      `${dateY4M2D2__H2M2S2_20daysAfterAsterisk} S1Q3.2 GARANTIA PROVISÓRIA | 0,000.00 / ALIAS2BANK`,
      `${dateY4M2D2__H2M2S2_20daysAfterAsterisk} S1Q4 AVALIAÇÃO`,
    ];
  } else {
    var quoteAmountPlaceholder = ' | ' + issueDateAndDueDate + ' | C0,000.00' + chargedPercentageWithSymbolAndSpace;

    var subNameList = [
      serviceTypeFolder + quoteAmountPlaceholder,
      dateFoldersAndDocuments.slice(0, 6) + 'XX-HHMMSS S1Q R1 LEVANTAMENTO',
    ];
  }

  // Create base folder and structure (declarative)
  const baseName = `Y ${ctx.ND} ${quoteCs} ${ctx.ND} ${customer4Folders} ${ctx.ND} ${otherInfo4Folders}`;

  const base = makeFolder(Path(ctx.selection.destPathStr), baseName);

  if (helpCustomerStatus == 'Sim') {
    if (originType == 'Concurso Limitado (CL)') {
      helpCustomerFolderName = helpCustomerFolderNameS1Q;
    } else if (originType == 'Concurso Público (CP)') {
      helpCustomerFolderName = helpCustomerFolderNameS1Q0;
    }

    var subNameList = subNameList.concat(`${dateFoldersAndDocuments} ${helpCustomerFolderName}`);
  }

  for (var i = 0; i < subNameList.length; i++) {
    var forlderNameLev1 = subNameList[i];
    var { folderPathObj: thisFolderPathObj } = makeFolder(base.folderPathObj, forlderNameLev1);

    if (manage3QuotesStatus == 'Sim' && forlderNameLev1.includes('P&C')) {
      makeFolder(thisFolderPathObj, serviceC1AndDisciplineC1And5 + 'Q1');
      makeFolder(thisFolderPathObj, serviceC1AndDisciplineC1And5 + 'Q2');
    }

    if (forlderNameLev1.includes('P&C') && (service == 'Construção' || service == 'Empreitada')) {
      makeFolder(thisFolderPathObj, 'MESTRES');
    }

    if (forlderNameLev1.includes('M-INTERESSE')) {
      makeFolder(thisFolderPathObj, `${dateY4M2D2__H2M2S2_20daysAfterAsterisk} AVALIAÇÃO MI`);
    }
  }

  // -------------- EXTRA WORK FOLDER (TRABALHOS A MAIS)

  // "A" Adenda e "T" trabalhos adicionais
  if (quoteCs[quoteCsL - 2] == 'A' || quoteCs[quoteCsL - 2] == 'T') {
    makeAlias(base.folderPathObj, Path(mainFolderStr), '# ' + base.folder.name());
  }

  makeAlias(base.folderPathObj, Path(x5AliasQuotesPathStr), base.folder.name());
  ctx.apps.numbersApp.activate();

  docNumXG5.activeSheet.set(docNumXG5.sheets[propSheetName]);

  var propSheet = docNumXG5.sheets[propSheetName];

  var tableInputs1 = propSheet.tables['Inputs1'];

  if (isAppliedAmount) {
    tableInputs1.cells['C15'].value = chargedPercentageWithSymbol;
    tableInputs1.cells['F15'].value = 1;
  } else {
    tableInputs1.cells['C12'].value = chargedPercentageWithSymbol;
    tableInputs1.cells['F15'].value = 0;
  }

  var tableHeaderInfo = propSheet.tables['HeaderInfo'];
  tableHeaderInfo.cells['A1'].value = quoteCs;
  tableHeaderInfo.cells['B2'].value = object4FoldersAndExtrasUpper;
  tableHeaderInfo.cells['B4'].value = customer4Folders;
  tableHeaderInfo.cells['C3'].value = customer4Xero;
  tableHeaderInfo.cells['C5'].value = getDurationUnit(durationC1);
  // Desactivar manualNeedsStatus
  tableHeaderInfo.cells['B10'].value = 0;

  tableHeaderInfo.cells['C1'].value = projectSite;

  var tableProposalInfo = propSheet.tables['Table - ProposalInfo'];
  tableProposalInfo.cells['A2'].value = intervention;
  tableProposalInfo.cells['A3'].value = propOptions[0];
  tableProposalInfo.cells['A4'].value = propOptions[1];
  tableProposalInfo.cells['A5'].value = propOptions[2];
  tableProposalInfo.cells['A6'].value = propOptions[3];
  tableProposalInfo.cells['A7'].value = propOptions[4];
  tableProposalInfo.cells['A8'].value = propOptions[5];
  tableProposalInfo.cells['A9'].value = lot;

  tableProposalInfo.cells['B5'].value = requestDateWithPreposition;

  tableProposalInfo.cells['C1'].value = propLocal;
  tableProposalInfo.cells['C2'].value = propDateItems[0];
  tableProposalInfo.cells['C3'].value = propDateItems[1];
  tableProposalInfo.cells['C4'].value = propDateItems[2];
  tableProposalInfo.cells['C5'].value = propDateItems[3];

  var tableCustomerAndObjectInfo = propSheet.tables['Table - CustomerAndObjectInfo'];

  tableCustomerAndObjectInfo.cells['A11'].value = customer4Folders;
  tableCustomerAndObjectInfo.cells['B2'].value = biddingNum;

  if (biddingNum != '' && biddingNum != 'CONCURSO SEM NÚMERO') {
    tableCustomerAndObjectInfo.cells['C2'].value = 1;
  } else {
    tableCustomerAndObjectInfo.cells['C2'].value = 0;
  }

  tableCustomerAndObjectInfo.cells['B3'].value = object4Documents.toUpperCase();

  if (customerType == 'Estado') {
    tableCustomerAndObjectInfo.cells['B14'].value = ministryOrProvince;
    tableCustomerAndObjectInfo.cells['A15'].value = provincialDirectorateOrNationalService;

    if (provincialDirectorateOrNationalService == 'BANCO DE MOÇAMBIQUE') {
      tableCustomerAndObjectInfo.cells['C14'].value = 0;
    } else {
      tableCustomerAndObjectInfo.cells['C14'].value = 1;
    }

    tableCustomerAndObjectInfo.cells['C9'].value = 1; // Checkbox Estado

    tableCustomerAndObjectInfo.cells['A16'].value = contractManager;
  } else if (customerType == 'Empresa Privada' || customerType == 'Individual') {
    // privateCustomer UPPERCASE for Documents
    tableCustomerAndObjectInfo.cells['A18'].value = privateCustomer;

    // privateCustomer CAPITALIZE for Xero Create Quote Name
    tableCustomerAndObjectInfo.cells['A19'].value = capitalizeText(privateCustomer, 'WithExclusions');

    // Uncheckbox Estado to Particular
    tableCustomerAndObjectInfo.cells['C9'].value = 0;
  }

  // --------------- WRITE WORK WEEK NUMBERS

  if (serviceGroup === 'SG_PROJECTO') {
    writeWorkWeekNumbers(propSheet, quoteCs, workDurationNumbers);
  }

  var deadlineWithUnit = tableHeaderInfo.cells['C4'].value();

  // --------------- WRITE QUOTE INFO FOR INVOICES

  if ((flow.partnerId == 'J' && managerId == 'J5C') || flow.partnerId == 'N') {
    var customer4Documents = '— JustToSeeHere > ' + partner + ' + ' + customer4Documents;
    var object4DocumentsAndImagesAndFolderAndExtras = '— JustToSeeHere > ' + object4DocumentsAndImagesAndFolderAndExtras;
    projectSite = '— JustToSeeHere > ' + projectSite;
    var genderOptionsStr = '—';
  }

  var tableQuotes = docNumXG5.sheets['FACTURAÇÃO'].tables['Table - Quotes'];

  writeCustomerAndObject(
    tableQuotes,
    customerType,
    dateFoldersAndDocumentsBasicDatetime,
    quoteCs,
    customer4Documents,
    customer4SheetOrBimCloudOrNote,
    object4DocumentsAndImagesAndFolderAndExtras,
    projectSite,
    siteID,
    genderOptionsStr,
    intervention,
    customerGroup,
    contractManager,
    propLocal,
    needsHMTLStr,
    buildingObjectsStr,
    deadlineWithUnit,
    customer4Xero
    // object4FoldersAndExtrasUpper
  );

  docNumXG5.save();
  delay(ctx.delays.d1p5);

  docNumXG5.activeSheet.set(docNumXG5.sheets[propSheetName]);

  const updatedFlow = {
    ...flow,
    collected: {
      // discipline,
      // service,
      // isHerd,

      //----------
      customerAndObjectInfo,
      //---
      // customer4Documents,
      // customer4SheetOrBimCloudOrNote,
      // object4DocumentsAndImagesAndFolderAndExtras,
      // object4FoldersAndExtras,
      // object4Documents,
      // object4FoldersAndExtrasUpper,

      quoteCs,
      projectSite,
      customer4Xero,
      deadlineWithUnit,
      genderOptionsStr,
      intervention,
      customerGroup,
      contractManager,
      propLocal,
      buildingObjectsStr,
      durationInputWithUnit,
      needsHMTLStr,
      siteID,
      chargedPercentage,
      quoteAmountApproved,
      percentageStr,
      partner,
      otherInfo4Folders,
      xdimPrice,
      partnerPrice,
      docNumXG5,

      dates: {
        dateFoldersAndDocumentsBasicDatetime,
        endDate: {
          endYyyy,
          endMm,
          endDd,
        },
      },

      folders: {
        base,
      },
    },
  };

  runCommon({ ctx, flow: updatedFlow });
}

function runProject({ ctx, flow }) {
  const { originType, discipline, isHerd, disciplineC1, serviceC1 } = ctx.mission;

  const { centralInfo02Qgis: _centralInfo02Qgis, sellingAnimalReazon } = ctx.content;

  const {
    numXA5PathObj,
    numXG5PathObj,
    xa5XProdutionPathObj,
    qgisPackageTemplateTerrainPathStr,
    estimatesPathObj,
    materialFileNamePathObj,
    temporayPathObj,
    xa5TemporayOfflinePathObj,
    xa5VideoPathObj,
    xa5XmlProjInfoTemplatePathStr,
  } = ctx.paths;

  const {
    dateFoldersAndDocumentsBasicDatetime,
    dateFoldersAndDocumentsISO8601,
    dateFoldersAndDocuments,
    ddDateFoldersAndDocuments,
    mmDateFoldersAndDocuments,
    yyyyDateFoldersAndDocuments,
    yyDateFoldersAndDocuments,
  } = ctx.dates.generated;

  const { helpCustomerFolderName, qgisPackackageP5TemplateNameWtihExt, estimateFileName, materialFileName, xa5VideoName } =
    ctx.names;

  const provinceInfo = ctx.selection.provinceInfo;
  const provinceInfoItems = provinceInfo.split(' | ');

  let centralInfo02Qgis = _centralInfo02Qgis;

  const managerId = flow.managerId;

  var serviceCode = flow.partnerId + originType.match(/\((\w*)\)/)[1] + 'F' + disciplineC1 + serviceC1; //"P"

  var projectServiceCodeSimple = serviceCode.slice(0, 3);

  const provinceNumbered = provinceInfoItems[0];

  var provCode = addZero(Number(provinceNumbered.split('. ')[0]));

  var provAndNumberAndSiteAndFoldersItems = provAndNumberAndSiteAndFolders(
    ctx.selection.destPathStr,
    serviceCode,
    provCode,
    'Factura',
    yyDateFoldersAndDocuments
  ).split(' / ');

  var invoiceCs = provAndNumberAndSiteAndFoldersItems[0];

  var folderListInfo = provAndNumberAndSiteAndFoldersItems[1];
  var folderListInfoItems = folderListInfo.split(' | ');

  // Split to remove quoteFolderStr a partir da 2ª Factura, se for Factura directa
  var folderListInfoTrackESCREVER = folderListInfoItems[1].split(' | ')[0];

  // invoiceCs[invoiceCs.length - 2] == "T" // Factura de Trabalhos A Mais
  // Aqui forçamos <folderListInfoTrackESCREVER = "ESCREVER"> pois se for Factura Trabalhos A Mais <var folderListInfoTrackESCREVER = folderListInfoItems[1].split(" | ")[0]> não vai ser "ESCREVER" pois considera o nome da pasta da Factura principal (XDXFA210303) ou factura de trabalhos A Mais anterior (XDXFA210303T1)

  var invoiceCsL = invoiceCs.length;

  if (invoiceCs[invoiceCsL - 2] == 'A' || invoiceCs[invoiceCsL - 2] == 'T') {
    var folderListInfoTrackESCREVER = 'ESCREVER';

    var mainFolderName4ExtraWorkCs = folderListInfoItems[1];
    var selectedFolderStr = folderListInfoItems[2];

    var mainFolderStr = selectedFolderStr + '/' + mainFolderName4ExtraWorkCs;
  }

  xeroCompanyWebpage(invoiceCs);

  // var managerId = getConsultancyManagerId(flow.partnerId);

  var docNumXG5 = ctx.apps.numbersApp.open(numXG5PathObj);

  let customerAndObjectInfo = {};

  if (folderListInfoTrackESCREVER == 'ESCREVER') {
    ctx.apps.currentApp.activate();

    var company = getCompanyFromCs(invoiceCs);
    var intervention = getIntervention(invoiceCs);
    var siteDimensions = getSiteDimensions(invoiceCs, intervention);

    var { isValidUseThisSiteForProjectStr, projectSite, propLocal, siteInfoForMinistries } = getProjectSite(provinceInfoItems);

    var siteID = getSiteID(projectSite, flow.partnerId, managerId);

    var durationInputWithUnit = getDurationInputWithUnit(invoiceCs, 'Duração\n', '');

    if (originType == 'Concurso Limitado (CL)') {
      var manage3QuotesStatus = getManage3QuotesStatus();
    }

    if (originType == 'Concurso Limitado (CL)' || originType == 'Concurso Público (CP)') {
      var helpCustomerStatus = getHelpCustomerStatus();
    }

    if (isHerd) {
      /*   var herdKG = parseFloat(dialog(`Quilos do Animal`, ``));
        var herdKGPrice = parseFloat(dialog(`Preço por quilo`, `185`)); */

      const animalsArray = ['09B-93-190', 'V-16000', '10B-120-190', '16V-175-185', '18V-90-185'];

      const animalsString = dialog('Venda por KG: Número-Inicial-KGs-Preço\nVenda vivo: Inicial-Preço', animalsArray.join('\n'));

      var animals = animalsString.split('\n').map(item => {
        const [animalInitial, kgs, priceByKG] = item.replace(/\s/g, '').split('-');

        if (priceByKG) {
          // '09B-93-190' Venda por KGs
          const priceOfAnimal = parseFloat(kgs) * parseFloat(priceByKG);

          return `${animalInitial}${kgs}x${priceByKG} (${formatNumber(priceOfAnimal)})`;
        } else {
          //  '00V-16000' // VENDA VIVO kgs is PRICE
          return `${animalInitial} (${formatNumber(kgs)})`;
        }
      });

      const total = animals.reduce((accumulator, current) => {
        return accumulator + parseFloat(current.split(' (')[1].split(')')[0].replace(/,/g, ''));
      }, 0);

      const animalsCount = animals.length;
      const animalsCountOxes = animals.filter(item => item.includes('B')).length;
      const animalsCountCows = animals.filter(item => item.includes('V')).length;

      var csExtraAnimalsDetails = `Q${animalsCount}B${animalsCountOxes}V${animalsCountCows}`;

      var quoteAmountApproved = formatNumber(total);
    } else {
      var quoteAmountApproved = getQuoteAmountApproved(ctx);
    }

    if (invoiceCs[invoiceCsL - 2] == 'A' || invoiceCs[invoiceCsL - 2] == 'T') {
      // Substituir F por C
      var quoteCs = invoiceCs.slice(0, 3) + 'C' + invoiceCs.slice(4, invoiceCsL.length);
    } else {
      var quoteNumberD = folderListInfoItems[3];

      // Primeira cotação, se for primeira Factura (Directa)
      if (quoteNumberD == undefined) {
        var quoteNumberD = '1';
      }

      var quoteCs =
        projectServiceCodeSimple +
        'C' +
        disciplineC1 +
        serviceC1 +
        yyDateFoldersAndDocuments +
        provCode +
        quoteNumber(quoteNumberD);
    }

    if (isHerd) {
      var invoiceCs = `${invoiceCs}-${csExtraAnimalsDetails}`;
      var quoteCs = `${quoteCs}-${csExtraAnimalsDetails}`;
    }

    customerAndObjectInfo = customerAndObject(serviceCode, siteInfoForMinistries);

    var {
      customerType,
      ministryOrProvinceAndOrPrivateCustomer,
      provDirOrNatServiceOrEmpty4PrivateCustomer,
      customer4Documents,
      objectOptions: {
        object4Documents,
        object4ImagesAndVideoAndDrawings,
        object4FoldersAndExtras,
        object4FoldersAndExtrasUpper,
        object4DocumentsAndImagesAndFolderAndExtras,
      },
      customer4Folders,
      customer4SheetOrBimCloudOrNote,
    } = customerAndObjectInfo;

    var buildingObjectsStr = getBuildingObjectsStr(invoiceCs, managerId, object4Documents);

    if (customerType == 'Estado') {
      var ministryOrProvince = ministryOrProvinceAndOrPrivateCustomer;
    }

    if (customerType == 'Individual') {
      var customerGroup = 'Individual';
    } else {
      // "Estado" or "Empresa Privada"
      var customerGroup = 'Empresa';
    }

    if (customerType == 'Estado') {
      var contractManager = capitalizeText(contractManagerFunc(ministryOrProvince, customer4Documents), 'WithExclusions');
    } else if (customerType == 'Empresa Privada' || customerType == 'Individual') {
      var contractManager = '—';
    }

    // GENDER OPTIONS
    // Service é semre "Projecto"

    var genderOptionsStr = getGenderOptions('Projecto', discipline, customer4Folders, object4Documents, projectSite);
    var genderOptions = genderOptionsStr.split(' / ');

    var otherInfo4Folders = workInfo(object4FoldersAndExtrasUpper, isValidUseThisSiteForProjectStr, projectSite, quoteCs);

    // var docNumXG5 = ctx.apps.numbersApp.open(numXG5PathObj);

    if (manage3QuotesStatus == 'Sim') {
      var otherInfo4Folders = otherInfo4Folders + ' (3Q)';
    }

