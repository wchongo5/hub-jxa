    hostName +
    '\n' +
    'Ip Address: ' +
    ipv4Address +
    '\n' +
    'Ethernet: ' +
    primaryEthernetAddress +
    '\n' +
    'CPU Type: ' +
    cpuType +
    '\n' +
    'CPU Speed: ' +
    cpuSpeed +
    '\n' +
    'Physical Memory: ' +
    physicalMemory;

  var SystemInfo = '\n\n\n' + SytemInfo1 + '\n\n' + SytemInfo2;

  var response = cfl2Str(['Copy Serial Number', 'Display info', 'Save (In Selected Folder)'], 'Acção', 'Display info');

  if (response == 'Copy Serial Number') {
    setClipboard(macSerial);
  } else if (response == 'Display info') {
    dialog(SystemInfo, `Press OK`);
  } else if (response == 'Save (In Selected Folder)') {
    var doc = textEditApp.make({ new: 'document', withProperties: { text: SystemInfo } });

    var filePathStr = destinyFolderStr + '/SYSTEM INFO ' + longUserName + ' ' + dateY4M2D2H2M2S2 + '.txt';

    doc.save({ in: Path(filePathStr) });
    delay(0.3);

    finderApp.reveal(Path(filePathStr)).extensionHidden = true;
  }
} else if (option == 'Tags') {
  var tagOption = cfl2Str(['Color', 'List'], 'Tags no Documento', 'Color');

  if (tagOption == 'Color') {
    var tagColor = cfl2Str(['black', 'red', 'blue'], 'Escolhe a cor para Tags', 'blue');
  }

  //pagesApp.activate()
  var docPages = pagesApp.documents[0];

  var placeHolderTexts_ = docPages.placeholderTexts;
  var theseTags = placeHolderTexts_.tag();

  var uniqueTags = [];

  for (var i = 0; i < theseTags.length; i++) {
    var thisTag = theseTags[i];

    if (tagOption == 'Color') {
      placeHolderTexts_.color.set(tagColor);
    } else if (tagOption == 'List') {
      uniqueTags.push(i + 1 + '.	' + thisTag);
    }
  }

  if (tagOption == 'List') {
    var uniqueTagsSelection = currentApp.chooseFromList(uniqueTags, {
      withPrompt: 'Tags no Documento',
      defaultItems: uniqueTags[0],
      multipleSelectionsAllowed: true,
    });

