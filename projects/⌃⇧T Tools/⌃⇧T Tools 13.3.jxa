} else if (option == 'xxAuto _ AutoGetAndSaveContacts - RunNow') {
  xxAutoLib.autoGetAndSaveContacts('Manual');
}

// ------------------------------------------ FUNCTIONS

function deleteFolderActions() {
  seApp.folderActionsEnabled = false;

  while (seApp.folderActions.length > 0) {
    seApp.folderActions[0].delete();
    delay(d0p3); // Necessary to prevent error
  }
  //delay(d0p3) // Necessary to prevent error
}

function saveByFoldersAndByScripts() {
  var folderActions = seApp.folderActions;

  var folderActionsInfo = [];
  var folderActionsInfoDict = {};

  for (var i = 0; i < folderActions.length; i++) {
    var folderAction = folderActions[i];
    var folderActionName = folderAction.name();

    // In iCloud </Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs>
    // Offline </Users>
    var folderActionPathStr = folderAction
      .path()
      .toString()
      .replace('/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs', '')
      .replace('/Users', '');

    var scripts = folderAction.scripts;

    var srciptsNames = [];

    for (var j = 0; j < scripts.length; j++) {
      var scriptName = scripts[j].name();

      srciptsNames.push(scriptName);

      if (folderActionsInfoDict[scriptName] === undefined) {
        folderActionsInfoDict[scriptName] = ' - ' + folderActionName;
      } else {
        folderActionsInfoDict[scriptName] += '\n - ' + folderActionName;
      }
    }

    folderActionsInfo.push([folderActionPathStr, folderActionName, srciptsNames]);
  }

  // --------------- 🔴 LIST BY FOLDER ACTION
  var folderActionsTextByFoldersProcessed = folderActionsInfo
    .map(item => item.slice(0, 2).join('\n') + '\n' + item[2].join('\n'))
    .join('\n\n');

  var folderActionsInfoL = folderActionsInfo.length;

  saveFolderActionsFile(folderActionsTextByFoldersProcessed, folderActionsInfoL, 'Pasta');

  // // --------------- 🔴 LIST BY SCRIPT NAME
  var folderActionsInfoDictArray = Object.entries(folderActionsInfoDict);

  var folderActionsTextByScriptsProcessed = folderActionsInfoDictArray.map(item => item.join('\n')).join('\n\n');

  var folderActionsInfoDictArrayL = folderActionsInfoDictArray.length;

  saveFolderActionsFile(folderActionsTextByScriptsProcessed, folderActionsInfoDictArrayL, 'Script');
}

function saveFolderActionsFile(folderActionsTextProcessed, folderActionsL, listBy) {
  //var folderActionsInfoL = folderActionsInfo.length

  var folderActionsLTernary =
    folderActionsL > 0 ? folderActionsL : folderActionsL + ' (Erro — Repetir: Fez save antes de processamento)';

  var folderActionsLInfo = `${listBy}: ${folderActionsLTernary}`;

  var folderActionsText = folderActionsLInfo + '\n\n' + folderActionsTextProcessed;

  // var folderActionsTextPathStr = `${p4SP5DAutomatorFolderActionsPathStr}/WF - folderActionsInfo - Lista Por ${listBy} ${dateY4M2D2__H2M2S2}.txt`
  var folderActionsTextPathStr = `${p4SP5DAutomatorFolderActionsPathStr}/WF - folderActionsInfo - ${dateY4M2D2__H2M2S2} Lista Por ${listBy}.txt`;

  objCLib.writeToFile(folderActionsTextPathStr, '\n\n\n' + folderActionsText);

  finderApp.open(Path(folderActionsTextPathStr));
}

function dDialog(theTitle, theDefaultAnswer, theButtons, theDefaultButton, theCancelButton) {
  if (theButtons == undefined) {
    return currentApp.displayDialog(theTitle, { defaultAnswer: theDefaultAnswer }).textReturned;
  } else {
    return currentApp.displayDialog(theTitle, {
      defaultAnswer: theDefaultAnswer,
      buttons: theButtons,
      defaultButton: theDefaultButton,
      cancelButton: theCancelButton,
    }).textReturned;
  }
}

function doMenuBar(appName, menuName, menuItem) {
  var frontApp = Application(appName);

  frontApp.activate();

  var frontAppSE = seApp.processes.byName(appName);

  var menuName = frontAppSE.menuBars[0].menuBarItems.byName(menuName).click();
}

function doMenu(appName, menuName, menuItem) {
  var frontApp = Application(appName);

  frontApp.activate();

  var frontAppSE = seApp.processes.byName(appName);

  var menuName = frontAppSE.menuBars[0].menuBarItems.byName(menuName);
  delay(d0p3);

  menuName.menus[0].menuItems.byName(menuItem).click();
}

function compare(a, b) {
  var countA = counts[a];
  var countB = counts[b];

  return countB - countA;
}

function readAndSplitFile(filePath, delimiter) {
  return saApp.read(Path(filePath), { usingDelimiter: delimiter });
}

function formatNumber(numberToFomat, toFixedDecimals, maxdecimals) {
  return Number(parseFloat(numberToFomat).toFixed(toFixedDecimals)).toLocaleString('en', { minimumFractionDigits: maxdecimals });
}

function dAlert(theTitle, theMessage, theButtons, theDefaultButton, theCancelButton) {
  if (theButtons == undefined) {
    currentApp.displayAlert(theTitle, { message: theMessage });
  } else {
    currentApp.displayAlert(theTitle, {
      message: theMessage,
      buttons: theButtons,
      defaultButton: theDefaultButton,
      cancelButton: theCancelButton,
    });
  }
}

function dDialog(theTitle, theDefaultAnswer, theButtons, theDefaultButton, theCancelButton) {
  if (theButtons == undefined) {
    return currentApp.displayDialog(theTitle, { defaultAnswer: theDefaultAnswer }).textReturned;
  } else {
    return currentApp.displayDialog(theTitle, {
      defaultAnswer: theDefaultAnswer,
      buttons: theButtons,
      defaultButton: theDefaultButton,
      cancelButton: theCancelButton,
    }).textReturned;
  }
}

function cfl2StrWithEmpty(theList, thePrompt, theDefaultItems, multipleStatus) {
  if (multipleStatus == undefined) {
    return currentApp.chooseFromList(theList, { withPrompt: thePrompt, defaultItems: theDefaultItems }).toString();
  } else if (multipleStatus == 'm') {
    return currentApp
      .chooseFromList(theList, {
        withPrompt: thePrompt,
        defaultItems: theDefaultItems,
        multipleSelectionsAllowed: true,
        emptySelectionAllowed: true,
      })
      .toString();
  }
}

function addZero(i) {
  if (i < 10) {
    i = '0' + i;
  }
  return i.toString();
}

/* Returns the first tab that contains a page whose URL starts with the provided URL */
function getTab(url, window) {
  var result;
  window = window || safariApp.windows[0];
  for (var index in window.tabs) {
    var tab = window.tabs[index];
    var tabURL = tab.url();
    if (tabURL.startsWith(url)) {
      result = tab;
      break;
    }
  }
  return result;
}

function getURL() {
  return safariApp.windows[0].currentTab.url();
}

function openURL(urlInput) {
  const firstWindow = safariApp.windows[0];
  const tab = safariApp.Tab({ url: urlInput });
  firstWindow.tabs.push(tab);
  firstWindow.currentTab = tab;
  delay(d1);

  var urlSubscriptionCurrentTab = getURL();

  // "favorites://" is link of blank page
  if (urlSubscriptionCurrentTab == 'favorites://') {
    delay(d0p3);

    // Open Location - garantir que que barra de endereço esteja activa (Spend activa imediatamente mas Create Invoice não)
    seApp.keystroke('l', { using: 'command down' });
    delay(d0p3);

    saApp.setTheClipboardTo(urlInput);
    delay(d1);

    seApp.keystroke('v', { using: 'command down' });
    delay(d1);

    seApp.keyCode(76); // Press Enter
    delay(d1);
  }
}
