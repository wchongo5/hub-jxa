  }

  var senderEmail = message.sender.extractAddressFrom();
  var deliveredToEmail = message.allHeaders().split(' ')[1].split('\n')[0];

  var input = currentApp.displayAlert(senderName + '\n' + senderEmail + '\n' + timeStampMsg + '\n\n—\n' + deliveredToEmail, {
    buttons: [`Cancel`, `Copy LowerCase Email`, `OK`],
    defaultButton: 3,
    cancelButton: 1,
  });

  if (input.buttonReturned == `Copy LowerCase Email`) {
    saApp.setTheClipboardTo(senderEmail.toLowerCase());
  }
