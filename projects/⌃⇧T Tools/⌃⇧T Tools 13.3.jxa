  var DDMsg = messageDateReceived.toLocaleString('en', { day: '2-digit' });
  var timeMsg = messageDateReceived
    .toLocaleString('en', { hourCycle: 'h24', hour: '2-digit', minute: '2-digit', second: '2-digit' })
    .replace(/:/g, '');

  timeStampMsg = YYMsg + MMMsg + DDMsg + '-' + timeMsg;

  var senderName = message.sender.extractNameFrom();

  // Se não tiver nome (Como TVCabo, o Mail usa email como nome)
  if (senderName.includes('@')) {
    var senderName = `Não tem "systemName"`;
