        [
          pathLib.getSuppliersPathStr() + '/P1FSB — BANCOS5/ACTIVIDADES BANK5/WBCI1',
          pathLib.getSuppliersPathStr() + '/P1FSB — BANCOS5/ACTIVIDADES BANK5/WBIM1',
          pathLib.getSuppliersPathStr() + '/P1FSB — BANCOS5/ACTIVIDADES BANK5/WBIM2',
          pathLib.getSuppliersPathStr() + '/P1FSB — BANCOS5/ACTIVIDADES BANK5/XBIM1',
          pathLib.getSuppliersPathStr() + '/P1FSB — BANCOS5/ACTIVIDADES BANK5/XBIM2',
        ],
      ],

      ['WFCentralProcess.workflow', [plataformsPathStr + '/iWFCentralProcess']],
    ];

    for (var i = 0; i < folderActionsInfo.length; i++) {
      try {
        const [scriptName, foldersPathStrs] = folderActionsInfo[i];
        const scriptPathStr = `${folderActionsPathStr}/${scriptName}`;

        for (var j = 0; j < foldersPathStrs.length; j++) {
          // var script – Above out LOOP raise error, must create script for each Action
          const script = seApp.Script({ name: scriptName, posixPath: scriptPathStr });
          const folderPathStr = foldersPathStrs[j];
          const folderPathStrItems = folderPathStr.split('/');
          const folderName = folderPathStrItems.slice(-1)[0];
          const folderAction = seApp.FolderAction({ name: folderName, path: folderPathStr });

          seApp.folderActions.push(folderAction);

          delay(d0p3);
          folderAction.scripts.push(script);
        }
      } catch {
        alert(
          `Erro processando o item nº ${i}, scriptName: ${scriptName}`,
          `Verifique se o error não se deve ao facto da função "deleteFolderActions()" não ter apagado Folder Actions existentes. Se for o caso, execute a opção "Folder Actions" > "Delete" (para despertar o OS - por vezes falha  e aconteceu de macOS 13.0 para 14.0) e depois tente de novo.`
        );
      }
    }
    delay(d1);

    saveByFoldersAndByScripts();
