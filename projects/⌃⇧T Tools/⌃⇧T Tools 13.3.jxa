    var folderActionsInfo = [
      ['WF _ Emails Log.workflow', [plataformsPathStr + '/APPS WF/EMAILS LOG TRIGGER']],

      ['WF _ Estimate byM.workflow', [`${xa5TemporayPathStr}/TF 00 ${ND} WF_ESTIMATE A5E`]],

