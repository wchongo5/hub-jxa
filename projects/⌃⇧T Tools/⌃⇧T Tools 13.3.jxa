} else if (option == 'Encontre Soma na Lista de Valores') {
  // Input Array in String
  var numbersArrayInputStrings = dDialog('Valores para soma entre eles', '5,7,  8').split(',');

  //
  var numbersArray = []; // Para converter split string numbers (["5", "7", "  8"]) em numebrs ([5, 7, 8])
  for (var g = 0; g < numbersArrayInputStrings.length; g++) {
    numbersArray.push(Number(numbersArrayInputStrings[g]));
  }

  var searchedNumberInputStrings = dDialog('Somas a procurar', '13,15,16').split(',');

  var searchedNumber = []; // Para converter split string numbers () em numebrs ()
  for (var h = 0; h < searchedNumberInputStrings.length; h++) {
    searchedNumber.push(Number(searchedNumberInputStrings[h]));
  }

  var newNumbersArray = [];
  var foundNumbers = []; // [13]

  for (var i = 0; i < numbersArray.length; i++) {
    var numbersArraySliced = numbersArray.slice(i);

    for (var j = 0; j < numbersArraySliced.length; j++) {
      var sum = Number(numbersArray[i]) + Number(numbersArraySliced[j]);

      newNumbersArray.push(sum);

      if (searchedNumber.toString().includes(sum)) {
        var foundNumbersIndex = searchedNumber.indexOf(sum) + 1;

        //dAlert("Encontrado número " + foundNumbersIndex + "/" + searchedNumber.length + "\n" + sum + "=" + numbersArray[i] + "+" + numbersArraySliced[j], "")

        foundNumbers.push(sum);
      }
    }
  }

  if (foundNumbers.toString() == '') {
    foundNumbers = '<nada>';
  }

  dAlert(
    `Relatório`,
    `Valores introduzidos para soma entre eles\n${numbersArray
      .toString()
      .replace(/,/g, `, `)}\n\nSomas a procurar\n${searchedNumber
      .toString()
      .replace(/,/g, `, `)}\n\nSomas processadas\n${newNumbersArray
      .toString()
      .replace(/,/g, `, `)}\n\nSomas encotradas\n${foundNumbers.toString().replace(/,/g, `, `)}`
  );
