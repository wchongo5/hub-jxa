const optionsWithShortcuts = options.map((option, index) => {
  if (optionsToExclude.includes(option)) {
    return option;
  } else {
    return `${getNextNumberOrLetter(index)}. ${option}`;
  }
});

const optionD = optionsWithShortcuts.find(option => option.includes(optionD_ID));

alert('3');

var option = cfl2Str(optionsWithShortcuts, 'Tool', optionD);

if (option.includes('.')) {
  var option = option.split('. ')[1];
}

if (option == 'Apps & Versions') {
  var appsNamesListOutput = [];

  try {
    for (var i = 0; i < appsNamesListInput.length; i++) {
      var finderAppVersion = Application(appsNamesListInput[i]).version();
      appsNamesListOutput.push(`${appsNamesListInput[i]} ${finderAppVersion}`);
    }
  } catch (error) {
    alert(`${error.name}`, `${error.message}\n\n—\nTalvez o App "${appsNamesListInput[i]}" não está instalado`);
  }

  alert(appsAndVersionName, appsNamesListOutput.join('\n'));
} else if (option == 'Cálculo de Tempo') {
  var dateMain = new Date();

  var yyyy = dateMain.getFullYear();
  var mm = addZero(dateMain.getMonth() + 1);
  var dd = addZero(dateMain.getDate());

  var timeOperation = cfl2Str(
    [
      '1. Soma - Dias',
      '2. Soma - Meses',
      '3. Subtração - Dias',
      '4. Subtração - Meses',
      '---------------',
      'Subtração entre datas',
    ],
    'Cálculo',
    '2. Soma - Meses'
  );

  // Number(dd).toString() / Para eliminar 0 if dd < 10
  var ddEntry = addZero(dDialog('Dia (início)', Number(dd).toString()));
  var mmEntry = addZero(dDialog('Mês (início)', Number(mm).toString()));

  var startDateStr = dDialog('Data (início)', mmEntry + '/' + ddEntry + '/' + yyyy);

  var startDate = new Date(startDateStr);

  if (timeOperation == '1. Soma - Dias' || timeOperation == '3. Subtração - Dias') {
    var duration = Number(dDialog('Tempo em dias.', '15'));

    if (timeOperation == '1. Soma - Dias') {
      var endDateNum = startDate.setDate(startDate.getDate() + duration);
    } else if (timeOperation == '3. Subtração - Dias') {
      var endDateNum = startDate.setDate(startDate.getDate() - duration);
    }

    var endDate = new Date(endDateNum);

    var endMonth = addZero(endDate.getMonth() + 1);
    var endDay = addZero(endDate.getDate());
    var endYear = endDate.getFullYear();

    dAlert('Data fim (mm/dd/yyyy).\n\n' + endMonth + '/' + endDay + '/' + endYear, '');
  } else if (timeOperation == '2. Soma - Meses' || timeOperation == '4. Subtração - Meses') {
    var duration = Number(dDialog('Tempo em meses.', '3'));

    var durationStr = duration.toString();

    if (durationStr.includes('.')) {
      var durationDecimal = durationStr.split('.')[1];
    }

    if (timeOperation == '2. Soma - Meses') {
      if (durationStr.includes('.') && Number(durationDecimal) > 0) {
        var endDateNum = startDate.setDate(startDate.getDate() + duration * 4.33 * 7);
      } else {
        var endDateNum = startDate.setMonth(startDate.getMonth() + duration);
      }
    } else if (timeOperation == '4. Subtração - Meses') {
      if (durationStr.includes('.') && Number(durationDecimal) > 0) {
        var endDateNum = startDate.setDate(startDate.getDate() - duration * 4.33 * 7);
      } else {
        var endDateNum = startDate.setMonth(startDate.getMonth() - duration);
      }
    }

    var endDate = new Date(endDateNum);

    var endMonth = addZero(endDate.getMonth() + 1);
    var endDay = addZero(endDate.getDate());
    var endYear = endDate.getFullYear();

    dAlert('Data fim (mm/dd/yyyy).\n\n' + endMonth + '/' + endDay + '/' + endYear, '');
  } else if (timeOperation == 'Subtração entre datas') {
    var ddEntry = addZero(dDialog('Dia fim', Number(dd).toString()));
    var mmEntry = addZero(dDialog('Mês fim', Number(mm).toString()));

    var endDateStr = dDialog('Data fim', mmEntry + '/' + ddEntry + '/' + yyyy);

    var endDate = new Date(endDateStr);

    var durationUnit = cfl2Str(['Dias', 'Meses'], 'Unidades de cálculo', 'Meses');

    var duration = endDate - startDate;

    if (durationUnit == 'Dias') {
      var duration = duration / 24 / 60 / 60 / 1000;

      if (duration > 1 && durationUnit == 'Dias') {
        var durationUnit = 'dias';
      } else {
        var durationUnit = 'dia';
      }
    } else if (durationUnit == 'Meses') {
      var duration = duration / 30 / 24 / 60 / 60 / 1000;

      if (duration > 1 && durationUnit == 'Meses') {
        var durationUnit = 'meses';
      } else {
        var durationUnit = 'mês';
      }
    }

    var durationStr = duration.toString();

    if (durationStr.includes('.')) {
      //var durationDecimal = durationStr.split(".")[1]
      dAlert(formatNumber(duration, 1, 1) + ' ' + durationUnit, '');
    } else {
      dAlert(duration + ' ' + durationUnit, '');
    }
  }
} else if (option == 'Clear Invoicing Name') {
  var finderSelectionList = finderApp.selection();

  var fileNameOfFile1 = finderSelectionList[0].name();

  if (fileNameOfFile1.includes('(FR)') || fileNameOfFile1.includes('(R)')) {
    var renameOptionD = `2. R`;
  } else if (fileNameOfFile1.includes('(F)')) {
    var renameOptionD = `1. F`;
  }

  if (fileNameOfFile1.includes('(FR)')) {
    var renameOption = cfl2Str([`1. F`, `2. R`, `3. FR`], `Remover`, renameOptionD);
  } else {
    var renameOption = renameOptionD;
  }

  var renameOption = renameOption.split(`. `)[1];

  for (var i = 0; i < finderSelectionList.length; i++) {
    finderSelectionList[i].extensionHidden = true;

    var fileSelectedCurrent = finderSelectionList[i];

    var fileName = fileSelectedCurrent.name();
    var nameExtension = fileSelectedCurrent.nameExtension();

    var aliasNameWithOutExtension = fileName.split(`.` + nameExtension)[0];

    if (renameOption == `F`) {
      if (aliasNameWithOutExtension.includes('R)')) {
        var aliasNameWithOutExtension = aliasNameWithOutExtension.replace(/\(F/, `(`);
      } else {
        var aliasNameWithOutExtension = aliasNameWithOutExtension.replace(/\s_\sA \(F\)/, ``);
      }
    } else if (renameOption == `R`) {
      if (aliasNameWithOutExtension.includes('(F')) {
        var aliasNameWithOutExtension = aliasNameWithOutExtension.replace(/R\)/, `)`);
      } else {
        var aliasNameWithOutExtension = aliasNameWithOutExtension.replace(/\s_\sA \(R\)/, ``);
      }
    } else if (renameOption == `FR`) {
      var aliasNameWithOutExtension = aliasNameWithOutExtension.replace(/\s_\sA \(FR\)/, ``);
    }

    var docNameAndExtension = aliasNameWithOutExtension + `.` + nameExtension;

    // New Name
    fileSelectedCurrent.name = docNameAndExtension;
    delay(0.5);

    var fileNameRenamed = finderApp.selection()[0].name();

    if (!fileNameRenamed.includes('(F)') && !fileNameRenamed.includes('(R)')) {
      //var notifyToUpdateInXero = true

      dAlert(`Xero | Faz Upload final de "${fileNameRenamed.split('.pdf')[0]}"!`, ``);
    }
  }
} else if (option == 'Colors - Writing') {
  numbersApp.activate();

  // var designAndSpecsPathStr = pathLib.getNumDesignAndSpecsPathStr()

  var docNumDesignAndSpecs = numbersApp.open(Path(designAndSpecsPathStr));

  //var docNumbers = numbersApp.documents[0]

  var tableColorLib = docNumDesignAndSpecs.sheets['JAVASCRIPT COLOR'].tables['Table-colorsLib'];

  var tableColorLibRowsL = tableColorLib.rowCount();
  var tableColorLibRowsLMinus1 = tableColorLibRowsL - 1;

  var colors = colorsLib.getColors();

  var colorsList = Object.entries(colors);
  // [["black", "black"], ["blue", "blue"], ["brown", "brown"], ["cyan", "cyan"], ["cyanLight", [48059, 65535, 65535]], ["green", "green"], ["greenLight", [48573, 64764, 51657]], ["magenta", "magenta"], ["magentaLight", [65535, 48059, 65535]], ["orange", "orange"], ["purple", "purple"], ["red", "red"], ["redLight", [65535, 46774, 49601]], ["yellow", "yellow"], ["yellowLight", [65535, 63222, 36237]], ["white", "white"], ["grayLight1", [54998, 54998, 54998]]]

  var colorL = colorsList.length;

  if (colorL > tableColorLibRowsLMinus1) {
    // - 1 para excluir a fila de títulos
    alert(`A tabela "tableColorLib" tem menos filas (${tableColorLibRowsLMinus1}) para processar as cores (${colorL}).`, ``);
  } else {
    for (var i = 0; i < colorL; i++) {
      var iSum = i + 2; // + 2 to start from A2, A1 is for

      var color = colorsList[i];

      tableColorLib.cells['A' + iSum].backgroundColor = color[1];
      tableColorLib.cells['B' + iSum].value = color[0];
    }
  }
} else if (option == 'Consultoria - ExtractPDFImagesByPaperFormat') {
  // alert(`${destinyFolderStr}`, ``)

  imageLib.extractConsultancyPDFImagesByPaperFormat(finderFilePathSr);
} else if (option == 'Copiar Nomes de Items Selecionados no Finder') {
  const itemsToExcludeAtBeginningWithSpaceSplitter = Number(
    dialog(`Número de items a excluir no início considerando "splitter" de " "`, `0`)
  );
  const excludeExtension = cfl2Str(['Não', 'Sim'], 'Exluir extensão se for ficheiro?', 'Sim');
  const includeCommaAtEndOfNameAndPeriodInLast = cfl2Str(
    ['Não', 'Sim'],
    'Incluir ";" no fim de cada nome e "." no último',
    'Sim'
  );

  const names = getItemNamesFromPathStrs(getPathStrsFromPathObjs(finderApp.selection()), ['']);

  const processedNames = names
    .map((item, index, array) => {
      let processedName = item.split(' ').slice(itemsToExcludeAtBeginningWithSpaceSplitter, 100).join(' ');

      if (excludeExtension === 'Sim') {
        processedName = processedName.replace('.pdf', '');
      }

      if (includeCommaAtEndOfNameAndPeriodInLast === 'Sim') {
        processedName = processedName + (index === array.length - 1 ? '.' : ';');
      }
      return processedName;
    })
    .join('\n');

  setClipboard(processedNames);
  //dAlert(appsNamesListOutput.join("\n"))
} else if (option == 'CreateLinkInNotes - CopyLinkName_URLFrontPage' || option == 'CreateLinkInNotes - MultiCopyURLAndLinkName') {
  safariApp.activate();
  setClipboard(''); // Reset TheClipboard

  for (var h = 0; h < 1000; h++) {
    for (var i = 0; i < 1000; i++) {
      delay(d0p3);

      // d3 tempo suficiente para manualmente activar a área de URL, copiar e clicar fora para desactivar antes de dar bip (se System Event querer fechar enquanto estiver a mexer - SUPONHO QUE seja System Events na operação theClipboard())
      // Se não clicar fora para fechar área de URL, System Events fecha automaticamente
      // 🔴🔴🔴 A idéia é fazer copy de URL usando o mínimo de tempo possível para minimizar chances CRUZAMENTO com processos de System Events
      if (h > 0) {
        delay(3);
      }

      if (option == 'CreateLinkInNotes - CopyLinkName_URLFrontPage') {
        var linkUrl = safariLib.getURL();
      } else if (option == 'CreateLinkInNotes - MultiCopyURLAndLinkName') {
        var linkUrl = theClipboard();
      }

      //var linkUrl = theClipboard()
      delay(d0p3);

      if (linkUrl.slice(0, 6) == 'https:') {
        break;
      }
    }

    for (var i = 0; i < 1000; i++) {
      delay(d0p3);
      var linkName = theClipboard();

      // `linkName != ""` necessário se for "CreateLinkInNotes - CopyLinkName_URLFrontPage" pois clipboard teve Reset acima em `setClipboard("")`
      if (linkName.slice(0, 6) != 'https:' && linkName != '') {
        break;
      }
    }

    if (linkName.slice(0, 3) == 'htt') {
      alert(`PARECE QUE A CONDIÇÃO DE LINKNAME NÃO TEVE SATISFAÇÃO. LINKNAME É:\n\n${linkName}`, ``);
    }

    notesApp.activate();

    setClipboard(linkName);
    paste();
    setClipboard(linkUrl);
    selectPreviousInputParagraph(linkName, 'all');
    notesLib.applyLinkInSelectionFromClipboard();
    if (option == 'CreateLinkInNotes - MultiCopyURLAndLinkName') {
      enter(1);
    }
    setClipboard(''); // Reset TheClipboard
    safariApp.activate();

    if (option == 'CreateLinkInNotes - CopyLinkName_URLFrontPage') {
      break;
    }
  }
} else if (option == 'CreateLinkInNotes - YoutubePlaylists') {
  var sectionsLimit = 20;

  var pageText = safariLib.getPageText();
  var playlistsInfo = pageText.match(/\d\d*\nNOW PLAYING[\nPLAY ALL]*\n.*/g);

  var youtuberInfo = pageText.match(/.*\n[0-9A-Z,.]*\ssubscribers/)[0];
  var youtuberName = youtuberInfo.split('\n')[0].trim();

  var linksAndUrl = [];

  try {
    for (var i = 0; i < 3000000; i++) {
      var link = safariApp.doJavaScript("document.getElementsByTagName('" + 'a' + "')[" + i + '].innerHTML', {
        in: safariApp.windows[0].currentTab,
      });

      var linkTimed = link.trim().replace(/&amp;/g, '&');

      if (linkTimed == 'Test new features') {
        var startCollecting = true;
        continue;
      }

      if (startCollecting && linkTimed[0] != '<' && linkTimed != '' && !linkTimed.includes('View full playlist')) {
        var url = safariApp.doJavaScript("document.getElementsByTagName('" + 'a' + "')[" + i + '].href', {
          in: safariApp.windows[0].currentTab,
        });

        linksAndUrl.push([linkTimed, url]);
      }
    }
  } catch {
    //
  }

  var linksAndUrlSections = [];

  for (var h = 0; h < sectionsLimit; h++) {
    if (h > 0) {
      // Uses after first Playlist
      var linksAndUrl = linksAndUrlSortedNotSeleted;
    }

    try {
      // Try para se não tiver mais playlist remancescentes não dar erro

      var linksAndUrlSorted = sortArray(linksAndUrl);
      var linksAndUrlSortedL = linksAndUrlSorted.length;
      // sectionsLimit
      var linksSortedSeleted = cfl(
        linksAndUrlSorted.map(item => item[0]),
        `Selecione Playlists (${linksAndUrlSortedL}) para secção ${
          linksAndUrlSections.length + 1
        } \n\n• Número máximo de seções - ${sectionsLimit}\n\n—\nAntes fazer reload duas vezes para evitar leitura de número errado (maior) de vídeos❗️`,
        linksAndUrlSorted[0][0],
        'm'
      );

      // ------------ FIND SELETED PLAYLISTS

      var linksAndUrlSortedSeleted = [];
      var links = [];

      for (var i = 0; i < linksSortedSeleted.length; i++) {
        var linkSeleted = linksSortedSeleted[i];

        for (var j = 0; j < linksAndUrlSorted.length; j++) {
          var linkAndUrl = linksAndUrlSorted[j];
          var link = linkAndUrl[0];

          if (link == linkSeleted) {
            linksAndUrlSortedSeleted.push(linkAndUrl);
            links.push(link);
          }
        }
      }

      // ------------ FIND NOT SELETED PLAYLISTS

      var linksAndUrlSortedNotSeleted = [];

      for (var i = 0; i < linksAndUrlSorted.length; i++) {
        var linkToTrack = linksAndUrlSorted[i];
        var linkNameToTrack = linkToTrack[0];

        if (!links.includes(linkNameToTrack)) {
          linksAndUrlSortedNotSeleted.push(linkToTrack);
        }
      }

      linksAndUrlSections.push(linksAndUrlSortedSeleted);

      var linksAndUrlSortedSeleted = []; // Reset
    } catch {
      //
    }
  }

  var linksAndUrlSectionsL1 = linksAndUrlSections.length;

  for (var h = 0; h < linksAndUrlSectionsL1; h++) {
    var linksAndUrlSortedSeleted = linksAndUrlSections[h];

    delay(d0p3);

    var linksAndUrlL1 = linksAndUrlSortedSeleted.length;

    var sectionNameAndVideosNum =
      dialog(
        `Nome da secção para ${linksAndUrlL1} Playlists (${h + 1 + '/' + linksAndUrlSectionsL1})\n\n${linksAndUrlSortedSeleted
          .map(item => '• ' + item[0])
          .join('\n')}`,
        youtuberName
      ) + ` (${linksAndUrlL1})`;

    notesApp.activate();

    //var linksAndUrlSorted = sortArray(linksAndUrl)

    delay(d0p3);

    linksAndUrlSortedSeleted.unshift([sectionNameAndVideosNum, 'emptyUrl']);

    var linksAndUrlL2 = linksAndUrlSortedSeleted.length;

    for (var i = 0; i < linksAndUrlL2; i++) {
      // if (i == 0) {
      // 	var sectionName = dialog(`Nome da secção para ${linksAndUrlL2} Playlist`, youtuberName)
      // }

      var linkName = linksAndUrlSortedSeleted[i][0]; //.replace(/&amp;/g, "&")
      var linkUrl = linksAndUrlSortedSeleted[i][1];

      // --- Get videos Number of playlist

      try {
        var playlistInfo = playlistsInfo.filter(item => item.includes(linkName))[0];
        var playlistVideosNum = playlistInfo.split('\n')[0] + ' ';
      } catch {}

      // ---

      if (playlistVideosNum == undefined) {
        var playlistVideosNum = '';
      }

      setClipboard(playlistVideosNum + linkName);
      paste();

      if (i > 0) {
        setClipboard(linkUrl);
        selectPreviousParagraph();
        notesLib.applyLinkInSelectionFromClipboard();
      }

      if (i != linksAndUrlL2 - 1) {
        enter(1);
      }

      if (i == linksAndUrlL2 - 1 && h != linksAndUrlSectionsL1 - 1) {
        enter(2);
        var playlistVideosNum = undefined;
      }

      if (i == 0) {
        tab(1);
      }
    }
  }
} else if (option == 'Dinheiro Por Extenso') {
  var moneyInTextAmountClipb = saApp.theClipboard();

  if (Number(moneyInTextAmountClipb.replace(/,/g, ''))) {
    var moneyInTextAmountD = moneyInTextAmountClipb;
  } else {
    var moneyInTextAmountD = '';
  }

  var moneyInTextAmount = dDialog(
    `Valor\n\n—\n• Pode ter separador de múltiplos de mil, usando vírgulas ",".\n• Para casas decimais, usar ponto ".".`,
    moneyInTextAmountD
  );

  var moneyInTextAmount = moneyInTextAmount.replace(/,/g, '');

  var moneyInTextAmountFormated = formatNumber(moneyInTextAmount, 2, 2);
  var moneyInTextAmountConverted = getMoneyInText(moneyInTextAmount);

  var moneyInTextAmountAction = cfl2Str(
    ['Copiar', 'Em Pages Doc - Inserir valor por extenso', 'Em Pages Doc - Inserir valor numérico e valor por extenso'],
    moneyInTextAmountFormated + '\n—\n' + moneyInTextAmountConverted + '\n\n\n\n',
