  // const docNumXA5Name = docNumXA5.name()
  numbersApp.activate();

  numbersSheetsUpdatePrefixNumbers(docNumXA5);

  // if (docNumXA5Name.includes("TEXT XA5") && !docNumXA5Name.includes("ARCHIVED")) {
  if (numbersDocIsTextXA5(docNumXA5) && !numbersDocIsArchived(docNumXA5)) {
    numbersProjectInProcessInfoPopulate(docNumXA5);
  }

  docNumXA5.save();
} else if (option == 'Word Counter') {
  dAlert(`INCLUDE COPIED INFO OPTION IN "Word Counter"`, ``);

  // Can be log file
  var fileObject = saApp.chooseFile({ ofType: 'txt', withPrompt: 'Please select a txt file:' });

  var allwords = objCLib.readFile(fileObject.toString());

  var processOptionsStr = cfl2StrWithEmpty(
    ['Incluir números', 'Todas palavras em LowerCase', 'Palavra mais frequente no Topo'],
    'Opções de processamento',
    'Palavra mais frequente no Topo',
    'm'
  );

  var counts = {};
  var keys = [];
  var keysAndCounts = [];

  var allwordsPrepared = allwords.split('\n').join('\t').split('\t').join(' ').split(' ').join(' ');

  //var tokens = allwordsPrepared.split(/\W+/);

  var tokens = allwordsPrepared.split(' ');

  for (var i = 0; i < tokens.length; i++) {
    if (processOptionsStr.includes('Todas palavras em LowerCase')) {
      var word = tokens[i].toLowerCase();
    } else {
      var word = tokens[i];
    }

    if (processOptionsStr.includes('Incluir números')) {
      var patt = /\W+/;
    } else {
      var patt = /\d+/;
    }

    // Recebe o contrário de patt
    if (!patt.test(word)) {
      // Exclude numbers
      if (counts[word] === undefined) {
        counts[word] = 1;

        // Make array to get sort. Object does not support sort.
        keys.push(word);
      } else {
        counts[word] = counts[word] + 1;
      }
    }
  }

  if (processOptionsStr.includes('Palavra mais frequente no Topo')) {
    keys.sort(compare);
  } else {
    keys.sort();
  }

  for (var i = 0; i < keys.length; i++) {
    var key = keys[i];
    keysAndCounts.push(key + ' ' + counts[key]);
  }

  // var countsArray = []
  //
  // for (let key in counts) {
  // 	countsArray.push(key + " " + counts[key])
  // }

  dAlert('Resultados', keysAndCounts.join('\n'));
} else if (option == 'Open Invoices') {
  var invoicesOpen = paymentLib.invoices('').open1;

  var invoiceOpen = cfl2Str(invoicesOpen, 'Factura abertas', invoicesOpen[0]);
} else if (option == 'xd5ProfileMaker') {
  const sectionPathStrs = getPathStrsFromPathStr(assetPathStr, 'folders');

  const sectionPathStrsFiltered = sectionPathStrs.filter(url => !url.split('/').slice(-1)[0].startsWith('+'));

  // -------------

  const imageName = 'Imagem';

  const projectsPrefixes = ['proj1', 'proj2', 'proj3', 'proj4', 'proj5'];

  let headersFinal = ['Secção'];
  let headers = ['Separador', 'Consultoria', 'Objecto', 'CS', 'Cliente', 'Localizacão', 'Data'];

  const imagesPrefixes = [
    `${imageName}1`,
    `${imageName}2`,
    `${imageName}3`,
    `${imageName}4`,
    `${imageName}5`,
    `${imageName}6`,
    `${imageName}7`,
    `${imageName}8`,
  ];

  for (var i = 0; i < projectsPrefixes.length; i++) {
    const projectPrefix = projectsPrefixes[i];
    itemsGeneral = headers.map(item => projectPrefix + item);

    const itemsImages = imagesPrefixes.map(item => projectPrefix + item);

    headersFinal.push(...itemsGeneral, ...itemsImages);
  }

  headersFinal = headersFinal.join(',');
  // -------------

  const infoToFillFinalAll = [[headersFinal]];
  const sectionsNames = [];

  for (var h = 0; h < sectionPathStrsFiltered.length; h++) {
    var sectionName = sectionPathStrsFiltered[h].split('/').slice(-1).toString();
    let projPathStrs = getPathStrsFromPathStr(assetPathStr + '/' + sectionName, 'folders');

    projPathStrs = projPathStrs.filter(url => !url.split('/').slice(-1)[0].startsWith('+'));

    // var headersFinal = ["Secção"]
    var infoToFillFinal = [sectionName];
    sectionsNames.push(sectionName);
    var profilePagesRows = [];

    for (var i = 0; i < projPathStrs.length; i++) {
      const projName = projPathStrs[i].split('/').slice(-1).toString();

      const projectPath = assetPathStr + '/' + sectionName + '/' + projName;

      // const imagePathStrs = getPathStrsFromPathStr(assetPathStr + "/" + sectionName + "/" + projName, "files")

      const [, projDate, projCs, projConsultancy, projObject, projCustomer, projSite] = projName.split(` ${ND} `);

      // const [ , projConsultancy, projCs, projObject, projCustomer, projSite, projDate] = projName.split(` ${ND} `)

      // let headers = ["Separador", "Data", "CS", "Consultoria", "Objecto", "Cliente", "Localizacão"]
      var infoToFill = [' • ', projConsultancy, projObject, projCs, projCustomer, projSite, projDate];

      const projectPrefix = 'proj' + (i + 1);
      headers = headers.map(title => projectPrefix + title);

      // var headersFinal = headersFinal.concat(headers)
      var infoToFillFinal = infoToFillFinal.concat(infoToFill);

      // for (var j = 0; j < imagePathStrs.length; j++) {
      for (var j = 0; j < 8; j++) {
        // 8 placeholders for images
        // headersFinal.push(projectPrefix + "Imagem" + (j + 1))

        const jSum = j + 1;

        // const imagePathStr = imagePathStrs[j]
        // const imageName = getItemNamesFromPathStrs([imagePathStr], [""])[0]

        // if (!imageName.startsWith("+")) {
        infoToFillFinal.push(`${projectPath}/${imageName}${jSum}`);
        // }
      }
    }

    // const text = headersFinal.join(",") + "\n" + infoToFillFinal.join(",") + "\n\n"

    infoToFillFinalAll.push(infoToFillFinal.join(','));

    /*
		publisherCreateCSV(numbersApp, imageCsvInfoPathStr, text)
		delay(d1)

		// PUT OUT LOOP IN THIS VERSION
		// --------------- PREPARE AND EXPORT

		if (h == 0) {
			// ----- OPEN PUBLISHER DOC AND PROCESS
			finderApp.open(Path(a5ProfilePathStr))
			delay(d7)
		}

		// --------------- DATA MERGE
		publisherUpdateDataMerge(publisherAppControllerAp)

		const sectionNameUpdated = "X-DIM PERFIL - " + sectionName + ".pdf"

		const exportedPdfsPathStr = profileFolderPathStr + "/" + sectionNameUpdated

		publisherExport2PDF(publisherAppControllerAp, profileFolderPathStr, exportedPdfsPathStr, sectionNameUpdated)
		*/
  }

  const text = infoToFillFinalAll.join('\n'); //.normalize("NFC");

  // publisherCreateCSV(numbersApp, imageCsvInfoPathStr, text)
  objCLib.writeToFile(imageCsvInfoPathStr, text);
  delay(d1);

  finderApp.open(Path(a5ProfilePathStr));
  delay(d7);

  const exportedPdfsPathsStrs = [];
  const sectionNamesUpdated = [];

  for (let i = 0; i < sectionsNames.length; i++) {
    const nowFormatted = formatDateV3(new Date());
    const dateY4M2D2__H2M2S2 = nowFormatted.dateY4M2D2__H2M2S2;

    const sectionName = sectionsNames[i];

    // --------------- DATA MERGE
    publisherUpdateDataMerge(publisherAppControllerAp, affinityPublisherApp, i);

    delay(5); // 🔴🔴🔴 USEFULL?

    const sectionNameUpdated = `X-DIM PERFIL _ ${sectionName} _ ${dateY4M2D2__H2M2S2}.pdf`;

    sectionNamesUpdated.push(sectionNameUpdated);

    const exportedPdfsPathStr = profileFolderPathStr + '/' + sectionNameUpdated;

    exportedPdfsPathsStrs.push(exportedPdfsPathStr);

    delay(3);

    publisherExport2PDF(publisherAppControllerAp, profileFolderPathStr, exportedPdfsPathStr, sectionNameUpdated);
  }

  /*
	doMenu(affinityPublisherName, "File", "Close")
	delay(d1)
	// Application("System Events").applicationProcesses.byName("Affinity Publisher").windows.at(0).buttons.byName("Don't Save")


	// 🔴🔴🔴 USE // publisherAppControllerAp.windows[0].buttons["Don't Save"].click()
	publisherAppControllerAp.windows[0].buttons.byName("Don't Save").click()
	*/

  documentLib.pdfMerger(exportedPdfsPathsStrs, 'pdfPathStrs', 'addInNewPdfWihtNewName', true);
  delay(d5); // To make sure, last PDF was fully open

  const previewDocNames = previewApp.documents.name();

  // const justTest = cfl2Str(previewDocNames, "previewDocNames", previewDocNames[0])

  const pdfsNotOpen = sectionNamesUpdated.filter(item => !previewDocNames.includes(item));

  const pdfsNotOpenL = pdfsNotOpen.length;

  if (pdfsNotOpenL > 0) {
    const alertStr = pdfsNotOpenL > 1 ? `São ${pdfsNotOpenL} PDFs não abertos` : `Um PDF não aberto`;

    alert(`Erro. ${alertStr} automaticamente.`, `${pdfsNotOpen.map((item, i) => i + 1 + '. ' + item).join('\n')}`);
  }
} else if (option == 'xxAuto _ AutoBackup - RunNow') {
  xxAutoLib.autoBackup('MANUAL');
} else if (option == 'xxAuto _ AutoDisplay - RunNow') {
