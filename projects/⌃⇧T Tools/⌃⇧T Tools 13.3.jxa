} else if (
  option == 'Safari W1 - Close Tabs' ||
  option == 'Safari W1 - Order Tabs' ||
  option == 'Safari W1 - ClipboardURLTabs Opener'
) {
  const urlsSeparator = ' _ ';
  let filteredUrls = [];

  if (option == 'Safari W1 - Close Tabs' || option == 'Safari W1 - Order Tabs') {
    var urlsLogNameForFileName = '_ LOG WEB_OCW_TABS';
    var urlsLogNameForAlert = `${urlsLogNameForFileName} yyyyMm`;

    safariApp.activate();
    delay(d0p3);

    var urls = safariApp.windows[0].tabs.url();

    // login.xero.com inclui "go.xero" ao longo do URL

    // //192. é servidor

    /*
		var filteredUrls = urls.filter(url => !url.includes("//192.") && !url.includes("www.apple.com") && !url.includes("github.com") && !url.includes("infopedia.pt") && !url.includes("mail.google.com") && !url.includes("translate.google") && !url.includes("dropbox") && !url.includes("archicadapi.graphisoft") && !url.includes("graphisoftid.graphisoft") && !url.includes("portal.conslog.com") && !url.includes("portaldocliente.tvcabo") && !url.includes("sinonimos.com") && !url.includes("wetransfer.com") && !url.includes("www.epicgames.com"))
		*/

    const excludedSubstrings = [
      '//192.',
      'archicadapi.graphisoft',
      'dropbox',
      'github.com',
      'graphisoftid.graphisoft',
      'infopedia.pt',
      'mail.google.com',
      'millenniumbim.co.mz',
      'portal.conslog.com',
      'portaldocliente.tvcabo',
      'sinonimos.com',
      'translate.google',
      'wetransfer.com',
      'www.apple.com',
      'www.epicgames.com',
    ];

    filteredUrls = urls.filter(url => !excludedSubstrings.some(substring => url.includes(substring)));

    // --------------- START LOG
    // 🔴🔴🔴 PARA ARQUIVO DE SEGURANÇA DE URLs, FAZ LOG DE ULRs FILTRADOS

    var filteredUrlsStr = filteredUrls.join(urlsSeparator).replace(/,/g, 'VírgulaAqui');

    var text = dateY4M2D2__H2M2S2 + ',' + filteredUrlsStr; //+ "\n\n"

    var filePath = `/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Plataformas/INBOX/${urlsLogNameForFileName} ${yearY4M2}.csv`;

    objCLib.writeToFileWithAppend(filePath, text, false);

    // --------------- END OF LOG
  }

  // Intronced after Safari Groups - To keep it. Even before I was necessary to prevent open ordered tabs in another another active window after closed all tabs of window in process.
  let fakeTabUrlToStayWhenClosedTabsInSafariOrderTabs = '';
  const uniqueFilteredUrls = [];

  try {
    if (option == 'Safari W1 - Close Tabs' || option == 'Safari W1 - Order Tabs') {
      if (option == 'Safari W1 - Order Tabs') {
        fakeTabUrlToStayWhenClosedTabsInSafariOrderTabs = `https://www.xdimxd5.com`;
        openURL(fakeTabUrlToStayWhenClosedTabsInSafariOrderTabs);
      }

      // var uniqueFilteredUrls = [] // No duplicates

      // Close filteredUrls
      for (var i = 0; i < filteredUrls.length; i++) {
        const filteredUrl = filteredUrls[i];
        getTab(filteredUrl).close();

        if (!uniqueFilteredUrls.includes(filteredUrl)) {
          uniqueFilteredUrls.push(filteredUrl);
        }
      }
    }

    if (option == 'Safari W1 - Order Tabs' || option == 'Safari W1 - ClipboardURLTabs Opener') {
      var openUlrsStatus = true;

      if (option == 'Safari W1 - Order Tabs') {
        uniqueFilteredUrls.sort();

        // Consider BIM and xero at end of Tabs/URLs

        // go.xero
        var uniqueFilteredUrlsWithoutExcludedUrls = uniqueFilteredUrls.filter(
          url => !url.includes('xero') && !url.includes('millenniumbim.co.mz')
        );

        var uniqueFilteredUrlsGoxero = uniqueFilteredUrls.filter(url => url.includes('xero'));

        var uniqueFilteredUrlsMillenniumbim = uniqueFilteredUrls.filter(url => url.includes('millenniumbim.co.mz'));

        var urlsToOpen = uniqueFilteredUrlsWithoutExcludedUrls.concat(uniqueFilteredUrlsMillenniumbim, uniqueFilteredUrlsGoxero);
      } else if (option == 'Safari W1 - ClipboardURLTabs Opener') {
        // Identifier "VírgulaAqui" se os links foram gravados por "Safari W1 - Close Tabs" ou "Safari W1 - Order Tabs"

        var urlsToOpen = saApp
          .theClipboard()
          .replace(/VírgulaAqui/g, ',')
          .split(urlsSeparator);

        var httpCheckerOfItemOne = urlsToOpen[0].slice(0, 4);

        if (httpCheckerOfItemOne != 'http') {
          var openUlrsStatus = false;

          dAlert(`Parece que Clipboard não tem URLs para abrir!`, ``);
        }
      }

      if (openUlrsStatus) {
        // Reopen urlsToOpen
        for (var i = 0; i < urlsToOpen.length; i++) {
          openURL(urlsToOpen[i]);
          delay(d0p3);
        }
      }

      if (option == 'Safari W1 - Order Tabs') {
        // Close fake Tab after
        getTab(fakeTabUrlToStayWhenClosedTabsInSafariOrderTabs).close();
      }
    }
  } catch (error) {
    dAlert(
      `${error.name}`,
      `${error.message}\n\n—\n🔴🔴🔴\n\nDeu erro mas os URLs (${filteredUrls.length}) foram gravados no CSV "${urlsLogNameForAlert}"`
    );
  }
} else if (option == 'Save Numbers Info to PNG') {
