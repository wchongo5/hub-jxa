      seApp.keyCode(53); // Scape
    } else if (what2Save == 'Todos Itens do Sheet') {
      var ranges = activeSheet.tables.selectionRange.name();

      // Se não for "null", tem selecção de Range em Table
      // "null" é convertido em "" durante o processo mas teste directo dá "null"
