  var finderItem1 = finderApp.selection()[0];
  var properties = finderItem1.properties();

  var propertiesCollection = [];

  for (const key of Object.keys(properties)) {
    try {
      // Stringfy to show text objects like <bounds: {"x":-33,"y":-33,"width":64,"height":64}>
      propertiesCollection.push(`${key}: ${JSON.stringify(properties[key])}`);
