// --------------- COLOR TO DUPLICATES & ALTERNATE ROW COLOR BY DATE (COLOR2 FOR UNIQUEDATES PAIR INDEXES)

// ----- COLLECT UNIQUEDATES
// Collect Alternate Dates from uniqueDates based on pair indexes (i%2 == 0) FOR rows4Color1 and Odd indexes for rows4Color2
// uniqueDates[i] will be uniqueDates[0], uniqueDates[2], uniqueDates[4]

rows4Color1 = []
rows4Color2 = []

for(var i=0; i < uniqueDates.length; i++) {
  if (i%2 == 0) {
		rows4Color1.push(uniqueDates[i])
	} else {
		rows4Color2.push(uniqueDates[i])
	}

}

var rows4Color1Str = rows4Color1.toString()
var rows4Color2Str = rows4Color2.toString()

// ----- COLOR TO DUPLICATES & ALTERNATE ROW COLOR (COLOR2)

var emailsInNumbersWithoutTimeStampRepeatedStr = emailsInNumbersWithoutTimeStampRepeated.toString()

for (var c = 0; c < sheets2process.length ; c++) {

	var currentSheet = sheets2process[c]
	var numbersSheet = docNumbersLogEmails.sheets[currentSheet];

	var table = numbersSheet.tables[0]

	for (var d = 0; d < table.rowCount() ; d++) {
		var emailChecker = table.rows[d].cells[0].value();

		if (emailChecker != "" && emailChecker != null) {

			var emailTitleSplit = table.rows[d].cells[1].value().split(" __ ")[0]

			var timeStampMatch = emailTitleSplit.match(/\d{8}-\d{6}\s/)[0]
			var dateOnly = timeStampMatch.split("-")[0]

			if (rows4Color1Str.includes(dateOnly)) {
				table.rows[d].textColor = titleColor1

			} else if (rows4Color2Str.includes(dateOnly)) {
				table.rows[d].textColor = titleColor2

			}

			var emailTitleWithoutTimeStamp = emailTitleSplit.split(timeStampMatch)[1]

			if (emailsInNumbersWithoutTimeStampRepeatedStr.includes(emailTitleWithoutTimeStamp)) {
				table.rows[d].textColor = titleColorDuplicates
			}
		}
	}
}

if (docNumbersEdits.length == 0) { // Se todos emails do período foram processdos
	currentApp.displayAlert(`Todos emails de período de ${emailsPeriod} dias já foram processados!`)
}

docNumbersLogEmails.save()

var numbersWindowsNum = numbersApp.windows().length

if (numbersWindowsNum > 1) {
	numbersApp.windows[0].close()
} else {
	numbersApp.quit()
}
delay(1)

// --------------- Detele TRIGGER(s) Folder(s)

