}




// ------------------------------------------ FUNCTIONS

function doMenu(appName, menuName, menuItem) {

	var frontApp = Application(appName);

	frontApp.activate();

	var frontAppSE = systemEventsApp.processes.byName(appName);

	var menuName = frontAppSE.menuBars[0].menuBarItems.byName(menuName);
	delay(0.3)

	menuName.menus[0].menuItems.byName(menuItem).click();
}


function doSubMenu(appName, menuName, menuItem, subMenuItem) {

	var frontApp = Application(appName);

	frontApp.activate();

	var frontAppSE = systemEventsApp.processes.byName(appName);

	var menuName = frontAppSE.menuBars[0].menuBarItems.byName(menuName);
	delay(0.3)

	menuName.menus[0].menuItems.byName(menuItem).menus[0].menuItems.byName(subMenuItem).click();
}

function emailsGet(emailFilter) {

	var group = contactsApp.groups.whose({name: { _contains: emailFilter}})()[0]

	var peopleArrayLength = group.people().length
	var emailsGot = [];

  for (var i = 0; i <= peopleArrayLength-1; ++i) {
		var emails = group.people()[i].emails()

		for (var j =0; j <  emails.length; j++) {
			emailsGot.push(emails[j].value())
		}
	}
  return emailsGot;
}

function createPath(folderStr, folderName) {

	var newFolderStr = folderStr + "/" + folderName
	var newFolder = Path(newFolderStr)

	if (!finderApp.exists(newFolder)) {
		var attachmentsFolder = finderApp.make({new: "folder", at: Path(folderStr), withProperties: {name: folderName }});
	}

	return newFolderStr + "/" + originalNameAndTimestamp;
}
