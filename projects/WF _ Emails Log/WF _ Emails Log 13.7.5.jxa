				if (!attachmentsList[i].downloaded() || i > 0) {
				*/


					originalNameAndTimestamp = timeStampMsg + " | " + originalName

					attachmentsInfo.push(originalName)

					var dupEmails = "apoio@tvcabo.co.mz, facturas.vodacom@vm.co.mz"
