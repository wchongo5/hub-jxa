var dateMain = new Date();

var yyyy = (dateMain.getFullYear().toString());
var mm = dateMain.toLocaleString("en", {month: "2-digit"});
var dd = dateMain.toLocaleString("en", {day: "2-digit"});
var time = (dateMain.toLocaleString("en", {hourCycle: "h24", hour: "2-digit", minute: "2-digit", second: "2-digit"})).replace(/:/g, "");

var timeStamp = yyyy + mm + dd + "-" + time

// ---------------

var emailsPeriod = 4 // In days
var dateSet2Past = new Date();

dateSet2Past.setDate(dateSet2Past.getDate() - emailsPeriod)
dateSet2Past.setHours(0)
dateSet2Past.setMinutes(0)
dateSet2Past.setSeconds(0)

var messages = mailApp.inbox.messages.whose({ dateReceived: { '>': dateSet2Past } })()

messages.sort(function(a,b){
  return a.dateReceived() - b.dateReceived();
});


// --------------- COLORING ROWS
