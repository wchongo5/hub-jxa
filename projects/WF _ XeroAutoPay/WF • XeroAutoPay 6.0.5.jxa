		}

		var saveButtonStatus = saveButtons[saveButtonNumber]

		if (saveButtonStatus == "Save") {
			superSafari("click", "class", "xbtn green x-pad large", 0, 0) // Save

		} else if (saveButtonStatus == "Save & add another") {
