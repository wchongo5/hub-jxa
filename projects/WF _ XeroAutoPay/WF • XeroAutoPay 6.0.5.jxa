		} else {

			var spendDateSatusDisplay = currentApp.displayAlert("Data", {buttons: ["Hoje", "Dia deste Mês", "Edição da Data"], defaultButton: 2, givingUpAfter: 5, withIcon: 1}) // , as: "critical"

