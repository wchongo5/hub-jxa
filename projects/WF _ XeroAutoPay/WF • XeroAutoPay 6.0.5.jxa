			} else if (spendDateSatusDisplay.buttonReturned == "Edição da Data") {
				var spendDateSatusNumber = 2

			}

			var spendDateSatus = spendDateSatusList[spendDateSatusNumber]

			if (spendDateSatus == "Hoje") {
