let accountBankListXDIMX = ["1. CAIXA 90", "2. CAIXA 101", "3. CAIXA 102", "4. BIM1-MZN 135746263", "5. BIM2-MZN 303233835 12/XX"]

const spendDateSatusList = ["Hoje", "Dia deste Mês", "Edição da Data"]

const saveButtons = ["Save", "Save & add another"]
// Ver NOTAS pela opção "0"
const saveButtonNumber = 0


var dateMain = new Date();
var yyyy = dateMain.toLocaleString("en", {year: "numeric"});
var mm = dateMain.toLocaleString("en", {month: "2-digit"});
var mmShortStr = dateMain.toLocaleString("en", {month: "short"});
var dd = dateMain.toLocaleString("en", {day: "2-digit"});


function run(input, parameters) {

	var upLoadAttachments = true

	var company = company_()

	try {

		delay(d1p5)

		var currentUrl = getURL()

		if (!currentUrl.includes("go.xero.com")) {
			xeroLogIn("X-DIM X")

		}

		finderApp.reveal(input[0]).extensionHidden = true

		var filePathStr = (input[0]).toString()
		var filePathStrItems = filePathStr.split("/")
		var fileName = filePathStrItems.pop()
