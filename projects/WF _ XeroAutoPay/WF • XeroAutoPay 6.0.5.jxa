}




// ------------------------------------------ FUNCTIONS

function global5GoToFolder(filePathStr) {
	saApp.setTheClipboardTo(filePathStr)
	delay(d1)
	systemEventsApp.keystroke("g", { using: [ "shift down", "command down" ] })
	delay(d0p3)
	systemEventsApp.keystroke("v", { using: "command down" })
	delay(d0p3)
	systemEventsApp.keyCode(76) // Go
	delay(d1p5)
	systemEventsApp.keyCode(76) // OK
}

function formatNumber(numberToFomat, toFixedDecimals, maxdecimals) {
	return Number(parseFloat(numberToFomat).toFixed(toFixedDecimals)).toLocaleString('en', {minimumFractionDigits: maxdecimals});
}

function inputNumber(numberDescription, inputNumberParameter) {

	var condition = false

	while (!(condition)) {

		try {

			var titleDisplay = numberDescription + "\n\n—\nPode introduzir soma de valores!"

			var inputNumberParameter = dDialog(titleDisplay, inputNumberParameter)

			if (inputNumberParameter.includes("+")) {

				var inputNumberParameterSum = 0

				var inputNumberParameterItems = inputNumberParameter.split("+")

				for (var i = 0; i < inputNumberParameterItems.length; i++) {
					inputNumberParameterSum += Number(inputNumberParameterItems[i])
				}

			} else {
				var inputNumberParameterSum = inputNumberParameter
			}

			var theNumber = Number(inputNumberParameterSum)

			if (isNaN(theNumber)) {
				saApp.beep()
				var condition = false

			} else {
				if (theNumber > 0) {
					var condition = true
				}

				if (theNumber == 0) {
					saApp.beep()
				}
			}
		} catch {
			saApp.beep()
			dAlert("Introduz número!", "")
			var condition = false
		}
	}
	return theNumber.toString()
}

function capitalizeText(text, noOrWithExclusions) {

	if (noOrWithExclusions == "NoExclusions") {
		return text.split(" ").map(w => w[0].toUpperCase() + w.substr(1).toLowerCase()).join(" ")

	} else	if (noOrWithExclusions == "WithExclusions") {

		var textItems = text.split(" ")
		var textItemsCol = []

		for (i = 0; i < textItems.length ; i++) {

			var exclusions = "de, da, do, para, com"
			var track = textItems[i].toLowerCase().slice(0,2)
			var textItemL = textItems[i].length

			if (isNaN(track[0])) {
				if (exclusions.includes(track) && textItemL < 5) {
					textItemsCol.push(textItems[i].toLowerCase())
				} else {
					textItemsCol.push(textItems[i][0].toUpperCase() + textItems[i].slice(1).toLowerCase())
				}
			} else {
				textItemsCol.push(textItems[i])
			}
		}
		return textItemsCol.join(" ")

	}
}

function capitalizeTextIfNotInAbbreviation(text) {
	if (text.includes("CMC") || text.includes("MOPHRH")) {
		return text

	} else {
		return capitalizeText(text, "NoExclusions")
	}
}


function global5Tax(company, taxD, taxPercentageWithPrefixD) {

	if (company == "X-DIM W") {

		return "Tax Exempt (0%)"

	} else if (company == "X-DIM X") {

		if (taxPercentageWithPrefixD) {

			var taxPercentage = taxPercentageWithPrefixD.replace("iva", "")

			if (taxPercentage == "0") {
				return "Tax Exempt (0%)"

			} else if (taxPercentage == "8") {
				return `IVA COMPRA GASÓLEO (8%)`

			} else if (taxPercentage == "16") {

				return `IVA COMPRA (16%)`
			}

		} else {
			return cfl2Str(["IVA COMPRA GASÓLEO (8%)", "IVA COMPRA (16%)", "Tax Exempt (0%)"], "Percentagem do IVA", taxD)
		}
	}
}

function cfl(theList, thePrompt, theDefaultItems, multipleStatus) {
	if (multipleStatus == undefined) {
		return (currentApp.chooseFromList(theList, { withPrompt: thePrompt, defaultItems: theDefaultItems}));

	} else if (multipleStatus == "m") {
		return (currentApp.chooseFromList(theList, { withPrompt: thePrompt, defaultItems: theDefaultItems, multipleSelectionsAllowed: true}));
	}
}

function cfl2Str(theList, thePrompt, theDefaultItems, multipleStatus) {

	if (multipleStatus == undefined) {
		return (currentApp.chooseFromList(theList, { withPrompt: thePrompt, defaultItems: theDefaultItems})).toString();

	} else if (multipleStatus == "m") {
		return (currentApp.chooseFromList(theList, { withPrompt: thePrompt, defaultItems: theDefaultItems, multipleSelectionsAllowed: true})).toString();
	}
}

function dAlert(theTitle, theMessage, theButtons, theDefaultButton, theCancelButton) {

	if (theButtons == undefined) {
		currentApp.displayAlert(theTitle, { message: theMessage});
	} else {
		currentApp.displayAlert(theTitle, { message: theMessage, buttons: theButtons, defaultButton: theDefaultButton, cancelButton: theCancelButton});
	}
}

function dDialog(theTitle, theDefaultAnswer, theButtons, theDefaultButton, theCancelButton) {

	if (theButtons == undefined) {
		return currentApp.displayDialog(theTitle, { defaultAnswer: theDefaultAnswer}).textReturned;
	} else {
		return currentApp.displayDialog(theTitle, { defaultAnswer: theDefaultAnswer, buttons: theButtons, defaultButton: theDefaultButton, cancelButton: theCancelButton}).textReturned;
	}
}

function dateInfo(dateInput, theOptions) { //
	return dateInput.toLocaleString("en", theOptions)
}

function getURL() {
	return safariApp.windows[0].currentTab.url()
}

function company_() {
	var windowName = safariApp.windows[0].name();
	var company = windowName.split(" | ")[2]

	if (company == "X-DIM LDA") {
		return "X-DIM X"

	} else if (company == "X-DIM") {
		return "X-DIM W"
	}
}

function xeroLogIn(companyTrack) {

	delay(d0p3);

	safariApp.activate();
	delay(d0p3);
	openURL("https://login.xero.com");
	delay(d5)

	var windowNameInOrOutXero = safariApp.windows[0].name();

	if (!windowNameInOrOutXero.includes("X-DIM")) { // "X-DIM W" ou "X-DIM X"

		delay(d10);
	}

	var company = company_()

	if ((companyTrack == "X-DIM W") && !(company == "X-DIM W")) {

		superSafari("click", "class", "xnav-appbutton--text", 0, 0);
		delay(d0p5);


		var i=0;
		for (i = 0; i < 4; i++) { systemEventsApp.keyCode(125) }

		delay(d1p5);
		systemEventsApp.keyCode(76);

	} else if ((companyTrack == "X-DIM X") && !(company == "X-DIM X")) {

		superSafari("click", "class", "xnav-appbutton--text", 0, 0);
		delay(d0p5);

		var i=0;
		for (i = 0; i < 4; i++) { systemEventsApp.keyCode(125) }

		delay(d1p5);
		systemEventsApp.keyCode(76);
	}
}


function openURL(urlInput) {
	const firstWindow = safariApp.windows[0]
	const tab = safariApp.Tab({url: urlInput})
	firstWindow.tabs.push(tab)
	firstWindow.currentTab = tab
	delay(d1)

	var urlSubscriptionCurrentTab = getURL()

	// "favorites://" is link of blank page
	if (urlSubscriptionCurrentTab == "favorites://") {
		delay(d0p3)

		// Open Location - garantir que que barra de endereço esteja activa (Spend activa imediatamente mas Create Invoice não)
		systemEventsApp.keystroke("l", { using: "command down" })
		delay(d0p3)

		saApp.setTheClipboardTo(urlInput)
		delay(d1)

		systemEventsApp.keystroke("v", { using: "command down" })
		delay(d1)

		systemEventsApp.keyCode(76) // Press Enter
		delay(d1)
	}
}



function superSafari(theAction, type, identifier, num, input) {

	safariApp = Application('Safari')

	if (theAction == "click") {

		var action = "click();"

	} else if (theAction == "get") {

		var action = "innerHTML;"

	} else if (theAction == "submit") {

		var action = "submit();"

	} else if (theAction == "input") {

		var action = "value = \"" + input + "\";"

	} else if (theAction == "force") {

		var action = "onchange();"

	}

	if (type == "id") {

		var getElementBy = "getElementById('" + identifier + "')."

	} else if (type == "class") {

		var getElementBy = "getElementsByClassName('" + identifier + "')[" + num + "]."

	} else if (type == "tag") {

		var getElementBy = "getElementsByTagName('" + identifier + "')[" + num + "]."

	} else if (type == "name") {

		var getElementBy = "getElementsByName('" + identifier + "')[" + num + "]."

	}

	var theJS = "document." + getElementBy + action

	return safariApp.doJavaScript(theJS, { in: safariApp.windows[0].currentTab })
}
