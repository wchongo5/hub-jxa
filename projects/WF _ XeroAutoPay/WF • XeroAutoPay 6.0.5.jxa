		var quantity = "1"

		safariApp.activate()
		delay(d0p3)


		var titleLink = superSafari("get", "class", "titleLinks", 0, 0)

		var sourceAccountWithoutIndex = sourceAccount.split(". ")[1]
		delay(d0p3)

		if (titleLink == null || !titleLink.includes(sourceAccountWithoutIndex)) {

			openURL("https://go.xero.com/Banking/Account/#select/spend");
			delay(d7)

			var sourceAccountOriginal = sourceAccount

			if (sourceAccountOriginal == "1. CAIXA 90") {
				selectBank = superSafari("click", "name", "rg0", 0, 0);
			} else if (sourceAccountOriginal == "2. CAIXA 101") {
				selectBank = superSafari("click", "name", "rg0", 1, 0);
			} else if (sourceAccountOriginal == "3. CAIXA 102") {
				selectBank = superSafari("click", "name", "rg0", 2, 0);
			} else if (sourceAccountOriginal == "4. BIM1-MZN 135746263") {
				selectBank = superSafari("click", "name", "rg0", 3, 0);
			} else if (sourceAccountOriginal == "5. BIM2-MZN 303233835 12/XX") {
				selectBank = superSafari("click", "name", "rg0", 4, 0);
			}
			delay(d3)

			superSafari("click", "id", "common-button-submit-1015", 0, 0); // Next
			delay(d5) // 3
		}

		saApp.setTheClipboardTo(destinyPerson)
		delay(d1)
		systemEventsApp.keystroke("v", { using: "command down" })
		delay(d0p3)
		systemEventsApp.keyCode(48)
		delay(d0p3)
		systemEventsApp.keystroke("a", { using: "command down" })
		delay(d0p3)
		saApp.setTheClipboardTo(spendDate)
		delay(d0p3)
		systemEventsApp.keystroke("v", { using: "command down" })
		delay(d0p3)
		systemEventsApp.keyCode(48)
		delay(d0p3)
		saApp.setTheClipboardTo(reference)
		delay(d0p3)
		systemEventsApp.keystroke("v", { using: "command down" })
		delay(d0p3)
		systemEventsApp.keyCode(48)
		delay(d0p3)
		systemEventsApp.keyCode(48)
		delay(d0p3)
		systemEventsApp.keyCode(48)
		delay(d0p3)
		systemEventsApp.keyCode(48)
		delay(d0p3)
		saApp.setTheClipboardTo(quantity)
		delay(d0p3)
		systemEventsApp.keystroke("v", { using: "command down" })
		delay(d0p3)
		systemEventsApp.keyCode(48)
		delay(d0p3)
		saApp.setTheClipboardTo(autoPrice)
		delay(d0p3)
		systemEventsApp.keystroke("v", { using: "command down" })
		delay(d0p3)
		systemEventsApp.keyCode(48)
		delay(d0p3)
		saApp.setTheClipboardTo(account)
		delay(d0p3)
		systemEventsApp.keystroke("v", { using: "command down" })
		delay(d0p3)
		systemEventsApp.keyCode(48)
		delay(d0p3)
		saApp.setTheClipboardTo(taxRate)
		delay(d0p3)
		systemEventsApp.keystroke("v", { using: "command down" })
