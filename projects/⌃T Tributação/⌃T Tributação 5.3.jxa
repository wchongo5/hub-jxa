var financesPathStr = pathLib.getFinancesPathStr();

var vatProcessFilePathStr = `${financesPathStr}/F0000 PROCESSO/P20XX.numbers`;
var vatProcessFilePathStrPreviousYear = `${financesPathStr}/F${yearY4NMinus1}/P${yearY4NMinus1}.numbers`;
var taxPathStr = pathLib.getTaxPathStr();

var option = cfl2Str(
  ['1. Finanças P' + yearY4 + ' — Info Anual', '---------------', '2. Create - NumbersIRPS', `3. Create - P${yearY4NMinus1}`],
  'Opção',
  '2. Create - NumbersIRPS'
);

if (option == '1. Finanças P' + yearY4 + ' — Info Anual') {
  numbersApp.activate();

  const docNumProcessPreviousYear = numbersApp.open(Path(vatProcessFilePathStrPreviousYear));

  const previousYearSheetVatDecember = docNumProcessPreviousYear.sheets[`IVA${yearY4NMinus1}12`];
  const previousYearTableVatDecember = previousYearSheetVatDecember.tables[0];

  const previousYearTaxRecoverAmount = previousYearTableVatDecember.cells['Z59'].value();

  var docNumProcessXXXX = numbersApp.open(Path(vatProcessFilePathStr));
  // var docNumProcessXXXX = numbersApp.documents[0] // 🔴🔴🔴 FOR TESTING CURRENT DOCNUM
  delay(d3);

  // --------------- < BASE & VERSÕES >
  var tableSummary = docNumProcessXXXX.sheets['< INFO >'].tables['RESUMO'];

  var yyyyTrack = tableSummary.cells['C2'].value();

  var vatProcessFileName = vatProcessFilePathStr.split('/').slice(-1).toString().replace('.numbers', '');

  alert(`Valor de IVA${yearY4NMinus1}12\na recupeperar é\n${formatNumber(previousYearTaxRecoverAmount)}.`, ``);

  var displayInfoExtra = `, tem certeza que quer "actualizar a info"?❗️`;

  if (yyyyTrack.toString() == yearY4) {
    var displayInfo = `Este documento (${vatProcessFileName}) já foi actualizado (${yearY4})`;
  } else {
    var displayInfo = `Este documento (${vatProcessFileName}) tem conteúdo de ${yyyyTrack}`;
  }

  var alertAnswer = currentApp.displayAlert(`${displayInfo}${displayInfoExtra}`, {
    message: ``,
    buttons: ['Cancel', 'OK'],
    defaultButton: 2,
    cancelButton: 1,
  }); // , as: "critical"

  if (alertAnswer.buttonReturned == 'OK') {
    numbersApp.activate();

    // --------------- UPDATE SHEETS NAMES TO CURRENT YEAR

    var vatSheets = docNumProcessXXXX.sheets();

    for (var i = 0; i < vatSheets.length; i++) {
      var sheet = vatSheets[i];
      var sheetName = sheet.name();

      var match = sheetName.match(/SALÁRIO\d{4}|IRPS\d{4}|IVA\d{4}/);

      if (match) {
        sheet.name = sheetName.replace(/\d{4}/, yearY4);
      }
    }

    delay(d0p3);

    var procYearInText = getMoneyInText(yearY4).toLowerCase().replace(', ', ' e ').replace(' meticais', '');

    tableSummary.cells['C2'].value = yearY4;
    tableSummary.cells['B3'].value = procYearInText;

    // ---------------
    var sheetTaxSummary = docNumProcessXXXX.sheets[sheetTaxSummaryName];
    // --------------- IVARESUMO

    var tableVatSummary = sheetTaxSummary.tables[tableVatSummaryName];

    tableVatSummary.cells['L8'].value = previousYearTaxRecoverAmount;

    // for (var i = 9; i <= 20; i++) {
    for (var i = 11; i <= 22; i++) {
      var yyyyMm = tableVatSummary.cells['B' + i].value().toString();
      tableVatSummary.cells['C' + i].value = 'CashBasis';
      tableVatSummary.cells['D' + i].value = getTaxPlaceHolderDate(yyyyMm);
      tableVatSummary.cells['I' + i].value = 0.0;
      tableVatSummary.cells['J' + i].value = 0.0;
    }

    // ----- Delete InvoiceNumbers, not TESTED YET
    tableVatSummary;

    iWorkLib.selectionRange(tableVatSummary, 'P11:P22');
    systemLib.pressDelete(1);

    // --------------- TABLEIVAIRPSINSSNOTAS
