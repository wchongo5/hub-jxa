      var taxPlaceHolderDate = getTaxPlaceHolderDate(yyyyMm);

      tableNotes_vatAndOtherTaxes.cells['D' + i].value = taxPlaceHolderDate;
      tableNotes_vatAndOtherTaxes.cells['F' + i].value = taxPlaceHolderDate;
