const { addZero, formatNumber } = Library('numberLib');
const cflLib = Library('cflLib');
const { alert, dialog } = Library('displayLib');
const documentLib = Library('documentLib');

// ---------------------------------------

function calculateAlarmInputs(dateStart, dateEnd) {
  const alarms = [];
  const eventDuration = (new Date(dateEnd).getTime() - new Date(dateStart).getTime()) / 1000; // duration in seconds

  const oneDay = 24 * 60 * 60;
  const oneHour = 60 * 60;
  const fifteenMinutes = 15 * 60;

  // Add '3d' alarm only if the event duration is at least 3 days
  if (eventDuration >= 3 * oneDay) {
    alarms.push('3d');
  }

  // Add '2d' alarm only if the event duration is at least 2 days
  if (eventDuration >= 2 * oneDay) {
    alarms.push('2d');
  }

  // d: day, h: hour, m: minute

  // Add '1d' alarm only if the event duration is at least 1 day
  if (eventDuration >= oneDay) {
    alarms.push('1d');

    // Add additional alarms in the last 24 hours
    alarms.push('6h');
    alarms.push('3h');
    alarms.push('1h');
    // alarms.push('30m');
    // alarms.push('15m');
  } else if (eventDuration >= oneHour) {
    // Add alarms for shorter events
    alarms.push('1h');
    alarms.push('30m');
    alarms.push('15m');
  } else if (eventDuration >= fifteenMinutes) {
    alarms.push('15m');
  }

  return alarms; //.join(', ');
}

function convertBasicDT2ISO(basicDatetime) {
  // basicDatetime in XD5: 20240731-151222
  // DT - datetime. ISO 8601
  const [yyyy, mm, dd, h, min, s] = [
    basicDatetime.slice(0, 4),
    basicDatetime.slice(4, 6),
    basicDatetime.slice(6, 8),
    basicDatetime.slice(9, 11),
    basicDatetime.slice(11, 13),
    basicDatetime.slice(13, 15),
  ];
  // return `${y}-${m}-${d}T${h}:${min}:${s}`;

  return {
    yyyy,
    dd,
    mm,
    dateISO8601: `${yyyy}-${mm}-${dd}T${h}:${min}:${s}`,
  };
}

function convertDeadlineToDaysWithUnits(deadlineWithUnit) {
  var deadlineWithUnitItems = deadlineWithUnit.split(' ');

  if (deadlineWithUnitItems[1][0] == 'a') {
    return Number(deadlineWithUnitItems[0]) * 365 + 'd';
  } else if (deadlineWithUnitItems[1][0] == 'd') {
    return Number(deadlineWithUnitItems[0]) + 'd';
  } else if (deadlineWithUnitItems[1][0] == 'm') {
    return Number(deadlineWithUnitItems[0]) * 7 * 4 + 'd';
  } else if (deadlineWithUnitItems[1][0] == 's') {
    return Number(deadlineWithUnitItems[0]) * 7 + 'd';
  }
}

function dateEntry_mr(
  ddEntryDescription,
  dateDescription,
  yyyy,
  mm,
  mmNum,
  mmStr,
  dd,
  monthType,
  operationSlashType,
  payrunPayFrequency
) {
  if (operationSlashType == undefined) {
    var { ddEntry } = ddEntryWithPreviousAndOrNext30DaysDisplay(`Anteriores`, ddEntryDescription);
  } else if (operationSlashType == 'Extrato') {
    var { ddEntry } = ddEntryWithPreviousAndOrNext30DaysDisplay(`Anteriores`, ddEntryDescription);
  }

  if (operationSlashType != 'Extrato') {
    if (Number(ddEntry) > Number(dd)) {
      if (mmNum - 1 == 0) {
        var mmNum = '12';
      } else {
        var mmNum = mmNum - 1;
      }
      var mmStr = mmNum2mmStr(mmNum);
    }
  }

  var mmStrTrack = monthSelector('Mês', mmNum, mmStr, 'auto_mmStr').slice(0, 3);
  var mmNumTrack = mmStr2mmNum(mmStrTrack);

  if (Number(mmNumTrack) > Number(mm)) {
    // >= em Extrato Start Date
    var yyyyTrack = yyyy - 1;
  } else {
    var yyyyTrack = yyyy;
  }

  if (operationSlashType == 'D. Create - Payrun (WX)') {
    if (payrunPayFrequency == 'Monthly') {
      var date = new Date(dialog('Data', '1' + ' ' + mmStrTrack + ' ' + yyyyTrack));
    } else {
      var ddEntry = dialog('Dia (Início)', dd);
      var date = new Date(dialog('Data (Início)', ddEntry + ' ' + mmStrTrack + ' ' + yyyyTrack));
    }
  } else {
    var date = new Date(dialog(dateDescription, ddEntry + ' ' + mmStrTrack + ' ' + yyyyTrack));
  }

  var dateDdNew = dateInfo(date, { day: '2-digit' });
  var dateMmNew = dateInfo(date, { month: '2-digit' });
  var dateMmStrNew = dateInfo(date, { month: monthType });
  var dateYyyyNew = dateInfo(date, { year: 'numeric' });

  return dateDdNew + ' | ' + dateMmNew + ' | ' + dateMmStrNew + ' | ' + dateYyyyNew;
}

function ddEntryWithPreviousAndOrNext30DaysDisplay(previousOrNext, ddEntryDescription) {
  var dateCalculeted = new Date();
  //var dateCalculeted = new Date ("5/31/2022") // Testing
  var currentDay = dateCalculeted.getDate(); // 1 ou 13
  var numberOfNextDays = 30; // Aceita mais que 30 dias mas não está configurado para zerar se for mais que 1 mês - zero o primeiro mês apenas - 30 dias são suficientes para a necessidade actual

  if (previousOrNext == `Anteriores` || previousOrNext == `Anteriores15dEPróximos15d`) {
    if (previousOrNext == `Anteriores`) {
      // numberOfNextDays - 1 para incluir o último dia que é o corrente/hoje
      var daysToSubtract = 1;
    } else if (previousOrNext == `Anteriores15dEPróximos15d`) {
      var daysToSubtract = 16; // (1 + 15) para hoje estar no meio (será 16?)
    }

    var dateCalculeted = new Date(dateCalculeted.setDate(dateCalculeted.getDate() - (numberOfNextDays - daysToSubtract)));
  }

  var numberOfDaysInMonth = daysInMonth(dateCalculeted); // 28

  var startDay = dateCalculeted.getDate(); //13

  var monthGridDaysName = `${numberOfNextDays} dias (${previousOrNext})\n* dia de hoje.`;

  // Cada letra inicial do dia tem "espaço" e depois "tab" para centralização
  var next30DaysDisplay = [' M	 T	 W	 T	 F	 S	 S\n'];
  var next7DaysCollection = [];

  var startDayOfWeek = { Monday: 0, Tuesday: 1, Wednesday: 2, Thursday: 3, Friday: 4, Saturday: 5, Sunday: 6 };

  var currentWeekDay = dateCalculeted.toLocaleString('en', { weekday: 'long' }); //"Wednesday"

  for (var i = 0; i < numberOfNextDays; i++) {
    if (i == 0) {
      var loopToWeekDay = startDayOfWeek[currentWeekDay];

      for (var j = 0; j < loopToWeekDay; j++) {
        next7DaysCollection.push('');
      }
    }

    var day = i + startDay;

    if (numberOfDaysInMonth < day) {
      var day = (day - numberOfDaysInMonth).toString();
    }

    if (day.toString().length == 1) {
      var day = ' ' + day;
    }

    if (
      (previousOrNext == `Próximos` && i == 0) ||
      (previousOrNext == `Anteriores` && i == numberOfNextDays - 1) ||
      (previousOrNext == `Anteriores15dEPróximos15d` && day == currentDay)
    ) {
      day += '*';
    }

    next7DaysCollection.push(day);

    if (next7DaysCollection.length == 7) {
      next30DaysDisplay.push(next7DaysCollection.join('	') + '\n');

      var next7DaysCollection = [];
    } else if (next7DaysCollection.length + numberOfNextDays - i <= 7) {
      // O primeiro "	" pode ser "", "tab", não muda nada
      next30DaysDisplay.push(next7DaysCollection.join('	') + '	');

      var next7DaysCollection = [];
    }
  }

  var next30DaysDisplayStr = next30DaysDisplay.join('');

  const ddEntry = dialog(monthGridDaysName + `\n\n` + next30DaysDisplayStr + `\n\n\n${ddEntryDescription}`, currentDay);

  return {
    ddEntry,
    ddEntryPadded: addZero(ddEntry),
  };
}

function dateInfo(dateInput, theOptions) {
  //
  return dateInput.toLocaleString('en', theOptions);
}

function daysInMonth(anyDateInMonth) {
  // 0 is the last day of Month
  return new Date(anyDateInMonth.getFullYear(), anyDateInMonth.getMonth() + 1, 0).getDate();
}

function dueDays() {
  var invoiceDueDays = cflLib.cfl2Str(['7', '15', '30', 'X'], 'Validade (Dias)', '15');

  if (invoiceDueDays == 'X') {
    return dialog(`Dias`, ``);
  } else {
    return invoiceDueDays;
  }
}

