function formatDateV3(date) {
  if (isNaN(date.getTime())) return null;

  // Typed components
  const yearY4N = date.getFullYear(); // 4-digit year number
  const yearY4 = yearY4N.toString(); // 4-digit year
  const yearY2 = yearY4.slice(-2); // 2-digit year

  const monthM1 = date.getMonth() + 1; // 1-12
  const monthM2 = String(monthM1).padStart(2, '0'); // zero-padded
  const monthLong = date.toLocaleString('en', { month: 'long' }); // July
  const monthShort = monthLong.slice(0, 3); // Jul

  const dayD1 = date.getDate(); // 1-31
  const dayD2 = String(dayD1).padStart(2, '0'); // zero-padded

  const hourH1 = date.getHours(); // H
  const hourH2 = String(date.getHours()).padStart(2, '0'); // HH
  const minuteM2 = String(date.getMinutes()).padStart(2, '0'); // MM
  const secondS2 = String(date.getSeconds()).padStart(2, '0'); // SS

  // Time helpers (typed)
  const timeH2M2S2C = `${hourH2}:${minuteM2}:${secondS2}`; // "HH:MM:SS"
  const timeH2M2C = `${hourH2}:${minuteM2}`; // "HH:MM"
  const timeH2M2S2 = `${hourH2}${minuteM2}${secondS2}`; // "HHMMSS"
  const timeH2M2 = `${hourH2}${minuteM2}`; // "HHMM"

  const components = {
    year: {
      Y4: yearY4, //
      Y4N: yearY4N,
      Y2: yearY2,
    },
    month: {
      M2: monthM2, //
      M1: monthM1,
      long: monthLong,
      short: monthShort,
    },
    day: {
      D2: dayD2, //
      D1: dayD1,
    },
    time: {
      H1: hourH1, // "H"
      H2: hourH2, // "HH"
      M2: minuteM2, // "MM"
      S2: secondS2, // "SS"
      H2M2S2C: timeH2M2S2C, // "HH:MM:SS"
      H2M2C: timeH2M2C, // "HH:MM"
      H2M2S2: timeH2M2S2, // "HHMMSS"
      H2M2: timeH2M2, // "HHMM"
    },
  };

  // Directly-named formats
  const dateY4M2D2 = `${yearY4}${monthM2}${dayD2}`;
  const dateY4M2D2H2M2S2 = `${dateY4M2D2}${timeH2M2S2}`;
  const dateY4M2D2__H2M2 = `${dateY4M2D2}-${timeH2M2}`;
  const dateY4M2D2__H2M2S2 = `${dateY4M2D2}-${timeH2M2S2}`;
  const dateY4M2D2__H2M2S2C = `${dateY4M2D2}-${timeH2M2S2C}`;

  const dateDashD2M2Y4 = `${dayD2}-${monthM2}-${yearY4}`;
  const dateDashY4M2D2 = `${yearY4}-${monthM2}-${dayD2}`;
  const dateDashY4M2D2_H2M2 = `${dateDashY4M2D2} ${timeH2M2}`;
  const dateDashY4M2D2_H2M2S2 = `${dateDashY4M2D2} ${timeH2M2S2}`;
  const dateDashY4M2D2_H2M2S2C = `${dateDashY4M2D2} ${timeH2M2S2C}`;

  const dateDotY4M2D2 = `${yearY4}.${monthM2}.${dayD2}`;
  const dateDotY4M2D2_H2M2 = `${dateDotY4M2D2} ${timeH2M2}`;
  const dateDotY4M2D2_H2M2S2 = `${dateDotY4M2D2} ${timeH2M2S2}`;
  const dateDotY4M2D2__H2M2S2 = `${dateDotY4M2D2}-${timeH2M2S2}`;
  const dateDotY4M2D2_H2M2S2C = `${dateDotY4M2D2} ${timeH2M2S2C}`;

  const dateSlashY4M2D2 = `${yearY4}/${monthM2}/${dayD2}`;
  const dateSlashY4M2D2_H2M2 = `${dateSlashY4M2D2} ${timeH2M2}`;
  const dateSlashY4M2D2_H2M2S2 = `${dateSlashY4M2D2} ${timeH2M2S2}`;
  const dateSlashY4M2D2_H2M2S2C = `${dateSlashY4M2D2} ${timeH2M2S2C}`;

  const monthSlashM1Y4 = `${monthM1}/${yearY4}`;
  const monthSlashM2Y4 = `${monthM2}/${yearY4}`;
  const monthSlashLongY4 = `${monthLong}/${yearY4}`;
  const monthSlashShortY4 = `${monthShort}/${yearY4}`;

  const yearY4M2 = `${yearY4}${monthM2}`;
  const yearSlashY4M2 = `${yearY4}/${monthM2}`;
  const yearDashY4M2 = `${yearY4}-${monthM2}`;

  const humanD2MlongY4 = `${dayD2} ${monthLong} ${yearY4}`;
  const humanD1MShortY4 = `${dayD1} ${monthShort} ${yearY4}`;
  const humanD1MShortY2 = `${dayD1} ${monthShort} ${yearY2}`;

  const iso8601 = `${dateDashY4M2D2}T${timeH2M2S2C}`;

  const formats = {
    // Typed patterns
    dateY4M2D2, // 20250704
    dateY4M2D2H2M2S2, // 20250704140530
    dateY4M2D2__H2M2, // 20250704-1405
    dateY4M2D2__H2M2S2, // 20250704-140530
    dateY4M2D2__H2M2S2C, // 20250704-14:05:30

    // Dash-separated date
    dateDashD2M2Y4, // 04-07-2025
    dateDashY4M2D2, // 2025-07-04
    dateDashY4M2D2_H2M2, // 2025-07-04 1405
    dateDashY4M2D2_H2M2S2, // 2025-07-04 140530
    dateDashY4M2D2_H2M2S2C, // 2025-07-04 14:05:30

    // Dot-separated date
    dateDotY4M2D2, // 2025.07.04
    dateDotY4M2D2_H2M2, // 2025.07.04 1405
    dateDotY4M2D2_H2M2S2, // 2025.07.04 140530
    dateDotY4M2D2__H2M2S2, // 2025.07.04-140530
    dateDotY4M2D2_H2M2S2C, // 2025.07.04 14:05:30

    // Slash-separated date
    dateSlashY4M2D2, // 2025/07/04
    dateSlashY4M2D2_H2M2, // 2025/07/04 1405
    dateSlashY4M2D2_H2M2S2, // 2025/07/04 140530
    dateSlashY4M2D2_H2M2S2C, // 2025/07/04 14:05:30

    // Month/year
    monthSlashM1Y4, // 7/2025
    monthSlashM2Y4, // 07/2025
    monthSlashLongY4, // July/2025
    monthSlashShortY4, // Jul/2025

    // Year/month
    yearY4M2, // 202507
    yearSlashY4M2, // 2025/07
    yearDashY4M2, // 2025/07

    // Human-readable
    humanD2MlongY4, // 04 July 2025
    humanD1MShortY4, // 4 Jul 2025
    humanD1MShortY2, // 4 Jul 25

    // ISO8601
    iso8601, // 2025-07-04T14:05:30
  };

  return { components, formats };
}

function getAutoDate(dateYyyyMmDd) {
  // CODE555
  if (dateYyyyMmDd == 'now') {
    return new Date();
  } else {
    var dateYyyyMmDdItems = dateYyyyMmDd.split('');

    dateYyyyMmDdItems.splice(4, 0, '/');
    dateYyyyMmDdItems.splice(7, 0, '/');
    var dateYyyyMmDdWithSeparators = dateYyyyMmDdItems.join('');

    return new Date(dateYyyyMmDdWithSeparators);
  }
}

function getDateEnglishToPortugue(dateInput, monthFormat) {
  if (monthFormat == 'long') {
    var dateString = dateInput.toLocaleString('pt-PT', { day: '2-digit', month: 'long', year: 'numeric' });
    var dateStringSplit = dateString.split(' '); // ["12", "de", "abril", "de", "2020"]

    var monthStringLower = dateStringSplit[2]; //[0].toUpperCase() + dateStringSplit.slice(1);
    var monthCapitalized = monthStringLower[0].toUpperCase() + monthStringLower.slice(1);

    return dateString.replace(monthStringLower, monthCapitalized);
  } else if (monthFormat == '2-digit') {
    return dateInput.toLocaleString('pt-PT', { day: '2-digit', month: '2-digit', year: 'numeric' });
  } else if (monthFormat == 'numeric') {
    return dateInput.toLocaleString('pt-PT', { day: '2-digit', month: 'numeric', year: 'numeric' });
  }
}

function getDateYyyyMmDd__timeHhMnSs(date, dateDescription) {
  const dateFormatted = formatDate(date);
  const yyyy_mm = dateFormatted.yyyy_mm;
  const hh_mm_ss = dateFormatted.hh_mm_ss;

  const { ddEntryPadded } = ddEntryWithPreviousAndOrNext30DaysDisplay(`Anteriores`, 'Dia');

  return dialog(`${dateDescription}`, `${yyyy_mm}${ddEntryPadded}-${hh_mm_ss}`);
}

// function getExpedientDates(date, basicDatetime, tagThisFolder, dateDescription) {
function getExpedientDates(date, basicDatetime, priorityNumberString, dateDescription) {
  if (basicDatetime) {
    var { yyyy, mm, dd, dateISO8601 } = convertBasicDT2ISO(basicDatetime);
    var dateInput = new Date(dateISO8601);
    var ddEntryPadded = dd;
  } else {
    var dateInput = date;
    var { ddEntryPadded } = ddEntryWithPreviousAndOrNext30DaysDisplay(`Anteriores`, 'Dia');
  }

  const dateFormatted = formatDateV3(dateInput);

  if (!dateFormatted) return;

  const {
    components: {
      time: { H2M2S2C: timeH2M2S2C },
    },
    formats: { yearDashY4M2 },
  } = dateFormatted;

  const dateStart_ = `${yearDashY4M2}-${ddEntryPadded}T${timeH2M2S2C}`;
  const dateCreated_ = basicDatetime ? formatDateV3(new Date()).formats.iso8601 : dateStart_;

  if (priorityNumberString) {
    const expedientDuration = Number(dialog('Duração', '3'));

    const dateDue_ = getOffsetDate(new Date(dateStart_), 0, expedientDuration, undefined, true).dateISO8601;

    const datesStrs = dialog(`${dateDescription}`, `${dateCreated_}\n${dateStart_}\n${dateDue_}`);

    const [dateCreated, dateStart, dateDue] = datesStrs.split('\n');

    const dateY4M2D2__H2M2S2 = dateStart.replace(/-/g, '').replace('T', '-').replace(/:/g, '');

    return {
      dateCreated,
      dateStart,
      dateY4M2D2__H2M2S2,
      dateDue,
    };
  } else {
    const dateStart = dialog(`${dateDescription}`, `${dateStart_}`);
    const dateY4M2D2__H2M2S2 = dateStart.replace(/-/g, '').replace('T', '-').replace(/:/g, '');
    return {
      dateY4M2D2__H2M2S2,
    };
  }
}

