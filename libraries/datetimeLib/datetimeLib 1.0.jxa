function getAdjustedEventDatesIfNotSameDay(dateStartString, dateDueString) {
  let dateStart = new Date(dateStartString);
  let dateDue = new Date(dateDueString);

  const isSameDay = dateStart.toDateString() === dateDue.toDateString();

  const houDateDue = dateDue.getHours();

  // if (houDateDue < 10 || houDateDue > 15) {
  if (!isSameDay && (houDateDue < 10 || houDateDue > 15)) {
    dateDue.setHours(15, 0, 0, 0); // Set time to 15:30:00
  }

  dateStart = isSameDay ? dateStart : dateDue;
  dateDue = isSameDay ? dateDue : new Date(dateDue.getTime() + getEventStandardDuration());

  return { isSameDay, dateStartStr: formatDateV3(dateStart).formats.iso8601, dateDueStr: formatDateV3(dateDue).formats.iso8601 };
}

function getDurationUnit(durationC1) {
  var durationUnits = ['ano', 'dia', 'mês', 'semana'];

  return durationUnits.filter(item => item[0] === durationC1.toLocaleLowerCase());
}

function getEventStandardDuration() {
  return 20 * 60 * 1000; // 20 minutes
}

function getDurationInputWithUnit(invoiceCs, extraTitle1, extraTitle2) {
  var workID = invoiceCs.slice(4, 6);

  if (workID == 'AP') {
    var durationinputWithUnitD = '28d';
  } else if (workID == 'AA' || workID == 'AC' || workID == 'AE' || workID == 'AF') {
    var durationinputWithUnitD = '12m';
  } else if (workID == 'UP') {
    var durationinputWithUnitD = '6m';
  } else if (workID.startsWith('R')) {
    // Rebanho
    var durationinputWithUnitD = '1d';
  } else {
    var durationinputWithUnitD = 'SemDuraçãoDefault';
  }

  return dialog(`${extraTitle1}• Dias introduz Xd (12d)\n• Meses introduz Xm (12m)${extraTitle2}`, durationinputWithUnitD);
}

function getMonths() {
  return [
    '1. January',
    '2. February',
    '3. March',
    '4. April',
    '5. May',
    '6. June',
    '7. July',
    '8. August',
    '9. September',
    'Q. October',
    'A. November',
    'Z. December',
  ];
}

function getOffsetDate(
  baseDate, // New optional parameter
  offsetMonths,
  offsetDays = 0,
  providedDay = 1,
  useCurrentDay = false
) {
  // const currentDate = new Date();
  let targetYear = baseDate.getFullYear();
  let targetMonth = baseDate.getMonth() + offsetMonths; // Adjust month based on offset

  // Adjust year and wrap month if necessary
  while (targetMonth < 0) {
    targetMonth += 12;
    targetYear -= 1;
  }
  while (targetMonth > 11) {
    targetMonth -= 12;
    targetYear += 1;
  }

  let targetDay;

  if (useCurrentDay) {
    // If useCurrentDay is true, use the current day of the month
    // targetDay = 5 //currentDate.getDate();
    targetDay = baseDate.getDate();
  } else if (providedDay !== undefined) {
    // If providedDay is specified, use it regardless of useCurrentDay
    targetDay = providedDay;
  } else {
    // Otherwise, default to the first day of the month
    targetDay = 1;
  }

  // Create the target date
  // const targetDate = new Date(targetYear, targetMonth, targetDay);

  const targetDate = new Date(
    targetYear,
    targetMonth,
    targetDay,
    baseDate.getHours(),
    baseDate.getMinutes(),
    baseDate.getSeconds()
  );

  // Add offsetDays
  targetDate.setDate(targetDate.getDate() + offsetDays);

  const targetDateFormatted = formatDateV3(targetDate);

  const dateDashY4M2D2 = targetDateFormatted.formats.dateDashY4M2D2;
  const dateISO8601 = targetDateFormatted.formats.iso8601;

  return {
    dateDashY4M2D2,
    dateISO8601,
  };
}

function getTimeUnitDict(unitC1) {
  // NOT USED YET
  var timeUnitsDict = { a: 'Ano', d: 'Dia', s: 'Semana' };
  return timeUnitsDict[unitC1.toLowerCase()];
}

function getWorkDurationNumbersWithUnit(quoteCs) {
  let serviceGroup;

  if (quoteCs.slice(4, 6) == 'AP' || quoteCs.slice(4, 6) == 'UP') {
    serviceGroup = 'SG_PROJECTO';

    var a5PWorkPhasesNames = [
      '1. Levantamento planialtimétrico (Construções existentes)',
      '2. Programa Base/Estudo Preliminar',
      '3. Anteprojecto',
      '4. Projecto Básico',
      '5. Projecto executivo',
    ];

    var u5PWorkPhasesNames = [
      'Fase 1 | Procedimentos Iniciais',
      'Fase 2 | Estudos de Caracterização da Área de Intervenção',
      'Fase 3 | O Plano',
      'Fase 4 | O Plano Final (Conteúdo Documental)',
    ];

    const disciplineAndService = quoteCs.slice(4, 6);

    const isArchitectural = disciplineAndService == 'AP';
    const isUrbanism = disciplineAndService == 'UP';

    // if (quoteCs.slice(4, 6) == 'AP') {
    if (isArchitectural) {
      var workPhasesNames = a5PWorkPhasesNames;
      var workPhasesNumbersStrD = `0, 3, 11, 5, 9, d`; // `0, 1, 1, 2, s`
      // } else if (quoteCs.slice(4, 6) == 'UP') {
    } else if (isUrbanism) {
      var workPhasesNames = u5PWorkPhasesNames;
      var workPhasesNumbersStrD = `3, 6, 9, 8, s`;
    }

    var workPhasesNumbersStr = dialog(
      `Duração por fase em dias (d), meses (m) ou semanas (s), de forma sequenciada.\n—\n${workPhasesNames.join('\n')}`,
      workPhasesNumbersStrD
    );

    var workPhasesNumbers = documentLib.ensureSpaceAfterCommaInStr(workPhasesNumbersStr).split(', ');

    var workPhasesNumbersL = workPhasesNumbers.length;

    if ((isArchitectural && workPhasesNumbersL == 6) || (isUrbanism && workPhasesNumbersL == 5)) {
      const durationC1 = workPhasesNumbers.pop()[0];

      // return workPhasesNumbers
      return {
        serviceGroup,
        durationC1,
        workPhasesNumbers,
      };
    } else {
      // TERMINAR 20250122-090300
      return alert(
        `Erro: O número de fases + unidade deve ser 5 (U5) ou 6 (A5) e não "${disciplineAndService} | ${workPhasesNumbersL}".`,
        ``
      );
    }
  } else {
    alert(`Duração da obra já está configurada no Numbers XG5!`, ``);

    // return false // ["NoWorkWeekNumbersCodedForThisWorkID"]
    return {
      serviceGroup,
      durationC1: 'a',
      // workPhasesNumbers: ["a"] // "a" for ano
    }; // ["NoWorkWeekNumbersCodedForThisWorkID"]
  }
}

function getYearAndMonth(theDescription, yyyy, mm, mmNum, mmStr, dd) {
  var mmStrTrack = monthSelector(theDescription, mmNum, mmStr, 'mmStr');
  var mmNumTrack = mmStr2mmNum(mmStrTrack);

  if (Number(mmNumTrack) > Number(mm)) {
    var yyyyTrack = yyyy - 1;
  } else {
    var yyyyTrack = yyyy;
  }

  var date = new Date(dd + ' ' + mmStrTrack + ' ' + yyyyTrack);

  var dateMmNew = dateInfo(date, { month: '2-digit' });
  var dateYyyyNew = dateInfo(date, { year: 'numeric' });

  return dateYyyyNew + dateMmNew;
}

function getYyyyMmMinus1(yyyyMm) {
  var yyyyMmStr = yyyyMm.toString();
  var yyyy = Number(yyyyMmStr.slice(0, 4));
  var mm = Number(yyyyMmStr.slice(4, 6)) - 1;

  if (mm == 0) {
    var mm = 12;
    yyyy -= 1;
  }

  return yyyy.toString() + addZero(mm, 2, 2);
}

function getYyyyMmPlus1(yyyyMm) {
  var yyyyMmStr = yyyyMm.toString();
  var yyyy = Number(yyyyMmStr.slice(0, 4));
  var mm = Number(yyyyMmStr.slice(4, 6)) + 1;

  if (mm == 13) {
    var mm = 1;
    yyyy += 1;
  }

  return yyyy.toString() + addZero(mm, 2, 2);
}

function monthEnglishToPortuguese(monthStrToConvert) {
  return new Date('20 ' + monthStrToConvert + ' 1980').toLocaleString('pt-PT', { month: 'long' });
  // june // It's LowerCase
}

function monthSelector(theDescription, mmNum, mmStr, what2return) {
  var months = getMonths();

  if (mmNum == 10) {
    var mmNum = 'Q';
  }
  if (mmNum == 11) {
    var mmNum = 'A';
  }
  if (mmNum == 12) {
    var mmNum = 'Z';
  }

  if (what2return.includes('auto')) {
    // "auto_mmStr", "auto_mm"
    var monthStr = mmStr;
  } else {
    //var monthStr = cflLib.cfl2Str(["1. January","2. February","3. March","4. April","5. May","6. June","7. July", "8. August","9. September","Q. October","A. November","Z. December"], theDescription, (mmNum.toString()) + ". " + mmStr)

    var monthStr = cflLib.cfl2Str(months, theDescription, mmNum.toString() + '. ' + mmStr);
  }

  //if (what2return == "returnMmStr") { // June
  if (what2return.includes('mmStr')) {
    // June

    if (monthStr.includes('.')) {
      return monthStr.slice(3, monthStr.length);
    } else {
      return monthStr;
    }

    //} else if (what2return == "returnMm") { // 06
  } else if (what2return.includes('mm')) {
    // 06

    if (monthStr.includes('.')) {
      var monthNumber = monthStr.split('. ')[0];
    } else {
      var monthNumber = months.filter(month => month.includes(mmStr))[0].split('. ')[0];
    }

    if (monthNumber == 'Q') {
      var monthNumber = '10';
    }
    if (monthNumber == 'A') {
      var monthNumber = '11';
    }
    if (monthNumber == 'Z') {
      var monthNumber = '12';
    }

    return addZero(monthNumber);
  }
}

function mmEnglishToPortuguese(monthStrToConvert) {
  return documentLib.capitalizeText(
    new Date('20 ' + monthStrToConvert + ' 1980').toLocaleString('pt-PT', { month: 'long' }),
    'NoExclusions'
  );
}

function mmStr2mmNum(monthStr) {
  // Accept any year and day. I need month only
  // Formato de mês aceite "June", "Jun"
  var thisD = new Date(monthStr + ' 20 1980');
  return addZero(thisD.getMonth() + 1);
}

function mmNum2mmStr(mmNum) {
  return new Date(mmNum + '/20/1980').toLocaleString('en-EN', { month: 'long' });
}

// offsetDateByComponents was addTime
// const offsetEndDate = offsetDateByComponents()

function offsetDateByComponents(dateInput, { months = 0, days = 0, weeks = 0, years = 0 } = {}) {
  // Ensure dateInput is a Date object
  if (!(dateInput instanceof Date)) {
    dialog(`"dateInput" deve ser objecto de data.`, ``);
  }

  // Clone the date to avoid modifying the original
  let newDate = new Date(dateInput);

  newDate.setFullYear(newDate.getFullYear() + years);
  newDate.setMonth(newDate.getMonth() + months);
  newDate.setDate(newDate.getDate() + weeks * 7);
  newDate.setDate(newDate.getDate() + days);

  // Format the date as yyyy-mm-dd
  // return newDate; //.toISOString().split('T')[0];
  return {
    newDateNumStr: newDate.toString(),
  };
}

// offsetDateByInput was getDuration
// Update createOptionFolder in xxNodejsJXALibFolder.jxa
// Accept positve and negatve inputs (1.5m, -1.5m)
// const offsetStartDate = offsetDateByInput()
function offsetDateByInput(invoiceCs, startDate, extraTitle1, offsetD, showDialog) {
  let offsetWithUnit;

  if (showDialog === 'No') {
    offsetWithUnit = offsetD;
  } else if (showDialog === 'Yes') {
    const extraTitle2 = ' - aceita meses decimais';
    offsetWithUnit = getDurationInputWithUnit(invoiceCs, extraTitle1, extraTitle2);
  }

  // Parse offset input (e.g., "12d", "-2.5m")
  const offsetUnit = offsetWithUnit.slice(-1);
  const offset = Number(offsetWithUnit.slice(0, -1));

  if (offsetUnit === 'd') {
    var newDate = startDate.setDate(startDate.getDate() + offset);
  } else if (offsetUnit === 'm') {
    if (offset % 1 !== 0) {
      // Convert fractional months to days (1 month ≈ 4.33 weeks x 7 days)
      var newDate = startDate.setDate(startDate.getDate() + offset * 4.33 * 7);
    } else {
      var newDate = startDate.setMonth(startDate.getMonth() + offset);
    }
  } else {
    alert('Parece que falhou unidade de tempo!', '');
    return;
  }

  return {
    newDate: new Date(Number(newDate.toString())),
    newDateNumStr: newDate.toString(),
    offset,
    offsetUnit,
  };
}

function timeElapsed(date1, date2) {
  // / 1000 to convert from milissecoonds to seconds
  var calcultedTimeElapsed = (date2 - date1) / 1000;

  if (calcultedTimeElapsed >= 60) {
    return formatNumber(calcultedTimeElapsed / 60, 1, 1) + ' min';

    //return (calcultedTimeElapsed / 60)
  } else {
    return Math.round(calcultedTimeElapsed) + ' s';
  }

  // formatNumber(siteDimensionsItems[0], 2, 2)

  //return Math.round()
}
