function whereToExport(finderFolderPathSr, expExtension) {
  if (expExtension == 'PDF') {
    var folderName = 'PDF (APROVAÇÃO)';
  } else {
    // "editável"
    var folderName = 'EDITÁVEIS';
  }

  var a5PDFApprovalFolderStr = finderFolderPathSr + '/XX5 PROJECTO DIGITAL/' + folderName;

  if (finderApp.exists(Path(a5PDFApprovalFolderStr))) {
    return a5PDFApprovalFolderStr;
  } else {
    return finderFolderPathSr;
  }
}
