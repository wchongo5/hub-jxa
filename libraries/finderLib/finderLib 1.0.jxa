function goToFolderCopyPaste(filePathStr) {
  // alert('X2');

  //delay(d1) // Fica no App
  seApp.keystroke('g', { using: ['shift down', 'command down'] });
  delay(d1); // Era d0p3
  menuLib.copyPaste(filePathStr);
  delay(d0p3);
  seApp.keyCode(76); // Go // Era 76
  // systemLib.enter(1)
  delay(d1p5);
  seApp.keyCode(76); // OK // Era 76
  // systemLib.enter(1)
  delay(d0p3);
}

function goToFolderKeystroke(filePathStr) {
  seApp.keystroke('g', { using: ['shift down', 'command down'] });
  delay(d0p3);

  seApp.keystroke(filePathStr);
  delay(d3);
  seApp.keyCode(76); // Go
  delay(d1);
  seApp.keyCode(76); // OK
  delay(d1);
}

function itemProperties(itemPathStr) {
  return seApp.aliases.byName(itemPathStr).properties();
}

function makeAlias(itemToAlias, path, theName) {
  return finderApp.make({ new: 'aliasFile', to: itemToAlias, at: path, withProperties: { name: theName } });
}

function makeFolder(pathToFolder, theName) {
  const folder = finderApp.make({ new: 'folder', at: pathToFolder, withProperties: { name: theName } });
  const folderPathStr = getPathStrsFromPathObjs([folder])[0];
  const folderPathObj = Path(folderPathStr);

  return {
    folder,
    folderPathObj,
    folderPathStr,
  };
}

function moveItems(pathStrsToMove, pathStrWhereToMove) {
  for (var i = 0; i < pathStrsToMove.length; i++) {
    var pathStrToMove = pathStrsToMove[i];

    finderApp.move(Path(pathStrToMove), { to: Path(pathStrWhereToMove) });
    delay(d0p3);
  }
}

