function process255FolderNameCharacters(folderName) {
  const folderNameLMaximum = 255; // 255 maximum
  let folderNameItems = folderName.split(' ');

  while (folderName.length > folderNameLMaximum) {
    folderName = cflV2(
      folderNameItems,
      `Número de caracteres para para nome da pasta excede ${folderNameLMaximum} (${folderName.length}) Seleccione items para novo nome\n\n\—\n"${folderName}"`,
      folderNameItems,
      true,
      true
    ).join(' ');

    // Update folderNameItems with the new folderName
    folderNameItems = folderName.split(' ');
  }

  return folderName;
}

// ------------------------------ Related

function folderListing(
  destinyFolderStr,
  vatCodeType,
  invoicingStageC1,
  disciplineC1,
  serviceC1,
  province,
  yyDateFoldersAndDocuments
) {
  // O filtro da província foi considerado embora os projectos não precisem (estão agrupagos por província) mas é útil para obras pois estão na mesma pasta.
  // L significa letter

  var selectedFolderStr = destinyFolderStr;

  var folders_ = seApp.folders.byName(selectedFolderStr).folders;

  const checkedYy = checkYy(folders_, yyDateFoldersAndDocuments, disciplineC1, serviceC1);

  var quoteCsOfQuotesAndInvoices = [];
  var invoiceFolders = [];

  for (var i = 0; i < folders_.length; i++) {
    var folderName = folders_[i].name();

    // alert(folderName);

    var folderNameItems = folderName.split(` ${ND} `);
    var folderNameItemsL = folderNameItems.length;

    if (folderNameItemsL == 6) {
      // Listing quotes
      var quoteCs = folderNameItems[folderNameItems.length - 1];

      // XDWCAP221001
      // Added 202501-093700: quoteCs.slice(6, 8) == checkedYy &&
      if (
        quoteCs.slice(0, 3) == vatCodeType &&
        quoteCs[3] == 'C' &&
        quoteCs[4] == disciplineC1 &&
        quoteCs[5] == serviceC1 &&
        quoteCs.slice(6, 8) == checkedYy &&
        quoteCs.slice(8, 10) == province
      ) {
        quoteCsOfQuotesAndInvoices.push(folderName);
      }

      // Listing invoices
      var invoiceCs = folderNameItems[1];

      if (
        invoiceCs.slice(0, 3) == vatCodeType &&
        invoiceCs[3] == 'F' &&
        invoiceCs[4] == disciplineC1 &&
        invoiceCs[5] == serviceC1 &&
        invoiceCs.slice(6, 8) == checkedYy && // New
        invoiceCs.slice(8, 10) == province
      ) {
        invoiceFolders.push(folderName);
      }
    }
  }

  // --------------- QUOTES & INVOICES
  quoteCsOfQuotesAndInvoices.sort();
  //invoiceFolders.sort()

  console.log(quoteCsOfQuotesAndInvoices);

  // --------------- QUOTES
  var quoteFolders = quoteCsOfQuotesAndInvoices.filter(folder => folder[7] == 'C');

  var quoteCsOfQuotesAndInvoicesL = quoteCsOfQuotesAndInvoices.length;
  var quoteFoldersL = quoteFolders.length;

  // MORE WORK
  var quoteAddendumsL = quoteFolders.filter(folder => folder[11] == 'A').length;

  var quoteExtraWorksL = quoteFolders.filter(folder => folder[11] == 'T').length;

  var quoteAddendumsAndExtraWorksL = quoteAddendumsL + quoteExtraWorksL;

  var quoteMainsL = quoteFoldersL - (quoteAddendumsL + quoteExtraWorksL);

  // --------------- INVOICES
  invoiceFolders.sort();
  var invoiceFoldersL = invoiceFolders.length;

  // MORE WORK
  var invoiceAddendumsL = invoiceFolders.filter(folder => folder[11] == 'A').length;
  var invoiceExtraWorksL = invoiceFolders.filter(folder => folder[11] == 'T').length;
  var invoiceAddendumsAndExtraWorksL = invoiceAddendumsL + invoiceExtraWorksL;

  var invoiceMainsL = invoiceFoldersL - (invoiceAddendumsL + invoiceExtraWorksL);

  if (quoteCsOfQuotesAndInvoicesL > 0 || invoiceFoldersL > 0) {
    if (invoicingStageC1 == 'C') {
      // Subtrair Cotações de Adenda e Trabalhos A Mais
      var nextNumber = quoteCsOfQuotesAndInvoices.length + 1 - quoteAddendumsAndExtraWorksL;
    } else if (invoicingStageC1 == 'F') {
      // Subtrair Facturas de Adenda e Trabalhos A Mais
      var nextNumber = invoiceFolders.length + 1 - invoiceAddendumsAndExtraWorksL;
    }

    if (quoteCsOfQuotesAndInvoicesL > 0 && invoicingStageC1 == 'C') {
      var prompt = invoicingPrompt(
        'Cotação',
        nextNumber,
        quoteFoldersL,
        quoteMainsL,
        quoteAddendumsL,
        quoteExtraWorksL,
        invoiceFoldersL,
        invoiceMainsL,
        invoiceAddendumsL,
        invoiceExtraWorksL
      );

      if (quoteFoldersL == 0) {
        var quoteFolders = 'SEM COTAÇÕES';
      }

      if (invoiceFoldersL == 0) {
        var invoiceFolders = 'SEM FACTURAS';
      }

      //var optionSelected = cfl2Str(["NOVA COTAÇÃO"].concat("---------------", quoteFolders), "Pastas de cotações (" + quoteFoldersL + ") - Cria nova Cotação!\n\n—\nPróxima cotação: " + nextNumber + "\n", "NOVA COTAÇÃO")

      var optionSelected = cfl2Str(
        ['NOVA COTAÇÃO'].concat('---------------', quoteFolders, '---------------', invoiceFolders),
        prompt,
        'NOVA COTAÇÃO'
      );

      // optionSelected já não é útil nesta versão que nunca usa Cotação para criar Cotação
      // optionSelected fazia Return de "ESCREVER, agora editada para NOVA COTAÇÃO" ou "PASTA SELECIONADA"
      // Activamos para não dar erro no split SPLITZ1

      // ---------------------------------

      var csOrOptionSelectedItemOne = optionSelected.split(` ${ND} `)[0];

      // Somenete duas opções:
      // Ou é F de factura "XDXFA210303" ou R de "ESCREVER"
      if (csOrOptionSelectedItemOne[3] == 'F') {
        var moreWorkType = cfl2Str(['Adenda', 'Trabalhos A Mais'], 'Tipo de Trabalhos Extras', 'Adenda');

        var allInvoiceFoldersOfThisCs = invoiceFolders.filter(
          folder =>
            folder.split(` ${ND} `)[0] == csOrOptionSelectedItemOne ||
            folder.includes(csOrOptionSelectedItemOne + moreWorkType[0])
        );

        var csOfLastInvoiceFoldersOfThisCs = allInvoiceFoldersOfThisCs[allInvoiceFoldersOfThisCs.length - 1].split(` ${ND} `)[0];

        var csOfLastInvoiceFoldersOfThisCsL = csOfLastInvoiceFoldersOfThisCs.length;

        var moreWorkTypeCharacterCheck = csOfLastInvoiceFoldersOfThisCs[csOfLastInvoiceFoldersOfThisCsL - 2];

        if (moreWorkTypeCharacterCheck == 'A' || moreWorkTypeCharacterCheck == 'T') {
          var lastNumberOfExtraWork = csOfLastInvoiceFoldersOfThisCs.slice(-1);

          var cs4ExtraWork =
            csOfLastInvoiceFoldersOfThisCs.slice(0, csOfLastInvoiceFoldersOfThisCsL - 1) + (Number(lastNumberOfExtraWork) + 1);
        } else {
          var cs4ExtraWork = csOfLastInvoiceFoldersOfThisCs + moreWorkType[0] + '1';
        }

        var nextNumberOrCs4ExtraWork = cs4ExtraWork;
      } else {
        var nextNumberOrCs4ExtraWork = nextNumber;
      }

      // -------------------------

      // return nextNumberOrCs4ExtraWork + ' | ' + optionSelected + ' | ' + selectedFolderStr;
    } else if (quoteCsOfQuotesAndInvoicesL > 0 && invoicingStageC1 == 'F') {
      var prompt = invoicingPrompt(
        'Factura',
        nextNumber,
        quoteFoldersL,
        quoteMainsL,
        quoteAddendumsL,
        quoteExtraWorksL,
        invoiceFoldersL,
        invoiceMainsL,
        invoiceAddendumsL,
        invoiceExtraWorksL
      );

      if (invoiceFoldersL == 0) {
        // Se não tiver nenhuma Factura

        var optionSelected = cfl2Str(
          ['ESCREVER'].concat('---------------', quoteFolders),
          prompt,
          quoteFolders[quoteFoldersL - 1]
        );
      } else {
        if (quoteFoldersL == 0) {
          var quoteFoldersD = 'ESCREVER';
          var quoteFolders = 'SEM COTAÇÕES';
        } else {
          var quoteFoldersD = quoteFolders[quoteFoldersL - 1];
        }

        var optionSelected = cfl2Str(
          ['ESCREVER'].concat('---------------', quoteFolders, '---------------', invoiceFolders),
          prompt,
          quoteFoldersD
        );
      }

      if (optionSelected == 'ESCREVER') {
        //var quoteNextNumber = " | " + (quoteCsOfQuotesAndInvoicesL + 1) - quoteAddendumsAndExtraWorksL

        var quoteNextNumber = ' | ' + (invoiceMainsL + quoteMainsL + 1);
      } else {
        var quoteNextNumber = '';
      }

      var csOrOptionSelectedItemOne = optionSelected.split(` ${ND} `)[0];

      // Somenete duas opções:
      // Ou é F de factura "XDXFA210303" ou R de "ESCREVER"
      if (csOrOptionSelectedItemOne[3] == 'F') {
        var moreWorkType = cfl2Str(['Adenda', 'Trabalhos A Mais'], 'Tipo de Trabalhos Extras', 'Trabalhos A Mais');

        var allInvoiceFoldersOfThisCs = invoiceFolders.filter(
          folder =>
            folder.split(` ${ND} `)[0] == csOrOptionSelectedItemOne ||
            folder.includes(csOrOptionSelectedItemOne + moreWorkType[0])
        );

        var csOfLastInvoiceFoldersOfThisCs = allInvoiceFoldersOfThisCs[allInvoiceFoldersOfThisCs.length - 1].split(` ${ND} `)[0];

        var csOfLastInvoiceFoldersOfThisCsL = csOfLastInvoiceFoldersOfThisCs.length;

        var moreWorkTypeCharacterCheck = csOfLastInvoiceFoldersOfThisCs[csOfLastInvoiceFoldersOfThisCsL - 2];

        if (moreWorkTypeCharacterCheck == 'A' || moreWorkTypeCharacterCheck == 'T') {
          var lastNumberOfExtraWork = csOfLastInvoiceFoldersOfThisCs.slice(-1);

          var cs4ExtraWork =
            csOfLastInvoiceFoldersOfThisCs.slice(0, csOfLastInvoiceFoldersOfThisCsL - 1) + (Number(lastNumberOfExtraWork) + 1);
        } else {
          var cs4ExtraWork = csOfLastInvoiceFoldersOfThisCs + moreWorkType[0] + '1';
        }

        var nextNumberOrCs4ExtraWork = cs4ExtraWork;
      } else {
        var nextNumberOrCs4ExtraWork = nextNumber;
      }

      // nextNumberOrCs4ExtraWork // ExtraWork - Trabalhos A Mais
      // return nextNumberOrCs4ExtraWork + ' | ' + optionSelected + ' | ' + selectedFolderStr + quoteNextNumber;

      // return nextNumberOrCs4ExtraWork + ' | ' + optionSelected + ' | ' + selectedFolderStr + quoteNextNumber + ' | ' + checkedYy;
    }

    return nextNumberOrCs4ExtraWork + ' | ' + optionSelected + ' | ' + selectedFolderStr + quoteNextNumber + ' | ' + checkedYy;
  } else {
    // Este 1 é numeração da primeira Cotação (C) ou Factura (F)
    return '1 | ESCREVER';
  }
}

function provAndNumberAndSiteAndFolders(destinyFolderPath, serviceCode, provCode, quoteOrInvoice, yyDateFoldersAndDocuments) {
  var vatCodeType = serviceCode.slice(0, 3);
  var invoicingStageC1 = serviceCode[3];
  var disciplineC1 = serviceCode[4];
  var serviceC1 = serviceCode[5];

  var folderListInfo = folderListing(
    destinyFolderPath,
    vatCodeType,
    invoicingStageC1,
    disciplineC1,
    serviceC1,
    provCode,
    yyDateFoldersAndDocuments
  );

  // 3 | ESCREVER | /Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Plataformas/P5/P5A ARQUITECTURA/P5AP PROJECTO/PA2025/11 MAPUTO (CIDADE) | 3 | 25

  var folderListInfoItems = folderListInfo.split(' | '); // SPLITZ1
  var nextNumberOrCs4ExtraWork = folderListInfoItems[0];
  const optionSelected = folderListInfoItems[1];
  // const checkedYy = optionSelected === 'ESCREVER' ? folderListInfoItems[4] : folderListInfoItems[3];

  const checkedYy =
    folderListInfoItems.length === 2
      ? yyDateFoldersAndDocuments
      : optionSelected === 'ESCREVER'
      ? folderListInfoItems[4]
      : folderListInfoItems[3];

  // Se for sub factura de trabalhos a Mais não "nextNumberOrCs4ExtraWork" não será número pois é "05T1"
  // 05 número da factura inicial
  // T1 Trabalhos A Mais número 1

  if (
    Number(nextNumberOrCs4ExtraWork) &&
    (nextNumberOrCs4ExtraWork == '1' ||
      nextNumberOrCs4ExtraWork == '10' ||
      nextNumberOrCs4ExtraWork == '20' ||
      nextNumberOrCs4ExtraWork == '35' ||
      nextNumberOrCs4ExtraWork == '50')
  ) {
    var displayCS =
      vatCodeType +
      invoicingStageC1 +
      disciplineC1 +
      serviceC1 +
      // yyDateFoldersAndDocuments +
      checkedYy +
      provCode +
      addZero(nextNumberOrCs4ExtraWork);

    alert(
      'Celebração!',
      '👏👏👏\n\n\n' + quoteOrInvoice + ' número ' + nextNumberOrCs4ExtraWork + ' (' + displayCS + '), neste grupo!'
    );
  }

  var nextNumberOrCs4ExtraWorkL = nextNumberOrCs4ExtraWork.length;

  if (
    nextNumberOrCs4ExtraWork[nextNumberOrCs4ExtraWorkL - 2] == 'A' ||
    nextNumberOrCs4ExtraWork[nextNumberOrCs4ExtraWorkL - 2] == 'T'
  ) {
    var cs = nextNumberOrCs4ExtraWork;
  } else {
    // var cs = serviceCode + yyDateFoldersAndDocuments + provCode + addZero(nextNumberOrCs4ExtraWork);
    var cs = serviceCode + checkedYy + provCode + addZero(nextNumberOrCs4ExtraWork);
  }

  // Uso de " / " no lugar de usual " | " pois folderListInfo usa " | "
  return cs + ' / ' + folderListInfo;
}

function checkYy(folders, yyDateFoldersAndDocuments, disciplineC1, serviceC1) {
  if (disciplineC1 !== 'R' && serviceC1 !== 'P') {
    return dialog(
      `Sendo "${getServiceByC1(
        serviceC1
      )}", deve confirmar o ano. Note que o Projecto é o único serviço que é automático porque usa pastas por ano.`,
      yyDateFoldersAndDocuments
    );
  }

  let currentFolderIsOfCurrentYear = false;

  var folderNames = [];
  for (let i = 0; i < folders.length; i++) {
    folderNames.push(folders[i].name());
  }

  let yyFromCsLocal = null;

  for (let i = 0; i < folderNames.length; i++) {
    const folderNameItems = folderNames[i].split(` ${ND} `);
    const csPotionString = folderNameItems[1];

    if (!csPotionString || !isCs(csPotionString)) {
      continue;
    }

    const csInfo = getCsInfo(csPotionString);

    const { serviceYy: yyFromCs } = csInfo;

    yyFromCsLocal = yyFromCs;

    if (yyFromCs === yyDateFoldersAndDocuments) {
      currentFolderIsOfCurrentYear = true;
      break;
    }
  }

  if (!currentFolderIsOfCurrentYear && yyFromCsLocal) {
    yyDateFoldersAndDocuments = yyFromCsLocal;

    alert(`Pasta com ano não corrente (${yyFromCsLocal}), este será usado em "yyDateFoldersAndDocuments" na numeração.`);
  }

  return yyDateFoldersAndDocuments;
}

// ------------------------------

function renameItem(pathStr, newName, revealStatus) {
  delay(d0p1);

  var revealStatusItems = revealStatus.split('-');

  if (revealStatusItems[0] == 'reveal') {
    revealItem(pathStr, revealStatus);
  } // else "noReveal"

  var containerPathStr = getItemObj(pathStr).container().posixPath();

  var extension = getExtensionFromStr(pathStr);

  if (extension) {
    newName += `.${extension}`;
  }

  if (finderApp.exists(Path(`${containerPathStr}/${newName}`))) {
    alert(`Existe um${extension ? ' ficheiro' : 'a pasta'} com o nome "${newName}".`, ``);
  } else {
    // Extenstion if is File not Folder
    var filePathAlias = seApp.aliases.byName(pathStr);
    filePathAlias.name = newName;
    delay(d0p1);
  }
}

