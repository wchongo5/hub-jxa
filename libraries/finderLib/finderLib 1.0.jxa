function activateWindowById(windowId) {
  var windows = finderApp.windows;

  for (var i = 0; i < windows.length; i++) {
    var window = windows[i];
    if (window.id() == windowId) {
      window.index = 1; // Brings the window to the front
      break;
    }
  }

  //  🔴🔴🔴 IN THE FUTURE CHECK IF window object supports find or filter method, in 20230618 does not
  /*
	var windowToActivate = windows.find(window => window.id() == currentWindowId);

	if (windowToActivate) {
		windowToActivate.index = 1; // Brings the window to the front
	} else {
		console.log("Window not found");
	}
	*/
}

// Helper function to adjust path separators based on context.

function adjustPathSeparator(string, forUI = false) {
  if (forUI) {
    // For UI: replace all ':' with '/'
    return string.replace(/:/g, '/');
  } else {
    // For file system paths: replace all '/' with ':'
    return string.replace(/\//g, ':');
  }
}

function analyzePath(path, componentLimit = 255, totalLimit = 773) {
  // totalLimit = 1024
  // totalLimit is 1024 for macOS. But the study showed limit of 773, maybe includes extra parts before "/Users/..."

  // Normalize the entire path to the decomposed form (NFD)
  const normalizedPath = path.normalize('NFD');

  // Calculate the total byte count for the entire normalized path.
  let totalBytes = 0;
  for (let i = 0; i < normalizedPath.length; i++) {
    const code = normalizedPath.charCodeAt(i);
    if (code < 0x80) {
      totalBytes += 1;
    } else if (code < 0x800) {
      totalBytes += 2;
    } else if (code < 0x10000) {
      totalBytes += 3;
    } else {
      totalBytes += 4;
    }
  }

  // Create the total info object.
  const totalInfo = {
    exceeds: totalBytes > totalLimit,
    total: totalBytes,
    limit: totalLimit,
    excessBytes: totalBytes > totalLimit ? totalBytes - totalLimit : 0,
  };

  // Split the normalized path into components (handles both '/' and '\' as separators).
  const components = normalizedPath.split(/[/\\]/);

  // Check each component against the componentLimit.
  let maxExceed = 0;
  let componentDetail = null;
  for (let i = 0; i < components.length; i++) {
    let compBytes = 0;
    const component = components[i];
    for (let j = 0; j < component.length; j++) {
      const code = component.charCodeAt(j);
      if (code < 0x80) {
        compBytes += 1;
      } else if (code < 0x800) {
        compBytes += 2;
      } else if (code < 0x10000) {
        compBytes += 3;
      } else {
        compBytes += 4;
      }
    }

    if (compBytes > componentLimit) {
      const excess = compBytes - componentLimit;
      if (excess > maxExceed) {
        maxExceed = excess;
        componentDetail = {
          index: i, // Position of the component in the path.
          component: component, // The normalized component string.
          byteCount: compBytes, // Total byte count of the component.
          excessBytes: excess, // Number of bytes exceeding the component limit.
        };
      }
    }
  }

  const componentExcessInfo = {
    exceeds: maxExceed > 0,
    limit: componentLimit,
    // maxExceed: maxExceed,
    // detail: componentDetail,
    ...componentDetail,
  };

  if (totalInfo.exceeds) {
    const errorMessage = `Path excede limite de ${totalLimit} bytes`;

    alert(
      errorMessage,
      Object.entries(totalInfo)
        .map(([key, value]) => `${key}: ${value}`)
        .join('\n')
    );

    throw new Error(errorMessage);
  }

  if (componentExcessInfo.exceeds) {
    const errorMessage = `Path: um dos componentes excede limite de ${componentLimit} bytes`;

    alert(
      errorMessage,
      Object.entries(totalInfo)
        .map(([key, value]) => `${key}: ${value}`)
        .join('\n')
    );

    throw new Error(errorMessage);
  }

  // Consolidate all excess information in a single object.
  return {
    totalInfo,
    componentExcessInfo,
  };
}

function deleteFinderItems(pathStrs) {
  for (var i = 0; i < pathStrs.length; i++) {
    var pathStr = pathStrs[i];

    // --------------- USING REVEAL & DELETE
    delay(d0p3);
    var item = revealItem(pathStr, 'reveal'); // 🔴🔴🔴 It goes to trash
    delay(d0p3);

    // Sem este Activate mesmo depois de ter feito reveal do ficnheiro, apaga aquele que estava selecionado (ex  imagem 1 de Imagens) // 🔴🔴🔴 FUTURO VER SE CONTINUA NECESSÁRIO // Usar ImagensPUBLISHER como teste
    finderApp.activate();
    delay(d0p3);
    finderApp.selection()[0].delete();
    delay(d0p3);
  }
  seApp.keyCode(48, { using: 'command down' }); // Switch to previous App
  delay(d0p3);
}

function invoicingPrompt(
  invoicingStage,
  nextNumber,
  quoteFoldersL,
  quoteMainsL,
  quoteAddendumsL,
  quoteExtraWorksL,
  invoiceFoldersL,
  invoiceMainsL,
  invoiceAddendumsL,
  invoiceExtraWorksL
) {
  var invoicingStageLowerCase = invoicingStage.toLowerCase();

  var generalPrompt1 = `${invoicingStage} principal — Escreve ou escolhe a cotação!`;

  //var generalPrompt2 = "\nSubfactura (Adenda ou Trabalhos a Mais) – Escolhe a Factura principal❗️"
  var generalPrompt3 = `\n\n—\nPróxima ${invoicingStageLowerCase} principal: ${nextNumber}`;

  var quotePrompt = `\n\n• Cotações ${quoteFoldersL} – Principais ${quoteMainsL}, Adenda ${quoteAddendumsL}, Trabalhos A Mais ${quoteExtraWorksL}`;

  //var invoicePrompt = `\n• Facturas ${invoiceFoldersL} – Principais ${invoiceMainsL}, Adenda ${invoiceAddendumsL}, Trabalhos A Mais ${invoiceExtraWorksL}`

  if (invoiceFoldersL == 0) {
    var generalPrompt2 = '';
    var invoicePrompt = '';
  } else {
    var generalPrompt2 = `\nSub${invoicingStageLowerCase} (Adenda ou Trabalhos a Mais) – Escolhe a Factura principal❗️`;

    var invoicePrompt = `\n• Facturas ${invoiceFoldersL} – Principais ${invoiceMainsL}, Adenda ${invoiceAddendumsL}, Trabalhos A Mais ${invoiceExtraWorksL}`;
  }

  return generalPrompt1 + generalPrompt2 + generalPrompt3 + quotePrompt + invoicePrompt + '\n';
}

function getContratFolderInfo(containerPathStr) {
  let entityType;
  let isHubFolder = false;
  let isFolderWithoutCs = false;
  let contractNumbers = [];

  let parentFolderName = null;
  let findFolderSubject = false;
  let parentFolderSubject = null;

  let contractFolderName = null;

  var containerPathStrItems = containerPathStr.split('/');
  var containerPathStrItemsIntact = containerPathStr.split('/');

  let parentFolderNameItems = [];
  let foundFolderIsConsultancy = false;
  let foundFolderIsSupplierType2 = false;

  // 10 níveis de hierarquia de pastas // pode variar. Was 5
  for (var i = 0; i < 10; i++) {
    var currentFolderName = containerPathStrItemsIntact[containerPathStrItemsIntact.length - (1 + i)];

    var currentFolderNameItems = currentFolderName.split(` ${ND} `);

    if (i === 0) {
      parentFolderName = currentFolderName;
    }

    try {
      // THER ARE 3 TYPES OF FOLDER FOR CONTRACT
      // 01 CONSULTANCY FOLDER & TEMPORARY FOLDER - LOOKS FOR " _ CS"
      // <\s_\s[A-Z]{6}\d{6}\w*>
      // IN PASTA HUB
      /// 20230524 _ XDXCAF210603 _ TIJOLEIRA AMOSTRAS
      // PASTA NORMAL NORMAL
      /// Y _ XDXFAF210603 _ SENAMI _ REABILITAÇÃO POSTO TRAVESSIA ROTANDA _ BAIRRO X - ROTANDA _ XDXCAF210603
      // "\s_\s" para excluir pastas que contém CS. ex. "XX5 PROJECTO DIGITAL XDWFAP230901"

      // 02 SUPPLIER FOLDER - TIPO 1
      // <^\w*\d{1}\s_\s\d{6}[0-9.]*\s_\s\w*\s_\s\w*>
      // <XBIM01 _ 135746263 _ BIM _ CONTA _ MAPUTO _ DATAINICIO>
      // Inclui BM 233960606.555 (Ver notas do App para perber ".555")

      // 03 SUPPLIER FOLDER - TIPO 2
      /// <^\w*\s_\s\w*\d{1}\s_\s\d{6}\d*\s_\s\w*\s_\s\w*>
      /// <^\w*\s_\s\w*\d{1}\s_\s[A-Z]*\d{6}\d*\s_\s\w*\s_\s\w*>
      //  <P1FSCT _ XTVCABO1 _ 2018105550 _ TVCABO _ CONTRATO _ MAPUTO _ DATAINICIO>

      // var identifier = currentFolderName.match(/\s_\s[A-Z]{6}\d{6}\w*|^\w*\d{1}\s_\s\d{6}[0-9.]*\s_\s\w*\s_\s\w*|^\w*\s_\s\w*\d{1}\s_\s\d{6}\d*\s_\s\w*\s_\s\w*/)[0]

      if (currentFolderName.startsWith('XX5')) {
        // To skip "XX5 PROJECTO DIGITAL _ ALMEIDA TAMATAMA _ RESIDÊNCIA 3P _ XDWFAP240902"
        continue;
      }

      var identifier = currentFolderName.match(
        /\s_\s[A-Z]{6}\d{6}\w*|^\w*\d{1}\s_\s\d{6}[0-9.]*\s_\s\w*\s_\s\w*|^\w*\s_\s\w*\d{1}\s_\s[A-Z]*\d{6}\d*\s_\s\w*\s_\s\w*/
      )[0];

      var foundFolderName = currentFolderName;

      if (identifier) {
        break;
      }
    } catch {
      containerPathStrItems.pop(); // Remove currentFolderName
    }
  }

  if (!identifier) {
    isFolderWithoutCs = true;

    var finderFolderPathSr = getFinderFolderPathSr();

    var contractNumber = 'NO_CS';
    var entity4Folders = getItemNamesFromPathStrs([finderFolderPathSr], [''])[0];

    alert(
      `Não encontrou a pasta da Consultoria ou Fornecedor. Vai usar os dados abaixo:\n\ncontractNumber: ${contractNumber}\nentity4Folders: ${entity4Folders}`,
      ``
    );

    var companyIdentifier = dialog('companyIdentifier - W or X', 'X');

    return {
      isFolderWithoutCs,
      companyIdentifier,
      contractNumber,
      entity4Folders,
      // "contractFolderName": contractFolderName,
      // "contractFolderPathStr": containerPathStrItems.join("/"),
    };
  }

  // if (identifier) {
  var foundFolderNameItems = foundFolderName.split(` ${ND} `);

  foundFolderIsConsultancy =
    foundFolderNameItems.length === 6 && (foundFolderName.startsWith('Y') || foundFolderName.startsWith('Z'));
  foundFolderIsSupplierType2 = foundFolderNameItems.length === 7;

  if (foundFolderIsSupplierType2) {
    var foundFolderNameItems = foundFolderNameItems.slice(1);
  }

  var contractNumber = foundFolderNameItems[1];

  // Main "HUB" folder: Y _ XDXFAF210601 - XDXFAF210602 - XDXFAF210603 _ SENAMI _ HUB5
  // And Sub HUB Folder: 20240719-143018 _ XDXFAF210601 - XDXFAF210602 _ SITUAÇÃO DO FURO DE ÁGUA __ KENSANI - COMERCIAL | EMAIL
  if (contractNumber.includes(' - ')) {
    // In HUB, use first CS
    contractNumbers = contractNumber.split(' - ');
    var contractNumber = contractNumbers[0];
  }

  // alert(contractNumber);

  /*
    // if (!foundFolderIsConsultancy) {
    if (!foundFolderIsConsultancy && !foundFolderIsSupplierType2) {
      isHubFolder = true;
    }
      */

  if (containerPathStr.includes(` ${ND} HUB5`)) {
    isHubFolder = true;
  }

  parentFolderNameItems = parentFolderName.split(` ${ND} `);
  const startsWithDateTime = /^\d{8}-\d{6}$/.test(parentFolderNameItems[0]);

  // alert(parentFolderName);
  // alert(foundFolderName);
  /// -------------

  if (startsWithDateTime) {
    findFolderSubject = true;
  }

  if (!startsWithDateTime) {
    parentFolderNameItems = foundFolderName.split(` ${ND} `);
  }

  if (findFolderSubject) {
    if (isHubFolder) {
      // 20240502-205039 _ XDXFAF210601 - XDXFAF210602 - XDXFAF210603 _ POSTO DE TRAVESSIA DE ESPUNGABERA- ORÇAMENTO DE TRABALHOS A MAIS- TM001 __ KENSANI - COMERCIAL | EMAIL
      parentFolderSubject = parentFolderNameItems[2].split(` ${ND}`)[0];
    } else {
      // 20240629-083114 _ EIS OS MODELOS DOS SLIDES __ COOPERATIVA Q17 - HELDER JAUANA | EMAIL
      parentFolderSubject = parentFolderNameItems[1].split(` ${ND}`)[0];
    }
  }

  if (isHubFolder) {
    // 20240529-120139 _ XDXFAF210601 _ POSTO DE ESPUNGABERA- PROPOSTA DE ALTERAÇÃO DAS PORTAS INTERIORES __ KENSANI - COMERCIAL | EMAIL

    const contractNumberParentFolder = parentFolderNameItems[1];

    // alert(contractNumberParentFolder);

    if (contractNumberParentFolder.includes(' - ')) {
      // // In HUB, use first CS
      contractNumbers = contractNumberParentFolder.split(' - ');
      var contractNumber = contractNumbers[0];
    } else {
      contractNumbers = [];
      var contractNumber = contractNumberParentFolder;
    }
  }

  if (isCs(contractNumber)) {
    entityType = 'customer';
    var companyIdentifier = contractNumber[2];

    if (companyIdentifier != 'W') {
      // Check W in XDWFAP221004 XCPFUP220801
      var companyIdentifier = 'X';
    }

    const csPosition = foundFolderNameItems[1];

    if (
      (foundFolderNameItems[0] != 'Y' && foundFolderNameItems[0] != 'Z') ||
      (foundFolderNameItems[0] === 'Y' && csPosition.includes(' - '))
    ) {
      var { consultancyPathStr } = getConsultancyPathStrs(p5PathStrWithSuffixP5, contractNumber);

      var containerPathStrItems = consultancyPathStr.split('/');
      contractFolderName = containerPathStrItems.slice(-1)[0];
      var contractFolderNameItems = contractFolderName.split(` ${ND} `);
    } else {
      contractFolderName = foundFolderName;
      var contractFolderNameItems = foundFolderNameItems;
    }
  } else {
    entityType = 'supplier';

    // 2018105550 TVCABO
    // V0276269 VODACOM
    //// HUB5 "20230622 _ XDXFAF210603 _ ATRASO E SOLICITAÇÃO DE AMOSTRAS"
    //// PATAS DE SUPPLIERS
    if (contractNumber === 'TVC2018105550' || contractNumber === 'V0276269' || contractNumber === 'FPD20140722') {
      var companyIdentifier = 'X';
    } else {
      // WALTER: BIM, BCI, ECT

      alert(`companyIdentifier será "W", update Folder STRUCTURE if must "X"`, ``);

      var companyIdentifier = 'W';
    }

    contractFolderName = foundFolderName;
    var contractFolderNameItems = foundFolderNameItems;
  }

  var entity4Folders = contractFolderNameItems[2];

  if (parentFolderSubject && parentFolderSubject.includes(' | ')) {
    /* 
      ' | ' is used when original subject is edited like below. This was noted in QuickFOLDER txt note:
      	- 20240629-083114 _ POWER POINT PARA APRESENTAÇÃO | EIS OS MODELOS DOS SLIDES __ COOPERATIVA Q17 - HELDER JAUANA | EMAIL
					- Assunto orginal: "EIS OS MODELOS DOS SLIDES"
					- Novo assunto: "POWER POINT PARA APRESENTAÇÃO"
      */
    parentFolderSubject = parentFolderSubject.split(' | ')[0];
  }

  return {
    entityType, // 'customer' or 'supplier
    isHubFolder,
    parentFolderSubject,
    companyIdentifier,
    contractNumber,
    contractNumbers,
    entity4Folders,
    contractFolderName,
    contractFolderPathStr: containerPathStrItems.join('/'),
  };
  /*   } else {

  } */
}

function getExtensionFromStr(pathStr) {
  var matches = pathStr.match(/\.(\w*)$/); //[1]

  if (matches) {
    return matches[1];
  } else {
    return null;
  }
}

function getFinderFilePathSr() {
  try {
    return decodeURI(finderApp.selection()[0].url()).slice(7).replace(/\/$/, '');
  } catch {
    alert(`Seleciona um ficheiro!`, ``);
  }
}

function getFinderFolderPathSr() {
  try {
    var itemSelected = finderApp.selection()[0];
    var itemSelectedKind = itemSelected.kind();

    if (itemSelectedKind == 'Alias') {
      var originalItemPathObj = itemSelected.originalItem();

      if (originalItemPathObj.kind() == 'Folder') {
        var destinyFolder = originalItemPathObj;
      } else {
        var destinyFolder = itemSelected.container();
      }
    } else if (itemSelectedKind == 'Folder') {
      var destinyFolder = itemSelected;
    } else {
      var destinyFolder = itemSelected.container();
    }

    return decodeURI(destinyFolder.url()).slice(7).replace(/\/$/, '');

    // var path = decodeURI(destinyFolder.url()).slice(7).replace(/\/$/, '');
    // Normalize to NFD to decompose accented characters, which prevents errors when saving.
    // return path.normalize('NFD');
  } catch {
    alert(`Seleciona uma pasta ou ficheiro!`, ``);
  }
}

function getFolderNameByWhoseByBeginsWith(pathStr, filter) {
  if (!finderApp.exists(Path(pathStr))) {
    throw new Error(`Não existe "${pathStr}" para filtro "${filter}"`);
  }

  return seApp.folders
    .byName(pathStr)
    .folders.whose({ name: { _beginsWith: filter } })
    .name()[0];
}

function getFolderNameByWhoseByContains(pathStr, filter) {
  if (!finderApp.exists(Path(pathStr))) {
    throw new Error(`Não existe "${pathStr}" para filtro "${filter}"`);
  }

  return seApp.folders
    .byName(pathStr)
    .folders.whose({ name: { _contains: filter } })
    .name()[0];
}

function getFolderNameByWhoseByContainsNotEndsWith(pathStr, filter, filterNot) {
  if (!finderApp.exists(Path(pathStr))) {
    throw new Error(`Não existe "${pathStr}" para filtros "${filter}" e "${filterNot}"`);
  }

  return seApp.folders
    .byName(pathStr)
    .folders.whose({ _and: [{ name: { _contains: filter } }, { _not: [{ name: { _endsWith: filterNot } }] }] })
    .name()[0];
}

function getIsInEmailFolderInteraction(item) {
  const containerNameParts = item.container().name().split(' | ');

  if (containerNameParts[containerNameParts.length - 1] === 'EMAIL') {
    return true;
  }

  return false;
}

// filters [""] for all
function getItemNamesFromPathStrs(pathStrs, filters) {
  var itemNames = pathStrs.map(url => url.split('/').slice(-1).toString());

  var filteredItemNames = itemNames.filter(name => filters.some(filter => name.includes(filter)));

  return appLib.sortArray(filteredItemNames);
}

function getItemObj(pathStr) {
  return seApp.aliases.byName(pathStr);
}

function getItemsInfoFromPathStr(pathStr, itemsType) {
  let rawItems;

  switch (itemsType) {
    case 'files':
      rawItems = seApp.folders.byName(pathStr).files();
      break;
    case 'folders':
      rawItems = seApp.folders.byName(pathStr).folders();
      break;
    case 'diskItems':
      rawItems = seApp.folders.byName(pathStr).diskItems();
      break;
    default:
      return [];
  }

  const propsArray = rawItems.map(item => {
    return getItemPropertiesByItem(item);
  });

  const filtered = propsArray.filter(props => {
    return !props.posixPath.includes('.DS_Store');
  });

  filtered.sort((a, b) => {
    const classA = a.class.toLowerCase();
    const classB = b.class.toLowerCase();

    if (classA !== classB) {
      // If one is "folder", it should come first
      if (classA === 'folder') return -1;
      if (classB === 'folder') return 1;
      // Otherwise, fallback to string comparison of kinds
      return classA.localeCompare(classB);
    }

    // Same kind: compare by POSIX path
    return a.posixPath.localeCompare(b.posixPath);
  });

  // 4. If the only result is the root “/” placeholder, return an empty array
  if (filtered.length === 1 && filtered[0].posixPath === '/') {
    return [];
  }

  const itemsNames = filtered.map(item => {
    return item.name;
  });

  const itemsDisplayedNames = filtered.map(item => {
    return item.displayedName; //|| item.name;
  });

  return { itemsNames, itemsDisplayedNames, itemsProperties: filtered };
}

function getItemPropertiesByItem(item) {
  if (typeof item.properties === 'function') {
    // Usually Folder
    return item.properties();
  } else {
    // Usually File
    const posix = Path(item).toString();
    return getItemObj(posix).properties();
  }
}

function getItemPropertiesByPathStr(pathStr) {
  return getItemObj(pathStr).properties();
}

function getItemsPropertiesByPathStr(pathStrs, filters = []) {
  const itemsProperties = pathStrs
    .map(pathStr => {
      return getItemObj(pathStr).properties();
    })
    .filter(item => filters.some(filter => item.name.includes(filter)));

  const itemsNames = itemsProperties.map(item => {
    return item.name;
  });

  return { itemsNames, itemsProperties };
}

function getND(times = 1) {
  /* 
	- Use "+" instead of "&".
		- macOS, Windows, and Linux, support the use of "&";
		- Some softwres specially in command-line, can consider "&" as "control character (for instance, in Unix-like systems, "&" is used to run commands in the background)."
		- URLs and Web Contexts: For "&", the URL-encoded representation is "%26". Not properly encoding URLs can lead to issues with accessing the files or directories.
	- Now I use "|" (pipe) in Hub Folder, Replace in future if necessary
	 */

  return '_'.repeat(times);
}
// getNDClipboardPattern;
function getND4CP() {
  return '||';
}

function getPathStrFromUrl(urlToDecode) {
  return decodeURIComponent(decodeURI(urlToDecode).slice(7));
}

// function getPathStrsFromPathObjs(pathObjs) {
//   return pathObjs.map(item => decodeURIComponent(decodeURI(item.url()).slice(7)).replace(/\/$/, ''));
// }

function getPathStrsFromPathObjs(pathObjs) {
  return pathObjs.map(item => {
    try {
      // Properly encode URI components before decoding them to handle special characters like spaces and percent signs.
      const encodedUrl = encodeURI(item.url());
      const decodedPath = decodeURIComponent(decodeURI(encodedUrl.slice(7)));
      return decodedPath.replace(/\/$/, '');
    } catch (e) {
      // console.error('Failed to decode URI:', item.url(), e);
      // // Return the original URL slice or some error indicator as needed
      // return item.url().slice(7);

      alert(`Erro na função getPathStrsFromPathObjs, processando "${item.url().slice(7)}".`, ``);
    }
  });
}

function getPathStrsFromPathStr(pathStr, itemsType) {
  if (itemsType == 'files') {
    var urlsResult = appLib.sortArray(seApp.folders.byName(pathStr).files.posixPath()).filter(url => !url.includes('.DS_Store'));
  } else if (itemsType == 'folders') {
    var urlsResult = appLib
      .sortArray(seApp.folders.byName(pathStr).folders.posixPath())
      .filter(url => !url.includes('.DS_Store'));
  } else if (itemsType == 'diskItems') {
    var urlsResult = appLib
      .sortArray(seApp.folders.byName(pathStr).diskItems.posixPath())
      .filter(url => !url.includes('.DS_Store'));
  }

  // If empty result is ["/"]
  if (urlsResult.length == 1 && urlsResult[0] == '/') {
    // Empty result
    // var urlsResult = [""]
    return [''];
  }

  return urlsResult;
}

function getProjectPathStrUsingCs(projectCs, whereToSearch) {
  if (whereToSearch == 'xa5Temporay') {
    // var pathStr = "/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Plataformas/INBOX/XA5-TEMPORARY5"
    var pathStr = xa5TemporayPathStr;
  } else if (whereToSearch == 'xa5Xproduction') {
    // var pathStr = "/Users/xd5-wmac/Dropbox/DATACENTER/P5 X-PRODUÇÃO/PROJECTOS"
    var pathStr = `${xa5XProdutionPathStr}/PROJECTOS`;
  }

  var foldersList = seApp.folders.byName(pathStr).folders;

  for (var i = 0; i < foldersList.length; i++) {
    var folderName = foldersList[i].name();

    if (folderName.includes(projectCs)) {
      var temporaryProjectName = folderName;
    }
  }

  return pathStr + '/' + temporaryProjectName;
}

function getScan2BankFilePathStrs(bankIdentifier) {
  var scan2BankPathStr = '/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Plataformas/INBOX/SCAN2BANK';

  var scan2BankFilePathObjs = seApp.folders.byName(scan2BankPathStr).files;
  var scan2BankFilePathObjsL = scan2BankFilePathObjs.length;

  var scan2BankFilePathStrs = [];

  for (var i = 0; i < scan2BankFilePathObjsL; i++) {
    var filePathStr = decodeURI(scan2BankFilePathObjs[i].url()).slice(7);
    var fileName = filePathStr.split('/').splice(-1).toString();

    if (fileName.includes(bankIdentifier)) {
      scan2BankFilePathStrs.push(filePathStr);
    }
  }

  var collator = new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' });
  scan2BankFilePathStrs.sort(collator.compare);

  return scan2BankFilePathStrs;
}

