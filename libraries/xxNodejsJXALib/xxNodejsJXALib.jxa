// ------------------------------ TEMPORAY HERE
// Convert to AppleScript-style date strings (US English format)
function formatDateForAppleScript(date) {
  return date.toLocaleString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    second: '2-digit',
    hour12: true,
  });
}

// ------------------------------ Exists in NodeJS

function generateContractTitle(contract) {
  const isHub = contract.isHub;
  let contractsCountStr = '';

  if (isHub) {
    contractsCountStr = ` (${contract.number.split(' - ').length})`;
  }

  return `${contract.entityName}${contractsCountStr}`;
}

