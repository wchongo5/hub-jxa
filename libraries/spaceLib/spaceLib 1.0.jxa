function getIsValidUseThisSiteForProjectStr(adminInfoToTestItems) {
  // const useThisSiteForProjectStr = getUseThisSiteForProjectStr();

  const adminInfoToTestLastItem = adminInfoToTestItems[adminInfoToTestItems.length - 1];

  if (adminInfoToTestLastItem == useThisSiteForProjectStr) {
    return true;
  } else {
    return alert(
      `ERRO`,
      `Em múltiplas selecções, a última opção deve ser "${useThisSiteForProjectStr}" e não "${adminInfoToTestLastItem}"!`
    );
  }
}

