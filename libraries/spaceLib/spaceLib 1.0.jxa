function goToCoordinates(coordinates, observerAltitude) {
  googleEarthProApp.activate();
  delay(d0p3);

  for (var i = 0; i < coordinates.length; i++) {
    var coordinate = coordinates[i];
    var coordinateLat = coordinate[0].toString();
    var coordinateLon = coordinate[1].toString();
    delay(d0p3);

    googleEarthProAppControllerP.windows[0].splitterGroups[0].groups[0].splitterGroups[0].buttons[0].click();
    delay(d0p3);

    systemLib.tab(2);
    inputInfoInViewTab(coordinateLat, coordinateLon, observerAltitude, '0', '0');
    systemLib.scape();
  }
}

function inputInfoInViewTab(coordinateLat, coordinateLon, observerAltitude, heading, tilt) {
  googleEarthProAppControllerP.windows[0].groups['Description'].radioButtons['View'].click();
  systemLib.tab(1);

  // To Skip date field in v7.3.6.9285 (64-bit) / 20221124
  // Note que apesar da data estar abaixo de Latitude, … ela é a primeira nos Tabs e depois Latitude …
  systemLib.tab(6);

  menuLib.copyPaste(coordinateLat);
  systemLib.tab(1);

  menuLib.copyPaste(coordinateLon);
  systemLib.tab(1);

  if (observerAltitude != undefined) {
    // In "updateInput" is undefined
    menuLib.copyPaste(observerAltitude.toString()); // Range / Altitude
  }
  systemLib.tab(1);

  menuLib.copyPaste(heading); // Heading
  systemLib.tab(1);

  menuLib.copyPaste(tilt); // Tilt
  systemLib.tab(1);
}

function getBoundaryCenterCoordinate(points4BoundaryCenterCood) {
  var boundaryCoordinates = getBoundaryCoordinates(points4BoundaryCenterCood, 'decimal', 'dictionary');
  var topLeftCoordLat = boundaryCoordinates.topLeftCoordLat;
  var topLeftCoordLon = boundaryCoordinates.topLeftCoordLon;
  var bottonRightCoordLat = boundaryCoordinates.bottonRightCoordLat;
  var bottonRightCoordLon = boundaryCoordinates.bottonRightCoordLon;

  var latitude = topLeftCoordLat - (topLeftCoordLat - bottonRightCoordLat) * 0.5;
  var longitude = topLeftCoordLon + (bottonRightCoordLon - topLeftCoordLon) * 0.5;

  return [latitude, longitude];
}

function googlePointsInput(vertixes, inputOption, observerAltitude) {
  var vertixesL = vertixes.length;

  for (var i = 0; i < vertixesL; i++) {
    var vertix = vertixes[i];
    var vertixName = vertix[0];

    if (inputOption == 'initialInput' || (inputOption == 'updateInput' && i == 0)) {
      var vertixLat = vertix[1].toString();
      var vertixLon = vertix[2].toString();
    }
    delay(d0p3);

    // 🔴🔴 Localização // Go to coordinantes only and the location coordinate is input below
    if (i == 0) {
      goToCoordinates([[vertixLat, vertixLon]], observerAltitude);
      delay(d0p3);
    }

    if (inputOption == 'initialInput') {
      googleEarthProAppControllerP.windows[0].splitterGroups[0].groups[0].splitterGroups[0].buttons[0].click();
    } else if (inputOption == 'updateInput') {
      delay(d0p3);
      googleEarthProApp.activate();

      // After ipnut a Point Google activate search as default, tabs below to go to cativate Custmer Foldr

      systemLib.tab(4);
      systemLib.arrowDown(1);

      menuLib.doMenu('Google Earth Pro', 'Edit', 'Get Info');
    }
    delay(d0p3);
    menuLib.copyPaste(vertixName);

    if (inputOption == 'initialInput' || (inputOption == 'updateInput' && i == 0)) {
      systemLib.tab(1);
      menuLib.copyPaste(vertixLat);
      systemLib.tab(1);
      menuLib.copyPaste(vertixLon);
    }

    if (inputOption == 'updateInput' && i == 0) {
      inputInfoInViewTab(vertixLat, vertixLon, undefined, '0', '0');
    }

    systemLib.enter(1);

    if (i == vertixesL - 1) {
      systemLib.tab(4);

      for (var j = 0; j < vertixesL; j++) {
        systemLib.arrowUp(1);
      }
    }
  }
}

function getProjectSiteItemsWithShortcuts(siteItems, prompt, multipleStatus) {
  const optionsToExclude = [useThisSiteForProjectStr, '---------------'];
  const siteItemsWithShortcuts = siteItems.map((option, index) => {
    if (optionsToExclude.includes(option)) {
      return option;
    } else {
      return `${getNextNumberOrLetter(index)}. ${option}`;
    }
  });

  if (multipleStatus === 'm') {
    var siteItemsSelected = cfl(siteItemsWithShortcuts, prompt, siteItemsWithShortcuts[0], 'm').map(item => {
      const splitItem = item.split('. ');
      return splitItem.length > 1 ? splitItem[1] : item;
    });
  } else {
    var siteItemSelected = cfl2Str(siteItemsWithShortcuts, prompt, siteItemsWithShortcuts[0]).split('. ')[1];
  }

  return {
    siteItemSelected,
    siteItemsSelected,
  };
}

