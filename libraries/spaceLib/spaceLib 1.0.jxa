          Macaene: ['Bairro X'],
          Malengane: ['Bairro X'],
          Matunganhane: ['Bairro X'],
          'Sabié*': ['Bairro X'],
        },
      },

      Namaacha: {},
    },

    // Aplicado, não aparece na Web: Chiango
    // Editado: Inguide (não Inguice)
    '11. Maputo (Cidade)': {
      'Distrito Municipal KaMpfumo': [
        'Central A',
        'Central B',
        'Central C',
        'Alto Maé A',
        'Alto Maé B',
        'Malhangalene A',
        'Malhangalene B',
        'Polana Cimento A',
        'Polana Cimento B',
        'Coop',
        'Sommerschield',
      ],

      'Distrito Municipal de Nhlamankulu': [
        'Aeroporto A',
        'Aeroporto B',
        'Xipamanine',
        'Minkadjuíne',
        'Unidade 7',
        'Chamanculo A',
        'Chamanculo B',
        'Chamanculo C',
        'Chamanculo D',
        'Malanga',
        'Munhuana',
      ],

      'Distrito Municipal KaMaxakeni': [
        'Mafalala',
        'Maxaquene A',
        'Maxaquene B',
        'Maxaquene C',
        'Maxaquene D',
        'Polana Caniço A',
        'Polana Caniço B',
        'Urbanização',
      ],

      // Subdivisão da Costa do Sol introduzido manualmente on the Fly: Mapulene (Projecto de Adérito Ozias Cordeiro Mongo)
      // 🔴 Adicionados sem base da Web: Guebo (sem certeza que pertence a este distrito)
      'Distrito Municipal KaMavota': [
        'Mavalane A',
        'Mavalane B',
        'FPLM',
        'Hulene A',
        'Hulene B',
        'Ferroviário',
        'Laulane',
        '3 de Fevereiro',
        'Mahotas',
        'Albazine',
        'Costa do Sol',
        'Chiango',
        'Guebo',
      ],

      'Distrito Municipal KaMabukwana': [
        'Bagamoyo',
        'George Dimitrov (Benfica)',
        'Inhagoia A',
        'Inhagoia B',
        'Jardim',
        'Luís Cabral',
        'Magoanine',
        'Malhazine',
        'Nsalane',
        '25 de Junho A',
        '25 de Junho B',
        'Zimpeto',
      ],

      'Distrito Municipal KaTembe': ['Gwachene', 'Chale', 'Inguide', 'Incassene', 'Xamissava'],

      'Distrito Municipal KaNyaka': ['Ingwane', 'Ribjene', 'Nhaquene'],
    },
  };

  // provinceNumbered
  /* // DESACTIVADO, USA BUSCA NO PARAMETER provinceInfo
	var provinces = Object.keys(mozAdminDict)
	var provinceNumbered = cfl2Str(provinces, "Província", provinces[1])
	var provinceNumbered = cfl2Str(provinces, "Província", provinceNumbered)
	*/

  if (provinceInfoItems.length == 1) {
    var provinceNumbered = provinceInfoItems[0];

    try {
      // district
      var districts = Object.keys(mozAdminDict[provinceNumbered]);
    } catch {
      alert('Esta província (' + provinceNumbered + ') ainda não está configurada!', '');
    }

    currentApp.activate();

    // var districtInfoItems = cfl(districts.concat("---------------", useThisSiteForProjectStr), `Distrito\n—\n🔴 Até o último passo, nenhuma opção deve ter acentuação do tipo "Ponta d'Ouro"`, districts[0], "m")

    var { siteItemsSelected: districtInfoItems } = getProjectSiteItemsWithShortcuts(
      districts.concat('---------------', useThisSiteForProjectStr),
      `Distrito\n—\n🔴 Até o último passo, nenhuma opção deve ter acentuação do tipo "Ponta d'Ouro"`,
      'm'
    );

    if (districtInfoItems.length == 1) {
      var district = districtInfoItems[0];

      // Maputo e capitais provinciais (mesmo que distrito sede)
      if (provinceNumbered == '11. Maputo (Cidade)') {
        var province = provinceNumbered.split('. ')[1];
        var cityOrVillageAdministrativePost = '';
        //var location = ""

        // Neighborhood
        // Cidade Maputo vem até aqui pois não tem Localidades, não tem Location
        var neighborhoods = mozAdminDict[provinceNumbered][district];

        // var neighborhood = cfl2Str(neighborhoods, "Bairro", neighborhoods[0])
        var { siteItemSelected: neighborhood } = getProjectSiteItemsWithShortcuts(neighborhoods, `Bairro`);

        var projectSite = neighborhood + ', ' + district.replace('*', '') + ', ' + province;

        // Maputo e capitais provinciais (mesmo que distrito sede)
      } else {
        // cityOrVillageAdministrativePost
        var cityOrVillageAdministrativePostList = Object.keys(mozAdminDict[provinceNumbered][district]);

        // var cityOrVillageAdministrativePostInfoItems = cfl(cityOrVillageAdministrativePostList.concat("---------------", useThisSiteForProjectStr), "Cidade / Vila / Posto Administrato", cityOrVillageAdministrativePostList[0], "m")

        var { siteItemsSelected: cityOrVillageAdministrativePostInfoItems } = getProjectSiteItemsWithShortcuts(
          cityOrVillageAdministrativePostList.concat('---------------', useThisSiteForProjectStr),
          `Cidade / Vila / Posto Administrato`,
          'm'
        );

        if (cityOrVillageAdministrativePostInfoItems.length == 1) {
          var cityOrVillageAdministrativePost = cityOrVillageAdministrativePostInfoItems[0];

          //if (provinceNumbered == "10. Maputo" || district.includes("*")) {

          if (district.includes('*')) {
            // Neighborhood
            // Cidade Maputo vem até aqui pois não tem Localidades, não tem Location
            var neighborhoods = mozAdminDict[provinceNumbered][district][cityOrVillageAdministrativePost];

            // var neighborhood = cfl2Str(neighborhoods, "Bairro", neighborhoods[0])

            var { siteItemSelected: neighborhood } = getProjectSiteItemsWithShortcuts(neighborhoods, `Bairro`);
          } else {
            // Outras Províncias e outros distritos depois de capitais provinciais (mesmo que distrito sede)

            // Location
            var locations = Object.keys(mozAdminDict[provinceNumbered][district][cityOrVillageAdministrativePost]);

            //var location = cfl2Str(locations, "Localidade ou Similar", locations[0])

            // var locationInfoItems = cfl(locations.concat("---------------", useThisSiteForProjectStr), "Localidade ou Similar", locations[0], "m")

            var { siteItemsSelected: locationInfoItems } = getProjectSiteItemsWithShortcuts(
              locations.concat('---------------', useThisSiteForProjectStr),
              `Localidade ou Similar`,
              'm'
            );

            var location = locationInfoItems[0];

            if (locationInfoItems.length == 1) {
              // Neighborhood
              var neighborhoods = mozAdminDict[provinceNumbered][district][cityOrVillageAdministrativePost][location];

              // var neighborhood = cfl2Str(neighborhoods, "Bairro", neighborhoods[0])

              var { siteItemSelected: neighborhood } = getProjectSiteItemsWithShortcuts(neighborhoods, `Bairro`);
            } else {
              var isValidUseThisSiteForProjectStr = spaceLib.getIsValidUseThisSiteForProjectStr(locationInfoItems);

              if (isValidUseThisSiteForProjectStr) {
                // var province = provinceNumbered.split(". ")[1]
                // var district = districtInfoItems[0]
                // var cityOrVillageAdministrativePost = cityOrVillageAdministrativePostInfoItems[0]
                //var neighborhood = undefined
                //var projectSite = cityOrVillageAdministrativePost.replace("*", "") + ", " + district.replace("*", "") + ", " + province
              }
            }
          }

          var province = provinceNumbered.split('. ')[1];

          var projectSiteItemsCollection = [neighborhood, location, cityOrVillageAdministrativePost, district, province];

          var projectSiteItemsCollectionFiltered = projectSiteItemsCollection.filter(item => item != undefined);

          var projectSiteItems = [];

          for (var i = 0; i < projectSiteItemsCollectionFiltered.length; i++) {
            var item = projectSiteItemsCollectionFiltered[i];
            var item = item.replace('*', '');

            if (i == 0) {
              projectSiteItems.push(item);
            } else {
              if (!projectSiteItems[projectSiteItems.length - 1].includes(item)) {
                projectSiteItems.push(item);
              }
            }
          }

          var projectSite = projectSiteItems.join(', ');
        } else {
          var isValidUseThisSiteForProjectStr = spaceLib.getIsValidUseThisSiteForProjectStr(
            cityOrVillageAdministrativePostInfoItems
          );

          if (isValidUseThisSiteForProjectStr) {
            var province = provinceNumbered.split('. ')[1];
            var district = districtInfoItems[0];
            // var cityOrVillageAdministrativePost = cityOrVillageAdministrativePostInfoItems[0]
            var cityOrVillageAdministrativePost = cityOrVillageAdministrativePostInfoItems
              .slice(0, cityOrVillageAdministrativePostInfoItems.length - 1)
              .join(' + ');

            var projectSite =
              cityOrVillageAdministrativePost.replace('*', '') + ', ' + district.replace('*', '') + ', ' + province;
          }
        }
      }
    } else {
      var isValidUseThisSiteForProjectStr = spaceLib.getIsValidUseThisSiteForProjectStr(districtInfoItems);

      if (isValidUseThisSiteForProjectStr) {
        var province = provinceNumbered.split('. ')[1];
        var district = districtInfoItems
          .slice(0, districtInfoItems.length - 1)
          // For "MONTEPUEZ + NAMUNO" in "Y _ XCPCAF240202 _ DPDOPHRHC DELGADO _ 20 FUROS ABASTECIMENTO ÁGUA DISTRITOS NAMUNO (11) E MONTEPUEZ (9) 1P _ MONTEPUEZ + NAMUNO - CABO DELGADO _ XCPCAF240202"
          .join(' + ');
        var cityOrVillageAdministrativePost = ''; // Prevent Error

        var projectSite = district.replace('*', '') + ', ' + province;
      }
    }
  } else {
    // Validade de "useThisSiteForProjectStr" testdada antes desta Função
    var projectSite = provinceInfoItems[0].split('. ')[1]; // Only province
    var province = projectSite;
  }

  if (originType == 'Ajuste Directo (DW)' || provinceInfoItems.length > 1) {
    var propLocal = province;
  } else {
    var propLocalOptions = [province, district.replace('*', ''), cityOrVillageAdministrativePost.replace('*', '')];

    //if (province != "Maputo") {
    if (province != 'Maputo (Cidade)') {
      var propLocalOptions = propLocalOptions.concat('---------------', 'Maputo');
    }

    var propLocal = cfl2Str(
      propLocalOptions.filter(item => item != ''),
      'Local que vem junto com data para Propostas.',
      province
    );
  }

  var siteInfoForMinistries = `${province} / ${district} / ${cityOrVillageAdministrativePost}`;

  // return `${projectSite} | ${propLocal} | ${siteInfoForMinistries}`

  return {
    isValidUseThisSiteForProjectStr,
    projectSite,
    propLocal,
    siteInfoForMinistries,
  };
}

