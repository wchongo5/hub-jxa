function areaFromCoordinates(points) {
  var pointA4Area = [];
  var areaBaseTotal = 0;
  var areaTotal = 0;

  // 🔴🔴🔴 BASE FROM SWIFT
  // 🔴🔴🔴 Note that area for 3 points uses 4 points because first one is used two times (is the first and is the last)

  for (var i = 0; i < points.length; i++) {
    let point = points[i];

    if (i > 0) {
      let utmCoordinatePointA = pointA4Area;
      let utmCoordinatePointB = point;

      areaBaseTotal +=
        Number(utmCoordinatePointA[1]) * Number(utmCoordinatePointB[0]) -
        Number(utmCoordinatePointB[1]) * Number(utmCoordinatePointA[0]);
    }

    pointA4Area = point;

    if (i == points.length - 1) {
      areaTotal = Math.abs(areaBaseTotal / 2);
    }
  }

  return areaTotal; // Área em m2
}

