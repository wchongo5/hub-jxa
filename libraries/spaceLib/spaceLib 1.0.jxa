function getBoundaryCoordinates(terrainVertixCoordinates, coordinatesType, what2Return) {
  var topLeftCoord = { latitude: -90, longitude: 180 };
  var bottomRightCoord = { latitude: 90, longitude: -180 };

  for (var i = 0; i < terrainVertixCoordinates.length; i++) {
    var coordinate = terrainVertixCoordinates[i];

    topLeftCoord.longitude = Math.min(topLeftCoord.longitude, coordinate[1]);
    topLeftCoord.latitude = Math.max(topLeftCoord.latitude, coordinate[0]);
    bottomRightCoord.longitude = Math.max(bottomRightCoord.longitude, coordinate[1]);
    bottomRightCoord.latitude = Math.min(bottomRightCoord.latitude, coordinate[0]);
  }

  // -26.011067563, 32.42010316, -26.011667901, 32.420673644
  //return [[topLeftCoord.latitude,topLeftCoord.longitude], [bottomRightCoord.latitude, bottomRightCoord.longitude]]

  var topRightCoord = { latitude: topLeftCoord.latitude, longitude: bottomRightCoord.longitude };

  var bottomLeftCoord = { latitude: bottomRightCoord.latitude, longitude: topLeftCoord.longitude };

  // return {
  // 	topLeftCoord: topLeftCoord,
  // 	topRightCoord: topRightCoord,
  // 	bottomLeftCoord: bottomLeftCoord,
  // 	bottomRightCoord: bottomRightCoord,
  // }

  if (coordinatesType == 'utm') {
    // "utm" or "decimal"
    var topLeftCoord = utmLib.fromLatLon(topLeftCoord.latitude, topLeftCoord.longitude, 36);
    var bottomLeftCoord = utmLib.fromLatLon(bottomLeftCoord.latitude, bottomLeftCoord.longitude, 36);

    var topRightCoord = utmLib.fromLatLon(topRightCoord.latitude, topRightCoord.longitude, 36);
    var bottomRightCoord = utmLib.fromLatLon(bottomRightCoord.latitude, bottomRightCoord.longitude, 36);
  } // else is "decimal" already set as default

  var topLeftCoordLat = topLeftCoord.latitude;
  var topLeftCoordLon = topLeftCoord.longitude;
  var bottonLeftCoordLat = bottomLeftCoord.latitude;
  var bottonLeftCoordLon = bottomLeftCoord.longitude;

  var topRightCoordLat = topRightCoord.latitude;
  var topRightCoordLon = topRightCoord.longitude;
  var bottonRightCoordLat = bottomRightCoord.latitude;
  var bottonRightCoordLon = bottomRightCoord.longitude;

  if (what2Return == 'dictionary') {
    return {
      topLeftCoordLat: topLeftCoordLat,
      topLeftCoordLon: topLeftCoordLon,
      bottonLeftCoordLat: bottonLeftCoordLat,
      bottonLeftCoordLon: bottonLeftCoordLon,
      topRightCoordLat: topRightCoordLat,
      topRightCoordLon: topRightCoordLon,
      bottonRightCoordLat: bottonRightCoordLat,
      bottonRightCoordLon: bottonRightCoordLon,
    };
  } else if (what2Return == 'arrayOfCoordinates') {
    return [
      [topLeftCoordLat, topLeftCoordLon],
      [topRightCoordLat, topRightCoordLon],
      [bottonRightCoordLat, bottonRightCoordLon],
      [bottonLeftCoordLat, bottonLeftCoordLon],
    ];
  }
}

// ---------------
function getDistanceFromLatLonInMeters(lat1, lon1, lat2, lon2) {
  var R = 6371; // Radius of the earth in km
  var dLat = deg2rad(lat2 - lat1); // deg2rad below
  var dLon = deg2rad(lon2 - lon1);
  var a =
    Math.sin(dLat / 2) * Math.sin(dLat / 2) +
    Math.cos(deg2rad(lat1)) * Math.cos(deg2rad(lat2)) * Math.sin(dLon / 2) * Math.sin(dLon / 2);
  var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  var d = R * c; // Distance in km
  //return d;
  // 1.003270646 coeficiente XD5
  // Edição 1.0015 (este coeficiente acertou duas medidas no Terreno Niquisse) e as outras duas com diferença de 14 cm
  return d * 1000 * 1.0015; // Distance in meters
}
// ---------------

function deg2rad(deg) {
  return deg * (Math.PI / 180);
}

