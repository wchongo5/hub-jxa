function getProvinceInfo(provincesToExclude, provinceD_Filter) {
  const provincesNumbered = getProvinces(provincesToExclude);
  const provinceD = provincesNumbered.find(province => province.includes(provinceD_Filter));

  const provinceNumbered = cflLib.cfl2Str(provincesNumbered, 'Província', provinceD);

  const provinceItems = provinceNumbered.split('. ');
  const provinceNumber = provinceItems[0];
  const provinceNumberPadded = numberLib.addZero(provinceNumber);
  const provinceName = provinceItems[1];

  return {
    provinceNumbered,
    provinceNumber,
    provinceNumberPadded,
    provinceName,
  };
}

function getProvinces(provincesToExclude, isNumbered = true) {
  const provinces = [
    'Niassa',
    'Cabo Delgado',
    'Nampula',
    'Zambézia',
    'Tete',
    'Manica',
    'Sofala',
    'Inhambane',
    'Gaza',
    'Maputo',
    'Maputo (Cidade)',
  ];

  let provincesProcessed = [];

  provincesProcessed = provinces.filter(province => {
    return provincesToExclude.every(filter => province != filter);
  });

  if (isNumbered) {
    provincesProcessed = provincesProcessed.map((province, index) => `${index + 1}. ${province}`);
  }

  return provincesProcessed;
}

function getProvinceInfoByPathObjV2(destinyFolder) {
  // "01 NIASSA", "02 CABO DELGADO"

  const provinces = getProvinces(['']);
  // var useThisSiteForProjectStr = getUseThisSiteForProjectStr();

  var provincesWithCodesAndUpper = provinces.map(
    province => numberLib.addZero(Number(province.split('. ')[0])) + ' ' + province.split('. ')[1].toUpperCase()
  );

  var folderName = destinyFolder.name();

  if (provincesWithCodesAndUpper.includes(folderName)) {
    var folderNameItems = folderName.split(' ');
    let provinceWithNum = documentLib.capitalizeText(
      Number(folderNameItems[0]) + '. ' + folderNameItems.slice(1).join(' '),
      'NoExclusions'
    );

    // return documentLib.capitalizeText(provinceWithNum, "NoExclusions")
    // .replace("cidade", "Cidade") para Maputo (Cidade)

    provinceInfo = provinceWithNum.replace('cidade', 'Cidade');

    return {
      provinceInfo,
    };
  } else {
    /*
    var provinceInfo = cflLib.cfl(
      provinces.concat('---------------', useThisSiteForProjectStr),
      'Província',
      '11. Maputo (Cidade)',
      'm'
    );

    if (provinceInfo.length == 1) {
      return provinceInfo[0];
    } else {
      if (getIsValidUseThisSiteForProjectStr(provinceInfo)) {
        return provinceInfo.join(' | ');
      }
    }
      */

    return {
      provinceInfo: null,
    };
  }
}

function getProvinceInfoByPathObj(destinyFolder) {
  // "01 NIASSA", "02 CABO DELGADO"

  const provinces = getProvinces(['']);
  // var useThisSiteForProjectStr = getUseThisSiteForProjectStr();

  var provincesWithCodesAndUpper = provinces.map(
    province => numberLib.addZero(Number(province.split('. ')[0])) + ' ' + province.split('. ')[1].toUpperCase()
  );

  var folderName = destinyFolder.name();

  if (provincesWithCodesAndUpper.includes(folderName)) {
    var folderNameItems = folderName.split(' ');
    var provinceWithNum = documentLib.capitalizeText(
      Number(folderNameItems[0]) + '. ' + folderNameItems.slice(1).join(' '),
      'NoExclusions'
    );

    // return documentLib.capitalizeText(provinceWithNum, "NoExclusions")
    // .replace("cidade", "Cidade") para Maputo (Cidade)
    return provinceWithNum.replace('cidade', 'Cidade');
  } else {
    var provinceInfo = cflLib.cfl(
      provinces.concat('---------------', useThisSiteForProjectStr),
      'Província',
      '11. Maputo (Cidade)',
      'm'
    );

    if (provinceInfo.length == 1) {
      return provinceInfo[0];
    } else {
      if (getIsValidUseThisSiteForProjectStr(provinceInfo)) {
        return provinceInfo.join(' | ');
      }
    }
  }
}

