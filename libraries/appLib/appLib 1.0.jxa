  // Before Ventura

  // // Click PDF
  // appControllerP.windows[0].sheets[0].splitterGroups[0].menuButtons["PDF"].click()
  // delay(d0p3)

  // appControllerP.windows[0].sheets[0].splitterGroups[0].menuButtons["PDF"].menus["PDF"].menuItems["Save as PDF"].click() // Click PDF

  // Click PDF directly in Ventura
  appControllerP.windows[0].sheets[0].splitterGroups[0].groups[1].buttons[0].click();
  delay(d3); // NEW was d2 in saveAsPDF after <printSaveAsPDF>
}

function saveLogAutoProcess(startTime, endTime, processedFilePathStr, autoOrManualRun) {
  const timeElapsed_ = timeElapsed(startTime, endTime);

  const { dateY4M2D2__H2M2S2: start_dateY4M2D2__H2M2S2 } = formatDateV3(startTime).formats;

  const { yearY4M2, dateY4M2D2__H2M2S2: end_dateY4M2D2__H2M2S2 } = formatDateV3(endTime).formats;

  const txtToLog = `${start_dateY4M2D2__H2M2S2} - ${end_dateY4M2D2__H2M2S2} - ${timeElapsed_} - ${autoOrManualRun}`;

  const processedFilePathStrItems = processedFilePathStr.split('/');
  const fileName = processedFilePathStrItems.pop().split('.')[0];

  const filePathStr = processedFilePathStrItems.join('/') + `/XX5 - ${yearY4M2} - Log - ${fileName}.txt`;

  if (finderApp.exists(Path(filePathStr))) {
    const loggedFileText = objCLib.readFile(filePathStr);
    const nextLogNumber = loggedFileText.split('\n').length;

    objCLib.appendToFile(filePathStr, `${nextLogNumber + 1} - ${txtToLog}`, (revealFile = false));
  } else {
    objCLib.writeToFile(filePathStr, `1 - ${txtToLog}`, (revealFile = false));
  }
}

function saveAsPDF(pathStr, fileName) {
  var frontmostAppName = seApp.applicationProcesses.where({ frontmost: true }).name()[0];

  printSaveAsPDF(frontmostAppName);
  // delay(d2)
  saApp.setTheClipboardTo(fileName);
  delay(d0p3);
  //seApp.keystroke("v", { using: "command down" })
  paste();
  delay(d0p3);

  goToFolderCopyPaste(pathStr);
  delay(d3);

  finderApp.reveal(Path(pathStr + '/' + fileName + '.pdf')).extensionHidden = true;
  delay(d0p3);
}

function saveDoc(docObj, destinyPathStr, fileDatetimeAndVersion, fileName, fileExt, deleteExistingFile = false, datePosition) {
  let finalFileName = '';

  if (datePosition == 'dateAtStart') {
    finalFileName = `${fileDatetimeAndVersion} ${fileName}.${fileExt}`;
  } else if (datePosition == 'dateAtEnd') {
    finalFileName = `${fileName} ${ND} ${fileDatetimeAndVersion}.${fileExt}`;
  }

  if (deleteExistingFile) {
    var filePathsStrs = getPathStrsFromPathStr(destinyPathStr, 'files');

    if (filePathsStrs.length > 0) {
      var fileNames = getItemNamesFromPathStrs(filePathsStrs, ['']);

      // var fileNameToDelete = fileNames.find(fileNameExisting => documentLib.doesStr1IncludeStr2(fileNameExisting, fileName))
      var fileNameToDelete = documentLib.deletePreviousFile(fileNames, fileName);

      if (fileNameToDelete) {
        var filePathStrToDelete = `${destinyPathStr}/${fileNameToDelete}`;
        deleteFinderItems([filePathStrToDelete]);
      }
    }
  }

  // Replace all "/" with ":", what is expected of macOS for "/" in a file or folder name
  // finalFileName = finalFileName.replace(/\//g, ':');
  finalFileName = adjustPathSeparator(finalFileName);

  const filePath = `${destinyPathStr}/${finalFileName}`;

  // const { totalInfo, componentExcessInfo } =
  analyzePath(filePath);

  const filePathObj = Path(filePath);

  docObj.save({ in: filePathObj }); // SAVE
  delay(d1); // Era d0p3

  finderApp.reveal(Path(filePath)).extensionHidden = true;
  // delay(d0p3)

  return filePath;
}

/*
function sortArray(array) {
  // ----- ALPHANUMERICAL STRINGS
  var collator = new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' });
  return array.sort(collator.compare);
}
*/

function sortArray(arr) {
  // ----- ALPHANUMERICAL STRINGS
  return [...arr].sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
}

