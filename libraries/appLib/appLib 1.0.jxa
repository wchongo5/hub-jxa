function publisherUpdateDataMerge(publisherAppControllerAp) {

	doMenu(affinityPublisherName, "Window", "Data Merge Manager…")
	delay(d1p5)

	publisherAppControllerAp.windows.byName("Data Merge").scrollAreas[1].buttons.byName("Update").click()
	delay(d1p5)

	publisherAppControllerAp.windows.byName("Data Merge").buttons[4].click() // Close Data Merge
	delay(d5) // Era d1p5
}
*/

function publisherUpdateDataMerge(publisherAppControllerAp, affinityPublisherApp, index) {
  const pageNumber = index + 1;

  if (pageNumber > 1) {
    affinityPublisherApp.activate();
    delay(d1); // To open DataMerge window while Publisher visible
  }

  doMenu(affinityPublisherName, 'Window', 'Data Merge Manager…');
  delay(d1p5);

  publisherAppControllerAp.windows.byName('Data Merge').scrollAreas[1].buttons.byName('Update').click();
  // delay(d1p5)
  delay(10);
  delay(10);
  // delay(d0p3)

  if (pageNumber > 1) {
    tab(1);
    copyPaste(pageNumber.toString());
  }

  // delay(d1p5)
  delay(d0p3);

  publisherAppControllerAp.windows.byName('Data Merge').buttons[4].click(); // Close Data Merge
  delay(d0p3); // Era d5, d1p5
}

// --------------------------------------- Calendar

function calendarAddIcsFile(iscFilePathStr, calendarNameIcs) {
  currentApp.doShellScript(`open -a Calendar "${iscFilePathStr}"`);

  const calendarApp = Application('Calendar');

  calendarApp.activate();

  var seApp = Application('System Events');
  var calendarAppControllerP = seApp.processes['Calendar'];
  delay(1);
  calendarAppControllerP.windows[0].popUpButtons[0].click();
  delay(1);
  calendarAppControllerP.windows[0].popUpButtons[0].menus[0].menuItems[calendarNameIcs].click();

  enter();
  delay(1);
  // enter();
  scape();
}

function calendarExtractDatesFromIcs(filePath) {
  const content = currentApp.doShellScript(`cat "${filePath}"`);
  const lines = content.split(/\r\n|\n|\r/);

  let startDate = null;
  let endDate = null;

  lines.forEach(line => {
    line = line.trim(); // Clean up the line from any extra whitespace

    if (line.startsWith('DTSTART')) {
      // "startDate": "20240814T100000"
      startDate = line.split(':')[1].trim();

      // "startDate": "2024-08-14T10:00:00"
      startDate = convertBasicDT2ISO(startDate.replace('T', '-')).dateISO8601;
    } else if (line.startsWith('DTEND')) {
      // "endDate": "20240814T113000"
      endDate = line.split(':')[1].trim();

      // "endDate": "2024-08-14T11:30:00"
      endDate = convertBasicDT2ISO(endDate.replace('T', '-')).dateISO8601;
    }
  });

  return { startDate, endDate };
}
