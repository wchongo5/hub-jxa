function publisherPathDialogFinder(docName, pathStr) {
  if (docName != '') {
    // seApp.keyCode([48, 48]);

    /* // DEIXOU DE SER NECESSÁRIO 20220710
		if (operation == "imagesPreration") {
			seApp.keyCode(48);
			delay(d0p3)
			seApp.keyCode(48);
		}
		*/

    delay(d0p3);
    saApp.setTheClipboardTo(docName);
    delay(d1);
    seApp.keystroke('v', { using: 'command down' });
    delay(d0p3);
  }

  saApp.setTheClipboardTo(pathStr);

  delay(d1);
  seApp.keystroke('g', { using: ['shift down', 'command down'] });

  delay(d1); // Era d0p3
  seApp.keystroke('v', { using: 'command down' });
  delay(d1); // Era d0p3
  seApp.keyCode(76); // Go
  delay(d1); // Era d0p3
  seApp.keyCode(76); // Go
}

