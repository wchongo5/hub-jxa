function cloudClipMenu() {
  delay(d0p1);
  seApp.keystroke('V', { using: ['control down', 'option down', 'command down'] });
  delay(d0p1);
}

function generateTextOfObjectKeysAndValues(object) {
  return Object.entries(object)
    .filter(([_, value]) => value != null) // Remove null and undefined
    .map(([key, value]) => `• ${key}: ${value}`)
    .join('\n');
}

function getUniqueItems(list) {
  var uniqueItems = [];

  for (var i = 0; i < list.length; i++) {
    var uniqueItem = list[i];

    if (!uniqueItems.includes(uniqueItem)) {
      uniqueItems.push(uniqueItem);
    }
  }

  return uniqueItems;
}

function itemsAreEqual(items) {
  var itemsCollection = [];
  for (var i = 0; i < items.length; i++) {
    var item = items[i];

    if (!itemsCollection.includes(item)) {
      itemsCollection.push(item);
    }
  }

  if (itemsCollection.length > 1) {
    return false;
  } else {
    return true;
  }
}

