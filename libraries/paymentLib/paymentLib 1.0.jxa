function bimGetRechargeDetails(pdfString) {
  // Define regular expressions for each field
  const operatorRegex = /Operadora\s+(\w+)/i;
  const amountRegex = /Montante\s+([\d.,]+)\s+MZN/i;
  const rechargeCodeRegex = /Código de recarga\s+(\d+)/i;

  // Extract Operator
  const operatorMatch = pdfString.match(operatorRegex);
  const operator = operatorMatch ? operatorMatch[1] : null;

  // Extract Amount
  const amountMatch = pdfString.match(amountRegex);
  let amount = null;
  if (amountMatch) {
    // Replace comma with dot for decimal conversion and parse as float
    amount = parseFloat(amountMatch[1].replace(',', '.'));
  }

  // Extract Recharge Code
  const rechargeCodeMatch = pdfString.match(rechargeCodeRegex);
  const rechargeCode = rechargeCodeMatch ? rechargeCodeMatch[1] : null;

  // Return the extracted data as an object
  return {
    operator,
    amount,
    rechargeCode,
  };
}

