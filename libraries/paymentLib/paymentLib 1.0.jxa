function getInssGuideInfo(pdfGuidePage1Text) {
  // const inssGuideNumber = pdfGuidePage1Text.match(/(\b\d{8}\b)/)[0];
  const inssGuideNumber = pdfGuidePage1Text.match(/(\b\d{8}\d*\b)/)[0];
  const inssMmSlashYyyy = pdfGuidePage1Text.match(/(?<!\d\/)\b\d{2}\/\d{4}\b(?!\/\d)/)[0];
  const amount = getAmount(pdfGuidePage1Text, 0);
  const amountFormatted = numberLib.formatNumber(amount, 2, 2);

  return {
    inssGuideNumber,
    inssMmSlashYyyy,
    amount,
    amountFormatted,
  };
}

function getEdmCredelecInfo(pdfPage1Text) {
  const amountKwh = pdfPage1Text.match(/(\d[0-9.]*)\sKwh/)[1];
  const amountKwhFormatted = numberLib.formatNumber(amountKwh, 2, 2);
  const amountKwhFormattedWithUnit = amountKwhFormatted + ` kWh`;
  const amount = getAmount(pdfPage1Text, 0);
  const amountFormatted = numberLib.formatNumber(amount, 2, 2);

  const credelecRechargeCode = pdfPage1Text.match(/\b\d{4} \d{4} \d{4} \d{4} \d{4}\b/)[0];
  const credelecNumber = pdfPage1Text.match(/\b\d{11}\b/)[0];

  return {
    credelecRechargeCode,
    credelecNumber,
    amountKwhFormatted,
    amountKwhFormattedWithUnit,
    amount,
    amountFormatted,
  };
}

// --------------------------------------- tvcaboPayment

function getTvcaboStandardAmount(servicePayment, includeThousandsSeparator) {
  var standardAmounts = { Recarga1000: '1,000.00', Recarga2500: '2,500.00', Recarga4500: '4,500.00', Subscrição: '6,315.00' };
  var standardAmount = standardAmounts[servicePayment];

  if (!includeThousandsSeparator) {
    var standardAmount = standardAmount.replace(/,/g, '');
  }

  return standardAmount;
}

function tvcaboPayment(unitPriceD) {
  var tvcaboSubsAmount = numberLib.formatNumber(getTvcaboStandardAmount('Subscrição'), 2, 2);

  var amountAsNumber = Number(unitPriceD.replace(/,/g, ''));
  var amountFormatted = numberLib.formatNumber(amountAsNumber, 2, 2);

  if (
    amountFormatted == getTvcaboStandardAmount('Recarga1000', true) ||
    amountFormatted == getTvcaboStandardAmount('Recarga2500', true) ||
    amountFormatted == getTvcaboStandardAmount('Recarga4500', true)
  ) {
    var tvcaboPaymentTrack = 'internetRecharge';
    var tvcaboPaymentType = 'Recarga';

    var tvRechargeDictionary = { '1,000.00': '15 GB', '2,500.00': '50 GB', '4,500.00': '100 GB' };

    var tvcaboPaymentType = tvcaboPaymentType + ' ' + tvRechargeDictionary[amountFormatted];
  } else {
    var tvcaboPaymentType = 'Internet + TV';

    if (amountFormatted == tvcaboSubsAmount) {
      var tvcaboPaymentTrack = 'subscriptionOneMonth';
    } else {
      var tvcaboPaymentTrack = cflLib.cfl2Str(
        ['subscriptionOneMonth', 'subscriptionMoreThanOneMonth'],
        'Opção',
        'subscriptionOneMonth'
      );
    }
  }

  return tvcaboPaymentType + ' | ' + tvcaboPaymentTrack;
}
