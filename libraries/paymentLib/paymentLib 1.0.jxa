function splitDebitCredit(desc) {
  // TO SPLIT: "SALARIOXT04A202504 + TANCYAMAMA202504 + SALARIOWA05E202504SALARIOXT04A202504 + TANCYAMAMA202504 + SALARIOWA05E202504"

  // TO: "SALARIOXT04A202504 + TANCYAMAMA202504 + SALARIOWA05E202504" "SALARIOXT04A202504 + TANCYAMAMA202504 + SALARIOWA05E202504"

  // find every index where the YYYYMM appears
  const regex = /\d{6}/g;
  const matches = Array.from(desc.matchAll(regex), m => m.index);

  // if we have an even number of matches, assume two equal halves
  if (matches.length >= 2 && matches.length % 2 === 0) {
    const groupSize = matches.length / 2;
    // split right after the last match of the first group
    const splitAt = matches[groupSize - 1] + 6;

    const debit = desc.slice(0, splitAt).trim();
    let credit = desc.slice(splitAt).trim();
    // remove any leading “+ ” from the credit side
    credit = credit.replace(/^(\+)\s*/, '');

    return [debit, credit];
  }

  // fallback: no split
  return [desc.trim(), ''];
}

function bimpdfGetDescrs(pdfText) {
  const patternDebit =
    /Descrição Conta Débito\s*([\s\S]*?)\s*(?=(Data da Transacção|Agendamento Pontual|Descrição Conta Crédito|Comissão|Comissões|$))/;
  const patternCredit =
    // /Descrição Conta Crédito\s*([\s\S]*?)\s*(?=(Data da Transacção|Agendamento Pontual|Descrição Conta Débito|Comissão|Comissões|$))/;
    /Descrição Conta Crédito\s*([\s\S]*?)\s*(?=(Data da Transacção|Agendamento Pontual|Descrição Conta Débito|Comissão|Comissões|Montante|$))/;

  /* 
    Explanation:
    "Descrição Conta Débito or Descrição Conta Crédito": Matches the exact label.
    "\s*": Matches any whitespace characters (including newlines).
    "([\s\S]*?)": Non-greedy capture of any character (including newlines), representing the value to extract.
    "\s*": Matches any trailing whitespace after the value.
    "(?=...)": Positive lookahead to stop matching when the next label or the end of the string is encountered.
  */

  const debitMatch = pdfText.match(patternDebit);
  const creditMatch = pdfText.match(patternCredit);

  // let debitDescription = debitMatch ? debitMatch[1].trim().split('\n').join('') : null;

  let debitDescription = debitMatch
    ? debitMatch[1]
        .trim()
        .split('\n')
        .map((item, i, array) => {
          if (i > 0 && array[i - 1].endsWith('+')) {
            /* 
            // debitMatch[1]:
            SALARIOXT04A202504 + TANCYAMAMA202504 +
            SALARIOWA05E202504
            SALARIOXT04A202504 + TANCYAMAMA202504 +
            SALARIOWA05E202504
            
            // Direct join(''): error does not consider space after +
            SALARIOXT04A202504 + TANCYAMAMA202504 +SALARIOWA05E202504SALARIOXT04A202504 + TANCYAMAMA202504 +SALARIOWA05E202504
            */

            // This adds a space after the '+' sign
            // Before: "SALARIOXT04A202504 + TANCYAMAMA202504 +SALARIOWA05E202504SALARIOXT04A202504 + TANCYAMAMA202504 +SALARIOWA05E202504 _ 202504"
            // After: "SALARIOXT04A202504 + TANCYAMAMA202504 + SALARIOWA05E202504SALARIOXT04A202504 + TANCYAMAMA202504 + SALARIOWA05E202504"
            return ` ${item}`;
          }

          return item;
        })
        .join('')
    : null;

  // let creditDescription = creditMatch ? creditMatch[1].trim().split('\n').join('') : null;
  let creditDescription = creditMatch
    ? creditMatch[1]
        .trim()
        .split('\n')
        // Not verified that is necessary, copied from debitDescription
        .map((item, i, array) => {
          if (i > 0 && array[i - 1].endsWith('+')) {
            return ` ${item}`;
          }

          return item;
        })
        .join('')
    : null;

  const errorMessages = [];

  if (!debitDescription) {
    errorMessages.push('Descrição de débito não encontrada.');
  }

  // Add this error if debitDescription not availalble because TRANSFERS MINHAS contas não tem creditDescription
  if (!creditDescription && !debitDescription) {
    errorMessages.push('Descrição de crédito não encontrada.');
  }

  if (
    debitDescription &&
    debitDescription.includes('SALARIOXT04') &&
    (debitDescription.includes('SALARIOWA') || debitDescription.includes('TANCYAMAMA'))
  ) {
    [debitDescription, creditDescription] = splitDebitCredit(debitDescription);
  }

  if (errorMessages.length > 0) {
    // TEMPXD5 ALERTS

    const errorMessagesString = errorMessages.map(e => `• ${e}`).join('\n');

    if (!debitDescription && creditDescription) {
      /*
      Fix situation, debitDescription and creditDescription in creditDescription. When from BIM to MazaBanco:
      {
        "debitDescription": "",
        "creditDescription": "SALARIORW1C01M202409 + PASTORRW1P02N202409SALARIORW1C01M202409 + PASTORRW1P02N202409"
      }
      */

      const delimiter = creditDescription.split(' ')[0];
      const parts = splitAtOccurrence(creditDescription, delimiter, 2);

      debitDescription = parts[0];
      creditDescription = parts[1];
    } else if (pdfText.includes('Descrição Conta Débito Descrição Conta Crédito')) {
      // BIM to BANCO UNICO
      // const patternDebitAndCredit = /MZN\s*([\s\S]*?)\s*(?=(Data|$))/;
      const blockRegex = /Comissão \d+,\d{2} MZN([\s\S]*?)Data \d{2}-\d{2}-\d{4}/;

      const match = pdfText.match(blockRegex);

      if (match) {
        const debitAndCreditString = match[1].replace(/\n/g, '');
        const delimiter = debitAndCreditString.split(' ')[0];
        const parts = splitAtOccurrence(debitAndCreditString, delimiter, 2);

        debitDescription = parts[0];
        creditDescription = parts[1];
      } else {
        alert(errorMessagesString);
      }
    } else if (pdfText.includes('Descrição Conta Crédito Descrição Conta Débito Data')) {
      // BIM to BIM Cunhada Adelia

      /* 
      Descrição Conta Crédito Descrição Conta Débito Data da Transacção 08-10-2024
      Agendamento Pontual
      85729668 - ADELIA SALOMAO COME - MZN
      Contribuição Casamento Tia Elisa - Cunhada Adelia
      Contribuição Casamento Tia Elisa - Cunhada Adelia
      Comissões e respectivos impostos de acordo com o preçário e lei em vigor.
      */
      const blockRegex = /Agendamento Pontual\s+.*? - MZN\s+([\s\S]*?)Comissões e respectivos impostos/;

      const match = pdfText.match(blockRegex);

      if (match) {
        const debitAndCreditString = match[1].replace(/\n/g, '');
        const delimiter = debitAndCreditString.split(' ')[0];
        const parts = splitAtOccurrence(debitAndCreditString, delimiter, 2);

        debitDescription = parts[0];
        creditDescription = parts[1];
      } else {
        // BIM to BIM SALARIOS SALARIOXT04A202412 + SALARIOWA05E202412
        /* 
        Descrição Conta Crédito Descrição Conta Débito Data da Transacção 18-12-2024
        Agendamento Pontual
        SALARIOXT04A202412 + SALARIOWA05E202412
        SALARIOXT04A202412 + SALARIOWA05E202412
        Comissões e respectivos impostos de acordo com o preçário e lei em vigor.
        */
        const blockRegex = /Agendamento Pontual\s+([\s\S]*?)Comissões e respectivos impostos/;

        const match = pdfText.match(blockRegex);

        if (match) {
          const parts = match[1].split('\n');

          debitDescription = parts[0];
          creditDescription = parts[1];
        } else {
          alert(errorMessagesString);
        }
      }
    } else {
      alert(errorMessagesString);
    }
  }

  return {
    debitDescription,
    creditDescription,
  };
}

function bimpdfGetCompanyInfo(pdfText) {
  let companyIdentifier = null;
  let companyName = null;

  const isXdimW = /WALTER ALEXANDRE MARIA CHONGO/.test(pdfText);
  const isXdimX = /X DIM ARQUITECTURA LDA/.test(pdfText);

  if (isXdimW) {
    companyIdentifier = 'W';
  }

  if (isXdimX) {
    companyIdentifier = 'X';
  }

  return {
    companyIdentifier,
  };
}

function getSupplierPaymentsInfoFromPDF(pdfText) {
  let subjectStr = '';

  // Não podia aplicar grouping pois o index ENZ Renda (\d{6}-\d{6}) é 1
  // E para ENZ Renda (\d{6}) é 2
  // Ver mais detalhes "•• RegEx - 00"
  const payPeriodDescription = pdfText.match(/ENZ RENDA\d{6}-\d{6}|ENZ RENDA\d{6}/)[0];
  const payPeriod = payPeriodDescription.split('ENZ RENDA')[1];

  if (payPeriodDescription.includes('ENZ RENDA')) {
    subjectStr = `RENDA ${payPeriod} ${ND} ENZ`;
  }

  return {
    payPeriod,
    subjectStr,
  };
}

function writeInssIrpsPayDate(tableNotes_vatAndOtherTaxes, irpsSheetName, yyyy___mm___dd, inssOrIrps) {
  for (var i = 2; i <= 13; i++) {
    var yyyyMm = tableNotes_vatAndOtherTaxes.cells['B' + i].value().toString();

    if (inssOrIrps == 'irps') {
      var letter = 'D';
    } else if (inssOrIrps == 'inss') {
      var letter = 'F';
    }

    if (yyyyMm == irpsSheetName.slice(4, 10)) {
      tableNotes_vatAndOtherTaxes.cells[letter + i].value = yyyy___mm___dd;
    }
  }
}

function getCustomerFromInvoiceNumberWithF(invoiceNumberWithF) {
  var pathStrs = finderLib.getPathStrsFromPathStr(taxPathStr, 'files');
  var itemNamesFromPathStrs = finderLib.getItemNamesFromPathStrs(pathStrs, ['']);
  var itemNameFound = itemNamesFromPathStrs.filter(itemName => itemName.includes(invoiceNumberWithF))[0];

  if (itemNameFound) {
    return itemNameFound.split(` ${ND} `)[3];
  } else {
    return alert(`Não encontrou factura com número "${invoiceNumberWithF}".`, ``);
  }
}

function getInvoiceNumbersWithF(text, what2return) {
  if (what2return == 'first') {
    return text.match(/f\d\d*/i)[0].toUpperCase();
  } else if (what2return == 'all') {
    return text
      .match(/f\d\d*/gi)
      .join('')
      .toUpperCase();
  }
}

function getReceiptNumberWithR(text) {
  return text.match(/r\d\d*/i)[0].toUpperCase();
}

function invoices(invoiceCs) {
  var pathStrs = finderLib.getPathStrsFromPathStr(taxPathStr, 'files');
  var fileNames = finderLib.getItemNamesFromPathStrs(pathStrs, ['']);

  var all1 = fileNames
    .filter(fileName => fileName.includes(`XD5 ${ND} F`) && !fileName.includes(' | R'))
    .map(item => {
      return item.replace(/\.(\w*)$/, '');
    });

  var all2 = processInvoicesNames(all1);

  var open1 = all1.filter(fileName => fileName.includes(`XD5 ${ND} F`) && fileName.includes('OPEN'));

  var open2 = processInvoicesNames(open1);

  if (invoiceCs == '') {
    var openByCs2 = [];
  } else {
    var allByCs1 = all1.filter(fileName => fileName.includes(`XD5 ${ND} F`) && fileName.includes(invoiceCs));

    var allByCs2 = processInvoicesNames(allByCs1);

    var openByCs1 = all1.filter(
      fileName => fileName.includes(`XD5 ${ND} F`) && fileName.includes('OPEN') && fileName.includes(invoiceCs)
    );

    var openByCs2 = processInvoicesNames(openByCs1);
  }

  return {
    all1,
    all2,
    allByCs1,
    allByCs2,
    open1,
    open2,
    openByCs1,
    openByCs2,
  };
}

function invoiceUpdate(invoicePaymentInfo) {
  var pathStrs = finderLib.getPathStrsFromPathStr(taxPathStr, 'files');
  var fileNames = finderLib.getItemNamesFromPathStrs(pathStrs, ['']);

  var fileNamesFiltered = fileNames.filter(fileName => fileName.includes(`XD5 ${ND} F`) && fileName.includes('OPEN'));

  var invoicePaymentInfoItems = invoicePaymentInfo.split(' | ');
  var invoiceNumberWithStr = invoicePaymentInfoItems[0];
  var invoicePayment = invoicePaymentInfoItems[1];

  var invoiceFileName = fileNamesFiltered.filter(
    fileName => fileName.includes(`XD5 ${ND} ${invoiceNumberWithStr}`) && !fileName.includes('|')
  )[0];

  var invoicePathAlias = seApp.aliases.byName(pathStr + '/' + invoiceFileName);

  var invoiceAmount = invoiceFileName.match(/[0-9,]*\.\d{2}/)[0];

  if (invoiceAmount == invoicePayment) {
    var invoicePaymentStatus = 'Full';
  } else {
    var invoicePaymentStatus = cflLib.cfl2Str(
      ['Full', 'Partial'],
      `${invoiceNumberWithStr} (${invoicePayment}) - Situação da Factura`,
      'Full'
    );
  }

  if (invoicePaymentStatus == 'Full') {
    invoicePathAlias.name = invoicePathAlias.name().replace(` ${ND} OPEN`, ' 🔴');
  } else if (invoicePaymentStatus == 'Partial') {
    invoicePathAlias.name = invoicePathAlias.name().replace(` ${ND} OPEN`, ` ${ND} OPEN 🔴`);
  }
}

function processInvoicesNames(invoicesNames) {
  var processedInvoicesNames = [];

  for (var i = 0; i < invoicesNames.length; i++) {
    var fileNamesFilteredItems = invoicesNames[i].split(` ${ND} `);

    processedInvoicesNames.push(i + 1 + '. ' + fileNamesFilteredItems[1].slice(1) + ' — ' + fileNamesFilteredItems[4]);
  }

  return processedInvoicesNames;
}

function paymentDateItemsFromPDF(pdfText) {
  return pdfText.match(/\d{2}-\d{2}-\d{4}/)[0].split('-');
}

