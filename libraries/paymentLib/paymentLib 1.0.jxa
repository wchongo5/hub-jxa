function getAmount(pdfText, indices2Return) {
  //var matches = pdfText.match(/[0-9.]*(,00)\sMZN/)

  // [0] é número da conta da X-DIM
  // var matches = pdfText.match(/\d[0-9,.]*\sMZN/g)

  var matches = pdfText
    .match(/\d[0-9,.]*(\sMZN|MZN|\sMT|MT)/g)
    // Exclude <"303233835\nMZN"> situattions
    .filter(item => item.split('\n').length == 1)
    .map(function (item) {
      var amount = item.split(/ MZN|MZN| MT|MT/)[0];

      var decimalSeparatorTypeID = amount[amount.length - 3];

      // if (decimalSeparatorTypeID == ".") {

      // } else

      if (decimalSeparatorTypeID == ',') {
        var amount = amount.replace(/\./g, '').replace(',', '.'); //.replace(" MZN", "")
      } // elese is "."

      return amount; //.replace(/ MZN|MZN| MT|MT/, "")
    });

  if (!isNaN(indices2Return)) {
    return matches[indices2Return];
  } else if (indices2Return == 'All') {
    return matches;
  }

  // return matches
  // // Exclude <"303233835\nMZN"> situattions
  // .filter(item => item.split("\n").length == 1)
  // .map(
  // 	function(item) {

  // 		var amount = item.split(/ MZN|MZN| MT|MT/)[0]

  // 		var decimalSeparatorTypeID = amount[amount.length - 3]

  // 		// if (decimalSeparatorTypeID == ".") {

  // 		// } else

  // 		if (decimalSeparatorTypeID == ",") {
  // 			var amount = amount.replace(/\./g, "").replace(",", ".") //.replace(" MZN", "")
  // 		} // elese is "."

  // 		return amount //.replace(/ MZN|MZN| MT|MT/, "")
  // 	}
  // )
  // return matches[1].replace(/\./g, "").replace(",", ".").replace(" MZN", "")
}

function amountFromFileName(fileName) {
  // fileName format
  // "TVCABO _ INTERNET + TV _ 202301 _ 20230116 _ 500.00 _ A (FR) 🟢 AJUSTE PARA INTERNET 8 MB ILIMITADA"

  try {
    return fileName.split(` ${ND} `)[4].match(/\d[0-9,.]*/)[0];
  } catch (error) {
    return null;
  }
}

