//function contractsDetails(company, action, p5DisciplinePathStr, disciplines, services, yyyy, whatReturn, typeOfInvoicingC1, numberOfYearsToRead) {

function contractsDetails(
  company,
  action,
  p5DisciplinePathStr,
  disciplines,
  services,
  yyyy,
  whatReturn,
  typeOfInvoicingC1,
  numberOfYearsToRead,
  filterInputStrs
) {
  var disciplinesStr = disciplines.toString();
  var servicesStr = services.toString();

  if (disciplinesStr === 'All') disciplines = getDisciplines(['Rebanho'], false);
  if (servicesStr === 'All') services = getServices([''], false);

  try {
    if (action.includes('ReadFolderName')) {
      if (filterInputStrs == undefined) {
        var filterInputStrs = dialog(`Filtros\n\n—\nAdicione "-3", <filtro-3> 3 são anos a ler`, ``);
      }

      if (filterInputStrs.includes('-')) {
        var filterInputStrs = filterInputStrs.replace(/" "/g, '');
        var filterInputStrsItems = filterInputStrs.split('-');
        var filterStrs = filterInputStrsItems[0];
        var numberOfYearsToRead = Number(filterInputStrsItems[1]);
      } else {
        var filterStrs = filterInputStrs;
      }
    }

    if (filterStrs === 'n') return 'NEW';
    if (filterStrs === 's') return 'SELECTINOLDPROJECTS';

    var xproj5xbuild5FoldersNames = [];
    var contractsInfo = [];

    for (const discipline of disciplines) {
      const disciplineUpperCase = discipline.toUpperCase();

      const p5DisciplinePathStrInCateg = p5DisciplinePathStr + disciplineUpperCase[0] + ' ' + disciplineUpperCase;

      for (const consultancyCateg of services) {
        if (consultancyCateg == 'Projecto') {
          const xproj5PathStr = p5DisciplinePathStrInCateg + '/P5' + disciplineUpperCase[0] + 'P PROJECTO';

          // years // -1 para a lista ter número de anos igual a numberOfYearsToRead
          const years = Array.from({ length: numberOfYearsToRead }, (_, i) => yyyy - (numberOfYearsToRead - 1 - i));

          for (const year of years) {
            const sdYear = 'P' + disciplineUpperCase[0] + year;

            const yearPathString = xproj5PathStr + '/' + sdYear;

            if (!finderApp.exists(Path(yearPathString))) continue;

            const provinces = seApp.folders.byName(yearPathString).folders.name();

            for (const province of provinces) {
              const provincePathString = xproj5PathStr + '/' + sdYear + '/' + province;

              if (!finderApp.exists(Path(provincePathString))) continue;

              // Projectos
              const xproj5Folders = seApp.folders.byName(provincePathString).folders;

              for (var k = 0; k < xproj5Folders.length; k++) {
                const folderName = xproj5Folders[k].name();
                const folderNameItems = folderName.split(` ${ND} `);
                const folderNameItemsL = folderNameItems.length;

                if (!(folderNameItems[0] == 'Y' && folderNameItemsL == 6)) continue;

                const customer4Folders = folderName.split(` ${ND} `)[2];

                const csAndCustomerAndObjItems = whatReturnCsAndCustomerAndObj(folderName, folderNameItems, whatReturn).split(
                  ' | '
                );

                const cs = csAndCustomerAndObjItems[0];

                if (action == 'ReadInvoiceInfoAndUpdateJSON') {
                  const xproj5ProjectPathStr = xproj5PathStr + '/' + sdYear + '/' + province + '/' + folderName;

                  const quoteOrInvoiceInfo = getQuoteOrInvoiceInfo(xproj5ProjectPathStr, cs, customer4Folders);

                  if (!quoteOrInvoiceInfo) continue;

                  contractsInfo.push(quoteOrInvoiceInfo);
                } else if (action == 'ReadFolderName') {
                  // var csAndCustomerAndObj = csAndCustomerAndObjItems[1];

                  if (isCs(cs)) {
                    xproj5xbuild5FoldersNames.push(csAndCustomerAndObjItems[1]);
                  }
                }
              }
            }
          }
        } else if (
          consultancyCateg == 'Assistência' ||
          consultancyCateg == 'Construção' ||
          consultancyCateg == 'Empreitada' ||
          consultancyCateg == 'Fiscalização'
        ) {
          var xo5PathStr =
            p5DisciplinePathStrInCateg +
            '/P5' +
            discipline[0].toUpperCase() +
            consultancyCateg[0] +
            ' ' +
            consultancyCateg.toUpperCase();

          if (!finderApp.exists(Path(xo5PathStr))) continue;

          var xo5Folders = seApp.folders.byName(xo5PathStr).folders;

          for (var k = 0; k < xo5Folders.length; k++) {
            /* 
            for (const folder of xo5Folders) { // Raised error in 20250411-203400
            const folderName = folder.name();
            */

            const folderName = xo5Folders[k].name();
            const folderNameItems = folderName.split(` ${ND} `);

            if (!(folderNameItems[0] === 'Y' && folderNameItems.length === 6)) continue;

            const customer4Folders = folderName.split(` ${ND} `)[2];

            const csAndCustomerAndObjItems = whatReturnCsAndCustomerAndObj(folderName, folderNameItems, whatReturn).split(' | ');

            const cs = csAndCustomerAndObjItems[0];

            if (action == 'ReadInvoiceInfoAndUpdateJSON') {
              const xo5PathStrWithFolderName = xo5PathStr + '/' + folderName;

              const quoteOrInvoiceInfo = getQuoteOrInvoiceInfo(xo5PathStrWithFolderName, cs, customer4Folders);

              if (!quoteOrInvoiceInfo) continue;

              contractsInfo.push(quoteOrInvoiceInfo);
            } else if (action == 'ReadFolderName') {
              // var csAndCustomerAndObj = csAndCustomerAndObjItems[1];

              if (isCs(cs)) {
                xproj5xbuild5FoldersNames.push(csAndCustomerAndObjItems[1]);
              }
            }
          }
        }
      }
    }

    if (action === 'ReadFolderName') {
      const filters = documentLib.ensureSpaceAfterCommaInStr(filterStrs).split(', ');

      // FILTERS BY XDIMW & XDIMX & BY INVOICING TYPE CHARECTER 1 (C - Cotação ou F - Factura)
      // 🔴 typOfInvoicingC1 se for "" inclui Cotações e Facturas
      //if (typeOfInvoicingC1 != "") {

      const allFolderNames = filterFoldersNames(company, typeOfInvoicingC1, xproj5xbuild5FoldersNames);

      const filteredFolderNames = filterFoldersNames(
        company,
        typeOfInvoicingC1,
        xproj5xbuild5FoldersNames.filter(folder => filters.some(f => folder.toLowerCase().includes(f.toLowerCase())))
      );

      const sortFolderNames = arr => arr.sort(new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' }).compare);

      sortFolderNames(allFolderNames);
      sortFolderNames(filteredFolderNames);

      let cfl2StrPrompt = '';
      let namesToRender = [];

      if (filteredFolderNames.length === 0 || filterStrs === '') {
        const filterInfo = filterStrs === '' ? 'Filtro vazio' : 'Filtros não encontrados ' + '(' + filterStrs + ')';

        cfl2StrPrompt =
          'Lista de CSs Cliente | Lista completa | ' + xproj5xbuild5FoldersNames.length + '\n—\n' + filterInfo + '\n';
        namesToRender = allFolderNames;
      } else {
        cfl2StrPrompt = `Lista de CSs Cliente | Filtros (${filterStrs}) | ${filteredFolderNames.length}`;
        namesToRender = filteredFolderNames;
      }

      return filteredFolderNames.length === 1
        ? filteredFolderNames[0]
        : cfl2Str(namesToRender, cfl2StrPrompt, namesToRender.at(-1), 'm').replace(/,/g, ', ');
    }

    // ---------------------- Because of return above if is 'ReadFolderName', below run only if is 'ReadInvoiceInfoAndUpdateJSON'

    try {
      var text = [];

      for (var i = 0; i < contractsInfo.length; i++) {
        var contractInfo = contractsInfo[i];
        var contractInfoItems = contractInfo.split(' | ');

        var id = i + 1;
        var cs = contractInfoItems[0];
        var customer = contractInfoItems[1];

        var invoicingInfo = contractInfoItems[2];

        var percentage = invoicingInfo.match(/[A-Z0-9.]*%/)[0];

        var dateInfoItems = contractInfoItems[3].split('-');
        var date = dateInfoItems[0].slice(0, 4) + '.' + dateInfoItems[0].slice(4, 6) + '.' + dateInfoItems[0].slice(-2);
        var dueDate = dateInfoItems[1].slice(0, 4) + '.' + dateInfoItems[1].slice(4, 6) + '.' + dateInfoItems[1].slice(-2);

        if (cs[3] == 'C') {
          var amount = invoicingInfo.match(/C([0-9,.]*)/)[1];

          text.push(
            `{"id":${id}, "cs":"${cs}", "customer":"${customer}", "amount":"${amount}", "percentage":"${percentage}", "date":"${date}", "dueDate":"${dueDate}"}`
          );
        } else if (cs[3] == 'F') {
          var amount = invoicingInfo.match(/F([0-9,.]*)/)[1];
          var dueAmount = invoicingInfo.match(/R([0-9,.]*)/)[1];

          text.push(
            `{"id":${id}, "cs":"${cs}", "customer":"${customer}", "amount":"${amount}", "dueAmount":"${dueAmount}", "percentage":"${percentage}", "date":"${date}", "dueDate":"${dueDate}"}`
          );
        }
      }
    } catch (e) {
      alert(
        `${e.message}❗️\n\nPreparando contractsInfo para gravar em JSON!`,
        `Talvez seja o item "${cs} ${customer} ${invoicingInfo}"`
      );
    }

    try {
      // 🔴 NAOTAR
      // Precisa de JSON.Stringfy para situação de text2
      //var text = JSON.stringify(text2)

      // Text já vem com aspas devidamente por não precisa de JSON.Stringfy
      var text = `[` + text.join(',\n') + `]`;

      var file = '/Users/xd5-wmac/Dropbox/SWIFTUITEMPORAY/JSONInfoA5.json';

      // Converting to UTF8 to accept accents
      var outputStr = $.NSString.alloc.initWithUTF8String(text);
      // WRITING TO FILE
      outputStr.writeToFileAtomically(file, true);
    } catch (e) {
      alert(`${e.message}❗️`, `Gravando no ficheiro JSON!`);
    }
    // }
  } catch (e) {
    alert(`${e.message}❗️`, ``);
  }
}

function getQuoteOrInvoiceInfo(consultancyPathStr, cs, customer4Folders) {
  let infoStr = '';

  if (cs[3] == 'C') {
    const folderPAndCInvoice = getFolderNameByWhoseByContains(consultancyPathStr, 'P&C');

    if (!folderPAndCInvoice) return;

    var folderPAndCItems = folderPAndCInvoice.split(' | ');
    var dateInfo = folderPAndCItems[1];
    var invoicingInfo = folderPAndCItems[2];

    infoStr = `${cs} | ${customer4Folders} | ${invoicingInfo} | ${dateInfo}`;
  } else if (cs[3] == 'F') {
    const xd5Folder = getFolderNameByWhoseByBeginsWith(consultancyPathStr, 'XD5');

    if (!xd5Folder) return;

    const folderPAndCInvoice = getFolderNameByWhoseByContains(consultancyPathStr + '/' + xd5Folder, 'P&C');

    if (!folderPAndCInvoice) return;

    var folderPAndCItems = folderPAndCInvoice.split(' | ');
    var dateInfo = folderPAndCItems[1];
    var invoicingInfo = folderPAndCItems[2];

    infoStr = `${cs} | ${customer4Folders} | ${invoicingInfo} | ${dateInfo}`;
  }

  return infoStr;
}

function filterFoldersNames(company, typeOfInvoicingC1, xproj5xbuild5FoldersNames) {
  return xproj5xbuild5FoldersNames.filter(function (name) {
    var cs = name.split(' ').slice(-1).toString();

    if (company == '') {
      if (typeOfInvoicingC1 == '') {
        return cs;
      } else if (typeOfInvoicingC1 == 'C' || typeOfInvoicingC1 == 'F') {
        return cs[3] == typeOfInvoicingC1;
      }
    } else if (company == 'X-DIM W') {
      if (typeOfInvoicingC1 == '') {
        return cs.slice(1, 3).includes('DW');
      } else if (typeOfInvoicingC1 == 'C' || typeOfInvoicingC1 == 'F') {
        return cs.slice(1, 3).includes('DW') && cs[3] == typeOfInvoicingC1;
      }
    } else if (company == 'X-DIM X') {
      if (typeOfInvoicingC1 == '') {
        return !cs.slice(1, 3).includes('DW');
      } else if (typeOfInvoicingC1 == 'C' || typeOfInvoicingC1 == 'F') {
        return !cs.slice(1, 3).includes('DW') && cs[3] == typeOfInvoicingC1;
      }
    }
  });
}

function getBuildingGroupIdFromText(text) {
  return text.match(/G\d{3}/g)[0];
}

function getBuildingsGroupIDAndNames(invoiceCs) {
  var invoiceCsWithoutExtras = invoiceCs.slice(0, 12);

  var xproductionProjectPathStr = getProjectPathStrUsingCs(invoiceCsWithoutExtras, 'xa5Xproduction');

  const buildingsNameTxt = `EDIFICAÇÕES.txt`;

  var buildingsGroupIDAndNamesPathStr = `${xproductionProjectPathStr}/${buildingsNameTxt}`;

  if (finderApp.exists(Path(buildingsGroupIDAndNamesPathStr))) {
    var buildingsGroupIDAndNamesText = objCLib.readFile(buildingsGroupIDAndNamesPathStr);

    return buildingsGroupIDAndNamesText.match(/G\d{3}\s.*/g); // match(/G3\d{2}\s.*/g)

    // const buildingsGroupIDAndNames = buildingsGroupIDAndNamesText.match(/G\d{3}\s.*/g) // match(/G3\d{2}\s.*/g)
    // return buildingsGroupIDAndNames
  } else {
    return alert(`Não encontrado ficheiro "${buildingsNameTxt}" em X-PRODUÇÃO.`, ``);
  }

  // return buildingsGroupIDAndNamesText.match(/G3\d{2}\s.*/g) // Only G300
}

function getBuildingTypes() {
  return [
    { value: 'Commercial', label: 'Comercial' },
    { value: 'Educational', label: 'Educacional' },
    { value: 'Office', label: 'Escritório' },
    { value: 'Industrial', label: 'Industrial' },
    { value: 'MixedUse', label: 'Misto' },
    { value: 'Residential', label: 'Residencial' },
    { value: 'Other', label: 'Outros' },
  ];
}

function getDisciplineAndServiceFromPath(path) {
  let isDisciplineAndServicePath = false;

  // This regex matches "P5" followed by two letters, then a space, and then a word including accented characters
  // The \p{L} part matches any kind of letter from any language, including accented characters
  // The "u" flag at the end of the regex enables Unicode support, allowing \p{L} to match accented characters

  /* // Match all occurrencies
  const regex = /P5[A-Z]{2}\s[\p{L}]+/gu;
  const matches = path.match(regex);
  return matches ? matches : [];
   */

  // Match first occurrency only
  const regex = /P5[A-Z]{2}\s[\p{L}]+/u;

  // Using match to find the first occurrence that matches the pattern
  const match = path.match(regex);

  // If a match is found, return it; otherwise, return an empty string
  // return match ? match[0] : '';

  if (match) {
    isDisciplineAndServicePath = true;
    const disciplineAndServiceStr = match[0]; // P5AP PROJECTO
    var discipline = getDisciplineByC1(disciplineAndServiceStr[2]);
    var service = getServiceByC1(disciplineAndServiceStr[3]);
  }

  return {
    isDisciplineAndServicePath,
    discipline,
    service,
  };
}

function getCompanyFromCs(cs) {
  if (cs[2] == 'W') {
    return 'X-DIM W';
  } else {
    return 'X-DIM X';
  }
}

function getCompanyNameByCS(cs) {
  // NOT USED
  if (cs[2] == 'W') {
    return 'X-DIM';
  } else {
    return 'X-DIM LDA';
  }
}

function getConstructionManagerAndCsAndCustomer(operation, constructionManager) {
  var customerAndCs = contractsDetails(
    company,
    `ReadFolderName`,
    p5DisciplinePathStr,
    ['Arquitectura'],
    ['Empreitada'],
    yyyy,
    `customerAndCsNoBullet`,
    'F'
  );

  if (constructionManager == undefined) {
    return customerAndCs;
  } else if (constructionManager == '') {
    var constructionManager = cfl2Str(['09L Leotério'], 'Gestor da Obra', '09L Leotério');
    return constructionManager.split(' ')[0] + ' - ' + customerAndCs;
  } else {
    return constructionManager.split(' ')[0] + ' - ' + customerAndCs;
  }
}

function getConsultancyPathStrs(p5DisciplinePathStr, cs) {
  try {
    const invoicinStageC1 = cs[3];
    const disciplineCharacter1 = cs[4];
    const serviceC1 = cs[5];

    const disciplineUpperCase = getDisciplineByC1(disciplineCharacter1).toUpperCase();
    const categoryCodeAndName = `P5${disciplineCharacter1}${serviceC1} ${getServiceByC1(serviceC1).toUpperCase()}`;

    const p5DisciplinePathStrInCateg = p5DisciplinePathStr + disciplineUpperCase[0] + ' ' + disciplineUpperCase;

    const xproj5PathStr = p5DisciplinePathStrInCateg + '/' + categoryCodeAndName;

    if (serviceC1 === 'P') {
      const sdYear = cs.slice(6, 8);
      const year = getFolderNameByWhoseByContains(xproj5PathStr, sdYear);
      const provinceNumber = cs.slice(8, 10);
      const yearPathStr = `${xproj5PathStr}/${year}`;
      const province = getFolderNameByWhoseByContains(yearPathStr, provinceNumber);
      var consultancyContainerPathStr = yearPathStr + '/' + province;
    } else {
      // Obras: Assistência, Construção, Fiscalização
      var consultancyContainerPathStr = xproj5PathStr;
    }

    // `${cs} _` to make sure to select "XDXFAP210302" not "XDXFAP210302A1"
    const consultancy = getFolderNameByWhoseByContainsNotEndsWith(consultancyContainerPathStr, `${cs} _`, 'HUB5'); // In HUB5 was POSTAL

    const consultancyPathStr = consultancyContainerPathStr + '/' + consultancy;

    // XDWFAP240902

    if (invoicinStageC1 === 'C') {
      const folderPAndCQuote = getFolderNameByWhoseByContains(consultancyPathStr, 'P&C');
      const folderPAndCQuotePathStr = `${consultancyPathStr}/${folderPAndCQuote}`;

      return {
        consultancyPathStr,
        folderPAndCQuotePathStr,
      };
    } else {
      // Factura

      if (serviceC1 === 'P') {
        // alert('1');
        // ----------- 00A5D ORIGINAIS iWORK
        const originals = seApp.folders
          .byName(consultancyPathStr)
          .folders.whose({ name: { _contains: 'ORIGINAIS' } })
          .name()[0];

        // alert('2');

        const originalsPathStr = `${consultancyPathStr}/${originals}`;
        const originals_del5 = getFolderNameByWhoseByBeginsWith(originalsPathStr, '+ DEL5');

        // alert('3');

        const originals_del5PathStr = `${originalsPathStr}/${originals_del5}`;

        // ----------- XD5 20240220 | F38,530.24
        const xd5Folder = getFolderNameByWhoseByBeginsWith(consultancyPathStr, 'XD5');

        const folderXd5PathStr = `${consultancyPathStr}/${xd5Folder}`;

        const folderPAndCInvoice = getFolderNameByWhoseByContains(folderXd5PathStr, 'P&C');

        const folderPAndCInvoicePathStr = `${folderXd5PathStr}/${folderPAndCInvoice}`;

        // ----------- XX5 PROJECTO DIGITAL E INTERAÇÃO

        const folderXx5String = 'XX5';
        const folderXx5 = getFolderNameByWhoseByContains(folderXd5PathStr, folderXx5String);

        const folderXx5PathStr = `${folderXd5PathStr}/${folderXx5}`;

        if (!finderApp.exists(Path(folderXx5PathStr))) {
          throw new Error(`Pasta "${folderXx5String}" não encontrada.`);
        }

        const imagesString = 'IMAGENS';
        const images = getFolderNameByWhoseByContains(folderXx5PathStr, imagesString);

        const imagesPathStr = `${folderXx5PathStr}/${images}`;

        if (!finderApp.exists(Path(imagesPathStr))) {
          throw new Error(`Pasta "${imagesString}" não encontrada.`);
        }

        const materialString = 'MATERIAL';

        const material = getFolderNameByWhoseByContains(folderXx5PathStr, materialString);

        const materialPathStr = `${folderXx5PathStr}/${material}`;

        if (!finderApp.exists(Path(materialPathStr)) && cs[2] === 'W') {
          throw new Error(`Pasta "${materialString}" não encontrada.`);
        }

        const videoString = 'VÍDEO';

        const video = getFolderNameByWhoseByContains(folderXx5PathStr, videoString);

        const videoPathStr = `${folderXx5PathStr}/${video}`;

        if (!finderApp.exists(Path(videoPathStr))) {
          throw new Error(`Pasta "${videoString}" não encontrada.`);
        }

        return {
          consultancyPathStr,
          folderXd5PathStr,
          folderXx5PathStr,
          folderPAndCInvoicePathStr,
          imagesPathStr,
          materialPathStr,
          videoPathStr,
          originalsPathStr,
          originals_del5PathStr,
        };
      } else {
        return { consultancyPathStr };
      }
    }
  } catch (error) {
    alert(`${error.message}`, ``);
  }
}
// function getCSs(text) {

// 	// Inclui Adendas e trabalhos a mais "w*"
// 	var matches = text.match(/\w{6}\d{6}\w*/g)

// 	if (matches == null) {

// 		// return [false]
// 		return false

// 	} else {
// 		return matches
// 	}
// }

function getCSs(text) {
  // const matches = text.match(/^[A-Z]{6}\d{6}(?:[A-Z]\d)?[A-Z\d]*$/g);
  // const matches = text.match(/[A-Z]{6}\d{6}(?:(?:[A-Z]\d)*[A-Z]?\b)/g);
  const matches = text.match(/(?!RANCHO|SALARIO|TVCABO)[A-Z]{6}\d{6}(?:(?:[A-Z]\d)*[A-Z]?\b)/g);
  return matches;
}

function getCsInfo(cs) {
  // XDWCAP251107

  return {
    serviceCode: cs.slice(0, 6), // XDWCAP
    vatCodeType: cs.slice(0, 3), // XDW, XCP,
    invoicingStageC1: cs[3], // C ou F
    disciplineC1: cs[4], // A
    serviceC1: cs[5], // P
    // AP (Arquitectura Projecto, Construção, …), RA (Rebanho A, B, C, D)
    workID: `${cs[4]}${cs[5]}`,
    serviceYy: cs.slice(6, 8), // 25
    provinceCode: cs.slice(8, 10), // 11
    serviceNumber: cs.slice(10, 12), // 07
  };
}

// 20231127 DOES NOT ACCEPT, IT OUTPUTS <[object Object]>. NodeJS ACCEPTS. So this pattern will be repeated in isCS and getCCs functions
function getCSRegexPattern() {
  // return /^[A-Z]{6}\d{6}(?:[A-Z]\d?)*?$/;
  return /[A-Z]{6}\d{6}(?:(?:[A-Z]\d)*[A-Z]?\b)/;
}

function getCustomerAndObject(docNumXG5, quoteCs, invoiceCs, dateFoldersAndDocumentsBasicDatetime) {
  docNumXG5.activeSheet.set(docNumXG5.sheets['FACTURAÇÃO']);
  var sheetInvoicing = docNumXG5.sheets['FACTURAÇÃO'];
  var tableQuotes = sheetInvoicing.tables['Table - Quotes'];
  var tableQuotesRownCount = tableQuotes.rowCount();

  for (var i = 1; i <= tableQuotesRownCount; i++) {
    var iSum = i + 1;

    var quoteCsInQuotes = tableQuotes.cells['B' + iSum].value();

    if (quoteCsInQuotes == quoteCs) {
      var rowheight = tableQuotes.rows[i].height();

      var customer4Documents = tableQuotes.cells['C' + iSum].value();
      var customer4SheetOrBimCloud = tableQuotes.cells['D' + iSum].value();
      var object4DocumentsAndImagesAndFolderAndExtras = tableQuotes.cells['E' + iSum].value();
      var projectSite = tableQuotes.cells['F' + iSum].value();
      var siteID = tableQuotes.cells['G' + iSum].value();
      var genderOptionsStr = tableQuotes.cells['H' + iSum].value();
      var intervention = tableQuotes.cells['I' + iSum].value();
      var customerGroup = tableQuotes.cells['J' + iSum].value();
      var contractManager = tableQuotes.cells['K' + iSum].value();
      var propLocal = tableQuotes.cells['L' + iSum].value();
      var buildingObjectsStr = tableQuotes.cells['M' + iSum].value();
      var deadlineWithUnit = tableQuotes.cells['N' + iSum].value();
      var needsHMTLStr = tableQuotes.cells['O' + iSum].value();
      var customer4Xero = tableQuotes.cells['P' + iSum].value();
      // var objectName4NeedsInXero = tableQuotes.cells['Q' + iSum].value();

      break;
    }
  }

  numbersApp.activate();

  delay(d1p5);

  if (customer4Documents) {
    // Podia ser outra variável acima dentro do IF

    tableQuotes.selectionRange = tableQuotes.rows[i];
    delay(d0p3);
    seApp.keystroke('c', { using: 'command down' });
    delay(d0p3);
    tableQuotes.rows[i].delete();
    delay(d0p3);

    // --------------------------- WRITE QUOTE INFO IN TABLE OF INVOICED QUOTES
    var tableInvoices = sheetInvoicing.tables['Table - Invoices'];

    tableInvoices.cells['A2'].addRowAbove();
    // To fix height, no more flexible
    tableInvoices.rows[1].height = rowheight;
    delay(d0p3);
    seApp.keystroke('v', { using: 'command down' });
    delay(d0p3);

    tableInvoices.cells['B2'].value = `${quoteCs} (${dateFoldersAndDocumentsBasicDatetime} - ${invoiceCs})`;

    delay(d0p3);

    finderApp.activate(); // Activate after show Quote list in Finder
    delay(d0p5);

    const object4DocumentsAndImagesAndFolderAndExtrasItems = object4DocumentsAndImagesAndFolderAndExtras.split(' / ');

    const object4FoldersAndExtras = object4DocumentsAndImagesAndFolderAndExtrasItems[2];

    return {
      customer4Documents,
      customer4SheetOrBimCloud,
      objectOptions: {
        object4Documents: object4DocumentsAndImagesAndFolderAndExtrasItems[0],
        object4ImagesAndVideoAndDrawings: object4DocumentsAndImagesAndFolderAndExtrasItems[1],
        object4FoldersAndExtras,
        object4FoldersAndExtrasUpper: object4FoldersAndExtras.toUpperCase(),
      },
      projectSite,
      siteID,
      genderOptionsStr,
      genderOptions: genderOptionsStr.split(' / '),
      intervention,
      customerGroup,
      contractManager,
      propLocal,
      needsHMTLStr,
      buildingObjectsStr: buildingObjectsStr.split('\n').join(', '),
      deadlineWithUnit,
      customer4Xero,
      // objectName4NeedsInXero,
    };
  } else {
    alert('CS não encontrado na lista de Cotações!', '', ['Cancel', 'OK'], 2, 1);
  }
}

function getCustomerAndCsOptions(customerAndCsList, numberOfDefaultSelection, prompt, csPosition, what2return) {
  // what2return: "nameWithCs" or "nameWithoutCs"
  // csPosition: "csAtStart" or "csAtEnd" or "noCs"

  var customerAndCsCollection = [];

  for (var h = 0; h < customerAndCsList.length; h++) {
    var customerAndCs = customerAndCsList[h];
    var customerAndCsItems = customerAndCs.split(' ');

    if (csPosition == 'csAtStart') {
      // CODEABOVE01

      var customerAndCsItems = customerAndCsItems.slice(1).concat(customerAndCsItems[0]);
    } // else is "csAtend" or "noCs"

    // NOME CS ou CS NOME ou NOME APELIDO (sem Cs)
    // if ((customerAndCsItems.length == 2 && csPosition != "noCs") || customerAndCsItems.length == 1 && csPosition == "noCs") {
    if (
      (customerAndCsItems.length == 2 && csPosition == 'noCs') ||
      (customerAndCsItems.length == 2 && csPosition != 'noCs') ||
      (customerAndCsItems.length == 1 && csPosition == 'noCs')
    ) {
      if (what2return == 'nameWithoutCs') {
        // 🔴 NOTE THAT CS NOW IS AT END BECAUSE OF CODEABOVE01
        if (csPosition == 'csAtEnd') {
          customerAndCsCollection.push(customerAndCsItems[1]);
        } else if (csPosition == 'csAtStart') {
          customerAndCsCollection.push(customerAndCsItems[0]);
        }
      } else {
        customerAndCsCollection.push(customerAndCsItems.join(' '));
      }
    } else {
      // customerAndCsItems.length > 2 ou … <= 2 but with CS

      var wordsSelected = [];
      var wordsAbbreviationSelected = [];
      var customerAbbreviation = [];

      for (var i = 0; i < customerAndCsItems.length; i++) {
        var word = customerAndCsItems[i];

        if (isCs(word)) {
          var thisWordIsCs = word;
        }

        //if (word.length > 2) {
        // GD Governo do Distrito
        // GP Governo da Província
        if (word.length > 2 || word == 'GD' || word == 'GP') {
          if (thisWordIsCs) {
            if (what2return == 'nameWithCs') {
              wordsSelected.push(word);
            }
          } else {
            wordsSelected.push(word);
          }

          if (i == 0 || thisWordIsCs) {
            if (i == 0 || what2return == 'nameWithCs') {
              wordsAbbreviationSelected.push(word);
            }
          } else {
            wordsAbbreviationSelected.push(word.slice(0, 3));
          }

          if (thisWordIsCs) {
            if (what2return == 'nameWithCs') {
              customerAbbreviation.push(' ' + word);
            }
          } else {
            customerAbbreviation.push(word[0]);
          }
        }
      }

      if (csPosition == 'noCs' || what2return == 'nameWithoutCs') {
        customerAndCsCollection.push(
          customerAbbreviation.join('') +
            ' | ' +
            wordsSelected.join(' | ') +
            ' | ' +
            wordsAbbreviationSelected.join(' ') +
            ' | ' +
            wordsSelected.join(' ')
        );

        if (what2return == 'nameWithoutCs') {
          var thisWordIsCs = undefined; // Reset
        }
      } else {
        var wordsSelected = wordsSelected.filter(word => !word.match(/\w{6}\d{6}/));
        var nameItemsWithCs = wordsSelected.map(name => name + ' ' + thisWordIsCs);

        customerAndCsCollection.push(
          customerAbbreviation.join('') +
            ' | ' +
            nameItemsWithCs.join(' | ') +
            ' | ' +
            wordsAbbreviationSelected.join(' ') +
            ' | ' +
            wordsSelected.join(' ') +
            ' ' +
            thisWordIsCs
        );

        var thisWordIsCs = undefined; // Reset
      }
    }
  }

  // .replace(/\sMOC\s/g, " MOÇ ") funciona somente se for a ler nome de Finder
  // Se for nome MOÇAMBIQUE, no code reconhece "Ç"
  var customerAndCsCollectionExpandedStr = customerAndCsCollection.join(' | --------------- | ').replace(/\sMOC\s/g, ' MOÇ ');

  var customerAndCsCollectionExpanded = customerAndCsCollectionExpandedStr.split(' | ');

  if (customerAndCsCollectionExpanded.length == 1) {
    var customerAndCs = customerAndCsCollectionExpanded[0];
  } else {
    if (numberOfDefaultSelection == 1) {
      // var customerAndCs = cfl2Str(customerAndCsCollectionExpanded, prompt, customerAndCsCollectionExpanded[1], "m")

      var customerAndCs = documentLib.generateStrFromCFL(
        customerAndCsCollectionExpanded,
        prompt,
        customerAndCsCollectionExpanded[1],
        true
      );
    } else if (numberOfDefaultSelection == 2) {
      // var customerAndCs = cfl2Str(customerAndCsCollectionExpanded, prompt, [customerAndCsCollectionExpanded[1], customerAndCsCollectionExpanded[3]], "m")

      var customerAndCs = documentLib.generateStrFromCFL(
        customerAndCsCollectionExpanded,
        prompt,
        [
          customerAndCsCollectionExpanded[1],
          customerAndCsCollectionExpanded.length >= 7 ? customerAndCsCollectionExpanded[4] : customerAndCsCollectionExpanded[3],
        ],
        true
      );
    }
  }

  // return customerAndCs.replace(/,/g, ", ")
  return customerAndCs;
}

function getDiscipline(disciplinesToExclude, disciplineD_Filter) {
  const disciplinesNumbered = getDisciplines(disciplinesToExclude);
  const disciplineD = disciplinesNumbered.find(discipline => discipline.includes(disciplineD_Filter));

  const disciplineNumbered = cfl2Str(disciplinesNumbered, 'Disciplina', disciplineD);

  return disciplineNumbered.split('. ')[1];
}

function getDisciplines(disciplinesToExclude, isNumbered = true) {
  const disciplines = ['Arquitectura', 'Design', 'Rebanho', 'Simplitask', 'Urbanismo'];

  let disciplinesProcessed = [];

  disciplinesProcessed = disciplines.filter(discipline => {
    return disciplinesToExclude.every(filter => discipline != filter);
  });

  if (isNumbered) {
    disciplinesProcessed = disciplinesProcessed.map((discipline, index) => `${index + 1}. ${discipline}`);
  }

  return disciplinesProcessed;
}

function getDisciplineByC1(disciplineCharacter1) {
  var disciplinesDict = { a: 'Arquitectura', d: 'Design', r: 'Rebanho', s: 'Simplitask', u: 'Urbanismo' };

  return disciplinesDict[disciplineCharacter1.toLowerCase()];
}

function getEstimatesPathStrs(originalsPathStr, invoiceCs) {
  var filePathStrs = getPathStrsFromPathStr(originalsPathStr, 'files');

  const findEstmateDoc = (filePathStrs, filter) => {
    const filesPathString = filePathStrs.filter(url => {
      const docName = getItemNamesFromPathStrs([url], [''])[0];

      return docName.includes(filter) && !docName.includes(' - ') && url.endsWith('.numbers');
    }); //[0];

    return filesPathString ? filesPathString[0] : null;
  };

  /*  const estimateByMPathStr = filePathStrs.filter(
    url => url.includes(' MATERIAL') && !url.includes(' - ') && url.includes('.numbers')
  )[0]; */

  const estimateByMPathStr = findEstmateDoc(filePathStrs, ' MATERIAL');

  /*   const estimateByQPathStr = filePathStrs.filter(
    url => url.includes('ESTIMATIVA DE CUSTO E DURAÇÃO') && !url.includes('_') && url.includes('.numbers')
  )[0];
 */

  const estimateByQPathStr = findEstmateDoc(filePathStrs, 'ESTIMATIVA DE CUSTO E DURAÇÃO');

  if (!estimateByMPathStr || (!estimateByQPathStr && invoiceCs[2] != 'W')) {
    if (invoiceCs[2] == 'W') {
      var errorMessage = `estimateByMPathStr: ${estimateByMPathStr ? 'Sim' : 'Não'}\nestimateByQPathStr: N/A`;
    } else {
      var errorMessage = `estimateByMPathStr: ${estimateByMPathStr ? 'Sim' : 'Não'}\nestimateByQPathStr: ${
        estimateByQPathStr ? 'Sim' : 'Não'
      }`;
    }

    alert(`Há erro na busca de "EstimatesPathStrs". Encontrado?`, errorMessage);
  }

  return {
    estimateByMPathStr,
    estimateByQPathStr,
  };
}

function getIntervention(sc) {
  var interventions = [
    'Ampliação',
    'Conclusão',
    'Conclusão e Ampliação',
    'Construção',
    'Reabilitação',
    'Reabilitação e Ampliação',
    'Remodelação', // Talvez haja necessidade de actualizar o Text A5 para considerar Remodelação
    'Remodelação e Ampliação',
    'Restauração',
    'Restauração e Ampliação',
  ];

  // XDWFRA251001

  if (sc[4] === 'R') {
    return '—';
  }

  if (sc.slice(4, 6) == 'AP') {
    var interventions = interventions.concat('-----', 'As-Built');
  }

  /* // EXCLUIR ALGUMAS DISCIPLINAS DE ESCOLHER INTERVENÇÃO
	if (sc[4] == "A" || sc[4] == "U") {
	} else {
	}
	*/

  return cfl2Str(interventions, 'Tipo de Intervenção\n\n\nREMOVE - TEST - THANKS GOD!', 'Construção');
}

function getIsInvoiceOrQuoteXeroPdfName(fileName) {
  var isInvoiceOrQuoteXeroPdfName = fileName.match(/Invoice\s\w{6}\d{6}|Quote\s\w{6}\d{6}/);

  return isInvoiceOrQuoteXeroPdfName ? true : false;
}

