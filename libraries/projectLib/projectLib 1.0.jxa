      'Governo da Província de ' + province,
      'Direcção Provincial do Mar, Águas Interiores e Pescas de ' + province,
      '--------------- Distrital',
      'Coming',
    ],

    '19 Ministério dos Recursos Minerais e Energia / MIREME': [
      '--------------- Nacional',
      'Electricidade de Moçambique',
      '--------------- Provinvial',
      'Governo da Província de ' + province,
      'Direcção Provincial dos Recursos Minerais e Energia de ' + province,
      '--------------- Distrital',
      'Coming',
    ],

    '20 Ministério do Género, Criança e Acção Social / MGCAS': [
      '--------------- Nacional',
      'Coming',
      '--------------- Provinvial',
      'Governo da Província de ' + province,
      'Direcção Provincial do Género, Criança e Acção Social de ' + province,
      'Delegação Provincial do Instituto Nacional de Acção Social de ' + province,
      '--------------- Distrital',
      'Coming',
    ],

    '21 Ministério dos Combatentes / MICO': [
