function getObjectsAndCss(objectsAndCssInfo) {
  var objectsAndCss = [];
  // var objects = [];

  for (var i = 0; i < objectsAndCssInfo.length; i++) {
    var objectIems = objectsAndCssInfo[i].split(' | ');
    var currentObject = objectIems[0];
    var locationID = objectIems[1];
    var currentObjectInvoiceCs = objectIems[2];

    if (currentObject.includes('Fiscalização da ')) {
      var currentObject = currentObject.replace('Fiscalização da ', '');
    }

    /*
    if (isCs(currentObjectInvoiceCs)) {
      var service = getServiceByC1(currentObjectInvoiceCs[5]);

      if (service == 'Projecto' && currentObjectInvoiceCs[4] == 'U') {
        var service = 'Plano'; // substituir "Projecto" por "Plano"
      }

      if (service[0] != 'P') {
        // If is not Plano ou Projecto
        var service = 'Obra';
      }

      objectsAndCss.push(`${currentObject} (${service} ${locationID} ${currentObjectInvoiceCs})`);
    } else {
      // objectsAndCss | Não precisa de service e currentObjectInvoiceCs por que o objecto já vem com currentObjectInvoiceCs
      objectsAndCss.push(`${currentObject}`);
    }
		*/

    // objects.push(currentObject);

    if (isCs(currentObjectInvoiceCs)) {
      var service = getServiceByC1(currentObjectInvoiceCs[5]);

      if (service == 'Projecto' && currentObjectInvoiceCs[4] == 'U') {
        var service = 'Plano'; // substituir "Projecto" por "Plano"
      }

      if (service[0] != 'P') {
        // If is not Plano ou Projecto
        var service = 'Obra';
      }

      objectsAndCss.push(`${currentObject} (${service} ${locationID} ${currentObjectInvoiceCs})`);
    } else {
      // Para gestão. Ex. Contrato Locação. service não é necessário por que vem mencionado no Objecto
      objectsAndCss.push(`${currentObject} (${locationID} ${currentObjectInvoiceCs})`);
    }
  }

  return objectsAndCss;
  // return { objects, objectsAndCss };
}

/*
function getOriginType() {
	return cfl2Str(["1. Ajuste Directo (DW)", "2. Ajuste Directo (DX)", "3. Concurso Limitado (CL)", "4. Concurso Público (CP)"], "Tipo de Proveniência", "1. Ajuste Directo (DW)")
}
*/
function getOriginType(origintypesToExclude, origintypeD_Filter) {
  const origintypesNumbered = getOriginTypes(origintypesToExclude);
  const origintypeD = origintypesNumbered.find(origintype => origintype.includes(origintypeD_Filter));

  const origintypeNumbered = cfl2Str(origintypesNumbered, 'Tipo de Proveniência', origintypeD);

  return origintypeNumbered.split('. ')[1];
}

function getOriginTypes(origintypesToExclude, isNumbered = true) {
  const origintypes = ['Ajuste Directo (DW)', 'Ajuste Directo (DX)', 'Concurso Limitado (CL)', 'Concurso Público (CP)'];

  let origintypesProcessed = [];

  origintypesProcessed = origintypes.filter(origintype => {
    return origintypesToExclude.every(filter => origintype != filter);
  });

  if (isNumbered) {
    origintypesProcessed = origintypesProcessed.map((origintype, index) => `${index + 1}. ${origintype}`);
  }

  return origintypesProcessed;
}

function getProjectInProcessInfo(docNumXA5) {
  const extractBuildingsNumbers = text => {
    return text.toString().match(/\d{1}\d*/g);
  };

  const projectInProcessSheetName = 'PROJECT IN PROCESS';

  docNumXA5.activeSheet.set(docNumXA5.sheets[projectInProcessSheetName]);

  const projectInProcessTable = docNumXA5.sheets[projectInProcessSheetName].tables[0];

  const selectedProjectQuantity = projectInProcessTable.cells['D1'].value();
  const customerName = projectInProcessTable.cells['B1'].value();
  const invoiceCs = projectInProcessTable.cells['C1'].value();

  const numberOfTxtFilesToProcess = projectInProcessTable.cells['L2'].value();
  let includeCost = projectInProcessTable.cells['L3'].value();
  let savePdf = projectInProcessTable.cells['L4'].value();
  let hideBarsSurfacesVolumesDetails = projectInProcessTable.cells['L5'].value();
  let filteredBuildingsToProcessInEstimateByM = projectInProcessTable.cells['L6'].value();

  if (filteredBuildingsToProcessInEstimateByM) {
    // filteredBuildingsToProcessInEstimateByM = filteredBuildingsToProcessInEstimateByM.toString().match(/\d{1}\d*/g);

    filteredBuildingsToProcessInEstimateByM = extractBuildingsNumbers(filteredBuildingsToProcessInEstimateByM);
  }

  const writeQuantitiesInEstimateByQ = projectInProcessTable.cells['L7'].value();
  let filteredBuildingsToWriteQuantitiesInEstimateByQ = projectInProcessTable.cells['L8'].value();

  if (filteredBuildingsToWriteQuantitiesInEstimateByQ) {
    // filteredBuildingsToWriteQuantitiesInEstimateByQ = filteredBuildingsToWriteQuantitiesInEstimateByQ
    //   .toString()
    //   .match(/\d{1}\d*/g);

    filteredBuildingsToWriteQuantitiesInEstimateByQ = extractBuildingsNumbers(filteredBuildingsToWriteQuantitiesInEstimateByQ);
  }

  if (selectedProjectQuantity == 1) {
    includeCost = includeCost == 0 ? false : true;
    savePdf = savePdf == 0 ? false : true;
    hideBarsSurfacesVolumesDetails = hideBarsSurfacesVolumesDetails == 0 ? false : true;

    return {
      customerName,
      invoiceCs,
      numberOfTxtFilesToProcess,
      includeCost,
      savePdf,
      hideBarsSurfacesVolumesDetails,
      filteredBuildingsToProcessInEstimateByM,
      writeQuantitiesInEstimateByQ,
      filteredBuildingsToWriteQuantitiesInEstimateByQ,
    };
  } else {
    if (selectedProjectQuantity == 0) {
      alert(`Nenhum projecto selecionado.`, ``);
    } else if (selectedProjectQuantity > 1) {
      alert(`Selecione um projecto e não "${selectedProjectQuantity}"!`, ``);
    }
  }
}

function getServicesAndSiteIDsAndCSs(text) {
  // Inclui Adendas e trabalhos a mais "w*"
  // Last - to include Xai-Xai
  // var matches = text.match(/[A-zÀ-ú-]*\s[A-zÀ-ú-]*\s\w{6}\d{6}\w*/g)
  var matches = text.match(/[A-zÀ-ú-0-9]*\s[A-zÀ-ú-0-9]*\s\w{6}\d{6}\w*/g);
  // var matches = text.match(/[A-zÀ-ú-0-9]*\s[A-zÀ-ú-0-9]*\s\w{3,6}\d{6}\w*/g)

  if (matches === null) {
    // return false
    alert(`Match não enctrontrou "ServicesAndSiteIDsAndCSs" em "${text}"`, `Talvez SiteID tem acentuação tipo "d'Ouro"`);
  }
  return matches;
}

function getService(servicesToExclude, serviceD_Filter) {
  const servicesNumbered = getServices(servicesToExclude);
  const serviceD = servicesNumbered.find(service => service.includes(serviceD_Filter));

  const serviceNumbered = cfl2Str(servicesNumbered, 'Serviço', serviceD);

  return serviceNumbered.split('. ')[1];
}

function getServices(servicesToExclude, isNumbered = true) {
  const services = ['Assistência', 'Construção', 'Empreitada', 'Fiscalização', 'Projecto'];

  let servicesProcessed = [];

  servicesProcessed = services.filter(service => {
    return servicesToExclude.every(filter => service != filter);
  });

  if (isNumbered) {
    servicesProcessed = servicesProcessed.map((service, index) => `${index + 1}. ${service}`);
  }

  return servicesProcessed;
}

