      'Coming',
      '--------------- Provinvial',
      'Governo da Província de ' + province,
      'Direcção Provincial dos Combatentes de ' + province,
      '--------------- Distrital',
      'Coming',
    ],
  };

  var ministries = Object.keys(mozMinistries);
  var ministryWithNumberAndAbbreviation = cfl2Str(ministries, 'Ministério', ministries[1]);

  var provincialDirectorateOrNationalServiceList = mozMinistries[ministryWithNumberAndAbbreviation];
  var provincialDirectorateOrNationalService = cfl2Str(
    provincialDirectorateOrNationalServiceList,
    'Selecione uma opção',
    provincialDirectorateOrNationalServiceList[1]
  );

  // To remove number and space
  var ministryItems = ministryWithNumberAndAbbreviation.split(' ');

  // Numerção 1 - 9 will be "1 + 1" // Numeração 10 - 21 will be "2 + 1"
  var ministryWithAbbreviation = ministryWithNumberAndAbbreviation.slice(ministryItems[0].length + 1);

  var provinceStr = 'Província de ' + province; //.replace("(", "").replace(")", "")

  var ministryOrProvince = cfl2Str(
    [ministryWithAbbreviation.split(' / ')[0], provinceStr],
    `Depois de "Repúplica de Moçambique", vem:\n\n\n—\nSelecione a opção\n"${provinceStr}"\ne\nvai desactivar em NumXG5, se for imediatamente\n"${provincialDirectorateOrNationalService}"`,
    provinceStr
  );

  if (ministryOrProvince.includes('Ministério')) {
    var ministryWithAbbreviation = ministryWithAbbreviation.toUpperCase();

    var provDirOrNatServiceOrEmpty4PrivateCustomer = provincialDirectorateOrNationalService.toUpperCase();

    var customer4Documents = cfl2Str(
      [ministryWithAbbreviation, provDirOrNatServiceOrEmpty4PrivateCustomer],
      'Cliente',
      ministryWithAbbreviation
    );
  } else if (ministryOrProvince.includes('Província')) {
    var provincialDirectorateOrNationalServiceWithProvince = provincialDirectorateOrNationalService.toUpperCase();

    var provDirOrNatServiceOrEmpty4PrivateCustomer = provincialDirectorateOrNationalServiceWithProvince;
    var customer4Documents = provincialDirectorateOrNationalServiceWithProvince;
  }

  return `${ministryOrProvince} | ${provincialDirectorateOrNationalService} | ${provDirOrNatServiceOrEmpty4PrivateCustomer} | ${customer4Documents}`;
}

function getNeedsA5Landscape(propSheet) {
  var tableNeedsLandscape = propSheet.tables['ARRANJO EXTERIOR'];
  var needsLandscape = [];

  for (var i = 0; i < tableNeedsLandscape.rowCount(); i++) {
    var iSum = i + 1;
    var lineChecker = tableNeedsLandscape.cells['B' + iSum].value();
    var infoLine = tableNeedsLandscape.cells['A' + iSum].value();

    if (lineChecker > 0) {
      if (!infoLine.toLowerCase().includes('muro de vedação')) {
        infoLine += ` (${lineChecker})`;
      }

      needsLandscape.push(`• ${infoLine}`);
    }
  }

  if (needsLandscape.length > 0) {
    return '\n\n# ARRANJO EXTERIOR\n' + needsLandscape.join('\n'); //+ "\n"
  } else {
    return '';
  }
}

function getNeedsA5Notes(propSheet) {
  var tableNeedsNotes = propSheet.tables['NOTAS DE NECESSIDADES'];
  var needsNotes = [];

  for (var i = 0; i < tableNeedsNotes.rowCount(); i++) {
    var iSum = i + 1;
    var lineChecker = tableNeedsNotes.cells['B' + iSum].value();
    var infoLine = tableNeedsNotes.cells['A' + iSum].value();

    if (lineChecker == 1) {
      needsNotes.push('• ' + infoLine);
    }
  }

  if (needsNotes.length > 0) {
    return '\n\n# NOTAS\n' + needsNotes.join('\n'); //+ "\n"
  } else {
    return '';
  }
}

function getNeedsA5Text(propSheet) {
  var tableNeeds = propSheet.tables['tableNeeds'];
  var tableNeedsRowsL = tableNeeds.rowCount();
  var tableNeedsColumnsL = tableNeeds.columnCount();

  var buildingUseIndexForSpace = 0;

  // var needsHMTL = []
  var needsTextCollection = [];
  // var needsTextXero = []

  for (var i = 0; i < tableNeedsColumnsL; i++) {
    var isStory = false;
    var buildingStory = ``;

    // // HMTL
    // var storySpacesHMTL = ["<ul>", "</ul>"]
    // var buildingsLinesHMTL = ["<ul>", "</ul>"]

    // Text
    var storySpacesText = [];
    var buildingsLinesText = [];

    // // TextXero
    // var storySpacesTextXero = []
    // var buildingsLinesTextXero = []

    var buildingUseStatus = tableNeeds.columns[i].cells[1].value();

    if (buildingUseStatus == 1) {
      if (buildingUseIndexForSpace == 0) {
        // Once get column index no more change
        var buildingUseIndexForSpace = i;
      }
    }

    var buildingStatus = tableNeeds.columns[i].cells[2].value();

    if (buildingStatus == 1) {
      var buildingName = tableNeeds.columns[i].cells[3].value();

      // // HMTL
      // var buildingNameHMTL = "<div><br></div><div>" + buildingName + "</div>"

      // Text
      var buildingNameText = '# ' + buildingName;

      // // TextXero
      // var buildingNameTextXero = "# " + buildingName

      //for (var j = 4; j < tableNeedsRowsL; j++) {
      for (var j = 5; j < tableNeedsRowsL; j++) {
        // 4 é cleaning RowIdentifier

        var space = tableNeeds.columns[buildingUseIndexForSpace].cells[j].value();
        var quantityBySpace = tableNeeds.columns[i - 1].cells[j].value();

        var spaceArea = tableNeeds.columns[i].cells[j].value();

        if (space && spaceArea == null) {
          var isStory = true;
        }

        if (space && !isStory && space != 'Circulação' && space != 'Subtotal') {
          space += ` (${quantityBySpace})`;
        }

        // After first Story
        if ((isStory && j > 4) || j == tableNeedsRowsL - 1) {
          // if (buildingsLinesHMTL.length > 2) { // 2 is HTML Tag "</ul>"
          // 	// HMTL
          // 	var storySpacPosition = storySpacesHMTL.length - 1
          // 	storySpacesHMTL.splice(storySpacPosition, 0, `<li>${[buildingStory + " (" + quantityByStory + ")</li>", buildingsLinesHMTL.join("\n")].join("\n")}`);

          // 	var buildingsLinesHMTL = ["<ul>", "</ul>"] // Reset
          // }

          if (buildingsLinesText.length > 0) {
            // Text
            storySpacesText.push(['• ' + buildingStory + ' (' + quantityByStory + ')', buildingsLinesText.join('\n')].join('\n'));

            var buildingsLinesText = []; // Reset

            // // TextXero
            // storySpacesTextXero.push(["• " + buildingStory + " (" + quantityByStory + ")", buildingsLinesTextXero.join(", ")].join(" — "))

            // var buildingsLinesTextXero = [] // Reset
          }
        }

        if (isStory) {
          var buildingStory = `${space}`;
          var isStory = false;
          var quantityByStory = quantityBySpace;
        } else {
          if (spaceArea > 0) {
            var length = numberLib.formatNumber(tableNeeds.columns[i - 3].cells[j].value(), 2, 2);
            var width = numberLib.formatNumber(tableNeeds.columns[i - 2].cells[j].value(), 2, 2);
            var quantity = tableNeeds.columns[i - 1].cells[j].value();

            // Deve ser avaliada a primeira palavra por que space vem com info de área

            try {
              // Space pode ser null
              var spaceToTrack = space.split(' ')[0];

              if (spaceToTrack != 'Circulação' && spaceToTrack != 'Subtotal') {
                var buildingLine = `${space} (${numberLib.formatNumber(spaceArea, 2, 2)} = ${length}x${width}x${quantity})`;

                // // HMTL
                // var buildingsLinePosition = buildingsLinesHMTL.length - 1
                // buildingsLinesHMTL.splice(buildingsLinePosition, 0, `<li>${buildingLine}</li>`);

                // Text
                buildingsLinesText.push(`•• ${buildingLine}`);

                // // TextXero
                // buildingsLinesTextXero.push(`${buildingLine}`)
              }
            } catch {
              //
            }
          }
        }
      }

      // needsHMTL.push([buildingNameHMTL, storySpacesHMTL])
      needsTextCollection.push([buildingNameText, storySpacesText]);
      // needsTextXero.push([buildingNameTextXero, storySpacesTextXero])
    } else {
      //
    }
  }

  // // HMTL
  // var needsHMTLStr = needsHMTL.map(item => item[0] + "\n" + item[1].join("\n")).join("\n\n")

  // // Text
  var needsText = needsTextCollection.map(item => item[0] + '\n' + item[1].join('\n')).join('\n\n');

  // // // TextXero
  // var needsTextXeroStr = needsTextXero.map(item => item[0] + "\n" + item[1].join("\n")).join("\n\n")

  // 🔴🔴🔴 Below REGEX TO REMOVE AREA INFO in string outsite function
  // <.replace(/\s\([0-9,.]*\s=\s[0-9,.x]*\)/g,"")>

  // if (areaDetailsStatus == "withAreaDetails") {
  // 	return [needsHMTLStr, needsText, needsTextXeroStr]

  // } else if (areaDetailsStatus == "withoutAreaDetails") {
  // 	return [needsHMTLStr.replace(/\s\([0-9,.]*\s=\s[0-9,.x]*\)/g,""), needsText.replace(/\s\([0-9,.]*\s=\s[0-9,.x]*\)/g,""), needsTextXeroStr.replace(/\s\([0-9,.]*\s=\s[0-9,.x]*\)/g,"")]
  // }

  // return [needsHMTLStr, needsText, needsTextXeroStr]

  return needsText;
}

