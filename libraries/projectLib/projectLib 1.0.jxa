//var services = ["Projecto"]
//var services = ["Assistência", "Projecto", "Construção", "Empreitada", "Fiscalização"]
var services = []
//var services = ["All"]
var whatReturn = "customerAndCsNoBullet" // Subscrições // customerAndCsNoBullet
var company = ""
