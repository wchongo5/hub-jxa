// ------------------------------ whatReturnCsAndCustomerAndObj

/*
var folderName = "Y _ XDWFA221001 _ COOPERATIVA Q17 _ PLANO DE PORMENOR DA ZONA COMPLEXO DESPORTIVO _ INCASSENE - DM KATEMBE _ XDWCA221001"
var folderNameItems = folderName.split(` ${ND} `)

var whatReturn = `customerAndCsNoBullet`

var csAndCustomerAndObjItems =  whatReturnCsAndCustomerAndObj(folderName, folderNameItems, whatReturn).split(" | ")

csAndCustomerAndObjItems
*/

function whatReturnCsAndCustomerAndObj(folderName, folderNameItems, whatReturn) {
  var cs = folderNameItems[1];
  var customerItems = folderNameItems[2].split(' ');
  var obj = folderNameItems[3];

  var customerFName = customerItems[0];
  var customerLName = customerItems[customerItems.length - 1];

  if (customerFName == customerLName) {
    if (whatReturn == 'csAndCustomerAndObj') {
      // Not Used
      var csAndCustomerAndObj = `${cs} ${customerFName} ${ND} ${obj}`;
    } else if (whatReturn == 'csAndCustomer') {
      // For Event

      var csAndCustomerAndObj = `${cs} ${customerFName}`;
    } else if (whatReturn == 'customerAndCsNoBullet') {
      // For Subscrições
      var csAndCustomerAndObj = `${customerFName} ${cs}`;
    }
  } else {
    //
    if (whatReturn == 'csAndCustomerAndObj') {
      // Not Used
      var csAndCustomerAndObj = `${cs} ${customerFName} ${customerLName} ${ND} ${obj}`;
    } else if (whatReturn == 'csAndCustomer') {
      // For Event

      var csAndCustomerAndObj = `${cs} ${customerFName} ${customerLName}`;
    } else if (whatReturn == 'customerAndCsNoBullet') {
      var csAndCustomerAndObj = `${customerFName} ${customerLName} ${cs}`;
    }
  }

  return cs + ' | ' + csAndCustomerAndObj;
}

function writeCustomerAndObject(
  tableQuotesOrInvoices,
  customerType,
  dateFoldersAndDocuments,
  quoteCs,
  customer4Documents,
  customer4SheetOrBimCloudOrNote,
  object4DocumentsAndImagesAndFolderAndExtras,
  projectSite,
  siteID,
  genderOptionsStr,
  intervention,
  customerGroup,
  contractManager,
  propLocal,
  needsHMTLStr,
  buildingObjectsStr,
  deadlineWithUnit,
  customer4Xero
  // objectName4NeedsInXero
) {
  numbersApp.activate();

  // var governCustomerColor = "red"
  // var privateCustomerColor = "gray"

  tableQuotesOrInvoices.cells['A2'].addRowAbove();

  tableQuotesOrInvoices.cells['A2'].value = dateFoldersAndDocuments;
  tableQuotesOrInvoices.cells['B2'].value = quoteCs;
  tableQuotesOrInvoices.cells['C2'].value = customer4Documents;
  tableQuotesOrInvoices.cells['D2'].value = customer4SheetOrBimCloudOrNote;
  tableQuotesOrInvoices.cells['E2'].value = object4DocumentsAndImagesAndFolderAndExtras;
  tableQuotesOrInvoices.cells['F2'].value = projectSite;
  tableQuotesOrInvoices.cells['G2'].value = siteID;
  tableQuotesOrInvoices.cells['H2'].value = genderOptionsStr;
  tableQuotesOrInvoices.cells['I2'].value = intervention;
  tableQuotesOrInvoices.cells['J2'].value = customerGroup;
  tableQuotesOrInvoices.cells['K2'].value = documentLib.capitalizeText(contractManager, 'WithExclusions');
  tableQuotesOrInvoices.cells['L2'].value = propLocal;
  tableQuotesOrInvoices.cells['M2'].value = buildingObjectsStr.split(', ').join('\n');
  tableQuotesOrInvoices.cells['N2'].value = deadlineWithUnit;
  tableQuotesOrInvoices.cells['O2'].value = needsHMTLStr;
  tableQuotesOrInvoices.cells['P2'].value = customer4Xero;
  // tableQuotesOrInvoices.cells['Q2'].value = objectName4NeedsInXero;

  if (customerType == 'Estado') {
    tableQuotesOrInvoices.rows[1].textColor = 'red'; //governCustomerColor

    // } else if (customerType == "Empresa Privada" || customerType == "Individual") {
    // 	tableQuotesOrInvoices.rows[1].textColor = privateCustomerColor
  } else if (customerType == 'Empresa Privada') {
    tableQuotesOrInvoices.rows[1].textColor = 'magenta';
  } else if (customerType == 'Individual') {
    tableQuotesOrInvoices.rows[1].textColor = 'gray'; //privateCustomerColor
  }
}

function writeNeeds(docNumXG5, quoteCs, needsHMTLStr, buildingObjectsStr) {
  const sheetInvoicing = docNumXG5.sheets['FACTURAÇÃO'];

  // docNumXG5.activeSheet.set(docNumXG5.sheets["FACTURAÇÃO"])
  docNumXG5.activeSheet.set(sheetInvoicing);

  const tableQuotes = sheetInvoicing.tables['Table - Quotes'];
  const tableQuotesRownCount = tableQuotes.rowCount();

  for (var i = 1; i <= tableQuotesRownCount; i++) {
    const iSum = i + 1;

    const quoteCsInQuotes = tableQuotes.cells['B' + iSum].value();

    if (quoteCsInQuotes == quoteCs) {
      var rowheight = tableQuotes.rows[i].height();

      // To fix height, no more flexible
      tableQuotes.rows[i].height = rowheight;
      tableQuotes.cells['M' + iSum].value = buildingObjectsStr;
      tableQuotes.cells['O' + iSum].value = needsHMTLStr;
      break;
    }
  }
}

function writeWorkWeekNumbers(propSheet, quoteCs, workWeekNumbersByPhase) {
  if (quoteCs.slice(4, 6) == 'AP' || quoteCs.slice(4, 6) == 'UP') {
    var workWeekNumberIndex = 0;
    var workID = quoteCs[4] + '5' + quoteCs[5];
    numbersApp.activate(); // 🔴🔴🔴 DESCATIVAR, PARECE NAO SER NECESSARIO

    var tableTechnicalProposal = propSheet.tables['Proposta Técnica'];
    var tableTechnicalProposalRowsL = tableTechnicalProposal.rowCount();

    for (var i = 0; i < tableTechnicalProposalRowsL; i++) {
      var iSum = i + 1;
      var workWeekNumber = tableTechnicalProposal.cells['A' + iSum].value();

      try {
        // disciplineTrack maybe is not a number
        var disciplineTrack = tableTechnicalProposal.cells['B' + iSum].value().slice(0, 3);

        // null is zero
        if (!isNaN(workWeekNumber) && workWeekNumber != null && disciplineTrack == workID) {
          if (workWeekNumberIndex == 0) {
            // To focus where to start putting info
            iWorkLib.selectionRange(tableTechnicalProposal, 'A' + iSum);
          }

          tableTechnicalProposal.cells['A' + iSum].value = Number(workWeekNumbersByPhase[workWeekNumberIndex]);

          workWeekNumberIndex += 1;
        }
      } catch {
        //
      }
    }
  }

  delay(d0p3);
}
