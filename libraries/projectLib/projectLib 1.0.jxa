  }
}

function getServiceByC1(serviceC1) {
  var servicesDict = { a: 'Assistência', p: 'Projecto', c: 'Construção', e: 'Empreitada', f: 'Fiscalização' };
  return servicesDict[serviceC1.toLowerCase()];
}

function getSiteDimensions(invoiceCs, intervention) {
  if (invoiceCs.slice(4, 6) == 'AP' || invoiceCs.slice(4, 6) == 'UP') {
    if (intervention == 'Construção') {
      return dialog('Dimensões do terreno em metros.\n\n\n—\n❗️Se for terreno irregular, ignore.', 'LxC');
    } else {
      // "Ampliação", "Conclusão", "Conclusão e Ampliação", "Reabilitação", "Reabilitação e Ampliação", "Restauração", "Restauração e Ampliação", "---------------", "As-Built"
      return 'LxC';
    }
  } else {
    return 'NOT_INCLUDED_FOR_DIMENSIONS';
  }
}

function getSpecialities() {
  return ['1 Paisagismo', '2 Arquitectura', '3 Hidráulica', '4 Estrutura', '5 Electrotecnia', '6 Climatização', '7 Gás'];
}

function isCs(csToTest) {
  // XDWFAC200902
  // XDWFAC200902X - No Xero (sc no Contacto Obra - C5 ou E5), CS principal termina com X (para isolar no search)
  // XDWFAC200902A1 - Adenda 1
  // XDWFAC200902R1 - Reajuste 1
  // XDWFAC200902T1 - Trabalhos Adicionais 1
  // XDWFAC200902A1P1 - Adenda 1 (A1), Trabalhos Pontuais 1 (T1)

  /* // 🔴🔴🔴 DEL OLDE TESTING
	var csStringPart = csToTest.slice(0,6)
	var csNumberPart = csToTest.slice(6,12)

	if ((isNaN(Number(csStringPart)) && csStringPart.length == 6) && (!isNaN(Number(csNumberPart)) && csNumberPart.length == 6)) {
		return true
	} else {
		return false
	}
  */

  // Match XDWFAP200902 and XDWFAP200902A1 (…R1, …T1) only. Does not include XDWFAC200902X and XDWFAC200902A1P1
  // const regex = /^[A-Z]{6}\d{6}(?:[A-Z]\d)?$/;

  // Match all situations including XDWFAC200902X and XDWFAC200902A1P1
  //   const regex = /^[A-Z]{6}\d{6}(?:[A-Z]\d?)*?$/;

  // const regex = /[A-Z]{6}\d{6}(?:(?:[A-Z]\d)*[A-Z]?\b)/;
  // (?!RANCHO|SALARIO) is a negative lookahead that ensures the string does not start with "RANCHO" or "SALARIO".

  /* // 🔴🔴🔴🔴 BEFORE SIMPLIFIED SOLUTION
    const regex = /(?!RANCHO|SALARIO|TVCABO)[A-Z]{6}\d{6}(?:(?:[A-Z]\d)*[A-Z]?\b)/;
    return regex.test(csToTest);
   */

  // Excluded words
  const excludedWords = ['PAGAMENTO', 'RANCHO', 'SALARIO', 'TVCABO'];

  // Check if the string contains any excluded words
  if (excludedWords.some(word => csToTest.includes(word))) {
    return false;
  }

  // Regex pattern to match the desired format
  const regex = /^[A-Z]{6}\d{6}(?:(?:[A-Z]\d)*[A-Z]?\b)$/;

  return regex.test(csToTest);
}

function needsA5RemoveAreaDetails(a5pNeeds) {
  return a5pNeeds.map(item => item.replace(/\s\([0-9,.]*\s=\s[0-9,.x]*\)/g, ''));
}

function needsTextFormatter(needsTextToFormat, outputFormat) {
  var buildingName = needsTextToFormat.match(/#\s.*/)[0];

  var needsTextToFormat = needsTextToFormat
    .replace(/(••.*)/g, `<li>$1</li>`)
    .replace(
      /(^•\s\w*.*(\n<li>••\s.*)*)/gm,

      // <To Get>
      // • PISO 1 (5)
      // •• Sala de Estar (1) (20.00 = 4.00x5.00x1)
      // •• Cozinha Exterior (3) (60.00 = 4.00x5.00x3)

      function (match) {
        // var buildingName = needsTextToFormat.match(/#(\s.*)/)[1]

        // var header = `
        // <div><br></div>
        // ${buildingName}
        // `

        var storyName = match.match(/(^•\s.*)/m)[0];
        var matchItems = match.split(storyName);

        var subItemsStr = matchItems[1];

        if (outputFormat == 'html') {
          // matchItems[1] - Sub items

          if (subItemsStr) {
            var needsTextOutput = `<ul>\n<li>${storyName}</li>\n<ul>${subItemsStr}\n</ul>\n</ul>\n`;
          } else {
            // var needsTextOutput = `<ul>\n<li>${storyName}</li>\n</ul><div><br></div>\n`

            var needsTextOutput = `<ul>\n<li>${storyName}</li>\n</ul>`;
          }

          return needsTextOutput; //.replace(/#\s(.*)/g, `<div><br></div>\n# $1 /// `)
        } else if (outputFormat == 'textXero') {
          var subItemsStrItems = subItemsStr.split('\n');
          var subItemsStrItemsL = subItemsStrItems.length;
          // Removed first empty item
          var subItemsStrItems = subItemsStrItems.slice(1, subItemsStrItemsL);

          var needsTextOutput = `${storyName} — ${subItemsStrItems.join(', ')}`;

          var needsTextOutput = needsTextOutput.replace(/<li>/g, '').replace(/<\/li>/g, '');

          return needsTextOutput;
        }
      }
    )
    // Replace all "•" and "••" after because before I used •• as filters
    .replace(/•• /g, ``) //.replace(/• /g, ``)
    .replace(/newLine/g, `<div><br></div>`); // Used in MessagesProcessing

  if (outputFormat == 'html') {
    var needsTextToFormat = needsTextToFormat.replace(/• /g, ``).replace(/#\s(.*)/g, `<div><br></div>\n$1`);
  }

  return needsTextToFormat; //.replace(buildingName, header)
}

function needsZero(propSheet, buildingObjectsStr) {
  var tableNeeds = propSheet.tables['tableNeeds'];
  var tableNeedsRowsL = tableNeeds.rowCount();
  var tableNeedsColumnsL = tableNeeds.columnCount();

  // GET BUILDING G300 NUM IN SHEET

  var buildingObjectsG300 = buildingObjectsStr.split(', ').filter(item => item.includes('G3'));

  var buildingObjectsG300L = buildingObjectsG300.length;

  var sheetBuildingG300Num = 0;

  for (var i = 0; i < tableNeedsColumnsL; i++) {
    var cellFormat = tableNeeds.columns[i].cells[4].format();

    if (cellFormat == 'checkbox') {
      if (buildingObjectsG300[sheetBuildingG300Num]) {
        tableNeeds.columns[i + 1].cells[2].value = 1;

        tableNeeds.columns[i].cells[3].value = buildingObjectsG300[sheetBuildingG300Num];

        var cellStartName = tableNeeds.columns[i].cells[3].name();
        var cellEndName = tableNeeds.columns[i + 1].cells[3].name();

        var rangeNameToFormat1 = cellStartName + ':' + cellEndName;

        iWorkLib.clearRange(tableNeeds, cellEndName);
        iWorkLib.mergeCells(tableNeeds, rangeNameToFormat1);
      } else {
        tableNeeds.columns[i + 1].cells[2].value = 0;
      }

      sheetBuildingG300Num += 1;
    }
  }

  if (buildingObjectsG300L > sheetBuildingG300Num) {
    // alert(`O sheet tem menos colunas (${sheetBuildingG300Num}) para receber (${buildingObjectsG300L}) objectos. Press "OK", vai preencher manualmente no fim do processo.`, `Objectos escritos: ${buildingObjectsG300.slice(0, sheetBuildingG300Num)}\nObjectos não escritos: ${buildingObjectsG300.slice(sheetBuildingG300Num, buildingObjectsG300L)}`)

    alert(
      `O sheet tem menos colunas (${sheetBuildingG300Num}) para receber (${buildingObjectsG300L}) objectos. Press "OK", vai acrescentar e preencher manualmente no fim do processo.`,
      `Objectos não escritos: ${buildingObjectsG300.slice(sheetBuildingG300Num, buildingObjectsG300L)}`
    );

    numbersApp.activate();
  }

  for (var i = 0; i < tableNeedsColumnsL; i++) {
    var cellNames = [];
    var cleaningStatus = tableNeeds.columns[i].cells[4].value();

    if (cleaningStatus == 1) {
      for (var j = 5; j < tableNeedsRowsL; j++) {
        var cellValue = tableNeeds.columns[i].cells[j].value();

        if (cellValue != null) {
          var cellName = tableNeeds.columns[i].cells[j].name();
          cellNames.push(cellName);
        }

        var cellNamesL = cellNames.length;

        if (cellValue == null && cellNamesL > 0) {
          iWorkLib.selectionRange(tableNeeds, cellNames[1] + ':' + cellNames[cellNamesL - 1]);
          menuLib.copyPaste('0');
          var cellNames = []; // Reset
        }
      }
    }
  }

  var tableNames = ['NOTAS DE NECESSIDADES', 'ARRANJO EXTERIOR'];

  for (var h = 0; h < tableNames.length; h++) {
    var table = propSheet.tables[tableNames[h]];

    iWorkLib.selectionRange(table, 'B1');

    for (var i = 0; i < table.rowCount(); i++) {
      var iSum = i + 1;
      table.cells['B' + iSum].value = '0'; // Checkbox aceita "0" quanto 0
    }
  }
}

function objectSlicer(object, object4FoldersAndExtrasFull, extraDescr) {
  var object4FoldersAndExtrasItems = object4FoldersAndExtrasFull.split(' ');
  var object4FoldersAndExtrasLast3Words = object4FoldersAndExtrasItems.slice(-3);

  const objectItems = object.split(' ');

  if (
    object4FoldersAndExtrasLast3Words[0] == 'Residência' &&
    (extraDescr == 'object4FoldersAndExtras' || extraDescr == 'object4Note')
  ) {
    return object4FoldersAndExtrasLast3Words.join(' ').replace(' Unifamiliar', '');
  } else {
    if (object4FoldersAndExtrasItems[object4FoldersAndExtrasItems.length - 4] == 'de') {
      var itemNumStart = object4FoldersAndExtrasItems.length - 3;
    } else {
      var itemNumStart = object4FoldersAndExtrasItems.length - 4;
    }

    if (extraDescr == 'object4FoldersAndExtras' || extraDescr == 'object4Note') {
      var object4FoldersAndExtrasItemsD = object4FoldersAndExtrasItems.slice(itemNumStart, object4FoldersAndExtrasItems.length);
    } else if (extraDescr == 'object4ImagesAndVideoAndDrawings') {
      // Se último caracter da última (3) palavra  de object4FoldersAndExtrasLast3Words for "P", chance é de ser de Piso e parte de "2P" não entra no nome de images sendo melhor excluir de default

      //if (object4FoldersAndExtrasLast3Words[2][1] == "P") {

      if (object4FoldersAndExtrasLast3Words[2].slice(-1) == 'P') {
        var object4FoldersAndExtrasItemsD = object4FoldersAndExtrasItems.slice(
          itemNumStart,
          object4FoldersAndExtrasItems.length - 1
        );
      } else {
        var object4FoldersAndExtrasItemsD = object4FoldersAndExtrasItems.slice(itemNumStart, object4FoldersAndExtrasItems.length);
      }
    }

    const alertGeneralString = `Geralmente, a palavra "construção" não faz parte no nome da pasta`;

    const object4FoldersAndExtrasSelected = cfl(
      object4FoldersAndExtrasItems,
      `Faz múltiplas selecções para compor "${extraDescr}".\n${
        objectItems.length === 1
          ? `🔴 "${object}" tem uma palavra, controle para, de forma errada, incluir "Construção de", visto que ${alertGeneralString.toLowerCase()}.`
          : ``
      }`,
      object4FoldersAndExtrasItemsD,
      'm'
    ).join(' ');

    if (object4FoldersAndExtrasSelected.toLowerCase().includes('construção')) {
      alert(``);
    }

    return object4FoldersAndExtrasSelected;
  }
}

function processServicesAndSiteIDsAndCSs(selectedObjectsAndCssStr, subject) {
  // var invoiceCsAndCustomer = "Thanks God Obra XDXFAF210601"
  var servicesAndSiteIDsAndCSs = getServicesAndSiteIDsAndCSs(selectedObjectsAndCssStr); //[0]

  var services = servicesAndSiteIDsAndCSs.map(item => item.split(' ')[0]);
  var siteIDs = servicesAndSiteIDsAndCSs.map(item => item.split(' ')[1]);
  // var css = servicesAndSiteIDsAndCSs.map(item => item.split(" ")[2])

  var siteIDsAreEqual = itemsAreEqual(siteIDs);
  var servicesAreEqual = itemsAreEqual(services);

  let subjectHasServicesStr = false;

  if (services.length > 1) {
    var servicesStr = services[0] + 's';

    subjectHasServicesStr = subject.includes(servicesStr);
  } else {
    var servicesStr = services[0];
  }

  const joinStr = ' & ';
  let result;

  if (servicesAreEqual && siteIDsAreEqual) {
    result =
      `${subjectHasServicesStr ? '' : servicesStr + ' '}` +
      siteIDs[0] +
      ' ' +
      servicesAndSiteIDsAndCSs.map(item => item.split(' ')[2]).join(joinStr);
  } else if (servicesAreEqual && !siteIDsAreEqual) {
    result =
      `${subjectHasServicesStr ? '' : servicesStr + ' '}` +
      servicesAndSiteIDsAndCSs.map(item => item.split(' ').slice(1, 3).join(' ')).join(joinStr);

    // } else if (!servicesAreEqual && !siteIDsAreEqual) {
  } else {
    result = servicesAndSiteIDsAndCSs.join(joinStr);
  }

  return result;
}

function removeLocationID_fromSelectedObjectsAndCss(selectedObjectsAndCss) {
  return selectedObjectsAndCss.map(function (item) {
    var serviceAndSiteIDAndCS = getServicesAndSiteIDsAndCSs(item)[0];
    var serviceAndSiteIDAndCSItems = serviceAndSiteIDAndCS.split(' ');

    var serviceAndAndCS = serviceAndSiteIDAndCSItems[0] + ' ' + serviceAndSiteIDAndCSItems[2];

    var re = new RegExp('\\b' + serviceAndSiteIDAndCS + '\\b');
    return item.replace(re, serviceAndAndCS);
  });
}

function updatePAndCFolderName({
  p5DisciplinePath,
  cs,
  quoteTotal,
  chargedPercentage,
  dateAndDueDate,
  dueAmountAndTotalWithPrefix,
}) {
  var { folderPAndCInvoicePathStr, folderPAndCQuotePathStr } = getConsultancyPathStrs(p5DisciplinePath, cs);

  var folderPAndCPath;
  var folderNameNew;

  // XDWCAA240901
  if (cs[3] === 'C') {
    folderPAndCPath = folderPAndCQuotePathStr;

    const folderPAndCName = folderPAndCPath.split('/').slice(-1)[0];
    folderNameNew = folderPAndCName.replace(/C\d[0-9,.]*\s[0-9.]*/, 'C' + quoteTotal + ' ' + chargedPercentage);
  } else {
    folderPAndCPath = folderPAndCInvoicePathStr;

    const folderPAndCName = folderPAndCPath.split('/').slice(-1)[0];
    folderNameNew = folderPAndCName
      .replace(/\d{8}-\d{8}/, dateAndDueDate)
      .replace(/R[0-9,.]*-F[0-9,.]*/, dueAmountAndTotalWithPrefix);
  }

  var folderAlias = seApp.aliases.byName(folderPAndCPath);
  folderAlias.name = folderNameNew;
}

function selectSubject(objectOfSubjects) {
  const subjects = Object.values(objectOfSubjects).filter(Boolean);

  const subjectsWithTheirVariableNames = generateTextOfObjectKeysAndValues(objectOfSubjects);

  return cfl2Str(subjects, `Escolhe o assunto\n\n—\n${subjectsWithTheirVariableNames}`, subjects[0]);
}

