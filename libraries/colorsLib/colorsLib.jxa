function getRbg255ToScale65535List(r, g, b) {

	// Ligeiras diferenças entre RGB obtido e original - vide Numbers "JAVASCRIPT COLOR STUDY" in "#P51A _ DESENHO & ESPECIFICAÇÕES"

	var rbg255ToScale1List = getRbg255ToScale1List(r, g, b)
	return rbg255ToScale1List.map(value => value * 65535)
}

