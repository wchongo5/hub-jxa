function getNextNumberOrLetter(sheetNumber, nextNumberIsNumber = false) {
  const isNumeric = /^\d+$/.test(sheetNumber);
  if (isNumeric) {
    let number = parseInt(sheetNumber, 10);
    if (number < 9) {
      return (number + 1).toString();
    } else if (number === 9 && !nextNumberIsNumber) {
      return 'A'; // Transition to 'A' after 9 when nextNumberIsNumber is false
    } else {
      // Handle numeric continuation or conversion to letters based on nextNumberIsNumber flag
      if (nextNumberIsNumber) {
        return (number + 1).toString(); // Continue with numbers after 9
      } else {
        // Convert numbers 10 and above to letters starting from 'A'
        //   const code = 'A'.charCodeAt(0) + (number - 10);
        const code = 'B'.charCodeAt(0) + (number - 10);
        if (code <= 'Z'.charCodeAt(0)) {
          return String.fromCharCode(code);
        } else {
          throw new Error("Sheet number exceeds 'Z'. Extension beyond 'Z' is not implemented.");
        }
      }
    }
  } else {
    if (sheetNumber >= 'A' && sheetNumber < 'Z') {
      return String.fromCharCode(sheetNumber.charCodeAt(0) + 1);
    } else if (sheetNumber === 'Z') {
      throw new Error("Sheet number 'Z' reached. Extension beyond 'Z' is not implemented.");
    } else {
      throw new Error('Invalid sheet number format.');
    }
  }
}

// ACEITA EXPRESSÃO DE SOMA NO INPUT
function inputNumber(numberDescription, inputNumberParameter) {
  var condition = false;

  while (!condition) {
    try {
      var titleDisplay = numberDescription + '\n\n—\nPode introduzir soma de valores!';

      var inputNumberParameter = displayLib.dialog(titleDisplay, inputNumberParameter);

      if (inputNumberParameter.includes('+')) {
        var inputNumberParameterSum = 0;

        var inputNumberParameterItems = inputNumberParameter.split('+');

        for (var i = 0; i < inputNumberParameterItems.length; i++) {
          inputNumberParameterSum += Number(inputNumberParameterItems[i]);
        }
      } else {
        var inputNumberParameterSum = inputNumberParameter;
      }

      var theNumber = Number(inputNumberParameterSum);

      if (isNaN(theNumber)) {
        saApp.beep();
        var condition = false;
      } else {
        if (theNumber > 0) {
          var condition = true;
        }

        if (theNumber == 0) {
          saApp.beep();
        }
      }
    } catch {
      saApp.beep();
      displayLib.alert('Introduz número!', '');
      var condition = false;
    }
  }
  return theNumber.toString();
}

