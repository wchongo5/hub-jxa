// 🔴🔴🔴🔴🔴🔴 EXISTE UM SITIO NUM APP QUE NÃO USEI, ESTA FUNCAO, FOI ANTES DE CRIA-LA, PROCURAR E SUBSTITUIR
function sumAllByReduce(arryOfNumbers) {
  return arryOfNumbers.reduce(function (total, number) {
    // return total + number;
    return total + Number(number.toString().replace(/,/g, ''));
  }, 0);
}
