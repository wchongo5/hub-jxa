const p4SP5AApplePathStr = pathLib.getP4SP5AApplePathStr();

// --------------- messagesMpesaProcess - v1.0

function messagesEmolaProcess(filePathStr, groupBy) {
  currentApp.displayAlert(
    `Test importing "needsTextFormatter()" if is not slowing process. If is better keep it here, replace this alert with one that will alert to keep local "needsTextFormatter()" updated from original one in projectLib()`,
    { buttons: ['Cance', 'OK'], defaultButton: 2, givingUpAfter: 5, withIcon: 1 }
  );

  var { dateY4M2D2__H2M2S2 } = formatDateV3(new Date()).formats;

  var filePathStrItems = filePathStr.split('/');
  var txtFileName = filePathStrItems.pop().split('.')[0];

  var messagesPeriodMacthes = txtFileName.match(/\d{8}-\d{8}/);

  if (messagesPeriodMacthes) {
    var messagesPeriod = messagesPeriodMacthes[0];
  } else {
    return alert(`Erro`, `"messagesPeriod" não encontrado no nome "${txtFileName}"`);
  }

  var message_txt = objCLib.readFile(filePathStr);

  var messages = message_txt.match(/\d{4}-\d{2}-\d{2}\s\d{2}:\d{2}:\d{2}\n\n.*/g);

  var transactionTypeDic = {
    Levantaste: 'Levantamento',
    Recebeu: 'Depósito',
    // Recebimento
    'Acabou de receber': 'Recebimento',
    transferiu: 'Recebimento',
    // Transferência
    'Acabou de transferir': 'Transferência',
    Enviaste: 'Transferência', // Para contas bancárias
    Transferiste: 'Transferência',
  };

  var messagesCollection = {};
  var messagesNotProcessed = [];

  for (var i = 0; i < messages.length; i++) {
    var message = messages[i];

    try {
      var transactionIDs = message.match(
        /(Acabou de receber|Acabou de transferir|Enviaste|Levantaste|Recebeu|transferiu|Transferiste)/
      );

      if (transactionIDs) {
        var timestamp = message.match(/\d{4}-\d{2}-\d{2}\s\d{2}:\d{2}:\d{2}/)[0];
        var amount = paymentLib.getAmount(message, 0);

        var transactionID = transactionIDs[0];

        var transactionType = transactionTypeDic[transactionID];

        if (transactionID == 'Levantaste') {
          var otherPersonName = message.match(/Agente\s(.*)\. Taxa/)[1].replace(', nome', '');
          var otherPerson = `${otherPersonName}`;
        } else if (transactionID == 'Recebeu') {
          var otherPersonName = message.match(/Agente.*\snome\s(.*)\sas/)[1];
          var otherPerson = `${otherPersonName}`;

          // ------------- Recebimento
        } else if (transactionID == 'Acabou de receber') {
          var otherPersonName = message.match(/Acabou de receber dinheiro\s(.*)\sas/)[1];
          var otherPersonName = otherPersonName.split(' ').slice(-2).join(' ');
          var otherPerson = `${otherPersonName}`;
        } else if (transactionID == 'transferiu') {
          // Recebimento

          var otherPersonName = message.match(/nome:\s(.*)\stransferiu/)[1].trim();
          var otherPerson = `${otherPersonName}`;

          // ------------- Transferência
        } else if (transactionID == 'Acabou de transferir') {
          var otherPersonName = message.match(/Acabou de transferir dinheiro para\s(.*)\s\d{2}:\d{2}:\d{2}/)[1];
          var otherPerson = `${otherPersonName}`;
        } else if (transactionID == 'Enviaste') {
          var otherPersonName = message.match(/Enviaste\s.*para(.*)\sas\s\d{2}/)[1];
          var otherPerson = `${otherPersonName}`;
        } else if (transactionID == 'Transferiste') {
          // Recebimento
          var telephoneNumber = message.match(/\d{9}/)[0];
          var otherPersonName = message.match(/nome:\s(.*)\sas/)[1];
          var otherPerson = `${otherPersonName} - ${telephoneNumber}`;
        }

        if (groupBy === 'otherPerson') {
          var messageInfo = `${timestamp.replace(/-|:/g, '').split(' ').join('-')} ${transactionType} — ${amount}`;

          if (messagesCollection[otherPerson] === undefined) {
            messagesCollection[otherPerson] = messageInfo;
          } else {
            messagesCollection[otherPerson] += ` | ` + messageInfo;
          }
        } else if (groupBy === 'transactionType') {
          var messageInfo = `${timestamp.replace(/-|:/g, '').split(' ').join('-')} ${otherPerson} — ${amount}`;

          if (messagesCollection[transactionType] === undefined) {
            messagesCollection[transactionType] = messageInfo;
          } else {
            messagesCollection[transactionType] += ` | ` + messageInfo;
          }
        }
      } else {
        messagesNotProcessed.push(message);
      }
    } catch (error) {}
  }

  var messagesCollectionArray = Object.entries(messagesCollection).map(item => {
    var otherPerson = item[0];

    var item2Items = item[1].split(' | ');
    var item2ItemsProcessed = item2Items.map(item => '• ' + item).join('\n');

    return `# ${otherPerson} (${item2Items.length})\n${item2ItemsProcessed}`;
  }); //.join("\n---------------\n")

  var messagesCollectionArrayL = messagesCollectionArray.length;
  var messagesCollectionArrayText = messagesCollectionArray.sort().join('\n\n');

  const messagesNotProcessedWithPrefixes = messagesNotProcessed.map(message => {
    const messageParts = message.split('\n');
    return `# ${messageParts[0]}\n• ${messageParts[2]}`;
  });

  const messagesNotProcessedBalance = messagesNotProcessedWithPrefixes.filter(item => item.includes('Saldo total:'));
  const messagesNotProcessedBalanceL = messagesNotProcessedBalance.length;

  const messagesNotProcessedRemaining = messagesNotProcessedWithPrefixes.filter(item => !item.includes('Saldo total:'));

  const messagesNotProcessedRemainingL = messagesNotProcessedRemaining.length;

  const messagesNotProcessedWithPrefixesGrouped = `\nnewLine\n---------- SALDO (${messagesNotProcessedBalanceL})\n\n${messagesNotProcessedBalance.join(
    '\n\n'
  )}\nnewLine\n---------- RESTO (${messagesNotProcessedRemainingL})\n\n${messagesNotProcessedRemaining.join('\n\n')}`;

  // var messagesProcessedAndNotProcessedTxt = `${messagesCollectionArrayText}\nnewLine\n----------------------- MENSAGENS NÃO PROCESSADAS (${messagesNotProcessedWithPrefixes.length})\n\n${messagesNotProcessedWithPrefixes.join("\n\n")}`

  var messagesProcessedAndNotProcessedTxt = `${messagesCollectionArrayText}\nnewLine\n----------------------- MENSAGENS NÃO PROCESSADAS (${
    messagesNotProcessedBalanceL + messagesNotProcessedRemainingL
  })\n\n${messagesNotProcessedWithPrefixesGrouped}`;

  // var messagesCollectionArrayHtml = projectLib.needsTextFormatter(messagesProcessedAndNotProcessedTxt, "html")
  var messagesCollectionArrayHtml = needsTextFormatter(messagesProcessedAndNotProcessedTxt, 'html');

  var noteTitle = `P1PG 📌 Messages - Emola ${dateY4M2D2__H2M2S2} (${messagesPeriod}) - groupBy ${groupBy}`;

  var newNote = notesLib.createNote('P1', noteTitle, messagesCollectionArrayHtml, ['#P0P1PG⌛️']);

  delay(d1);

  var messages_iMazingPathSr = `${p4SP5AApplePathStr}/T-MESSAGES/MESSAGES-IMAZING-PROCESSED`;

  finderApp.move(Path(filePathStr), { to: Path(messages_iMazingPathSr) });
  delay(d0p3);

  renameItem(
    `${messages_iMazingPathSr}/${txtFileName}.txt`,
    `Messages - eMola - ${dateY4M2D2__H2M2S2} (${messagesPeriod}) - groupBy ${groupBy}`,
    'reveal'
  );
}

function messagesMpesaProcess(filePathStr, groupBy) {
  currentApp.displayAlert(
    `Test importing "needsTextFormatter()" if is not slowing process. If is better keep it here, replace this alert with one that will alert to keep local "needsTextFormatter()" updated from original one in projectLib()`,
    { buttons: ['Cance', 'OK'], defaultButton: 2, givingUpAfter: 5, withIcon: 1 }
  );

  // var groupBy = `otherPerson`
  // var groupBy = `transactionType`

  var { dateY4M2D2__H2M2S2 } = formatDateV3(new Date());

  var filePathStrItems = filePathStr.split('/');
  var txtFileName = filePathStrItems.pop().split('.')[0];

  var messagesPeriodMacthes = txtFileName.match(/\d{8}-\d{8}/);

  if (messagesPeriodMacthes) {
    var messagesPeriod = messagesPeriodMacthes[0];
  } else {
    return alert(`Erro`, `"messagesPeriod" não encontrado no nome "${txtFileName}"`);
  }

  var message_txt = objCLib.readFile(filePathStr);

  var messages = message_txt.match(/\d{4}-\d{2}-\d{2}\s\d{2}:\d{2}:\d{2}\n\n.*/g);

  var transactionTypeDic = {
    Depositaste: 'Depósito',
    levantaste: 'Levantamento',
    Recebeste: 'Recebimento',
    Transferiste: 'Transferência',
  };

  var messagesCollection = {};
  var messagesNotProcessed = [];

  for (var i = 0; i < messages.length; i++) {
    var message = messages[i];

    try {
      // var messageExtracts = message.match(/(Depositaste|Recebeste|Transferiste)\s.*(AM|PM)/)
      var transactionIDs = message.match(/(Depositaste|levantaste|Recebeste|Transferiste)/);

      if (transactionIDs) {
        var timestamp = message.match(/\d{4}-\d{2}-\d{2}\s\d{2}:\d{2}:\d{2}/)[0];
        var amount = paymentLib.getAmount(message, 0);

        // var messageExtract = messageExtracts[0]

        var transactionID = transactionIDs[0];

        // var messageExtractItems = messageExtract.split(" ")
        // var transactionID = messageExtractItems[0]

        var transactionType = transactionTypeDic[transactionID];

        // alert(`${messageExtract}\n\n${transactionType}\n\n${amount}`, ``)

        if (transactionID == 'levantaste') {
          var otherPerson = message.match(/agente\s(.*)\. O novo saldo/)[1];
        } else if (transactionID == 'Recebeste' || transactionID == 'Transferiste') {
          var otherPersonInfo = message.match(/(\d{12}\s-\s.*\s)aos/)[1];
          // 258 844148252
          var telephoneNumber = otherPersonInfo.match(/\d{3}(\d{9})/)[1];

          var otherPersonName = otherPersonInfo.split(telephoneNumber + ' - ')[1];

          var otherPerson = `${otherPersonName} - ${telephoneNumber}`;
        } else if (transactionID == 'Depositaste') {
          var otherPerson = message.match(/agente\s(.*\s)aos/)[1];
        }

        if (groupBy === 'otherPerson') {
          var messageInfo = `${timestamp.replace(/-|:/g, '').split(' ').join('-')} ${transactionType} — ${amount}`;

          if (messagesCollection[otherPerson] === undefined) {
            messagesCollection[otherPerson] = messageInfo;
          } else {
            messagesCollection[otherPerson] += ` | ` + messageInfo;
          }
        } else if (groupBy === 'transactionType') {
          var messageInfo = `${timestamp.replace(/-|:/g, '').split(' ').join('-')} ${otherPerson} — ${amount}`;

          if (messagesCollection[transactionType] === undefined) {
            messagesCollection[transactionType] = messageInfo;
          } else {
            messagesCollection[transactionType] += ` | ` + messageInfo;
          }
        }
      } else {
        messagesNotProcessed.push(message);
      }
    } catch (error) {}
  }

  var messagesCollectionArray = Object.entries(messagesCollection).map(item => {
    var otherPerson = item[0];

    var item2Items = item[1].split(' | ');
    var item2ItemsProcessed = item2Items.map(item => '• ' + item).join('\n');

    return `# ${otherPerson} (${item2Items.length})\n${item2ItemsProcessed}`;
  }); //.join("\n---------------\n")

  var messagesCollectionArrayL = messagesCollectionArray.length;
  var messagesCollectionArrayText = messagesCollectionArray.sort().join('\n\n');

  const messagesNotProcessedWithPrefixes = messagesNotProcessed.map(message => {
    const messageParts = message.split('\n');
    return `# ${messageParts[0]}\n• ${messageParts[2]}`;
  });

  const messagesNotProcessedBuy = messagesNotProcessedWithPrefixes.filter(item =>
    item.includes('Registamos uma operacao de compra')
  );
  const messagesNotProcessedBuyL = messagesNotProcessedBuy.length;

  const messagesNotProcessedCredit = messagesNotProcessedWithPrefixes.filter(item => item.includes('de credito'));
  const messagesNotProcessedCreditL = messagesNotProcessedCredit.length;

  const messagesNotProcessedBalance = messagesNotProcessedWithPrefixes.filter(item => item.includes('O teu saldo'));
  const messagesNotProcessedBalanceL = messagesNotProcessedBalance.length;

  const messagesNotProcessedRemaining = messagesNotProcessedWithPrefixes.filter(
    item => !item.includes('Registamos uma operacao de compra') && !item.includes('de credito') && !item.includes('O teu saldo')
  );

  const messagesNotProcessedRemainingL = messagesNotProcessedRemaining.length;

  // const messagesNotProcessedWithPrefixesGrouped = `${messagesNotProcessedBuy}${messagesNotProcessedCredit}${messagesNotProcessedBalance}${messagesNotProcessedRemaining}`
  const messagesNotProcessedWithPrefixesGrouped = `\nnewLine\n---------- COMPRAS (${messagesNotProcessedBuyL})\n\n${messagesNotProcessedBuy.join(
    '\n\n'
  )}\nnewLine\n---------- CRÉIDTO (${messagesNotProcessedCreditL})\n\n${messagesNotProcessedCredit.join(
    '\n\n'
  )}\nnewLine\n---------- SALDO (${messagesNotProcessedBalanceL})\n\n${messagesNotProcessedBalance.join(
    '\n\n'
  )}\nnewLine\n---------- RESTO (${messagesNotProcessedRemainingL})\n\n${messagesNotProcessedRemaining.join('\n\n')}`;

  var messagesProcessedAndNotProcessedTxt = `${messagesCollectionArrayText}\nnewLine\n----------------------- MENSAGENS NÃO PROCESSADAS (${
    messagesNotProcessedBuyL + messagesNotProcessedCreditL + messagesNotProcessedBalanceL + messagesNotProcessedRemainingL
  })\n\n${messagesNotProcessedWithPrefixesGrouped}`;

  // alert(`2`, ``)

  // 🔴 ESTE PROCESSO FICA COMGELADO SE USRA "projectLib.needsTextFormatter" e não função AQUI neste ficheiro "needsTextFormatter"
  // var messagesCollectionArrayHtml = projectLib.needsTextFormatter(messagesProcessedAndNotProcessedTxt, "html")
  var messagesCollectionArrayHtml = needsTextFormatter(messagesProcessedAndNotProcessedTxt, 'html');

  var noteTitle = `P1PG 📌 Messages - Mpesa ${dateY4M2D2__H2M2S2} (${messagesPeriod}) - groupBy ${groupBy}`;

  var newNote = notesLib.createNote('P1', noteTitle, messagesCollectionArrayHtml, ['#P0P1PG⌛️']);

  delay(d1);

  var messages_iMazingPathSr = `${p4SP5AApplePathStr}/T-MESSAGES/MESSAGES-IMAZING-PROCESSED`;
  // alert( `${filePathStr}\n\n${messages_iMazingPathSr}`, ``)
  finderApp.move(Path(filePathStr), { to: Path(messages_iMazingPathSr) });
  delay(d0p3);
  // delay(3)

  // alert( `${messages_iMazingPathSr}/${txtFileName}\n\n$Messages - M-Pesa - (${messagesPeriod})`, ``)

  renameItem(
    `${messages_iMazingPathSr}/${txtFileName}.txt`,
    `Messages - M-Pesa - ${dateY4M2D2__H2M2S2} (${messagesPeriod}) - groupBy ${groupBy}`,
    'reveal'
  );
}

// --------------- Contacts - v1.0

function autoGetAndSaveContacts(autoOrManualRun) {
  var startTime = new Date();
  console.log('Start Time:', startTime);

  const contactsNotes = JSON.parse(objCLib.readFile(contactsNotesPathStr));

  // Create a Map for faster lookup
  const contactsNotesMap = new Map();
  contactsNotes.forEach(note => contactsNotesMap.set(note.id, note));

  var contactStore = $.CNContactStore.alloc.init;
  console.log('CNContactStore initialized:', contactStore);

  var authStatus = $.CNContactStore.authorizationStatusForEntityType($.CNEntityTypeContacts);
  console.log('Authorization status:', authStatus);

  if (authStatus === $.CNAuthorizationStatusNotDetermined) {
    contactStore.requestAccessForEntityTypeCompletionHandler($.CNEntityTypeContacts, (granted, error) => {
      if (granted) {
        autoFetchContacts(contactStore, contactsNotesMap, startTime, autoOrManualRun);
      } else {
        console.log('Error requesting contact access:', error ? ObjC.unwrap(error.localizedDescription) : 'Authorization denied');
      }
    });
  } else if (authStatus === $.CNAuthorizationStatusAuthorized) {
    autoFetchContacts(contactStore, contactsNotesMap, startTime, autoOrManualRun);
  } else if (authStatus === $.CNAuthorizationStatusDenied) {
    console.log('Access denied');
  } else if (authStatus === $.CNAuthorizationStatusRestricted) {
    console.log('Access restricted');
  }
}

