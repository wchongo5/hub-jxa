function autoFetchContacts(contactStore, contactsNotesMap, startTime, autoOrManualRun) {
  var keys = [
    $.CNContactGivenNameKey,
    $.CNContactFamilyNameKey,
    $.CNContactPhoneNumbersKey,
    $.CNContactBirthdayKey,
    $.CNContactEmailAddressesKey,
    $.CNContactUrlAddressesKey,
    $.CNContactNoteKey,
    $.CNContactPostalAddressesKey,
  ];

  var nsArray = $.NSMutableArray.alloc.init;
  keys.forEach(function (item) {
    nsArray.addObject(item);
  });
  var keysToFetch = nsArray;
  console.log('Keys to fetch:', keysToFetch);

  var contactsArray = [];
  var contactCount = 0;

  try {
    console.log('Creating fetch request...');
    var fetchRequest = $.CNContactFetchRequest.alloc.initWithKeysToFetch(keysToFetch);
    console.log('Fetch request created:', fetchRequest);

    console.log('Starting contact enumeration...');
    var result = contactStore.enumerateContactsWithFetchRequestErrorUsingBlock(fetchRequest, null, function (contact, stop) {
      // if (contactCount < 20) {
      if (contactCount < 20000) {
        // 1841 Contacts 2024.07.12
        var phoneNumbers = ObjC.unwrap(contact.phoneNumbers).map(phone => {
          if (phone.value && phone.value.stringValue) {
            return {
              label: ObjC.unwrap(phone.label),
              number: ObjC.unwrap(phone.value.stringValue),
            };
          } else {
            console.log('Phone object:', phone);
            return { label: 'No label', number: 'No number' };
          }
        });

        var emailAddresses = ObjC.unwrap(contact.emailAddresses).map(email => ({
          label: ObjC.unwrap(email.label),
          email: ObjC.unwrap(email.value),
        }));

        var urlAddresses = ObjC.unwrap(contact.urlAddresses).map(url => ({
          label: ObjC.unwrap(url.label),
          url: ObjC.unwrap(url.value),
        }));

        var addresses = ObjC.unwrap(contact.postalAddresses).map(address => ({
          label: ObjC.unwrap(address.label),
          street: ObjC.unwrap(address.value.street),
          city: ObjC.unwrap(address.value.city),
          state: ObjC.unwrap(address.value.state),
          postalCode: ObjC.unwrap(address.value.postalCode),
          country: ObjC.unwrap(address.value.country),
        }));

        var contactNoteObj = contactsNotesMap.get(ObjC.unwrap(contact.identifier));

        //   console.log(JSON.stringify(contactNoteObj));

        var note = contactNoteObj && contactNoteObj.note ? contactNoteObj.note : null;

        var birthday = contact.birthday.year
          ? {
              year: contact.birthday.year,
              month: contact.birthday.month,
              day: contact.birthday.day,
            }
          : null;

        var firstName = ObjC.unwrap(contact.givenName);
        var lastName = ObjC.unwrap(contact.familyName);
        var name = `${firstName} ${lastName}`;

        var contactObj = {
          id: ObjC.unwrap(contact.identifier),
          firstName: firstName,
          lastName: lastName,
          name: name,
          phones: phoneNumbers,
          emails: emailAddresses,
          urls: urlAddresses,
          addresses: addresses,
          note: note,
          birthday: birthday,
          code: '', // AppleContactExtended
          photoUrl: '', // AppleContactExtended
        };
        contactsArray.push(contactObj);
        contactCount++;
        console.log(`Fetched contact ${contactCount}: ${contactObj.name}`);
      } else {
        stop[0] = true;
      }
    });

    console.log('Finished contact enumeration.');
    console.log('Result:', result);

    if (contactCount === 0) {
      console.log('No contacts found.');
    } else {
      /*
      console.log('Number of contacts:', contactCount);
      var jsonData = JSON.stringify(contactsArray, null, 2); // Format JSON with 2 spaces for indentation
      var nsString = $.NSString.alloc.initWithUTF8String(jsonData);
      var filePath = contactsPtahStr; // Use path from pathLib
      var success = nsString.writeToFileAtomicallyEncodingError(filePath, true, $.NSUTF8StringEncoding, null);
      if (success) {
        console.log('Contacts saved to', filePath);
      } else {
        console.log('Failed to save contacts');
      }
      */

      objCLib.writeToFile(contactsPtahStr, JSON.stringify(contactsArray, null, 2), false);
    }
  } catch (e) {
    console.log('Exception during contact enumeration:', e);
  }

  var endTime = new Date();
  console.log('End Time:', endTime);
  // console.log('Total Execution Time:', (endTime - startTime) / 1000, 'seconds');

  // console.log('timeElapsed:', timeElapsed(startTime, endTime));

  // 🔴🔴🔴 DEACTIVATED HERE BEACUSE IT FREEZES HERE
  saveLogAutoProcess(startTime, endTime, contactsPtahStr, autoOrManualRun);
}

function autoUpdateContactsNotes(autoOrManualRun) {
  // Notas
  // • First run of 1841 contacts 15 min;
  // • Runs subsequentes de actualização de notas são 8 min;

  const startTime = new Date();
  console.log('For Loop Start Time:', startTime);

  const contacts = contactsApp.people();

  let contactsNotes = JSON.parse(objCLib.readFile(contactsNotesPathStr));

  // for (let i = 0; i < contacts.slice(0, 20).length; i++) {
  for (let i = 0; i < contacts.length; i++) {
    const contact = contacts[i];
    const id = contact.id();
    const note = contact.note();
    const modificationDate = contact.modificationDate().getTime().toString(); // Convert to string

    const existingContactIndex = contactsNotes.findIndex(c => c.id === id);

    if (existingContactIndex !== -1) {
      if (parseInt(contactsNotes[existingContactIndex].modificationDate) < parseInt(modificationDate)) {
        contactsNotes[existingContactIndex] = {
          id,
          modificationDate,
          note,
        };
      }
    } else {
      contactsNotes.push({
        id,
        modificationDate,
        note,
      });
    }
  }

  const contactsNotesStr = JSON.stringify(contactsNotes, null, 2);

  objCLib.writeToFile(contactsNotesPathStr, contactsNotesStr, false);

  const endTime = new Date();
  console.log('For Loop End Time:', endTime);
  // console.log('timeElapsed:', timeElapsed(startTime, endTime));

  // 🔴🔴🔴 DEACTIVATED HERE BEACUSE IT FREEZES HERE
  saveLogAutoProcess(startTime, endTime, contactsNotesPathStr, autoOrManualRun);

  // return contactsNotes;
}

