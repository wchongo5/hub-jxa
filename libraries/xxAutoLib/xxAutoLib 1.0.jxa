// --------------- autoDisplay - v7.0

// function autoDisplay() {

function autoDisplay(callback) {
  // var pathLib = Library("pathLib")

  var currentApp = Application.currentApplication();
  var saApp = ((currentApp.includeStandardAdditions = true), currentApp);
  var seApp = Application('System Events');

  var finderApp = Application('Finder');

  const theWatchFolderTotal = '7';

  //itemClass = "files", "folders", "files&folders"
  // itemFilter = "" / "#" / Any

  // All folders in EMAILS LOG TRIGGER
  var emailsProcessTriggerStr = pathLib.getPlataformsPathStr() + '/APPS WF/EMAILS LOG TRIGGER';
  folderWacther('1', emailsProcessTriggerStr, 'folders', '');

  // All files & folders in VAULT5 EDIT
  folderWacther('2', pathLib.getInboxPathStr() + '/VAULT5 EDIT', 'files&folders', '');

  // All files & folders in OFFLINE FOLDER
  folderWacther('3', '/Users/xd5-wmac/P0 OFFLINE FOLDER', 'files&folders', '');

  // All files & folders in XA5-TEMPORARY5 OFFLINE
  folderWacther('4', '/Users/xd5-wmac/P51A XA5-TEMPORARY5 OFFLINE', 'files&folders', '##');

  // All files & folders in SCAN5 & TEMPORARY
  folderWacther(
    '5',
    '/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Plataformas/INBOX/SCAN5 & TEMPORARY',
    'files&folders',
    ''
  );

  // All files & folders in ATTACHMENTS
  folderWacther(
    '6',
    '/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Plataformas/INBOX/ATTACHMENTS',
    'files&folders',
    ''
  );

  // All files in ICLOUD DOWNLOADS
  folderWacther('7', '/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Downloads', 'files', '');

  // All folders Whose Names Conatins # in FORNECEDORES5
  //folderWacther ("4", "/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Plataformas/P1/P1F FORNECEDORES5", "folders", "#")

  function folderWacther(folderSequence, folderString, itemClass, itemFilter) {
    var folderAlias = seApp.folders.byName(folderString);
    var uploadsFolderName = folderAlias.name();

    if (itemClass == 'files') {
      var itemsList = folderAlias.files;
    } else if (itemClass == 'folders') {
      var itemsList = folderAlias.folders;
    } else if (itemClass == 'files&folders') {
      var itemsList = folderAlias.diskItems;
    }

    var itemsNamesWithoutDS_StoreFiles = [];
    var itemsNamesWithoutDS_StoreFolders = [];

    for (var i = 0; i < itemsList.length; i++) {
      var itemName = itemsList[i].name();
      var itemClassExtracted = itemsList[i].class();

      if (!itemName.includes('.DS_Store')) {
        if (itemClassExtracted == 'file') {
          itemsNamesWithoutDS_StoreFiles.push('D' + itemName);
        } else if (itemClassExtracted == 'folder') {
          itemsNamesWithoutDS_StoreFolders.push('F' + itemName);
        }
      }
    }

    itemsNamesWithoutDS_StoreFiles.sort();
    itemsNamesWithoutDS_StoreFolders.sort();

    var itemsListWithoutDS_Store = itemsNamesWithoutDS_StoreFolders.concat(itemsNamesWithoutDS_StoreFiles);

    var itemsListWithIndex = [];

    // Numeração
    for (var i = 0; i < itemsListWithoutDS_Store.length; i++) {
      var itemNameClassPrefix = itemsListWithoutDS_Store[i][0];
      var itemNameWithoutClassPrefix = itemsListWithoutDS_Store[i].substr(1);

      if (itemsListWithoutDS_Store[i].includes(itemFilter)) {
        itemsListWithIndex.push(numberLib.addZero(i + 1) + itemNameClassPrefix + '	' + itemNameWithoutClassPrefix);
      }
    }

    var itemsListWithIndexLength = itemsListWithIndex.length;

    if (itemsListWithIndexLength > 0) {
      if (itemsListWithIndexLength > 1) {
        if (itemClass == 'files&folders') {
          var theWatchKindName = itemClass.replace('&', ' & ').toUpperCase();
        } else {
          var theWatchKindName = itemClass.split('s')[0].toUpperCase() + 'S';
        }
      } else {
        var theWatchKindName = itemClass.split('s')[0].toUpperCase();
      }

      // --------------- Detele TRIGGER(s) Folder(s)

      if (
        uploadsFolderName.includes('TRIGGER') ||
        uploadsFolderName.includes('VAULT5') ||
        uploadsFolderName.includes('OFFLINE FOLDER') ||
        uploadsFolderName.includes('XA5-TEMPORARY5 OFFLINE')
      ) {
        saApp.beep();

        if (uploadsFolderName.includes('TRIGGER')) {
          var emailsProcessTriggerFolders = seApp.folders.byName(emailsProcessTriggerStr).folders;

          var thisFolderL = emailsProcessTriggerFolders.length;

          for (var i = 0; i < thisFolderL; i++) {
            var emailsProcessTriggerFolders = seApp.folders.byName(emailsProcessTriggerStr).folders;

            emailsProcessTriggerFolders[0].delete();
            delay(0.3);
          }

          var specialExtraAlert = `\n❌ As pastas abaixo foram apagadas!`;
        } else if (uploadsFolderName.includes('VAULT5')) {
          var specialExtraAlert = `\n❌ Mover a info abaixo ao Dropbox VAULT5!`;
        } else if (uploadsFolderName.includes('OFFLINE FOLDER')) {
          var specialExtraAlert = `\n❌ Clean this folder!`;
        } else if (uploadsFolderName.includes('XA5-TEMPORARY5 OFFLINE')) {
          var specialExtraAlert = `\n❌ Move useful info do Dropbox & deldel useless info!`;
        }

        delay(0.3);
      } else {
        var specialExtraAlert = '';
      }

      var theDisplay = currentApp.displayDialog(
        itemsListWithIndexLength +
          ' ' +
          theWatchKindName +
          ' (' +
          uploadsFolderName +
          ' ' +
          folderSequence +
          '/' +
          theWatchFolderTotal +
          ')' +
          specialExtraAlert +
          '\n—\n' +
          itemsListWithIndex.join('\n') +
          '\n\n\n\n',
        { buttons: ['Show folder', 'Ok', 'Cancel'], defaultButton: 2, cancelButton: 3, givingUpAfter: 5, withIcon: 1 }
      );

      if (theDisplay.buttonReturned == 'Show folder') {
        finderApp.activate();
        finderApp.open(Path(folderString));
      }
    }
  }

  currentApp.displayDialog(`autoDisplay finished`, {
    givingUpAfter: 5,
    withIcon: 1,
  });

  callback && callback();
}

