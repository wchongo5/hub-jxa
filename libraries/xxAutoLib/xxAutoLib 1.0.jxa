// -------------- FUNCTIONS HERE

function needsTextFormatter(needsTextToFormat, outputFormat) {
  var buildingName = needsTextToFormat.match(/#\s.*/)[0];

  var needsTextToFormat = needsTextToFormat
    .replace(/(••.*)/g, `<li>$1</li>`)
    .replace(
      /(^•\s\w*.*(\n<li>••\s.*)*)/gm,

      // <To Get>
      // • PISO 1 (5)
      // •• Sala de Estar (1) (20.00 = 4.00x5.00x1)
      // •• Cozinha Exterior (3) (60.00 = 4.00x5.00x3)

      function (match) {
        // var buildingName = needsTextToFormat.match(/#(\s.*)/)[1]

        // var header = `
        // <div><br></div>
        // ${buildingName}
        // `

        var storyName = match.match(/(^•\s.*)/m)[0];
        var matchItems = match.split(storyName);

        var subItemsStr = matchItems[1];

        if (outputFormat == 'html') {
          // matchItems[1] - Sub items

          if (subItemsStr) {
            var needsTextOutput = `<ul>\n<li>${storyName}</li>\n<ul>${subItemsStr}\n</ul>\n</ul>\n`;
          } else {
            // var needsTextOutput = `<ul>\n<li>${storyName}</li>\n</ul><div><br></div>\n`

            var needsTextOutput = `<ul>\n<li>${storyName}</li>\n</ul>`;
          }

          return needsTextOutput; //.replace(/#\s(.*)/g, `<div><br></div>\n# $1 /// `)
        } else if (outputFormat == 'textXero') {
          var subItemsStrItems = subItemsStr.split('\n');
          var subItemsStrItemsL = subItemsStrItems.length;
          // Removed first empty item
          var subItemsStrItems = subItemsStrItems.slice(1, subItemsStrItemsL);

          var needsTextOutput = `${storyName} — ${subItemsStrItems.join(', ')}`;

          var needsTextOutput = needsTextOutput.replace(/<li>/g, '').replace(/<\/li>/g, '');

          return needsTextOutput;
        }
      }
    )
    // Replace all "•" and "••" after because before I used •• as filters
    .replace(/•• /g, ``) //.replace(/• /g, ``)
    .replace(/newLine/g, `<div><br></div>`); // Used in MessagesProcessing

  if (outputFormat == 'html') {
    var needsTextToFormat = needsTextToFormat.replace(/• /g, ``).replace(/#\s(.*)/g, `<div><br></div>\n$1`);
  }

  return needsTextToFormat; //.replace(buildingName, header)
}
