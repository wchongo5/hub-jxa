// --------------- autoBackup - v1.0

// function autoBackup(autoOrManualRun) {
function autoBackup(autoOrManualRun, callback) {
  currentApp.displayDialog(`autoBackup started`, {
    givingUpAfter: 5,
    withIcon: 1,
  });

  let filesFolderName = 'filesFolderNameNotUpdated';

  var startTime = new Date();

  try {
    var copyPasteAutoBackupPathStr = '/Users/xd5-wmac/Library/Mobile Documents/com~apple~CloudDocs/Plataformas/BACKUP-COPYPASTE';

    var processPathStrs = [
      // 🔴🔴🔴 Instructions
      // ["/Library/Scripts/Folder Action Scripts", ["WF _", "Image", "add"]]
      // "/Library/Scripts/Folder Action Scripts" is copy from Folder
      // ["WF _", "Image", "add"] Are filters for needed filea

      // ----- Files
      ['/Users', [''], 'files'],
      ['/Users/xd5-wmac', ['.z'], 'files'], // Profiles ".zprofile", ".zshrc"
      ['/Library/Scripts/Folder Action Scripts', ['WF _'], 'files'],
      ['/Users/xd5-wmac/Library/Application Support/Code/User', [''], 'files'],
      ['/Users/xd5-wmac/Library/Application Support/Code/User/snippets', [''], 'files'],
      ['/Users/xd5-wmac/Library/Keybindings', [''], 'files'],
      ['/Users/xd5-wmac/Library/LaunchAgents', ['xAuto'], 'files'],
      ['/Users/xd5-wmac/Library/Services', [''], 'files'],
      ['/Users/xd5-wmac/Library/Script Libraries', [''], 'files'],

      // // Copy by files
      // ['/Users/xd5-wmac/Dropbox/DATA/Contactos', [''], 'files'],
      // ['/Users/xd5-wmac/Dropbox/DATA/Contratos', [''], 'files'],
      // ['/Users/xd5-wmac/Dropbox/DATA/Xero', [''], 'files'],

      // ----- Folders
      // Copy all folders inside DATA
      ['/Users/xd5-wmac/Dropbox/DATA', [''], 'folders'],

      // ['/Users/xd5-wmac/Library/Application Support/QGIS/QGIS3/profiles/default/python/plugins', ['xd5_'], 'folders'],
    ];

    var { dateY4M2D2__H2M2S2 } = formatDateV3(new Date()).formats;

    var folderNameDate = dateY4M2D2__H2M2S2; //"20230128-165305"

    makeFolder(Path(copyPasteAutoBackupPathStr), folderNameDate);

    var filesLenthCollection = [];

    var processPathStrsL = processPathStrs.length;

    for (var i = 0; i < processPathStrsL; i++) {
      // var item = processPathStrs[i];
      // var fromPathStr = item[0];
      // var filters = item[1];

      const [fromPathStr, filters, itemsType] = processPathStrs[i];

      // var backupPathStrs = getPathStrsFromPathStr(fromPathStr, 'files');
      const backupPathStrs = getPathStrsFromPathStr(fromPathStr, itemsType);
      const backupPathStrsL = backupPathStrs.length;

      //
      // let filesFolderName = fromPathStr.split('/').slice(-1)[0];
      filesFolderName = fromPathStr.split('/').slice(-1)[0];

      if (filesFolderName === 'DATA' && fromPathStr.includes('Dropbox/DATA')) {
        filesFolderName = 'Dropbox - ' + filesFolderName;
      }

      // if (filesFolderName === 'plugins') {
      //   filesFolderName = 'QGIS - ' + filesFolderName;
      // }

      if (filesFolderName === 'snippets') {
        filesFolderName = 'VS Code - ' + filesFolderName;
      }

      if (filesFolderName === 'User') {
        filesFolderName = 'VS Code - ' + filesFolderName;
      }

      if (filesFolderName === 'xd5-wmac') {
        filesFolderName = filesFolderName + ' - hidden-profiles';
      }

      var folderNameDatePathStr = `${copyPasteAutoBackupPathStr}/${folderNameDate}`;

      // const folderNameDatePathObj = Path(folderNameDatePathStr);

      makeFolder(Path(folderNameDatePathStr), filesFolderName);

      let toPathStr;

      for (var j = 0; j < backupPathStrsL; j++) {
        var backupPathStr = backupPathStrs[j];
        const backupFileName = backupPathStr.split('/').slice(-1)[0];

        let backupThis = false;
        let isProfileFile = false;

        for (var k = 0; k < filters.length; k++) {
          var filter = filters[k];

          isProfileFile = backupPathStr.endsWith('/.zprofile') || backupPathStr.endsWith('/.zshrc');

          // if (backupPathStr.includes(filter)) {
          if (backupPathStr.includes(filter) || isProfileFile) {
            backupThis = true;
            break;
          }
        }

        /* 
          - (backupFileName[0] != '.' || isProfileFile) to exclude system files (.localized, …) but incude if is isProfileFile
        */

        // if ((filters[0] == '' || backupThis) && backupFileName[0] != '.') {
        if ((filters[0] == '' || backupThis) && (backupFileName[0] != '.' || isProfileFile)) {
          toPathStr = `${copyPasteAutoBackupPathStr}/${folderNameDate}/${filesFolderName}`;

          // const backupPathObj = Path(backupPathStr);

          // if (finderApp.exists(backupPathObj)) {

          finderApp.duplicate(Path(backupPathStr), { to: Path(toPathStr) });
          // }
        }

        // var backupThis = false;
      }

      // -------------- GET FOLDER QUANTITY AND RENAME - FOLDER BACKUPED FOLDER

      if (!toPathStr) continue;

      delay(d1); // Make all duplicates have been made

      const filesBackupedPathStrs = getPathStrsFromPathStr(toPathStr, 'diskItems');

      var filesBackupedPathStrsL = `${filesBackupedPathStrs.length}`;

      renameItem(toPathStr, `${filesFolderName} (${filesBackupedPathStrsL})`, 'noReveal');

      // ----- "renameItem" makes "reveal" folder, so close all except last one
      //if (i != (processPathStrsL - 1)) {
      //finderApp.windows[0].close()
      //}

      filesLenthCollection.push(Number(filesBackupedPathStrsL));
    }

    // -------------- GET FOLDER QUANTITY AND RENAME - FOLDER DATE NAME

    var filesLenthCollectionSum = numberLib.sumAllByReduce(filesLenthCollection);

    var foldersBackupedPathStrs = getPathStrsFromPathStr(folderNameDatePathStr, 'folders');

    var foldersBackupedPathStrsL = `${foldersBackupedPathStrs.length}`;

    renameItem(
      folderNameDatePathStr,
      `${folderNameDate} (${foldersBackupedPathStrsL}) (${filesLenthCollectionSum}) - ${autoOrManualRun}`,
      'noReveal'
    );
  } catch (error) {
    alert(`${error.name}`, `${error.message}\n\n—\nDeu erro processando a pasta "${filesFolderName}"❗️`);
  }

  var endTime = new Date();

  // Passing backupCopyPaste without extension, will be found in function

  // // 🔴🔴🔴 DEACTIVATED HERE BEACUSE IT FREEZES HERE
  // saveLogAutoProcess(
  //   startTime,
  //   endTime,
  //   `${backupCopyPastePathStr}/backupCopyPaste`,
  //   documentLib.capitalizeText(autoOrManualRun, 'NoExclusions')
  // );

  callback && callback();
}

