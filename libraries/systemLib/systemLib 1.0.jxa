function f5() {
  delay(d0p3);
  seApp.keyCode(96);
  delay(d0p3);
}

// ----- 🔴🔴🔴 REJECT SIMPLE NAMES BECAUSE ARE KEYWORDS
// pressDeletedelete() considerer System not Menu
// delete is keyword not accepted

function pressDelete(times) {
  for (var i = 0; i < times; i++) {
    delay(d0p3); // Was d0p3
    seApp.keyCode(51); // Delete
    delay(d0p3); // Was d0p3
  }
}

function space(times) {
  for (var i = 0; i < times; i++) {
    delay(d0p3);
    seApp.keyCode(49);
    delay(d0p3);
  }
}

function tab(times) {
  for (var i = 0; i < times; i++) {
    delay(d0p3);
    seApp.keyCode(48);
    delay(d0p3);
  }
}

function unTab(times) {
  for (var i = 0; i < times; i++) {
    delay(d0p3);
    seApp.keyCode(48, { using: 'shift down' }); // UnTab
    delay(d0p3);
  }
}

function scape() {
  delay(d0p3);
  seApp.keyCode(53); // Scape
  delay(d0p3);
}

// --------------------------------------- KEYSTROKES

function keystrokeStr(str) {
  // 🔴🔴🔴 NOT USED YET
  delay(d0p3);
  seApp.keystroke(str);
  delay(d0p3);
}

// --------------------------------------- ARROWS

