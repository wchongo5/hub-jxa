function getNoteTextAtFolderLevel1ByTitle(folderName, titleFilters) {
  const titleFilter1 = titleFilters[0];
  var notes = notesApp.folders[folderName].notes.whose({ name: { _contains: titleFilter1 } });

  const notesText = [];

  for (var i = 0; i < notes.length; i++) {
    var noteText = notes[i].plaintext();
    notesText.push(noteText);
  }

  if (notesText.length === 0) {
    alert(`Não encontrou "nota" com título contendo "${titleFilter1}"`, ``);
  } else if (notesText.length === 1) {
    return notesText[0];
  } else {
    return notesText.find(note => {
      // Check if the note's name contains all titles
      return titleFilters.every(filter => note.split('\n')[0].includes(filter));
    });
  }
}

// ---------------------------------------

function writeTags(tags) {
  for (var i = 0; i < tags.length; i++) {
    copyPaste(tags[i]);
    delay(d1);
    // delay(d0p5);
    space(1);
  }
}

function updateNote(noteName, noteBody, tags) {
  const note = notesApp.folders['P5'].notes.whose({ name: { _contains: noteName } })[0];

  //note.name = noteName
  note.plaintext = noteBody;

  formatNoteName(newNote);

  writeTags(['#P0XY⌛️', tags]);
  enter(2);
}

function createNote(folderName, noteTitle, noteBody, tags) {
  var atFolder = notesApp.folders[folderName];

  var newNote = notesApp.make({ new: 'note', at: atFolder, withProperties: { name: noteTitle, body: noteBody } });

  formatNoteName(newNote);

  writeTags(tags);

  return newNote;
}

function createServiceNote(cs, customer4SheetOrBimCloudOrNote, object4Note, noteBody) {
  // XDWFAP220901 // XDWFR1220901
  var disciplineC1ServiceC1 = cs.slice(4, 6);

  if (disciplineC1ServiceC1 === 'AP') {
    var icon = '📕';
  } else if (
    disciplineC1ServiceC1 === 'AA' ||
    disciplineC1ServiceC1 === 'AC' ||
    disciplineC1ServiceC1 === 'AE' ||
    disciplineC1ServiceC1 === 'AF'
  ) {
    var icon = '📘';
  } else if (disciplineC1ServiceC1 === 'DP') {
    var icon = '✏️';
  } else if (disciplineC1ServiceC1.startsWith('R')) {
    var icon = '🐄';
  } else if (disciplineC1ServiceC1 === 'UP') {
    var icon = '📗';
  } else {
    var icon = 'CodeIcon';
  }

  var noteTitle = `P5${disciplineC1ServiceC1} ${icon} ${cs} ${customer4SheetOrBimCloudOrNote} (${object4Note.toUpperCase()})`;

  var extraTagsToWrite = '';

  if (cs[3] == 'C') {
    var noteTitle = `X-${noteTitle}`;
    extraTagsToWrite += '#P0X00⌛️';
  } else {
    // F // XDWFAP221002

    if (cs[5] == 'P') {
      extraTagsToWrite += '#P0XP5⌛️';
    } else if (cs[5] == 'A' || cs[5] == 'C' || cs[5] == 'E' || cs[5] == 'F') {
      extraTagsToWrite += '#P0XO5⌛️';
    }
  }

  // 🔴 This applies h1 but the text is recognized as body not title
  // So its better keep title as plain small text and manually apple Title
  // noteBody = `<div><h1>${noteTitle}</h1></div>` + noteBody;

  var newNote = createNote('P5', noteTitle, noteBody, ['#P0XY⌛️', extraTagsToWrite]);
}

function formatNoteName(newNote) {
  // ---------- TEMPORARY UNTIL Apple fix to use "Notes"
  const isformatNoteName = noteAppNameToUse !== 'com.apple.Notes';

  if (!isformatNoteName) {
    alert(`Title will not be formatted, because "Notes" App come as "${noteAppNameAsIdentifier}"`);
  }
  delay(d1);
  // ----------

  notesApp.activate();
  delay(d3);
  notesApp.show(newNote);
  delay(d0p3); // More time to prevent TAB title // 🔴🔴🔴 Parece que o erro continua
  //tab(1) // Este Tab parece já não ser necessário
  delay(d1);
  selectNextParagraph();

  if (isformatNoteName) {
    doMenu('Notes', 'Format', 'Title');
    // doMenu(noteAppNameToUse, 'Format', 'Title');
  }

  arrowRight(1);
  enter(2);
  arrowUp(1);
}
