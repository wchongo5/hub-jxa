function getXd5MemberInfo(authorId) {
  if (!authorId) {
    throw new Error(`"authorId" inválido`);
  }

  return {
    isXd5Group: authorId.startsWith('1.'),
    isXd5Member: authorId.startsWith('1.1.'),
  };
}

function noteOpenInNewWindow(note) {
  note.show();
  delay(d0p3);
  // doMenu(noteAppNameToUse, 'Window', 'Open Note in New Window');
  doMenu('Notes', 'Window', 'Open Note in New Window');
  delay(d0p3);
}

function applyLinkInSelectionFromClipboard() {
  delay(d0p1);
  seApp.keystroke('k', { using: 'command down' });
  paste();
  enter(1);
  arrowRight(1);
  //enter(1)
}

function processCorrespondeceNoteText(
  production,
  customer4Folders,
  invoiceCSs,
  recipientContractorOrCustomerOrSupplierOrSupervisor,
  interationWay,
  interactionDirection,
  hubParentFolderSubject
) {
  function filterObjectsAndCss(items, filters) {
    return items.filter(item => filters.some(filter => item.includes(filter)));
  }

  const invoiceCs = invoiceCSs[0];

  /*   if (isCs(invoiceCs)) {
    var correspondeceNoteText = getNoteTextAtFolderLevel1ByTitle('P5', invoiceCSs);
  } else {
    var correspondeceNoteText = getNoteTextAtFolderLevel1ByTitle('P1', invoiceCSs);
  }

  const [authorsLinesInfo, objectsAndCssInfo, letterInfo] = correspondeceNoteText
    .match(/——————\n(.*(\n.*)*)\n——————/)[1]
    .split('\n———\n');

  var authorsLines = authorsLinesInfo
    .split('\n')
    // To exclude are 5 because of " | No"
    .filter(authorLine => authorLine.split(' | ').length == 4); */

  const {
    correspondeceNoteText,
    objectsAndCssInfo,
    letterInfo,

    authorsLinesFull,
    authorsLinesClean,
    authorsLinesFullXd5Excluded,
    authorsLinesCleanXd5Excluded,

    author1LinesFull,
    author1LinesFullXd5Excluded,
    author1LinesClean,
    author1LinesCleanXd5Excluded,

    author2LinesFull,
    author2LinesClean,

    author3LinesFull,
    author3LinesClean,

    author1HeadersInfo,
    author2HeadersInfo,
    author3HeadersInfo,
  } = getAuthorsInfo(invoiceCSs);

  const {
    // authorHeader: author3Header,
    // authorName: author3Name,
    authorNameShort: author3NameShort,
  } = getAuthorHeaderInfo(author3HeadersInfo[0], customer4Folders);

  if (
    recipientContractorOrCustomerOrSupplierOrSupervisor === 'Empreiteiro' ||
    recipientContractorOrCustomerOrSupplierOrSupervisor === 'Fiscal'
  ) {
    const authorHeaderInfoSelected = getAuthorHeaderInfoSelected(author3HeadersInfo);

    var { authorHeader: headerSelected, authorNameShort: shortNameSelected } = getAuthorHeaderInfo(
      authorHeaderInfoSelected,
      customer4Folders
    );
  } else if (recipientContractorOrCustomerOrSupplierOrSupervisor === 'Fiscal Residente') {
    const authorHeaderInfoSelected = getAuthorHeaderInfoSelected(author1HeadersInfo.filter(item => item.includes(invoiceCs)));

    var { authorHeader: headerSelected, authorNameShort: shortNameSelected } = getAuthorHeaderInfo(
      authorHeaderInfoSelected,
      customer4Folders
    );
  } else if (
    recipientContractorOrCustomerOrSupplierOrSupervisor === 'Fornecedor' ||
    recipientContractorOrCustomerOrSupplierOrSupervisor === 'Cliente' ||
    recipientContractorOrCustomerOrSupplierOrSupervisor === 'CriarPasta'
  ) {
    var { authorHeader: author2Header1, authorNameShort: shortNameSelected } = getAuthorHeaderInfo(
      author2HeadersInfo[0],
      customer4Folders
    );

    if (
      recipientContractorOrCustomerOrSupplierOrSupervisor != 'CriarPasta' &&
      (author2HeadersInfo.length === 1 || production === 'Solicitação Pagamento' || production === 'Propostas')
    ) {
      var headerSelected = author2Header1;
    } else {
      if (recipientContractorOrCustomerOrSupplierOrSupervisor === 'CriarPasta') {
        authorsLinesCleanXd5Excluded.push('---------------', 'Escrever');
      } else {
        const author2Names = getAuthorNames(author2HeadersInfo);

        var headerOption = cfl2Str(author2Names, `Destinatário — tem mais que um (${author2Names.length})`, author2Names[0]);

        const authorHeaderInfoSelected = author2HeadersInfo.find(item => item.includes(headerOption));

        var { authorHeader: headerSelected, authorNameShort: shortNameSelected } = getAuthorHeaderInfo(
          authorHeaderInfoSelected,
          customer4Folders
        );
      }
    }
  }

  const objectsAndCss = getObjectsAndCss(objectsAndCssInfo.split('\n'));
  const objectsAndCssL = objectsAndCss.length;

  if (objectsAndCssL == 1) {
    var selectedObjectsAndCssStr4servicesAndSiteIDsAndCSs = objectsAndCss[0];

    if (isCs(invoiceCs)) {
      var selectedObjectsAndCssStr = removeLocationID_fromSelectedObjectsAndCss(objectsAndCss)[0];
    } else {
      // GESTÃO
      var selectedObjectsAndCssStr = objectsAndCss[0];
    }

    var selectedObjectsAndCss = objectsAndCss;
  } else {
    if (tableObjectAndCsD == undefined) {
      var tableObjectAndCsD = objectsAndCss[0];
    } else {
      var tableObjectAndCsD = objectsAndCss.filter(item => item.includes(invoiceCs))[0];
    }

    let selectedObjectsAndCssLocal;

    if (recipientContractorOrCustomerOrSupplierOrSupervisor === 'CriarPasta') {
      if (hubParentFolderSubject) {
        selectedObjectsAndCssLocal = filterObjectsAndCss(objectsAndCss, invoiceCSs);
      } else {
        selectedObjectsAndCssLocal = cfl(
          objectsAndCss,
          `"${customer4Folders}" tem mais de um objecto (${objectsAndCssL}).\nSelecione o(s) necessário(s).\n\n\n—\n• Em caso de Fiscalização é eliminada a parte de "Fiscalização da "` +
            '\n',
          tableObjectAndCsD,
          'm'
        );
      }
    } else {
      selectedObjectsAndCssLocal = filterObjectsAndCss(objectsAndCss, invoiceCSs);
    }

    var selectedObjectsAndCssStr4servicesAndSiteIDsAndCSs = selectedObjectsAndCssLocal.join(' & ');

    if (isCs(invoiceCs)) {
      selectedObjectsAndCssLocal = removeLocationID_fromSelectedObjectsAndCss(selectedObjectsAndCssLocal);
    }

    var selectedObjectsAndCssStr = selectedObjectsAndCssLocal.join(' & ');

    var selectedObjectsAndCss = selectedObjectsAndCssLocal;
  }

  // -------------
  const [subjectsInfo, letterBodyInfo] = letterInfo.split('—\n');

  const subjects = subjectsInfo.replace(/Assunto: /g, '');

  const subjectsItems = subjects.split('\n').filter(item => item != '' && !item.includes(' | No'));

  const hasUseThisSubject = subjectsItems.find(item => item.includes(' | UseThis'));

  // if (interationWay === 'Email' && interactionDirection === 'Entrada') {
  //   var subject = undefined;
  // } else {
  if (hasUseThisSubject) {
    var subject = hasUseThisSubject.split(' | ')[0];
  } else if (!hubParentFolderSubject) {
    if (subjectsItems.length === 1) {
      var subject = subjectsItems[0];
    } else {
      var subject = cfl2Str(subjectsItems, 'Escolhe assunto', subjectsItems[0]);
    }
    // }
  }

  const selectedObjects = selectedObjectsAndCss.map(item => item.split(' (')[0]);

  return {
    correspondeceNoteText,
    headerSelected,
    shortNameSelected,
    letterBodyInfo,
    subject,
    hasUseThisSubject,
    selectedObjectsAndCssStr4servicesAndSiteIDsAndCSs,
    selectedObjects,
    selectedObjectsAndCssStr,
    selectedObjectsAndCss,
    authorsLinesFull,
    authorsLinesFullXd5Excluded,
    authorsLinesClean,
    authorsLinesCleanXd5Excluded,

    author1LinesFull, // Not used even in Text XD5
    author2LinesFull,
    author2LinesClean,
    author3LinesFull,
    author3LinesClean,
    author3NameShort,
  };
}

function getAuthorLineInfo(authorLine) {
  const authorLineItems = authorLine.split(' | ');
  if (authorLineItems.length < 4) {
    console.error('Invalid data format', authorLine);
    return;
  }

  const [authorId, authorHeaderOrName, authorRole, authorEmail] = authorLineItems;

  return {
    authorId,
    authorHeaderOrName,
    authorRole,
    authorEmail,
  };
}

function getAuthorsInfo(invoiceCSs) {
  const invoiceCs = invoiceCSs[0];

  if (isCs(invoiceCs)) {
    var correspondeceNoteText = getNoteTextAtFolderLevel1ByTitle('P5', invoiceCSs);
  } else {
    var correspondeceNoteText = getNoteTextAtFolderLevel1ByTitle('P1', invoiceCSs);
  }

  const [authorsLinesInfo, objectsAndCssInfo, letterInfo] = correspondeceNoteText
    .match(/——————\n(.*(\n.*)*)\n——————/)[1]
    .split('\n———\n');

  var authorsLines = authorsLinesInfo
    .split('\n')
    // To exclude are 5 because of " | No"
    .filter(authorLine => authorLine.split(' | ').length == 4);

  const authorsLinesFull = [];
  const authorsLinesClean = [];
  const authorsLinesFullXd5Excluded = [];
  const authorsLinesCleanXd5Excluded = [];

  const author1LinesFull = [];
  const author1LinesClean = [];
  const author1LinesFullXd5Excluded = [];
  const author1LinesCleanXd5Excluded = [];

  const author2LinesFull = [];
  const author2LinesClean = [];

  const author3LinesFull = [];
  const author3LinesClean = [];

  const authorsCentralNamesExclduingMainAuthor = [];

  authorsLines.forEach(authorLine => {
    /*   const authorLineItems = authorLine.split(' | ');
    if (authorLineItems.length < 4) {
      console.error('Invalid data format', authorLine);
      return;
    }

    const [authorId, authorHeaderOrName, authorRole, authorEmail] = authorLineItems; */

    const { authorId, authorHeaderOrName, authorRole, authorEmail } = getAuthorLineInfo(authorLine);

    if (authorId !== '2.1.1' && authorRole === 'Central') {
      authorsCentralNamesExclduingMainAuthor.push(authorHeaderOrName.split(' _ ')[1]);
    }

    const cleanName = authorHeaderOrName.split(` ${newLineDelimiter} `)[0];

    const lineFull = `${authorHeaderOrName} (${authorRole}) / ${authorEmail} / ${authorId}`;
    const lineClean = `${cleanName} (${authorRole}) / ${authorEmail} / ${authorId}`;

    authorsLinesFull.push(lineFull);

    authorsLinesClean.push(lineClean);

    if (authorEmail != xd5Email) {
      authorsLinesFullXd5Excluded.push(lineFull);
      authorsLinesCleanXd5Excluded.push(lineClean);
    }

    if (authorId.startsWith('1')) {
      author1LinesFull.push(lineFull);
      author1LinesClean.push(lineClean);

      if (authorEmail != xd5Email) {
        author1LinesFullXd5Excluded.push(lineFull);
        author1LinesCleanXd5Excluded.push(lineClean);
      }
    }

    if (authorId.startsWith('2')) {
      author2LinesFull.push(lineFull);
      author2LinesClean.push(lineClean);
    }

    if (authorId.startsWith('3')) {
      author3LinesFull.push(lineFull);
      author3LinesClean.push(lineClean);
    }
  });

  // ----------- EmailAndExtrasInfo
  // const authorsLinesFullXd5Excluded = authorsLinesFull.filter(item => !item.includes(xd5Email));

  // const author1LinesFull = authorsLinesFull.filter(item => /\/ 1\.\d+\.\d+$/.test(item));
  // const author1LinesFullXd5Excluded = author1LinesFull.filter(item => !item.includes(xd5Email));

  // const author2LinesFull = authorsLinesFull.filter(item => /\/ 2\.\d+\.\d+$/.test(item));
  // const author3LinesFull = authorsLinesFull.filter(item => /\/ 3\.\d+\.\d+$/.test(item));

  // ----------------------

  // ".map(line => line.split(' (')[0])" removes role from Header
  const author1HeadersInfo = getAuthorHeadersInfo(author1LinesFullXd5Excluded).map(line => line.split(' (')[0]);
  const author2HeadersInfo = getAuthorHeadersInfo(author2LinesFull).map(line => line.split(' (')[0]);
  const author3HeadersInfo = getAuthorHeadersInfo(author3LinesFull).map(line => line.split(' (')[0]);

  return {
    correspondeceNoteText,
    objectsAndCssInfo,
    letterInfo,

    authorsLinesFull,
    authorsLinesClean,
    authorsLinesFullXd5Excluded,
    authorsLinesCleanXd5Excluded,

    authorsCentralNamesExclduingMainAuthor,

    author1LinesFull,
    author1LinesFullXd5Excluded,
    author1LinesClean,
    author1LinesCleanXd5Excluded,

    author2LinesFull,
    author2LinesClean,

    author3LinesFull,
    author3LinesClean,

    author1HeadersInfo,
    author2HeadersInfo,
    author3HeadersInfo,
  };
}

function getAuthorNames(authorHeadersInfo) {
  return authorHeadersInfo.map(item => item.split(' / ')[0].split(` ${newLineDelimiter} `)[0]);
}

function getAuthorNamesShort(authorHeadersInfo) {
  return authorHeadersInfo.filter(item => item.includes(' _ ')).map(item => item.split(' / ')[0].split(' _ ')[1]);
}

function getAuthorHeaderInfoSelected(authorHeadersInfo) {
  if (authorHeadersInfo.length === 1) {
    return authorHeadersInfo[0];
  } else {
    return cfl2Str(authorHeadersInfo, 'Seleccione', authorHeadersInfo[0]);
  }
}

function getAuthorHeadersInfo(authorsLinesInfo) {
  return authorsLinesInfo.filter((item, i) => {
    if (i === 0) {
      return true;
    }
    return item.includes(' _ ');
  });
}

function getAuthorHeaderInfo(authorLine, customer4Folders) {
  if (!authorLine) {
    return {
      authorHeader: undefined,
      authorName: undefined,
      authorNameShort: undefined,
    };
  }

  let authorNameShort = undefined;

  const nameInfoItems = authorLine.split(' / ');
  const authorHeaderAndNameShotItems = nameInfoItems[0].split(' _ ');

  const authorHeaderItems = authorHeaderAndNameShotItems[0].split(` ${newLineDelimiter} `);

  if (authorHeaderAndNameShotItems[1] === undefined) {
    authorNameShort = customer4Folders;
  } else {
    authorNameShort = authorHeaderAndNameShotItems[1].split(' (')[0];
  }

  const authorHeader = authorHeaderItems.join('\n');
  const authorName = authorHeaderItems[0];

  return {
    authorHeader,
    authorName,
    authorNameShort,
  };
}

function workerNameProcess(workerName, upperCase = false, returnFirstAndLastNames = false) {
  if (upperCase) {
    workerName = workerName.toUpperCase();
  }

  if (returnFirstAndLastNames) {
    const workerNameItems = workerName.split(' ');
    workerName = workerNameItems.length > 1 ? `${workerNameItems[0]} ${workerNameItems[workerNameItems.length - 1]}` : workerName;
  }

  return workerName;
}

function getAuthorNameFromAuthorLine(authorLine) {
  const regex = new RegExp(`^(.*?)(?: ${newLineDelimiter} | \\()`);
  const match = regex.exec(authorLine);
  return match ? match[1] : '';
}

