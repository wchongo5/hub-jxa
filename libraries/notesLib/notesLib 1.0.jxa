function getCompanyAndPersonInfo(authorsLinesFull, authorId, customer4Folders, returnCompanyName = false) {
  let isCompany = false;

  const authorLineFull = authorsLinesFull.find(item => item.includes(authorId));

  const [authorHeaderOrNameAndRole] = authorLineFull.split(' / ');

  if (!authorId) {
    return {
      companyShortName: undefined,
      workerName: undefined,
    };
  }

  const authorIdGroupId = authorId.slice(0, 4);
  const authorLinesGroup = authorsLinesFull.filter(author => author.includes(authorIdGroupId));

  let workerName = undefined;

  // if (authorHeaderOrNameAndRole.includes('(Central)')) {
  //   isCompany = true;
  //   var authorLinesGroupWorkers = authorLinesGroup.slice(1, authorLinesGroup.length);
  // } else {
  //   workerName = getAuthorNameFromAuthorLine(authorHeaderOrNameAndRole);
  // }

  if (authorHeaderOrNameAndRole.includes('(Central)')) {
    if (authorHeaderOrNameAndRole.includes(' _ ')) {
      var companyShortName = authorHeaderOrNameAndRole.split(' _ ')[1].split(' (')[0];
    } else {
      var companyShortName = customer4Folders;
    }
  } else {
    if (authorId.includes('1.1.')) {
      var companyShortName = 'X-DIM';
    } else {
      const [authorHeader] = authorLinesGroup[0].split(' / ');

      if (authorHeader.includes(' _ ')) {
        var companyShortName = authorHeader.split(' _ ')[1].split(' (')[0];
      } else {
        var companyShortName = customer4Folders;
      }
    }
  }

  if (authorHeaderOrNameAndRole.includes('(Central)')) {
    isCompany = true;
    var authorLinesGroupWorkers = authorLinesGroup.slice(1, authorLinesGroup.length);
    // workerName = 'Central';

    if (returnCompanyName) {
      workerName = getAuthorNameFromAuthorLine(authorHeaderOrNameAndRole);
    } else {
      workerName = 'Central';
    }
  } else {
    workerName = getAuthorNameFromAuthorLine(authorHeaderOrNameAndRole);
  }

  // workerName = getAuthorNameFromAuthorLine(authorHeaderOrNameAndRole);

  if (workerName === companyShortName) {
    // A partir de segundo email do email do cliente, workerName é igual a companyShortName> Ex. "Comercial" depois de "Central"
    workerName = authorHeaderOrNameAndRole.match(/\(([^)]+)\)/)[1];
  }

  let role;
  if (authorHeaderOrNameAndRole.includes('(')) {
    role = authorHeaderOrNameAndRole.match(/\(([^)]+)\)/)[1];
  }

  return {
    // authorHeaderOrNameAndRole,
    // authorLinesGroup,
    isCompany,
    authorLinesGroupWorkers,
    companyShortName,
    workerName,
    role,
  };
}

