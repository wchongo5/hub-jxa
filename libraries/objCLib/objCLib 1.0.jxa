function writeToFile(pathStr, text, revealFile = true) {

	// OBJ C Não aceita escrever num ficheiro criado por JS
	
	var outputStr = $.NSString.alloc.initWithUTF8String(text);
	var error = $();

	var result = outputStr.writeToFileAtomicallyEncodingError(pathStr, true, $.NSUTF8StringEncoding, error);

	if (result === false) {
	
		var errorDescription = ObjC.unwrap(error.localizedDescription);
		// Added by AChtGPT

		return displayLib.alert("Error", `Failed to write file at "${pathStr}": ${errorDescription}`);
	}

	if (revealFile) {
		finderApp.reveal(Path(pathStr)).extensionHidden = true;
	}

	return result
}


function appendToFile(pathStr, text, revealFile = true) {
	var previousContent = readFile(pathStr)

	var error = $(); // Create an NSError instance

	var outputStr = $(previousContent).stringByAppendingFormat("\n" + text);
	outputStr.writeToFileAtomicallyEncodingError(pathStr, true, $.NSUTF8StringEncoding, error);

	if (revealFile) {
		finderApp.reveal(Path(pathStr)).extensionHidden = true
	}
}

function writeToFileWithAppend(pathStr, text, revealFile) {
	if (finderApp.exists(Path(pathStr))) {
		appendToFile(pathStr, text, revealFile)
	} else {
		writeToFile(pathStr, text, revealFile)
	}
}
