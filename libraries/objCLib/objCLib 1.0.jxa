// --------------------------------------- readFile
function readFile(fileStr) {	
	var error = $(); // Create an NSError instance
	// "$()" is used to pass an uninitialized "NSError" object. If an error occurs when reading the file, the "stringWithContentsOfFileEncodingError" method can set an "NSError" that provides more details about the problem.

	var fileString = $.NSString.alloc.initWithContentsOfFileUsedEncodingError(fileStr, $.NSUTF8StringEncoding, error)

	const fileStringJs = fileString.js; 

	if (fileStringJs === undefined) {
		return displayLib.alert(`Erro`, `O texto é "${fileStringJs}", lendo "${fileStr}".`)
	}

	return fileStringJs;
}

