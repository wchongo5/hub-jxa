function bimAuthenticationCredelecAndInssAndMobileRechargesAndServices(continueDelay, confirmNum) {

	// CONTINUAR
	safariLib.superSafari("click", "class", "Button_button_17jbo   Actions_button_217W7", 1, 0)

	delay(continueDelay) // Aceitou d13

	// CONFIRMAR
	safariLib.superSafari("click", "class", "Button_button_17jbo   Actions_button_217W7", confirmNum, 0)
	delay(d5) // Era d3



	safariLib.superSafari("click", "class", "CheckBox5_inner_2xS5U", 0, 0) // Select SMS
	delay(d1p5)

	var smsCode = displayLib.dialog("Código de autorização", "")

	safariApp.activate();
	delay(d0p3)

	seApp.keystroke(smsCode) // 20210310 Já não aceita shortcut de Paste

	delay(d0p3)

	// AUTORIZAR
	safariLib.superSafari("click", "class", "Button_button_17jbo   Actions_button_217W7", 2, 0)
}
