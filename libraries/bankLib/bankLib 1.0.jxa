function bciMenu(button, groupTrack) {
	safariAppControllerP.windows[0].splitterGroups[0].tabGroups[0].groups[0].groups[0].scrollAreas[0].uiElements[0].groups[1].scrollAreas[0].uiElements[0].groups[2].groups[groupTrack].uiElements.byName(button).uiElements.byName(button).staticTexts.byName(button).click()
}


function bciSubMenuTransfer(button, groupTrack) {
	safariAppControllerP.windows[0].splitterGroups[0].tabGroups[0].groups[0].groups[0].scrollAreas[0].uiElements[0].groups[1].scrollAreas[0].uiElements[0].groups[2].groups[3].uiElements[1].groups[0].groups[groupTrack].uiElements.byName(button).staticTexts.byName(button).click()
}

