function getContractDataByNumber(contractNumber) {
  if (contractNumber === null) {
    return null;
  }

  var contractsTxt = objCLib.readFile(contractsPathStr);
  const contracts = JSON.parse(contractsTxt);

  let contract = contracts.find(contract => contract.number === contractNumber);

  if (!contract) {
    contract = contracts.find(contract => contract.number === '400182221');
  }

  // return contract;
  return { contract, contracts };
}

function addContract({
  appleContactExtended,
  entityType,
  contractNumber,
  entityName,
  contractName,
  contractPercentage,
  contractAmount,
  contractDateCreated,
  contractDateStart,
  contractDateDue,
  headerInfo,
  buildings,
  path,
  lineItems = [],
  payments = [],
  expedients = [],
}) {
  const newContract = {
    id: null,
    appleContactExtended,
    entityType,
    isHub: false,
    number: contractNumber,
    entityName,
    name: contractName,
    description: '',
    authors: [],
    // percentage: contractPercentage,
    total: contractAmount,
    amountPaid: 0,
    amountDue: contractAmount,
    dateCreated: contractDateCreated,
    dateStart: contractDateStart ?? contractDateCreated,
    dateDue: contractDateDue,
    dateCompleted: '',
    status: 'OPEN',
    priority: 0,
    headerInfo, // 🔴🔴 GET FROM Folder
    invoiceFinancials: {
      costPerSquareMeterUSD: 700,
      exchangeRateToMZN: 65,
      wagesPercentage: contractPercentage,
      // vatIncluded: false,
      vatIncluded: contractNumber[2] !== 'W',
      vatPercentage: 16,
      isTotalApplied: false,
      totalCalculated: 0,
      totalApplied: 0,
      total: 0,
      hasRepetitions: false,
      numberOfRepetitions: 5,
      hasPercentageDiscount: false,
      percentageDiscount: 10,
      hasAppliedDiscount: false,
      appliedDiscount: 0, // 7280
      applyManualAmountsInInvoiceItems: false,
      notes: '', // Initialize notes as an empty string
      language: 'pt',
    },
    invoiceItems: null,
    buildingsTotalArea: null,
    buildingsNotes: null,
    // // buildingsInfo: null,
    // buildings: [
    //   // 🔴🔴 GET FROM Folder
    //   {
    //     id: generateUUID(),
    //     code: 'G301',
    //     type: 'Residential',
    //     name: 'NOME',
    //     floors: 1,
    //     startStory: 1,
    //     circulationPercentage: 30,
    //     stories: [],
    //   },
    // ],
    buildings,
    path,
    lineItems,
    payments,
    expedients,
  };

  var contractsTxt = objCLib.readFile(contractsPathStr);
  const contracts = JSON.parse(contractsTxt);
  const newContractUpdated = { ...newContract, id: generateUUID() };

  contracts.push(newContractUpdated);

  objCLib.writeToFile(contractsPathStr, JSON.stringify(contracts, null, 2), false);

  const changesAndTagsDetails = {
    oldObj: null,
    newObj: newContractUpdated,
    folderPathStr: newContractUpdated.path,
    objName: 'contrato',
  };

  saveChangesAndModifyTags(changesAndTagsDetails);
}

function addExpedient({
  contractNumber,
  customer4Folders,
  emailId,
  name,
  dateCreated,
  dateStart,
  dateDue,
  priority,
  usePathAbsolute,
  pathRelative,
  path,
}) {
  const dateStartToUse = dateStart ?? dateCreated;
  let dateStartIcs = null;
  let dateDueToUse = dateDue;
  // const expedientPath = expedient.path;
  const expedientPath = path;

  let expedientIcsPathStr = null;

  const pathStrs = getPathStrsFromPathStr(expedientPath, 'files');

  const pathStrsIcs = pathStrs.filter(path => path.endsWith('.ics'));
  const pathStrsIcsL = pathStrsIcs.length;

  const folderName = getItemNamesFromPathStrs([expedientPath], [''])[0];
  const icsNames = getItemNamesFromPathStrs(pathStrsIcs, ['']);

  if (pathStrsIcsL > 0) {
    if (pathStrsIcsL === 1) {
      expedientIcsPathStr = pathStrsIcs[0];
    } else {
      alert(
        `A pasta "${folderName}" tem mais de 1 ICS ficehiros (${pathStrsIcsL}):\n${icsNames
          .map((n, i) => `${i + 1}. ${n}`)
          .join('\n')}`
      );
    }
  }

  if (expedientIcsPathStr) {
    const { startDate, endDate } = calendarExtractDatesFromIcs(expedientIcsPathStr);

    dateStartIcs = startDate;
    dateDueToUse = endDate;
  }

  const alarmInputs = calculateAlarmInputs(dateStartToUse, dateDueToUse);

  const expedient = {
    id: generateUUID(),
    uid: null,
    updateEventInCalendar: null,
    isRecurrence: null,
    emailId,
    name,
    dateCreated,
    dateStart: dateStartToUse,
    dateStartIcs,
    dateDue: dateDueToUse,
    dateCompleted: '',
    status: 'OPEN',
    priority: priority || 0,
    alarmInputs,
    usePathAbsolute,
    pathRelative,
    path,
    attendees: [],
    note: '',
    recurrenceRule: null,
  };

  /*
    var contractsTxt = objCLib.readFile(contractsPathStr);
    const contracts = JSON.parse(contractsTxt);
    
    let contract = contracts.find(contract => contract.number === contractNumber);
    if (!contract) {
      expedient.name = customer4Folders + ' - ' + name;
      contract = contracts.find(contract => contract.number === '400182221');
      }
      */

  const { contract, contracts } = getContractDataByNumber(contractNumber);
  if (contract.number === '400182221') {
    expedient.name = customer4Folders + ' - ' + name;
  }

  /* 
  const contractTitle = generateContractTitle(contract);
  */

  // ----------- generateContractTitle FUNCTION

  const isHub = contract.isHub;
  let contractsCountStr = '';

  if (isHub) {
    contractsCountStr = ` (${contract.number.split(' - ').length})`;
  }

  const contractTitle = `${contract.entityName}${contractsCountStr}`;

  // -----------

  alert('PASSOU "contractTitle"', contractTitle);

  if (!expedient.usePathAbsolute) {
    expedient.path = null;
  }
  const summary = `${contractTitle} - ${name}`;

  const eventDetails = {
    environment: 'jxa',
    eventUid: null,
    contract,
    expedient, //
    expedientIcsPathStr,
    summary,
    description: `Note updated by ManagerXD5 yet`,
  };

  const stdout = createOrReplaceCalendarEvent(eventDetails);

  const { uid: eventUid } = JSON.parse(stdout);

  alert(stdout, eventUid);

  if (eventUid) {
    expedient.uid = eventUid;
    expedient.updateEventInCalendar = true;
  }

  contract.expedients.push(expedient);

  objCLib.writeToFile(contractsPathStr, JSON.stringify(contracts, null, 2), false);

  const changesAndTagsDetails = {
    oldObj: null,
    newObj: expedient,
    folderPathStr: expedientPath,
    objName: 'expediente',
  };

  saveChangesAndModifyTags(changesAndTagsDetails);
}

function generateExpedients(expedientsInfo) {
  var expedients = [];

  expedientsInfo.forEach(info => {
    expedients.push({
      id: generateUUID(),
      uid: null,
      updateEventInCalendar: null,
      isRecurrence: null,
      emailId: null,
      name: info.name,
      dateCreated: info.dateCreated,
      dateStart: info.dateStart ?? info.dateCreated,
      dateStartIcs: null,
      dateDue: info.dateDue,
      dateCompleted: '',
      status: info.status ?? 'OPEN',
      priority: info.priority ?? 0,
      alarmInputs: [],
      usePathAbsolute: false,
      pathRelative: '',
      path: '',
      attendees: [],
      note: '',
      recurrenceRule: null,
    });
  });

  return expedients;
}

function getFileInfo(filePathStrOrFileObject) {
  let fileObject;

  if (typeof filePathStrOrFileObject === 'string') {
    const filePathAlias = seApp.aliases.byName(filePathStrOrFileObject);
    fileObject = filePathAlias;
  } else {
    // Is FileObject
    fileObject = filePathStrOrFileObject;
  }

  const extensionName = fileObject.nameExtension();
  const fileName = fileObject.name().split(extensionName)[0];
  const dateCreation = fileObject.creationDate();
  const dateModification = fileObject.creationDate();

  return {
    extensionName,
    fileName,
    dateCreation,
    dateModification,
  };
}

function getDischargeInssPdfInfo(pdtText) {
  if (!pdtText) {
    return {
      isDischargeInssPdf: null,
      dischargeInssIssueDate: null,
    };
  }

  let dischargeInssIssueDate = null;

  const isDischargeInssPdf =
    pdtText.includes('Certid') &&
    pdtText.includes('Quita') &&
    pdtText.includes('Instituto Nacional de Seguran') &&
    pdtText.includes('mero de Contribuinte: 090174300') &&
    pdtText.includes('NUIT: 400182221');

  if (isDischargeInssPdf) {
    const datesMatches = pdtText.match(/\b\d{2}\/\d{2}\/\d{4} \d{2}:\d{2}:\d{2}\b/g);
    dischargeInssIssueDate = datesMatches[0].split(' ')[0];
  }

  return {
    isDischargeInssPdf,
    dischargeInssIssueDate,
  };
}

function getInteractionWayInfo(interactionWay) {
  const isMultiAuthor =
    interactionWay === `Encontro` ||
    interactionWay === `Google Meet` ||
    interactionWay === `Telefonema` ||
    interactionWay === `WhatsApp` ||
    interactionWay === `Zoom`;

  const isPlaceBased = interactionWay === `Encontro` || interactionWay === `Hardcopy`;

  return { isMultiAuthor, isPlaceBased };
}

function getInteractionWayAndPlaceInfo(folderType, authorNames) {
  const { officeName } = getXdimInfo();

  let place = null;
  let interactionWayAndPlace = '';

  if (folderType === 'Produção') {
    var interactionWay = folderType;
  } else {
    var interactionWay = cfl2Str(
      ['Email', 'Encontro', 'Hardcopy', '---------------', 'Google Meet', 'Mensagem', 'Telefonema', 'WhatsApp', 'Zoom'],
      'Meio de interação - Produção refere-se a pasta para XD5 somente\n- Encontro inclui apresentação e reuinião',
      'Email'
    );
  }

  const { isMultiAuthor, isPlaceBased } = getInteractionWayInfo(interactionWay);

  if (isPlaceBased) {
    const placeExampleStr = `"SENAMI" ou "${officeName}" ou "KFC 25 SETEMBRO" ou …`;

    place = cfl2Str(
      [officeName, '-----', ...authorNames, '-----', 'Escrever'],
      `Lugar da interação para "${interactionWay}"`,
      officeName
    );

    if (place === 'Escrever') {
      place = dialog(`Escreve o lugar"\n\nEx: ${placeExampleStr}`, '');
    }

    interactionWayAndPlace = `${interactionWay} || ${place}`;
  } else {
    interactionWayAndPlace = interactionWay;
  }

  if (interactionWayAndPlace === 'WhatsApp') {
    var whatsAppPersonalOrGroup = cfl2Str(['Grupo', 'Pessoal'], 'WhatsApp pessoal ou grupo', 'Grupo');

    interactionWayAndPlace += ` ${whatsAppPersonalOrGroup.toUpperCase()}`;
  }

  return {
    interactionWay,
    place, // Not used yet
    interactionWayAndPlace,
    isMultiAuthor,
    isPlaceBased,
  };
}

