function listTasks(rawTasks) {
  const tasks = rawTasks.map(([title, subTasks]) => ({ title, subTasks }));

  const flatTaks = tasks
    .map(({ title, subTasks }, i) => {
      if (subTasks && subTasks.length > 0) {
        subTasks = subTasks.map(subTask => `  • ${subTask}`);
      }

      return [`${i + 1}.  ${title}`, ...(subTasks ?? [])];
    })
    .flat();

  // return flatTaks;

  cfl2Str(flatTaks, `Tarefas e subtarefas (${flatTaks.length})\n🔴🔴🔴`, flatTaks[0]);
}

