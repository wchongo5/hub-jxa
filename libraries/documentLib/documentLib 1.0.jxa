function ensureSpaceAfterCommaInStr(string) {
  // return string.replace(/, /g, ",").replace(/,/g, ", ")
  return string.replace(/, | , /g, ',').replace(/,/g, ', ');
}

/* function trimInStringArray(array) {

} */

function replaceAccentC1(str) {
  // C1 Character 1
  var str = str.replace(/[ÁÓ]+/g, replaceMatch);

  function replaceMatch(match) {
    if (match == 'Á') {
      return 'A';
    } else if (match == 'Ó') {
      return 'O';
    }
  }
  return str;
}

function changeCase(str, caseInput) {
  if (caseInput == 'lower') {
    var someStringCaseChanged = str.toLowerCase();
  } else if (caseInput == 'UPPER') {
    var someStringCaseChanged = str.toUpperCase();
  }
  return someStringCaseChanged;
}

function replaceC(str) {
  // Replace character
  var str = str.replace(/[áãÁÃçÇéÉíÍóõÕÓúÚ]/g, replaceMatch);

  function replaceMatch(match) {
    if (match == 'á' || match == 'ã') {
      return 'a';
    } else if (match == 'Á' || match == 'Ã') {
      return 'A';
    } else if (match == 'ç') {
      return 'c';
    } else if (match == 'Ç') {
      return 'C';
    } else if (match == 'í') {
      return 'i';
    } else if (match == 'Í') {
      return 'I';
    } else if (match == 'é') {
      return 'e';
    } else if (match == 'É') {
      return 'E';
    } else if (match == 'ó' || match == 'õ') {
      return 'o';
    } else if (match == 'Ó' || match == 'Õ') {
      return 'O';
    } else if (match == 'ú') {
      return 'u';
    } else if (match == 'Ú') {
      return 'U';
    }
  }
  return str;
}

function capitalizeText(text, noOrWithExclusions) {
  if (noOrWithExclusions == 'NoExclusions') {
    return text
      .split(' ')
      .map(w => w[0].toUpperCase() + w.substr(1).toLowerCase())
      .join(' ');
  } else if (noOrWithExclusions == 'WithExclusions') {
    var textItems = text.split(' ');
    var textItemsCol = [];

    var abbreviations = ['BIM'];
    var exclusions = 'com, de, da, das, do, dos, e, em, na, nas, no, nos, para';

    for (i = 0; i < textItems.length; i++) {
      // var abbreviations = ["BIM"]
      // var exclusions = "e, de, da, das, do, dos, para, com"

      var word = textItems[i];

      var track = word.toLowerCase().slice(0, 2);
      var textItemL = word.length;

      if (abbreviations.includes(word)) {
        textItemsCol.push(word);
      } else {
        if (isNaN(track[0])) {
          if (exclusions.includes(track) && textItemL < 5) {
            textItemsCol.push(word.toLowerCase());
          } else {
            textItemsCol.push(word[0].toUpperCase() + word.slice(1).toLowerCase());
          }
        } else {
          textItemsCol.push(word);
        }
      }
    }
    return textItemsCol.join(' ');
  }
}

function capitalizeTextIfNotInAbbreviation(text) {
  if (text.includes('CMC') || text.includes('MOPHRH')) {
    return text;
  } else {
    return capitalizeText(text, 'NoExclusions');
  }
}

