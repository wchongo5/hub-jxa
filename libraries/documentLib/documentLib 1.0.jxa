// Display the result
console.log(parts);

// Expected Output:
// [
//   "SALARIORW1C01M202409 + PASTORRW1P02N202409",
//   "SALARIORW1C01M202409 + PASTORRW1P02N202409"
// ] */

/**
 * Function to split the string at the n-th occurrence of the delimiter
 * @param {String} str - The string to be split
 * @param {String} delimiter - The delimiter used for splitting
 * @param {Number} occurrence - The occurrence number at which to split
 * @returns {Array} - An array containing part1 and part2
 */
function splitAtOccurrence(str, delimiter, occurrence) {
  if (occurrence < 1) {
    throw new Error('Occurrence must be a positive integer.');
  }

  let currentIndex = -1;
  let nextIndex = -1;

  // Iterate to find the n-th occurrence
  for (let i = 0; i < occurrence; i++) {
    currentIndex = nextIndex;
    nextIndex = str.indexOf(delimiter, currentIndex + 1);
    if (nextIndex === -1) {
      // If the specified occurrence is not found, return the original string in an array
      return [str];
    }
  }

  // Extract part1: from the start up to (but not including) the n-th occurrence
  let part1 = str.substring(0, nextIndex);

  // Extract part2: from the n-th occurrence to the end (includes the delimiter)
  let part2 = str.substring(nextIndex);

  return [part1, part2];
}

// NOT USED IN JXA YET
function replaceAccents(str, replaceFirstFound = false, firstCharOnly = false) {
  var accents = /[\u0300-\u036f]/g;

  if (firstCharOnly) {
    var firstChar = str[0].normalize('NFD');
    var restOfString = str.slice(1);

    if (accents.test(firstChar)) {
      return firstChar.replace(accents, '').normalize('NFC') + restOfString;
    } else {
      return str;
    }
  } else {
    var foundAccent = false;
    var originalChars = Array.from(str);

    var result = originalChars.map(char => {
      var isAccented = accents.test(char.normalize('NFD'));
      if (!foundAccent && isAccented) {
        foundAccent = true;
        return char.normalize('NFD').replace(accents, '').normalize('NFC');
      }
      return char;
    });

    return replaceFirstFound && foundAccent ? result.join('') : str.normalize('NFD').replace(accents, '').normalize('NFC');
  }
}

