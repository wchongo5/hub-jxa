function generateStrFromCFL(items, prompt, defaultItems, includeCommasInReturn = false) {
  var itemsSelected = cfl(items, prompt, defaultItems, 'm');

  if (includeCommasInReturn) {
    return itemsSelected.join(', ');
  } else {
    return itemsSelected.join(' ');
  }
}

function areStringsEqual(str1, str2) {
  // NOT USED YET
  var normalizedStr1 = str1.normalize('NFC');
  var normalizedStr2 = str2.normalize('NFC');

  return normalizedStr1 === normalizedStr2;
}

function doesStr1IncludeStr2(str1, str2) {
  var normalizedStr1 = str1.normalize('NFC');
  var normalizedStr2 = str2.normalize('NFC');

  // if (normalizedStr1.endsWith("_")) {

  //  alert(`${normalizedStr1}`, ``)
  // }

  return normalizedStr1.includes(normalizedStr2);
  //  return (normalizedStr1.includes(normalizedStr2) && !normalizedStr1.endsWith("_.pdf"));
}

function deletePreviousFile(fileNames, fileName) {
  return fileNames.find(fileNameExisting => {
    // 00T02 _ ERMELINDA CHIRUTE _ TERMO DE RESPONSABILIDADE _ 20231109-135336-V1

    let fileNameExistingDate = null;

    const matchesDate = fileNameExisting.match(/\d{8}-\d{6}/);

    if (matchesDate) {
      fileNameExistingDate = matchesDate[0].split('-')[0];
    }

    const fileNameDate = dateY4M2D2;

    return doesStr1IncludeStr2(fileNameExisting, fileName) && fileNameExistingDate == fileNameDate;
  });
}

// --------------------------------------- pdfMerger

/*
var pdfFinderSelection  = finderApp.selection()

pdfMerger(pdfFinderSelection, "pdfFinderSelection")
//pdfMerger(pdfPathStrs, "pdfPathStrs")
*/

function pdfMerger(pdfFinderSelectionOrPdfPathStrs, inputOption, whereToAddPdfs, openNewPdf = false) {
  if (inputOption == 'pdfFinderSelection') {
    var pdfFinderSelection = pdfFinderSelectionOrPdfPathStrs;
    var pdfPathStrs = [];

    for (var i = 0; i < pdfFinderSelection.length; i++) {
      var pdfPathStr = decodeURI(pdfFinderSelection[i].url()).slice(7);
      pdfPathStrs.push(pdfPathStr);
    }
  } else if (inputOption == 'pdfPathStrs') {
    var pdfPathStrs = pdfFinderSelectionOrPdfPathStrs;
  }

  var newPdfDoc = $.PDFDocument.alloc.init; // new empty PDF Doc;
  var pdf1PathStr = pdfPathStrs[0];

  // Com este pop() pdf1PathStr indica a pasta pois já não tem nome
  var pdf1PathStrItems = pdf1PathStr.split('/');
  var pdf1Name = pdf1PathStrItems.pop();

  var pdf1PathAlias = seApp.aliases.byName(pdf1PathStr);

  // "00T0" - docs de técnicos
  // "00X0" - docs de parte escrita - Projecto (Memórias, Especificações, …) - Plano (Regulamento, Relatório, …)
  // "00XYZ" Índice (primeira folha) de Projecto ou Plano

  var a5OrU5WritingPartPdfsFileNames = getItemNamesFromPathStrs(pdfPathStrs, ['00T0', '00X0', '00XYZ']);

  if (pdf1Name.includes(' - 00 CAPA')) {
    // var newPdfName = pdf1Name.split(" - ")[0] + ".pdf"
    var newPdfName = `${pdf1Name.split(' _ ')[0]}.pdf`;
  } else if (pdf1Name.startsWith('X-DIM PERFIL _ ')) {
    const pdfPathStrLast = pdfFinderSelectionOrPdfPathStrs.slice(-1)[0];
    const pdfPathStrLastDate = pdfPathStrLast.match(/(\d{8}-\d{6})/)[0];

    var newPdfName = `${pdf1Name.split(' _ ')[0]} ${pdfPathStrLastDate}.pdf`;
  } else if (a5OrU5WritingPartPdfsFileNames.length > 0) {
    var contratFolderInfo = getContratFolderInfo(pdfPathStrs[0]);

    var invoiceCs = contratFolderInfo.contractNumber;
    var customer4Folders = contratFolderInfo.entity4Folders;
    // var customerFolderName = contratFolderInfo.contractFolderName
    var consultancyFolderPathStr = contratFolderInfo.contractFolderPathStr;

    if (a5OrU5WritingPartPdfsFileNames[0].includes('XYZ')) {
      var newPdfName = `00XP02 ${ND} ${customer4Folders} ${ND} PARTE DESENHADA ${invoiceCs} ${ND} ${dateY4M2D2__H2M2S2}-V1.pdf`;
    } else if (a5OrU5WritingPartPdfsFileNames[0].includes('00X00 CAPA')) {
      var newPdfName = `00X00EM ${ND} ${customer4Folders} ${ND} QUANTIDADE DE MATERIAL ${invoiceCs} ${ND} ${dateY4M2D2__H2M2S2}-V1.pdf`;
    } else if (
      a5OrU5WritingPartPdfsFileNames[0].includes('00T0') &&
      a5OrU5WritingPartPdfsFileNames.slice(-1)[0].startsWith('00X0')
    ) {
      var newPdfName = `00XX00 ${ND} ${customer4Folders} ${ND} DOCUMENTOS DOS TÉCNICOS E PARTE ESCRITA ${invoiceCs} ${ND} ${dateY4M2D2__H2M2S2}-V1.pdf`;
    } else if (a5OrU5WritingPartPdfsFileNames[0].includes('00T0')) {
      var newPdfName = `00T00 ${ND} ${customer4Folders} ${ND} DOCUMENTOS DE TÉCNICOS ${invoiceCs} ${ND} ${dateY4M2D2__H2M2S2}-V1.pdf`;
    } else {
      var newPdfName = `00XP01 ${ND} ${customer4Folders} ${ND} PARTE ESCRITA ${invoiceCs} ${ND} ${dateY4M2D2__H2M2S2}-V1.pdf`;
    }
  } else {
    if (whereToAddPdfs == 'addInPdf1') {
      var newPdfName = pdf1Name;
    } else if (whereToAddPdfs == 'addInNewPdfWihtNewName') {
      var newPdfName = dialog(`Nome para novo PDF.`, pdf1Name.split('.pdf')[0] + ' + MERGEDPDFs') + '.pdf';
    }
  }

  var newPdfPathStrNew = pdf1PathStrItems.join('/') + '/' + newPdfName;

  var pdfNewURL = $.NSURL.fileURLWithPath(newPdfPathStrNew);

  for (var i = 0; i < pdfPathStrs.length; i++) {
    var newPdfNumPages = newPdfDoc.pageCount;

    var pdfPathStr = pdfPathStrs[i];

    var currentPdfURL = $.NSURL.fileURLWithPath(pdfPathStr);
    var currentPdfDoc = $.PDFDocument.alloc.initWithURL(currentPdfURL);
    var currentPdfNumPages = currentPdfDoc.pageCount;

    for (var j = 0; j < currentPdfNumPages; j++) {
      var page = currentPdfDoc.pageAtIndex(j);
      newPdfDoc.insertPageAtIndex(page, Number(newPdfNumPages) + j);
    }

    newPdfDoc.writeToURL(pdfNewURL);
  }

  if (a5OrU5WritingPartPdfsFileNames.length > 0) {
    delay(d1);

    moveItems([newPdfPathStrNew], consultancyFolderPathStr);
    delay(d1);

    var newPdfPathStrNew = consultancyFolderPathStr + '/' + newPdfName;
    delay(d1);
  }

  finderApp.reveal(Path(newPdfPathStrNew)).extensionHidden = true;

  if (openNewPdf) {
    delay(d1);
    finderApp.open(Path(newPdfPathStrNew));
  }
}

function readPdfText(pathStr) {
  var pdfURL = $.NSURL.fileURLWithPath(pathStr);
  var pdfDoc = $.PDFDocument.alloc.initWithURL(pdfURL);

  var pdfDocNumPages = pdfDoc.pageCount;

  // alert('Páginas', pdfDocNumPages);

  // pdfDocNumPages == 2 para TVCabo Pagamento e Recibo faltando factura
  if (pdfDocNumPages == 1 || pdfDocNumPages == 2) {
    var pageIndex = 0;
  } else if (pdfDocNumPages > 2) {
    var pageIndex = 1;
  }

  // alert(pageIndex.toString());

  var pdfPage1 = pdfDoc.pageAtIndex(pageIndex);

  // alert('2');

  return $(pdfPage1.string).js; // Returns " " is scanned PDF
}

/* 
  
  The issue you're experiencing stems from the inherent complexity of PDF files. PDFs are designed primarily for accurately rendering content on a page, not necessarily for preserving the logical reading order of text. As a result, when you extract text using pdfPage1.string, the words may not come out in the sequence you expect because the PDF's internal structure might store text in a different order than it appears visually.

  The PDFPage class provides a method called selectionsByLine() that returns an array of PDFSelection objects, each representing a line of text on the page. By iterating over these selections, you can extract text line by line, which often preserves the correct reading order.
*/

