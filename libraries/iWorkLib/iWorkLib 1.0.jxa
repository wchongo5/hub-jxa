}

function checkRowAvailabilityAndAddIfNotFound(table, belowRowsNumToExclude, [textToWriteIfAvailable, columnWhereToWrite]) {
  var tableRowsL = table.rowCount() - belowRowsNumToExclude;

  for (var i = 5; i < tableRowsL; i++) {
    var iSum = i + 1;
    var columnA_Identifier = table.cells['A' + iSum].value();

    if (columnA_Identifier == null) {
      writeInRowAvailable(table, iSum, [textToWriteIfAvailable, columnWhereToWrite]);
      break;
    } else {
      if (i == tableRowsL - 1) {
        table.cells['A' + iSum].addRowBelow();

        writeInRowAvailable(table, iSum + 1, [textToWriteIfAvailable, columnWhereToWrite]);
      }
    }
  }
}

function clearRange(table, rangeName) {
  delay(d0p3);
  selectionRange(table, rangeName);
  delay(d0p3);
  systemLib.pressDelete(1);
}

function deleteColumns(table, numOfRowsToDelete, referenceColumnNum) {
  for (var i = 0; i < numOfRowsToDelete; i++) {
    table.columns[referenceColumnNum].delete();
  }
}

function deleteRows(table, numOfRowsToDelete, referenceRownNum) {
  for (var i = 0; i < numOfRowsToDelete; i++) {
    table.rows[referenceRownNum].delete();
  }
}

function deleteTablesByName(sheet, tablesNamesToDelete) {
  for (var i = 0; i < tablesNamesToDelete.length; i++) {
    sheet.tables[tablesNamesToDelete[i]].delete();
  }
}

function exportDoc(iWorkApp, pathStr, expExtension) {
  if (expExtension.toLowerCase().includes('excel')) {
    iWorkApp.export({ to: Path(pathStr), as: expExtension, withProperties: { excludeSummaryWorksheet: true } });
  } else {
    iWorkApp.export({ to: Path(pathStr), as: expExtension });
  }
}

function getCellNamePartColumnOrRow(cellName, columnOrRow) {
  if (columnOrRow == 'columnName') {
    return cellName.match(/[A-Z]*/)[0];
  } else if (columnOrRow == 'rowName') {
    return Number(cellName.match(/\d{1}\d*/)[0]);
  }
}

function getFileExtensionFromNameOrUrl(fileName) {
  try {
    return fileName.match(/\.(\w*$)/)[1];
  } catch {
    return null;
  }
}

function getTableInfo(table) {
  // 🔴🔴🔴  NOT USED

  var tableRowsL = table.rowCount();
  var tableColumnsL = table.columnCount();

  // Get Rows with information
  for (var i = 0; i < tableRowsL; i++) {
    var iSum = i + 1;
    var aValue = table.cells['A' + iSum].value();

    if (aValue == null) {
      var numberOfRowsWithInfo = i; //+ 1
      break;
    }
  }

  var reportSection3Items = [];
  var rowValues = [];

  for (var i = 0; i < numberOfRowsWithInfo; i++) {
    for (var j = 0; j < tableColumnsL; j++) {
      var cellValue = table.rows[i].cells[j].value();

      if (cellValue != null || (cellValue == null && j > 0)) {
        if (cellValue == null) {
          rowValues.push('');
        } else {
          rowValues.push(cellValue);
        }
      }
    }

    reportSection3Items.push(rowValues.join('\t'));
    var rowValues = []; // Reset
  }

  return reportSection3Items.join('\n');
}

function getTableInfoVertixCoordTable(table) {
  var tableRowsL = table.rowCount();
  var tableColumnsL = table.columnCount();

  // Get Rows with information
  for (var i = 0; i < tableRowsL; i++) {
    var iSum = i + 1;
    var aValue = table.cells['A' + iSum].value();

    if (aValue == null) {
      var numberOfRowsWithInfo = i; //+ 1
      break;
    }
  }

  var reportSection3Items = [];
  var rowValues = [];

  for (var i = 0; i < numberOfRowsWithInfo; i++) {
    for (var j = 0; j < tableColumnsL; j++) {
      var cellValue = table.rows[i].cells[j].value();

      if (cellValue != null || (cellValue == null && j > 0)) {
        if (cellValue == null) {
          rowValues.push('');
        } else {
          // i > 0 After header
          if (i > 0) {
            if (j == 1 || j == 2) {
              var cellValue = formatNumber(cellValue, 9, 9);
            } else if (j == 3) {
              var cellValue = formatNumber(cellValue, 1, 1);
            }
          }

          rowValues.push(cellValue);
        }
      }
    }

    reportSection3Items.push(rowValues.join('\t'));
    var rowValues = []; // Reset
  }

  return reportSection3Items.join('\n');
}

function hideColumns(table, columnsLetters) {
  for (var i = 0; i < columnsLetters.length; i++) {
    // var columnLetter = columnsLetters[i]
    // selectionRange(table, columnLetter + "1")
    selectionRange(table, columnsLetters[i] + '1');
    menuLib.doMenu('Numbers', 'Table', 'Hide Column');
  }
}

function hideRows(table, numOfRowsToHide, referenceRownNum) {
  for (var i = 0; i < numOfRowsToHide; i++) {
    // var columnLetter = columnsLetters[i]
    // selectionRange(table, columnLetter + "1")

    selectionRange(table, 'A' + (referenceRownNum + i));
    menuLib.doMenu('Numbers', 'Table', 'Hide Row');
  }
}

function hideRowsRange(table, numOfRowsToHide, rangeName) {
  selectionRange(table, rangeName);

  if (numOfRowsToHide == 1) {
    menuLib.doMenu('Numbers', 'Table', 'Hide Row');
  } else {
    //menuLib.doMenu("Numbers", "Table", "Hide '" + numOfRowsToHide + "' Rows")
    menuLib.doMenu('Numbers', 'Table', 'Hide ' + numOfRowsToHide + ' Rows');
  }
}

function mergeCells(table, rangeName) {
  delay(d0p3);
  table.ranges[rangeName].merge();
  delay(d0p3);
}

function rowPopulateItems(table, itemsToPopulate, rowIndex) {
  for (var i = 0; i < itemsToPopulate.length; i++) {
    table.rows[rowIndex].cells[i].value = itemsToPopulate[i];
  }
}

function rowsSelectionNumInColumn(table, range) {
  selectionRange(table, range);
  delay(d0p3);
  menuLib.copy();
  delay(d0p3);

  /*
   return menuLib.theClipboard().split("\r")
		.map(item => item != "")
		.length - 3
		*/

  const clipboardItemsL = menuLib.theClipboard().split('\r').length;

  if (clipboardItemsL === 1) {
    // ["Varão 12"]
    // Copying one cell does not include extra items
    return clipboardItemsL;
  } else {
    // ["", "Varão 12 (Pilares 2)", "Varão 12", "", ""]
    // ("") at start and at end (, "", "") are extra items when copying two cells
    return clipboardItemsL - 3;
  }
}

function selectionRange(table, rangeName) {
  delay(d0p3);
  table.selectionRange = table.ranges[rangeName];
  delay(d0p3);
}

function setDecimals(numbersAppControllerP, table, rangeName, increment, incrementOption) {
  delay(d0p3);

  // ---- NEW
  numbersActivateFormatIndex(numbersAppControllerP, 1); // "Cell"
  delay(d0p3); // 🔴🔴🔴 Testar d0p3
  selectionRange(table, rangeName);
  delay(d0p3); // 🔴🔴🔴 Testar d0p3
  // -----

  for (var i = 0; i < increment; i++) {
    delay(d0p3);

    if (incrementOption == 'Up') {
      //numbersAppControllerP.windows[0].scrollAreas[3].incrementors[0].buttons[0].click()

      // Numbers v12.2 // 20221117
      numbersAppControllerP.windows[0].scrollAreas[2].incrementors[0].buttons[0].click();

      //.scrollAreas.at(2).incrementors.at(0).buttons.at(0)
    } else if (incrementOption == 'Down') {
      numbersAppControllerP.windows[0].scrollAreas[2].incrementors[0].buttons[1].click();
    }
  }

  delay(d0p3);
}

function sumFromSelectionRange(table, range) {
  selectionRange(table, range);
  delay(d0p3);
  menuLib.copy();
  delay(d0p3);

  var arryOfNumbers = menuLib.theClipboard().split('\r');

  return sumAllByReduce(arryOfNumbers);
}

function tableDelimeterUpdate(numbersAppControllerP, table) {
  numbersActivateFormatIndex(numbersAppControllerP, 0); // Activate table

  selectionRange(table, 'A7');

  numbersAppControllerP.windows[0].scrollAreas[2].buttons.byName('Adjust Import Settings…').click();
  delay(d0p3);

  numbersAppControllerP.windows[0].sheets[0].radioGroups[0].radioButtons[0].click();
  delay(d0p3);

  numbersAppControllerP.windows[0].sheets[0].groups[0].scrollAreas[0].groups[0].checkboxes[0].click(); // select "tab"
  delay(d0p3);

  numbersAppControllerP.windows[0].sheets[0].groups[0].scrollAreas[0].groups[0].checkboxes[1].click(); // deselet ","
  delay(d0p3);

  numbersAppControllerP.windows[0].sheets[0].buttons.byName('Update Table').click();
  delay(d0p3);
}

function tableOutlineNone(numbersAppControllerP, table, rangeName) {
