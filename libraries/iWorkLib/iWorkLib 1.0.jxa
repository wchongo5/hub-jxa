// 🔴🔴🔴 NOT USED YET
function addColumns(table, numOfColumnsToAdd, referenceColumnNum, position) {
  for (var i = 0; i < numOfColumnsToAdd; i++) {
    if (position == 'addColumnAfter') {
      table.columns[referenceColumnNum].addColumnAfter();
    } else if (position == 'addColumnBefore') {
      table.columns[referenceColumnNum].addColumnBefore();
    }
  }
}

function addRows(table, numOfRowsToAdd, referenceRownNum, position) {
  for (var i = 0; i < numOfRowsToAdd; i++) {
    if (position == 'addRowAbove') {
      table.rows[referenceRownNum].addRowAbove();
    } else if (position == 'addRowBelow') {
      table.rows[referenceRownNum].addRowBelow();
    }
  }
}

function alignHorizontal(table, rangeName, alignOption) {
  // "auto align"/‌"center"/‌"justify"/‌"left"/‌"right"
  table.ranges[rangeName].alignment = alignOption;
}

function alignVertical(table, rangeName, alignOption) {
  // "bottom"/‌"center"/‌"top
  table.ranges[rangeName].verticalAlignment = alignOption;
}

function alignHorizontalAndVertical(table, rangeName, horizontalAlignOption, verticalAlignOption) {
  table.ranges[rangeName].alignment = horizontalAlignOption;
  delay(d0p3);
  table.ranges[rangeName].verticalAlignment = verticalAlignOption;
}

function applyBackgroundColor(table, rangeName, color) {
  //delay(d0p3)
  table.ranges[rangeName].backgroundColor = color;
  //delay(d0p3)
}

function applyFontSize(table, rangeName, fontSizeNum) {
  //delay(d0p3)
  table.ranges[rangeName].fontSize = fontSizeNum;
  //delay(d0p3)
}

function applyFormulaResults(table, rangeName) {
  selectionRange(table, rangeName);
  menuLib.copy();
  menuLib.doMenu('Numbers', 'Edit', 'Paste Formula Results');
  systemLib.scape();
}

function applyTextColor(table, rangeName, color) {
  //delay(d0p3)
  table.ranges[rangeName].textColor = color;
  //delay(d0p3)
}

function bold(table, rangeName) {
  // numbersActivateFormatIndex(numbersAppControllerP, "Text")
  // delay(d0p3)
