function numbersSheetDuplicate(numbersAppControllerP, docNumbers, sheetNameReference, sheetName) {
  delay(d0p3);
  docNumbers.activeSheet.set(docNumbers.sheets[sheetNameReference]);
  delay(d0p3);

  try {
    numbersAppControllerP.windows[0].buttons['Duplicate Sheet'].click();
  } catch (error) {
    // SCAPE HERE

    systemLib.scape();
    // delay(d0p3)
    numbersAppControllerP.windows[0].buttons['Duplicate Sheet'].click();
  }
  delay(d0p3);

  // 00X00E SUPERFÍCIES 305-1
  // ----- CHANGE NAME
  //var sheetName = sheetNameReference.replace(/\d{3}/,buildingNum)

  docNumbers.sheets[`${sheetNameReference}-1`].name = sheetName;
  delay(d0p3);
}

function numbersSheetDuplicateAndUpdatePrefixNumber(numbersAppControllerP, docNum, customer4Folders) {
  // const docNumName = docNum.name()
  // const nextNumberIsNumber = docNumName.includes("ARCHIVED");
  const nextNumberIsNumber = numbersDocIsArchived(docNum);

  const { sheetFilterName, sheetTemplateName } = numbersSheetGetFilterAndNameReference(docNum);

  const proposalSheetNames = docNum.sheets
    .whose({
      _and: [{ name: { _contains: sheetFilterName } }, { _not: [{ name: { _beginsWith: templateProjAndPropGeneralPartName } }] }],
    })
    .name();

  const sheetNumbers = proposalSheetNames.map(sheet => sheet.split(' ')[0]);
  sheetNumbers;

  // Separate letters and numbers into two arrays
  const letters = sheetNumbers.filter(num => isNaN(Number(num)));
  const numbers = sheetNumbers.filter(num => !isNaN(Number(num)));

  // Sort each array in descending order
  letters.sort((a, b) => b.localeCompare(a));
  numbers.sort((a, b) => Number(b) - Number(a));

  // Determine the current sheetNumber
  const currentSheetNumber = letters.length > 0 ? letters[0] : numbers[0];

  const nextSheetNumber = getNextNumberOrLetter(currentSheetNumber, nextNumberIsNumber);

  // console.log(nextSheetNumber); // This will log '2' for the given example

  const sheetName = `${nextSheetNumber} ${sheetFilterName} ${customer4Folders}`;

  numbersSheetDuplicate(numbersAppControllerP, docNum, sheetTemplateName, sheetName);

  return sheetName;
}

