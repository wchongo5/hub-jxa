			sheetTemplateName = "0 PROP - TEMPLATE"
		}

		return {
			sheetFilterName,
			sheetTemplateName,
		}
	}

	return alert(`Erro. O nome "${docNumName}" deve incluir "${projSheetFilterName}" ou "${propSheetFilterName}"`, ``)
}
*/

function numbersSheetGetFilterAndNameReference(docNum) {
  const PROJ_SHEET_FILTER_NAME = 'PROJ -';
  const PROP_SHEET_FILTER_NAME = 'PROP -';
  const PROJ_TEMPLATE_NAME = '0 PROJ - TEMPLATE';
  const PROP_TEMPLATE_NAME = '0 PROP - TEMPLATE';
  // const docNumName = docNum.name();

  let sheetInfo = {};

  // if (docNumName.includes("TEXT XA5")) {
  if (numbersDocIsTextXA5(docNum)) {
    sheetInfo = {
      sheetFilterName: PROJ_SHEET_FILTER_NAME,
      sheetTemplateName: PROJ_TEMPLATE_NAME,
    };
    // } else if (docNumName.includes("TEXT XG5")) {
  } else if (numbersDocIsTextXG5(docNum)) {
    sheetInfo = {
      sheetFilterName: PROP_SHEET_FILTER_NAME,
      sheetTemplateName: PROP_TEMPLATE_NAME,
    };
  } else {
    return alert(`Erro. O nome "${docNum.name()}" deve incluir "${PROJ_SHEET_FILTER_NAME}" ou "${PROP_SHEET_FILTER_NAME}"`, ``);
  }

  return sheetInfo;
}

function numbersSheetsUpdatePrefixNumbers(docNumXG5) {
  const docNumName = docNumXG5.name();
  const nextNumberIsNumber = docNumName.includes('ARCHIVED');

  const { sheetFilterName } = numbersSheetGetFilterAndNameReference(docNumXG5);

  const sheets = docNumXG5.sheets.whose({
    _and: [{ name: { _contains: sheetFilterName } }, { _not: [{ name: { _beginsWith: templateProjAndPropGeneralPartName } }] }],
  });

  /*
	const generateCorrectedIdentifiers = (length) => {
		const correctedIdentifiers = [];
		let currentIdentifier = '0'; // Start with string '1'

		for (let i = 0; i < length; i++) {
			correctedIdentifiers.push(currentIdentifier);
			currentIdentifier = getNextNumberOrLetter(currentIdentifier, nextNumberIsNumber);
		}

		return correctedIdentifiers;
	};
	*/

  const generateCorrectedIdentifiers = (length, nextNumberIsNumber) => {
    const correctedIdentifiers = [];
    let currentIdentifier = nextNumberIsNumber ? '0' : '1'; // Adjust starting point based on nextNumberIsNumber
    // let currentIdentifier = '1'

    for (let i = 0; i < length; i++) {
      // correctedIdentifiers.push(currentIdentifier);
      // currentIdentifier = getNextNumberOrLetter(currentIdentifier, nextNumberIsNumber);

      if (nextNumberIsNumber) {
        currentIdentifier = getNextNumberOrLetter(currentIdentifier, nextNumberIsNumber);
        correctedIdentifiers.push(currentIdentifier);
      } else {
        correctedIdentifiers.push(currentIdentifier);
        currentIdentifier = getNextNumberOrLetter(currentIdentifier, nextNumberIsNumber);
      }
    }

    // var theVariable = cfl2Str(correctedIdentifiers, "Referência", correctedIdentifiers[0])

    return correctedIdentifiers;
  };

  const correctedIdentifiers = generateCorrectedIdentifiers(sheets.length, nextNumberIsNumber);
  const correctedIdentifiersDescendent = correctedIdentifiers.slice().reverse();

  // var theVariable = cfl2Str(correctedIdentifiersDescendent, "Referência", correctedIdentifiersDescendent[0])

  for (let i = 0; i < sheets.length; i++) {
    const [currentNumber, ...restOfName] = sheets[i].name().split(' ');

    // alert(`${i}\n\n${sheets[i].name()}\n\n${currentNumber}\n\n${correctedIdentifiersDescendent[i]}`, ``)

    if (currentNumber != correctedIdentifiersDescendent[i]) {
      console.log(currentNumber);

      sheets[i].name = `${correctedIdentifiersDescendent[i]} ${restOfName.join(' ')}`;
    }
  }
}

function numbersQuoteChargedPercentage(tableInputs1) {
  var appliedAmountCheck = tableInputs1.cells['F15'].value();

  if (appliedAmountCheck == 1) {
    // Will bring symbol only if is X%. 0.3% comes as number 0.003
    var chargedPercentageWithoutSymbol = tableInputs1.cells['C15'].value();

    if (Number(chargedPercentageWithoutSymbol)) {
      var chargedPercentage = formatNumber((chargedPercentageWithoutSymbol * 100).toString(), 2, 2);
    } else {
      var chargedPercentage = chargedPercentageWithoutSymbol.replace('%', '');
    }
  } else {
    var chargedPercentage = formatNumber((tableInputs1.cells['E12'].value() * 100).toString(), 2, 2);
  }

  var chargedPercentageItems = chargedPercentage.split('.');
  var chargedPercentageDecimalPart = chargedPercentageItems[1];

  // O "X" é de valor aplicado de percentagem X%
  if (chargedPercentageItems[0] != 'X') {
    if (chargedPercentageDecimalPart == '00') {
      var chargedPercentage = chargedPercentageItems[0];
    } else if (chargedPercentageDecimalPart.slice(-1) == '0') {
      var chargedPercentage = chargedPercentage.slice(0, chargedPercentage.length - 1);
    } else {
      var chargedPercentage = chargedPercentage;
    }
  }

  return chargedPercentage;
}

// function numbersWriteReference(numbersApp, docNumbers, productionTypeCode, referenceNumberWithDate, referenceToWrite) {
function numbersWriteReference(
  numbersApp,
  docNumbers,
  referenceNumberWithDate,
  referenceNumberIncrement1,
  referenceToWrite,
  filePathSaved
) {
  numbersApp.activate();
  // var referenceTableName = numbersReferenceTableName(productionTypeCode)
  // var tableReference = docNumbers.sheets["CUSTOMERS&SUPPLIERS"].tables[referenceTableName]
  var tableReference = docNumbers.sheets['CUSTOMERS&SUPPLIERS'].tables['OneTableForReference'];

  // const referenceNumberWithDateItems =

  const referenceNumberWithDateItems = referenceNumberWithDate.split(' | ');

  // tableReference.cells["A1"].value = referenceNumberWithDate
  tableReference.cells['A2'].addRowAbove();
  tableReference.cells['A2'].value = referenceNumberWithDateItems[1];
  tableReference.cells['B2'].value = referenceNumberIncrement1;
  tableReference.cells['C2'].value = referenceNumberWithDateItems[0][0]; // companyIdentifier
  tableReference.cells['D2'].value = referenceNumberWithDateItems[0];

  // XD24A5P03 is A for referenceNumberWithDateItems[1][6]
  tableReference.cells['E2'].value = projectLib.getDisciplineByC1(referenceNumberWithDateItems[0][4]);

  // XD24A5P03 is P for referenceNumberWithDateItems[1][6]
  tableReference.cells['F2'].value = projectLib.getServiceByC1(referenceNumberWithDateItems[0][6]);
  tableReference.cells['G2'].value = referenceToWrite;
  tableReference.cells['H2'].value = filePathSaved;
}

