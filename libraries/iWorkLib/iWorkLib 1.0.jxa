}

function tableTitleAlign(numbersAppControllerP, alignPosition) {
  var alignPositionDict = { Left: 0, Center: 1, Right: 2, Justify: 3 };

  // Alighn Title left
  // Before version 12.X
  //numbersAppControllerP.windows[0].scrollAreas[2].groups[1].checkboxes[0].click()

  numbersAppControllerP.windows[0].scrollAreas[1].groups[1].checkboxes[alignPositionDict[alignPosition]].click();
}

function textWrap(numbersAppControllerP, table, rangeName) {
  delay(d0p3);
  numbersActivateFormatIndex(numbersAppControllerP, 2); // "Text"
  delay(d0p3);
  table.ranges[rangeName].textWrap = true;
  delay(d0p3);
}

function thousandsSeparator(numbersAppControllerP, table, rangeName, rangeFormat) {
  selectionRange(table, rangeName);
  numbersActivateFormatIndex(numbersAppControllerP, 1); // "Cell"

  // Numbers 12.2 não aceita Thousands se for "Automatic" por isso mudei para "Number"
  // 🔴🔴🔴🔴 "Automatic" não será usado, se continuar no futuro pode eliminar "rangeFormat" pois será sempre "Number". Em "thousandsSeparatorWithCopyPaste" já eliminei.
  if (rangeFormat == 'Automatic') {
    numbersAppControllerP.windows[0].scrollAreas[1].popUpButtons[0].click();
    delay(d0p3);
    systemLib.arrowDown(1);
    systemLib.enter(1);
  } else if (rangeFormat == 'Number') {
    table.ranges[rangeName].format = 'number';
  }

  delay(d0p3);
  //numbersAppControllerP.windows[0].scrollAreas[3].checkboxes.byName(" Thousands Separator").click()

  // Numbers v12.2 // 20221117
  numbersAppControllerP.windows[0].scrollAreas[2].checkboxes[' Thousands Separator'].click();
  delay(d0p3);
}

function thousandsSeparatorWithCopyPaste(numbersAppControllerP, table, rangeName, decimalsClicks) {
  selectionRange(table, rangeName);

  numbersActivateFormatIndex(numbersAppControllerP, 1); // "Cell"

  menuLib.copy();
  systemLib.pressDelete(1);
  table.ranges[rangeName].format = 'number';
  delay(d0p3);

  numbersAppControllerP.windows[0].scrollAreas[2].checkboxes[' Thousands Separator'].click();
  delay(d0p3);

  setDecimals(numbersAppControllerP, table, rangeName, decimalsClicks, 'Up');

  menuLib.doMenu('Numbers', 'Edit', 'Paste and Match Style');
}

// 🔴🔴 NOT USED YET
function unMergeCells(table, rangeName) {
  delay(d0p3);
  table.ranges[rangeName].unmerge();
  delay(d0p3);
}

function writeInRowAvailable(table, referenceRownNum, [textToWriteIfAvailable, columnWhereToWrite]) {
  if (textToWriteIfAvailable != '') {
    if (columnWhereToWrite == '') {
      var textToWriteIfAvailableItems = textToWriteIfAvailable.split(' | ');

      // for (var i = 0; i < textToWriteIfAvailableItems.length; i++) {
      // 	//seApp.keyCode(125)

      // 	table.rows[referenceRownNum - 1].cells[i].value = textToWriteIfAvailableItems[i]
      // }

      rowPopulateItems(table, textToWriteIfAvailableItems, referenceRownNum);
    } else {
      // Uses columnWhereToWrite
      table.cells[columnWhereToWrite + referenceRownNum].value = textToWriteIfAvailable;
    }
  }
}

