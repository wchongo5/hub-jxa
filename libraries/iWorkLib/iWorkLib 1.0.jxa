// --------------------------------------- Pages

function pagesApplyLetterHeader(tableHeader, header, reference, date, production) {
  if (!production.includes('Quitações')) {
    tableHeader.cells['A1'].value = header;

    // Because A1 is merged with B1, when you apply info in it, it pushes existing info to B1 and unmerge, so must be cleared before merge again
    tableHeader.cells['B1'].value = '';

    mergeCells(tableHeader, 'A1:B1');
  }

  tableHeader.cells['A2'].value = reference;
  tableHeader.cells['B2'].value = date;
}
