function numbersDateAndReference(docNumbers, productionTypeCode, yyyy_mm_dd__hh_mm_ss, companyIdentifier) {
  const yyyy_mm_dd = yyyy_mm_dd__hh_mm_ss.split('-')[0];

  const yyyy = yyyy_mm_dd.slice(0, 4);

  const tableReference = docNumbers.sheets['CUSTOMERS&SUPPLIERS'].tables['OneTableForReference'];

  const referencePrevious = tableReference.cells['D2'].value();

  const previousDate = tableReference.cells['A2'].value();
  const previousYyyy = previousDate.toString().slice(0, 4);

  const referenceCurrentYy = yyyy.slice(-2);
  const referencePreviousYy = previousYyyy.slice(-2);

  const isFirstReferenceOfYear = referenceCurrentYy != referencePreviousYy;

  var referenceNumberPreviousWithDate = `${referencePrevious} | ${previousDate}`;

  var referenceNumberPrevious = isFirstReferenceOfYear ? 0 : Number(tableReference.cells['B2'].value());

  const referenceNumberIncrement1 = addZero(Number(referenceNumberPrevious) + 1);
  const referenceNumberIncrement2 = addZero(Number(referenceNumberPrevious) + 2);

  var referenceItemWitcompanyIdentifier = `${companyIdentifier}D${referenceCurrentYy}`;

  var referenceNumber1 = referenceItemWitcompanyIdentifier + productionTypeCode + referenceNumberIncrement1;

  var referenceNumber2 = referenceItemWitcompanyIdentifier + productionTypeCode + referenceNumberIncrement2;

  var referenceNumber1WithDate = referenceNumber1 + ' | ' + yyyy_mm_dd__hh_mm_ss;

  var referenceNumber2WithDate = referenceNumber2 + ' | ' + yyyy_mm_dd__hh_mm_ss;

  var dateDotDdMmYyyy = yyyy_mm_dd.slice(6, 8) + '.' + yyyy_mm_dd.slice(4, 6) + '.' + yyyy;

  if (isFirstReferenceOfYear) {
    alert(
      `Primeira referência de ${yyyy}.\n Será registada na tabela "OneTableForReference" de ${previousYyyy}, arquive a tabela e separe a referência.`,
      `Referência anterior: ${referenceNumberPreviousWithDate}`
    );
  }

  return {
    referenceNumber1WithDate,
    referenceNumber2WithDate,
    dateDotDdMmYyyy,
    referenceNumberIncrement1,
    referenceNumberIncrement2,
    referenceNumber1,
    referenceNumber2,
    referenceNumberPreviousWithDate,
    referencePreviousYy,
    referenceCurrentYy,
  };
}

function numbersDocIsArchived(docNum) {
  return docNum.name().includes('ARCHIVED');
}

function numbersDocIsTextXA5(docNum) {
  return docNum.name().includes('TEXT XA5');
}

function numbersDocIsTextXG5(docNum) {
  return docNum.name().includes('TEXT XG5');
}

function numbersExportNumbersCSV2CSV(numbersApp, docNumCsvWritten, pathStr, expExtension) {
  numbersApp.export(docNumCsvWritten, { to: Path(pathStr), as: expExtension });
}

function numbersProjectInProcessInfoPopulate(docNumXA5, invoiceCs) {
  const { sheetFilterName } = numbersSheetGetFilterAndNameReference(docNumXA5);

  const projSheets = docNumXA5.sheets.whose({
    _and: [{ name: { _contains: sheetFilterName } }, { _not: [{ name: { _beginsWith: templateProjAndPropGeneralPartName } }] }],
  });

  let projectInProcessInfoToPopulate = [];

  for (let i = 0; i < projSheets.length; i++) {
    const projSheet = projSheets[i];
    const projSheetName = projSheet.name();
    const projSheetNumber = projSheetName.split(' ')[0];

    const customerCellName = "'" + projSheetName + "'::Project Info::C1";
    const csCellName = "'" + projSheetName + "'::Project Info::C2";

    projectInProcessInfoToPopulate.push({
      projSheetNumber,
      customerCellName,
      csCellName,
    });
  }

  const projectInProcessInfoToPopulateL = projectInProcessInfoToPopulate.length;

  const projectInProcessTable = docNumXA5.sheets['PROJECT IN PROCESS'].tables[0];
  const projectInProcessTableRowsL = projectInProcessTable.rowCount();
  const rowsL_forProjects = projectInProcessTableRowsL - 1;

  let csActive = '';

  if (!invoiceCs) {
    for (let i = 1; i < projectInProcessTableRowsL; i++) {
      var iSum = i + 1;
      const projectCheck = projectInProcessTable.cells['E' + iSum].value();

      if (projectCheck == 1) {
        projectInProcessTable.cells['E' + iSum].value = 0;

        if (csActive === '') {
          csActive = projectInProcessTable.cells['C' + iSum].value();
        }
      }
    }
  }

  clearRange(projectInProcessTable, `A2:C${projectInProcessTableRowsL}`);

  // alert(`rowsL_forProjects: ${rowsL_forProjects}`, `projectInProcessInfoToPopulateL: ${projectInProcessInfoToPopulateL}`);

  if (projectInProcessInfoToPopulateL > rowsL_forProjects) {
    // projectInProcessTable.rows[projectInProcessInfoToPopulateL - 1].addRowBelow();

    const numOfRowsToAdd = projectInProcessInfoToPopulateL - rowsL_forProjects;
    const referenceRownNum = projectInProcessTableRowsL - 1;

    addRows(projectInProcessTable, numOfRowsToAdd, referenceRownNum, 'addRowBelow');
  }

  for (var i = 0; i < projectInProcessInfoToPopulateL; i++) {
    var iSum = i + 2;

    const projectInfo = projectInProcessInfoToPopulate[i];

    projectInProcessTable.cells['A' + iSum].value = `${projectInfo.projSheetNumber}`;
    projectInProcessTable.cells['B' + iSum].value = `=${projectInfo.customerCellName}`;
    projectInProcessTable.cells['C' + iSum].value = `=${projectInfo.csCellName}`;

    const cs = projectInProcessTable.cells['C' + iSum].value();

    if ((!invoiceCs && cs === csActive) || (invoiceCs && cs === invoiceCs)) {
      projectInProcessTable.cells['E' + iSum].value = 1;
    }
  }

  if (invoiceCs) {
    projectInProcessTable.cells['L2'].value = invoiceCs[2] == 'W' ? 1 : 0;
    projectInProcessTable.cells['L3'].value = 0;
    projectInProcessTable.cells['L4'].value = invoiceCs[2] == 'W' ? 0 : 1;
    projectInProcessTable.cells['L6'].value = '';
    // São 8 TXT Estimate files, mas Cobertura não é frequente
    projectInProcessTable.cells['L7'].value = 7;
    projectInProcessTable.cells['L17'].value = 0;
  }
}

function numbersReferenceTableName(productionTypeCode) {
  var tableNamesDict = {
    C: 'Construção (XC5)',
    E: 'Empreitada (XE5)',
    F: 'Fiscalização (XF5)',
    P: 'Projecto (XP5)',
    G: 'Gestão (XG5)',
  };

  return tableNamesDict[productionTypeCode[2]];
}

function numbersSaveAsPDF(numbersAppControllerP, docFront, i, sheetNames, sheetName, docPathStr, formatedPdfNewName) {
  docFront.activeSheet.set(docFront.sheets[sheetName]);

  if (i == 0) {
    menuLib.print('Numbers');

    //numbersAppControllerP.windows[0].radioGroups[1].radioButtons[0].click() // This Sheet

    // Numbers v12.2 // 20221117
    // This Sheet
    numbersAppControllerP.windows[0].radioGroups[1].radioButtons['This Sheet'].click();
    delay(d0p3); // NEW
  }

  appLib.printSaveAsPDF('Numbers');
  delay(d2);
  saApp.setTheClipboardTo(formatedPdfNewName);
  delay(d0p3);
  seApp.keystroke('v', { using: 'command down' });
  delay(d0p3);

  // alert("X1")

  // goToFolderCopyPaste(docPathStr);

  // --------- 🔴🔴🔴 TEMPORARY, replace "goToFolderCopyPaste"
  //delay(d1) // Fica no App
  seApp.keystroke('g', { using: ['shift down', 'command down'] });
  delay(d1); // Era d0p3
  menuLib.copyPaste(docPathStr);
  delay(d0p3);
  seApp.keyCode(76); // Go // Era 76
  // systemLib.enter(1)
  delay(d1p5);
  seApp.keyCode(76); // OK // Era 76
  // systemLib.enter(1)
  delay(d0p3);
  // ---------

  delay(d3);

  if (i == sheetNames.length - 1) {
    delay(d3); // Time to Scape not cancel if PDF has many pages
    seApp.keyCode(53); // Scape to Go to Normal View
  }

  finderApp.reveal(Path(docPathStr + '/' + formatedPdfNewName + '.pdf')).extensionHidden = true;
  delay(d0p3);
}

