function saveMailMessagesAttachments(messages, pathStr) {
  for (var message of messages) {
    var attachments = message.mailAttachments();
    if (attachments.length === 0) {
      alert('Sem anexos');
    } else {
      for (var attachment of attachments) {
        var originalName = attachment.name();
        try {
          attachment.save({ in: Path(`${pathStr}/${originalName}`) });
        } catch (error) {
          app.displayDialog(`Erro gravando anexos: ${error.message}`);
        }
      }
    }
  }
}

function processAndSaveHtmlFile(emailSource, headerEssential, pathStrWithName) {
  // FOUR SITUATIONS, ONE REGEX see situations in file "• MAIL - SOURCE SITUATIONS.md"
  const matches1 = emailSource.match(/Content-Type: text\/html;.*?\n.*?\n\n([\s\S]*?)(?:\n------|=\n.*\n--Apple-Mail.*|\n\n)/m);

  try {
    var encodedContent = matches1[1];
  } catch (error) {
    var decodedContent = null;
  }

  if (encodedContent) {
    var decodedContent = decodeQuotedPrintable(encodedContent);
  } else {
    var decodedContent = 'No HTML content found';
  }

  const headerEssentialHtml = headerEssential
    .split('\n')
    .map(item => `<div>${item}</div>`)
    .join('\n');

  let htmlContent = `${headerEssentialHtml}${decodedContent}`;

  const metaCharsetUTF8Tag = `<meta charset="UTF-8">`;
  const hasMetaCharsetUTF8 = htmlContent.toLowerCase().includes(metaCharsetUTF8Tag.toLocaleLowerCase());

  if (!hasMetaCharsetUTF8) {
    htmlContent = `${metaCharsetUTF8Tag}${htmlContent}`;
  }

  const htmlContentBlocksColored = applyColorsToBlocks(htmlContent);

  const htmlPathStr = `${pathStrWithName}.html`;
  const fileWritten = objCLib.writeToFile(htmlPathStr, `${htmlContentBlocksColored}`);

  if (fileWritten) {
    finderApp.open(Path(htmlPathStr));
  }
}

