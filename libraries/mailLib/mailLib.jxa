function applyColorsToBlocks(htmlContent) {
  const colors = [
    'red',
    'blue',
    'green',
    'purple',
    'orange',
    'cyan',
    'magenta',
    'lime',
    'pink',
    'teal',
    'lavender',
    'brown',
    'beige',
    'maroon',
    'mint',
    'olive',
    'apricot',
    'navy',
    'grey',
    'yellow',
    'turquoise',
    'tan',
    'salmon',
    'plum',
    'orchid',
    'black',
    'indigo',
    'coral',
    'crimson',
    'fuchsia',
  ];

  let colorIndex = 0;

  // At this stage the code was decoed so "=3D" is "=" after decoded. So we are looking for <blockquote type="cite"> not <blockquote type=3D"cite"> before decoded.
  const blockquoteRegex = /<blockquote type="cite">/g;

  return (htmlContent = htmlContent.replace(blockquoteRegex, () => {
    const color = colors[colorIndex++ % colors.length];
    return `<blockquote type="cite" style="color: ${color};">`;
  }));
}

