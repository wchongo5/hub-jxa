  const senderName = senderItems[0];
  const senderEmail = senderItems[1].split('>')[0];

  return {
    senderName,
    senderEmail,
  };
}
*/

function getMailMessageSender(message) {
  const sender = message.sender();

  if (sender.includes('<') && sender.includes('>')) {
    const startOfEmail = sender.indexOf('<');
    const endOfEmail = sender.indexOf('>');
    const senderName = sender.substring(0, startOfEmail).trim();
    const senderEmail = sender.substring(startOfEmail + 1, endOfEmail).trim();

    return {
      senderName,
      senderEmail,
    };
  } else {
    return {
      senderName: 'No System Name',
      senderEmail: sender.trim(),
    };
  }
}

