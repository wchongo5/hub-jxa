function jointVentureDwJ5XAlert(cs, quoteOrInvoice, consultancyManagerId) {
  if (cs[0] == 'J' && cs[2] == 'W' && consultancyManagerId == 'J5X') {
    if (quoteOrInvoice == 'Cotação') {
      var extraTitle = ``;
    } else if (quoteOrInvoice == 'Factura') {
      var extraTitle = `Janela Xero aberta não vai ser usada.\n\n`;
    }

    alert(
      `🔴🔴🔴\n${extraTitle}JointVenture para este tipo de CS "${cs}", DW com gestão "J5X" segue facturação normal da firma (Xero Quote then Invoice - Quote to Invoice) e não Folder5 > "XERO DIRECT INVOICE"\n\nEm J5 e N5 (XDIMW & XDIMX), é a única situação que segue esta lógica.`,
      ``
    );
  }
}

