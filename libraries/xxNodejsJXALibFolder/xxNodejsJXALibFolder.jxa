    } else if (option == '6. Obra - Subpastas') {
      // ----- addendumFolderNext & se X-DIM é AO1 (Empreitada) ou AO3 (Fiscalização, Assistência, …)
      var currentFolderSelection = finderApp.selection()[0];
      var currentFolderFolders = currentFolderSelection.folders();

      var addendumFoldersList = [];
      var xdimConstructionAuthorPositionList = [];
      for (var i = 0; i < currentFolderFolders.length; i++) {
        var folderName = currentFolderFolders[i].name();

        if (folderName.includes('ADENDA')) {
          addendumFoldersList.push(folderName);
        }

        if (folderName.includes('AO3')) {
          xdimConstructionAuthorPositionList.push(folderName);
        }
      }

      if (addendumFoldersList.join('') == '') {
        var lastAddendumFolderNameNextNumber = 1;
        var addendumFolderNext = 'ADENDA ' + lastAddendumFolderNameNextNumber;
      } else {
        var lastAddendumFolderName = addendumFoldersList[addendumFoldersList.length - 1];

        var lastAddendumFolderNameNextNumber = Number(`${lastAddendumFolderName.split(` ${ND} `)[2]}`.split(' ')[1]) + 1;

        var addendumFolderNext = 'ADENDA ' + lastAddendumFolderNameNextNumber;
      }

      var option = cflLib.cfl2Str(
        [
          `ESCREVERBULLETESCREVER`,
          `---------------`,
          addendumFolderNext,
          `AMOSTRAS ${ND} IMPERMEABILIZAÇÃO`,
          `APRESENTAÇÃO ${ND} PROJECTO SESSÃO`,
          `COBRANÇA ${ND} AO1 (FORA) + AO3`,
          `COMUNICAÇÃO ${ND} SITUAÇÃO ACTUAL DA OBRA`,
          `CONVOCATÓRIA ${ND} VISITA A OBRA`,
          `CRONOGRAMA ${ND} CORRECÇÕES`,
          `EMBARGO ${ND} LICENÇA CADUCADA`,
          `ENTREGA DEFINITIVA ${ND} (ADICIONAL)`,
          `ENTREGA PROVISÓRIA ${ND} (ADICIONAL)`,
          `FACTURAÇÃO ${ND} AO1 (FORA) + AO3`,
          `MARCAÇÃO ${ND} VISTORIA DA FISCALIZAÇÃO`,
          `PARECER ${ND} TRABALHOS A MAIS`,
          `PROCESSO ${ND} COMPENSAÇÕES`,
          `QUESTIONAMENTO ${ND} QUALIDADE BAIXA PORQUE?`,
          `RECOMENDAÇÕES ${ND} ACESSO LIGAÇÃO COM A ESTRADA`,
          `RESPOSTA ${ND} CONVOCATÓRIA ` + yearY4 + monthM2 + `XX`,
          `REUNIÃO ${ND} QUALIDADE & ATRASO`,
          `SOLICITAÇÃO ${ND} DATA PARA REUNIÇÃO`,
          `---------------`,
          `${ND} PROJECTO V2 (+ GUARITA)`,
          `---------------`,
          `+ SUBCONTRATAÇÃO_X5`,
        ],
        `Nome da pasta`,
        `REUNIÃO ${ND} QUALIDADE & ATRASO`
      );

      if (option.includes(`${ND} PROJECTO`)) {
        var constructionAuthor = '';
      } else {
        if (option.includes('ADENDA')) {
          if (addendumFoldersList.length > 0) {
            var addendumFoldersListString = addendumFoldersList.join('\n') + '\n\n\n';
          } else {
            var addendumFoldersListString = '';
          }

          var option =
            `${option} ${ND} ` + dialog(addendumFoldersListString + 'Objecto da Adenda ' + lastAddendumFolderNameNextNumber, '');
        }

        if (option.includes('ADENDA') && xdimConstructionAuthorPositionList.length == 0) {
          var constructionAuthor = `AO1 ${ND} `;
        } else {
          var constructionAuthor =
            cflLib.cfl2Str(['AO1', 'AO2', 'AO3'], 'Elaborado ou convocado por / A01 X-DIM', 'AO1', 'm') + ` ${ND} `;

          var constructionAuthor = constructionAuthor.replace(',', ' & ');
        }
      }

      var optionEdit = dialog('Edição do nome da pasta', constructionAuthor + option);

      var theTodayDateEdition = dialog('Data', yearY4 + monthM2 + dayD2);

      if (optionEdit.includes(`${ND} PROJECTO`)) {
        var newJobFolder = makeFolder(Path(destinyFolderStr), `${optionEdit} ${ND} ${theTodayDateEdition}`);
      } else {
        var newJobFolder = makeFolder(Path(destinyFolderStr), `${theTodayDateEdition} ${ND} ${optionEdit}`);
      }
    } else if (option == 'Q. Anual Projectos') {
      var jobYear = dialog('Ano', 'PA' + yearY4);
      var subNameList = ['08 INHAMBANE', '09 GAZA', '10 MAPUTO', '11 MAPUTO (CIDADE)'];

      var newJobFolder = makeFolder(Path(destinyFolderStr), jobYear);

      for (var i = 0; i < subNameList.length; i++) {
        makeFolder(Path(getPathStrsFromPathObjs([newJobFolder])[0]), subNameList[i]);
      }
    } else if (option == 'A. Província') {
      const {
        // provinceNumbered,
        provinceNumberPadded,
        provinceName,
      } = spaceLib.getProvinceInfo([''], 'Sofala');

      const newJobFolder = makeFolder(Path(destinyFolderStr), `${provinceNumberPadded} ${provinceName.toUpperCase()}`);
    }

    finderApp.activate();
    delay(d1p5);

    // ---------------

    if ((option == '2. Projecto' && !isHerd) || option == '3. Obra') {
      if (
        option == '2. Projecto' &&
        (discipline == 'Arquitectura' || discipline == 'Urbanismo') &&
        (partnershipIdentifier == 'X' || (partnershipIdentifier == 'J' && consultancyManagerId == 'J5X'))
      ) {
        /* // 🔴🔴🔴 DESACTIVADO 20240705, variável foldersCreatedStr parece que não é usada
         var foldersCreatedStr = '00 Configurações A5, + TM COLLECTED, A5 Referências';
   
         if (originType == 'Ajuste Directo (DW)') {
           var foldersCreatedStr = foldersCreatedStr + ', A5 Relatórios';
         }
           */

        delay(d1);
        numbersApp.activate();

        var projSheet = docNumXA5.sheets[projSheetName];
        var tableProjectInfo = projSheet.tables['Project Info'];

        tableProjectInfo.cells['B1'].value = customer4Documents;
        tableProjectInfo.cells['C1'].value = customer4SheetOrBimCloudOrNote;
        tableProjectInfo.cells['C2'].value = invoiceCs;
        tableProjectInfo.cells['B2'].value = object4Documents;
        tableProjectInfo.cells['B3'].value = object4ImagesAndVideoAndDrawings;
        tableProjectInfo.cells['B6'].value = projectSite;
        tableProjectInfo.cells['E1'].value = customerGroup;
        tableProjectInfo.cells['E2'].value = intervention;
        tableProjectInfo.cells['B7'].value = startDateTextAndDeliveryTime;

        tableProjectInfo.cells['C8'].value = endDd;
        tableProjectInfo.cells['D8'].value = endMmStrInPT;
        tableProjectInfo.cells['E8'].value = endYyyy;

        // GENDER OTIONS
        tableProjectInfo.cells['B11'].value = genderOptions[0];
        tableProjectInfo.cells['D11'].value = genderOptions[1];

        var neighborhoodWord = genderOptions[2];

        if (neighborhoodWord == 'Bairro') {
          tableProjectInfo.cells['E10'].value = 1;
        } else if (neighborhoodWord == 'emptyBairro') {
          tableProjectInfo.cells['E10'].value = 0;
        }

        // SITE DIMENSIONS
        writeSiteDimensions(projSheet, siteDimensions);

        // ----- ADD CUSTOMER NAME IN SHEET
        // projSheet.name = projSheetName.split(" - ")[0] + " - " + customer4SheetOrBimCloudOrNote + " " + invoiceCs

        numbersProjectInProcessInfoPopulate(docNumXA5);

        // ----- SET PROJECT IN PROJECT IN PROCESS TABLE
        // setProjectInProjectInProcessTable(docNumXA5, customer4SheetOrBimCloudOrNote, invoiceCs);
        setProjectInProjectInProcessTable(docNumXA5, invoiceCs);

        // ----- UPDATE "COORDENADAS" SHEET
        var sheetCoordinates = docNumXA5.sheets['COORDENADAS'];
        var coordTable = sheetCoordinates.tables['COORDENADAS - PONTOS CURVAS DE NÍVEL'];
        coordTable.cells['E3'].value = 0; // Uncheck Correct Altitudes
      }

      // WRITE AND MERGE CUSTOMERANDCS
      if (service == 'Construção' || service == 'Empreitada') {
        numbersApp.activate();
        // var docNumXG5 = numbersApp.open(numXG5PathObj);

        docNumXG5.activeSheet.set(docNumXG5.sheets['CONTRATOS']);

        var tableConstructorGeneral = docNumXG5.sheets['CONTRATOS'].tables['Table - ContractConstructorGeneral'];

        var customerAndCs = invoiceCsAndCustomer.slice(12) + ' ' + invoiceCsAndCustomer.slice(0, 11);

        tableConstructorGeneral.cells['C3'].value = customerAndCs;

        var range4CustomerAndCS = tableConstructorGeneral.ranges['B3:C3'];
        range4CustomerAndCS.format = 'pop up menu';

        tableConstructorGeneral.cells['C3'].value = '';
        tableConstructorGeneral.cells['C3'].format = 'text';

        docNumXG5.save();
      }
    }

    if (option == '2. Projecto' || option == '3. Obra') {
      if (option == '2. Projecto') {
        makeAlias(Path(newJobFolderStr), Path(xa5TemporayFolderStr), '# ' + newJobFolder.name());
        delay(d0p3);
      }

      if (option == '3. Obra') {
        makeAlias(Path(newJobFolderStr), xo5AliasObrasPathObj, newJobFolder.name());
      }

      delay(d1p5);

      // WRITE IN CUSTOMERS&SUPPLIERS

      /*
   
         if (((option == "2. Projecto" && invoiceCs[2] != "W") || (option == "3. Obra" && (service == "Empreitada" || service == "Fiscalização"))) && (partnershipIdentifier == "X" || (partnershipIdentifier == "J" && consultancyManagerId == "J5X"))) {
   
            numbersApp.activate()
   
            if (option == "2. Projecto") {
               menuLib.doMenu("Numbers", "Window", docNumXG5Name)
            }
   
            var tableRecipient = customerAndSupplierSheet.tables[tableRecipientName]
            var tableRecipientRowsL = tableRecipient.rowCount()
   
            tableRecipient.cells["A1"].value = documentLib.capitalizeText(customer4Documents, "WithExclusions") + "\n" + contractManager + "\n\n" + propLocal
   
            if (addObject) {
               tableRecipient.cells["A" + tableRecipientRowsL].addRowBelow()
   
               tableRecipient.cells["A" + (tableRecipientRowsL + 1)].value = object4Documents
               tableRecipient.cells["B" + (tableRecipientRowsL + 1)].value = siteID
               tableRecipient.cells["C" + (tableRecipientRowsL + 1)].value = invoiceCs
   
            } else { // Replace TableInfo
   
   
               if (tableRecipientRowsL > 6) {
                  iWorkLib.deleteRows(tableRecipient, (tableRecipientRowsL - 6), 6)
               }
   
               tableRecipient.cells["A6"].value = object4Documents
               tableRecipient.cells["B6"].value = siteID
               tableRecipient.cells["C6"].value = invoiceCs
   
               tableRecipient.name = tableRecipient.name()[0] + invoiceCs.slice(4,6) + " - " + customer4Folders
            }
   
            docNumXG5.save()
         }
         */

      // ----------------- WRITE INVOICE INFO

      if (folderListInfoTrackESCREVER == 'ESCREVER') {
        var tableInvoicedQuotesInfo = docNumXG5.sheets['FACTURAÇÃO'].tables['Table - InvoicedQuotesInfo'];

        // Sem REPLACE em <durationInputWithUnit.replace("d", " Dias").replace("m", " Meses")>, Numbers converte 56d em 8w
        writeCustomerAndObject(
          tableInvoicedQuotesInfo,
          customerType,
          dateFoldersAndDocuments,
          invoiceCs,
          customer4Documents,
          customer4SheetOrBimCloudOrNote,
          object4DocumentsAndImagesAndNote,
          projectSite,
          siteID,
          genderOptionsStr,
          intervention,
          customerGroup,
          contractManager,
          propLocal,
          needsHMTLStr,
          buildingObjectsStr,
          durationInputWithUnit.replace('d', ' dias').replace('m', ' meses')
        );
      }

      // ----------------- DELETE QUOTE ALIAS

      var quoteAliasPathObjs = seApp.folders.byName(x5AliasQuotesPathStr).files;

      for (var i = 0; i < quoteAliasPathObjs.length; i++) {
        var quoteAliasName = quoteAliasPathObjs[i].name();

        if (quoteAliasName.includes(quoteCs)) {
          seApp.aliases.byName(x5AliasQuotesPathStr + '/' + quoteAliasName).delete();
          break;
        }
      }

      // --------------- CREATE NOTE

      if (needsHMTLStr == 'null') {
        // We get "null" string if no needs

        var needsHMTLStrExtraNote = ` \n• Se for:\n"Obra integrar Code in NumXG5 - introduzir info de empreiteior em NumXG5"\n"• Urbanismo code to Get Name from QuoteTable"\n`;

        if (folderListInfoTrackESCREVER == 'ESCREVER') {
          // A5 Direct invoice

          var needsHMTLStr = `Necessidades: "É Direct invoice": ${needsHMTLStrExtraNote}\n\n• Ou Escrever or codeIt`;
        } else {
          var needsHMTLStr = `Necessidades: "É Quote To invoice": ${needsHMTLStrExtraNote}`;
        }
      }
    }

    if (option == '1. Cotação' || option == '2. Projecto' || option == '3. Obra') {
      /*
         if (option == "1. Cotação") {
            var invoiceOrQuoteCs = quoteCs
         } else {
            var invoiceOrQuoteCs = invoiceCs
         }
         */

      if (option == '1. Cotação') {
        var cs = quoteCs;
      } else {
        // option == "2. Projecto" || option == "3. Obra"
        var cs = invoiceCs;
      }

      // -------------- ARCHIVE INVOICE CONSULANCY INFO
      var projectInfo2Archive = `\n\n${dateFoldersAndDocuments} | ${cs} | ${customer4Documents} | ${customer4SheetOrBimCloudOrNote} | ${object4DocumentsAndImagesAndNote} | ${projectSite} | ${genderOptionsStr} | ${intervention} | ${customerGroup} | ${contractManager} | ${propLocal} | ${buildingObjectsStr} | ${durationInputWithUnit
        .replace('d', ' dias')
        .replace('m', ' meses')}\n-------------- Abaixo é needsHMTLStr\n${needsHMTLStr}`;

      // ARCHIVE PROJECT INFO
      objCLib.writeToFileWithAppend(
        `${inboxPathStr}/ARCHIVE - FOLDER - FACTURAÇÃO INFO - ${option.split('. ')[1].toUpperCase()} ${yearY4}${monthM2}.txt`,
        projectInfo2Archive
      );

      // Close ARCHIVE WINDOW
      finderApp.windows[0].close();

      if (partnershipIdentifier == 'X' || (partnershipIdentifier == 'J' && consultancyManagerId == 'J5X')) {
        var letteringInfoStr = processLetteringInfoHtml(
          customer4Documents,
          object4Documents,
          cs,
          siteID,
          contractManager,
          propLocal
        );

        // needsHMTLStr += "\n\n" + letteringInfoStr
        needsHMTLStr += `${cs[4] === 'R' ? '' : `\n\n${letteringInfoStr}`}`;
      }

      // 🔴🔴🔴🔴🔴 DÁ ERRO AQUI, TALVEZ QUER RESTART
      notesLib.createServiceNote(cs, customer4SheetOrBimCloudOrNote, object4Note, needsHMTLStr);

      // const expedients = [];
      let expedients = [];

      // XDWFAP241102

      const dateISO8601End = formatDateV3(new Date(`${endYyyy}-${endMm}-${endDd}T15:30:00`)).formats.iso8601;

      if (cs[3] === 'C') {
        /*
         expedients.push({
           id: generateUUID(),
           name: 'Gerir a aprovação da cotacão',
           dateCreated: dateFoldersAndDocumentsISO8601,
           dateDue: dateISO8601End,
           dateCompleted: '',
           isCompleted: false,
           priority: 3,
         });
         */

        expedients = documentLib.generateExpedients([
          {
            name: 'Gerir a aprovação da Cotacão',
            dateCreated: formatDateV3(new Date()).formats.iso8601,
            dateStart: dateFoldersAndDocumentsISO8601,
            dateDue: dateISO8601End,
            priority: 3,
          },
        ]);
      }
      if (cs[3] === 'F' && cs[5] === 'P') {
        /*
         // Qualquer projecto
         expedients.push({
           id: generateUUID(),
           name: `Entrega ${cs.slice(4, 6) === 'AP' ? 'do Projecto' : cs.slice(4, 6) === 'UP' ? 'do Plano' : 'da Produção'}`,
           dateCreated: dateFoldersAndDocumentsISO8601,
           dateDue: dateISO8601End,
           dateCompleted: '',
           isCompleted: false,
           priority: 1,
         });
         */

        expedients = documentLib.generateExpedients([
          {
            name: `Entrega ${cs.slice(4, 6) === 'AP' ? 'do Projecto' : cs.slice(4, 6) === 'UP' ? 'do Plano' : 'da Produção'}`,
            dateCreated: formatDateV3(new Date()).formats.iso8601,
            dateStart: dateFoldersAndDocumentsISO8601,
            dateDue: dateISO8601End,
            priority: 1,
          },
        ]);

        // } if (cs.slice(3, 6) === 'FAP') {
      } else if (cs[3] === 'F' && cs[5] === 'F') {
        // Qualquer fiscalizacão
        // Início, entrega Provisória e Definitiva

        expedients = documentLib.generateExpedients([
          {
            name: 'Início da Obra',
            dateCreated: formatDateV3(new Date()).formats.iso8601,
            dateStart: stratStartDateBuildingISO8601,
            dateDue: endStartDateBuildingISO8601,
            priority: 1,
          },
          {
            name: 'Entrega Provisória',
            dateCreated: formatDateV3(new Date()).formats.iso8601,
            dateStart: startEndDateBuildingISO8601,
            dateDue: endEndDateBuildingISO8601,
            priority: 1,
          },
          {
            name: 'Entrega Definitiva',
            dateCreated: formatDateV3(new Date()).formats.iso8601,
            dateStart: startEndDatePlusPerfGuarPeriodISO8601,
            dateDue: endEndDatePlusPerfGuarPeriodISO8601,
            priority: 1,
          },
        ]);
      }

      documentLib.addContract({
        entityType: 'customer',
        contractNumber: cs,
        entityName: customer4SheetOrBimCloudOrNote,
        contractName: object4Note,
        contractPercentage: chargedPercentage,
        contractAmount: quoteAmountApproved | 0.0, // Quote is 'null'
        contractDateCreated: formatDateV3(new Date()).formats.iso8601,
        contractDateStart: dateFoldersAndDocumentsISO8601,
        contractDateDue: dateISO8601End,
        path: '🔴🔴🔴GetRecentFolderPathCreatedHere',
        payments: [],
        expedients,
      });

      // 🔴🔴🔴🔴🔴🔴 IN THE FUTURE MAYBE I MUST REMOVE THIS JSON FILE
      contractsDetails('', 'ReadInvoiceInfoAndUpdateJSON', p5PathStrWithSuffixP5, ['All'], ['All'], yearY4, '', '', 3, undefined);
    }

    // --------------- READ INVOICE INFO AND UPDATE JSON

    // --------------- XERO DIRECT INVOICE

    if (option == '2. Projecto' || option == '3. Obra') {
      if (
        isHerd ||
        originType == 'Ajuste Directo (DX)' ||
        originType == 'Concurso Limitado (CL)' ||
        originType == 'Concurso Público (CP)' ||
        (invoiceCs[0] == 'J' && invoiceCs[2] == 'W' && consultancyManagerId == 'J5C') ||
        partnershipIdentifier == 'N'
      ) {
        // Se payVatStatus for "Sim" será automático pois será uma das Opção DX, CL, CP

        delay(d0p3);

        // START DATE
        var dateDdNew = startDd;
        var dateMmNew = startMm;
        var dateMmShortNew = startMmStr.slice(0, 3);
        var dateYyyyNew = startYyyy;

        // END DATE
        var dateDdDue = endDd;
        var dateMmDue = endMm;
        var dateMmShortDue = endMmStr.slice(0, 3);
        var dateYyyyDue = endYyyy;

        var dueDate = Number(dateDdDue) + ' ' + dateMmShortDue + ' ' + dateYyyyDue;

        // PROCESS spendReceiveInvoiceBillPerson for XDIMX if J5X or partnershipIdentifier is X
        // != "W" para DX, CL, CP
        if ((invoiceCs[0] == 'J' && invoiceCs[2] != 'W') || partnershipIdentifier == 'X') {
          var customer4DocumentsItems = customer4Documents.split(' ');

          // 🔴🔴🔴 Aqui <customer4Documents> chega UPPERCASE mas reconhece o Xero se for isHerd. Acho que os outros também pode reconecer também.
          if (customer4DocumentsItems.length == 1 || isHerd) {
            var spendReceiveInvoiceBillPersonForXAndJ5X = customer4Documents;
          } else {
            var spendReceiveInvoiceBillPersonForXAndJ5X = documentLib.capitalizeText(customer4Documents, 'WithExclusions');
          }
        }

        if (partnershipIdentifier == 'J' || partnershipIdentifier == 'N') {
          // Se consultancyManagerId == "J5X" quer dizer que tem Xero Factura usando processo Cotação > Factura pois DW usa "Create - Quote (W)"

          if (invoiceCs[0] == 'J' && invoiceCs[2] == 'W' && consultancyManagerId == 'J5C') {
            var spendReceiveInvoiceBillPerson = 'JointVenture (J5C)';

            // Se payVatStatus for "Sim" será automático
          } else if (invoiceCs[0] == 'J' && invoiceCs[2] != 'W') {
            var spendReceiveInvoiceBillPerson = spendReceiveInvoiceBillPersonForXAndJ5X;
          } else if (partnershipIdentifier == 'N') {
            var spendReceiveInvoiceBillPerson = 'Negociacao (N5)';
          }

          var invoiceNumberEdition = invoiceCs + ' / ' + partner;
          var invoiceDescrEditionLine = `${percentageStr} / ${customer4Folders} ${ND} ${otherInfo4Folders} MZN${partnerPrice}`;

          var quoteAmountApproved = xdimPrice;
        } else {
          // "Ajuste Directo (DX)", "Concurso Limitado (CL)", "Concurso Público (CP)"

          var spendReceiveInvoiceBillPerson = spendReceiveInvoiceBillPersonForXAndJ5X;

          var invoiceNumberEdition = invoiceCs;
          var invoiceDescrEditionLine = otherInfo4Folders;
        }

        if (option == '2. Projecto') {
          if (isHerd) {
            var referenceEdition = 'P100'; // paymentDistribution
          } else {
            var referenceEdition = 'P5050'; // paymentDistribution
          }
        } else if (option == '3. Obra') {
          var referenceEdition = '';
        }

        if (company == 'X-DIM W') {
          if (partnershipIdentifier == 'N') {
            var account = 'Negociação';
          } else if (partnershipIdentifier == 'J') {
            var account = 'Jointventure';
          } else if (isHerd) {
            var account = '• Rebanho';
          }

          var taxRate = 'Taxa Venda (0%)';
        } else if (company == 'X-DIM X') {
          // Caracter 5 do serviço
          // XCLFPA200701 MINT MORE DETAILSHERE

          // XDWFAP220905

          if (invoiceCs.slice(4, 6) == 'AP') {
            var account = '• Arquitectura';
          } else if (invoiceCs.slice(4, 6) == 'AE') {
            var account = '• Empreitada';
          } else if (invoiceCs.slice(4, 6) == 'AF') {
            var account = '• Fiscalização';

            // 🔴🔴🔴 REVER NO XERO A NUMERAÇÃO DE CODES DE VENDA - Urbanismo poderá não ser "7.2.7"
          } else if (invoiceCs.slice(4, 6) == 'UP') {
            var account = '• Urbanismo';
          }

          //Was "IVA VENDA" before 16% because was ony 17%
          var taxRate = 'IVA VENDA (16%)';
        }

        var quantity = '1';
        var unitPrice = quoteAmountApproved.replace(/,/g, '');

        safariApp.activate();
        delay(d0p3);
        safariLib.openURL('https://go.xero.com/AccountsReceivable/Edit.aspx');
        delay(d5);

        xeroLib.headerInvoice(
          spendReceiveInvoiceBillPerson,
          dateDdNew,
          dateMmShortNew,
          dateYyyyNew,
          dueDate,
          referenceEdition,
          invoiceNumberEdition
        );

        xeroLib.new_lineSpendReceiveInvoiceBillQuote(
          invoiceDescrEditionLine,
          quantity,
          unitPrice,
          account,
          taxRate,
          'B. Create - Invoice'
        );

        delay(d1);

        //safariLib.superSafari("click", "class", "words", 2, 0) // APPROVE
        delay(d0p3);
      }
    }

    // BIMCLOUD

    if (
      option == '2. Projecto' &&
      (discipline == 'Arquitectura' || discipline == 'Urbanismo') &&
      (partnershipIdentifier == 'X' || (partnershipIdentifier == 'J' && consultancyManagerId == 'J5X'))
    ) {
      safariApp.activate();
      delay(d0p3);

      safariLib.openURL('http://192.168.0.81:22000');
      delay(d6); // Era d3

      var forgotPasswordLinkTrack = safariLib.superSafari('get', 'class', 'link test--link-forgot-password', 0, 0);
      delay(d0p3);

      if (forgotPasswordLinkTrack) {
        menuLib.copyPaste('walter');
        delay(d0p3);
        seApp.keyCode(48);
        delay(d0p3);
        menuLib.copyPaste('xxxxx');
        delay(d0p3);

        safariAppControllerP.windows[0].splitterGroups
          .at(0)
          .tabGroups.at(0)
          .groups.at(0)
          .groups.at(0)
          .scrollAreas.at(0)
          .uiElements.at(0)
          .groups.at(2)
          .groups.at(3)
          .staticTexts.byName('Log in')
          .click();
        delay(d1p5);

        // Open directly Template (PROP _ RESIDÊNCIA 2P)
        safariLib.openURL('http://192.168.0.81:22000/#module:project-manager&id:86C2B6F2-915E-A34C-9849-E8E9DB3C4CB1');
      } else {
        // Open directly Template (PROP _ RESIDÊNCIA 2P)
        safariLib.openURL('http://192.168.0.81:22000/#module:project-manager&id:86C2B6F2-915E-A34C-9849-E8E9DB3C4CB1');
      }
      delay(d6); //Era d5

      //safariAppControllerP.windows[0].splitterGroups[0].tabGroups[0].groups[0].groups[0].scrollAreas[0].uiElements[0].groups[71].staticTexts.byName("Duplicate").click()
      safariAppControllerP.windows[0].splitterGroups[0].tabGroups[0].groups[0].groups[0].scrollAreas[0].uiElements[0].groups[56].staticTexts
        .byName('Duplicate')
        .click();
      delay(d1);

      // PASTE NAME AND OBJECT
      menuLib.copyPasteWithSelectAll(customerAndObjectAndCs4BimCloud);

      delay(d0p3);

      safariAppControllerP.windows[0].splitterGroups[0].tabGroups[0].groups[0].groups[0].scrollAreas[0].uiElements[0].groups[0].groups[7].staticTexts
        .byName('01 Projectos')
        .click();
      delay(d1);

      safariAppControllerP.windows[0].splitterGroups[0].tabGroups[0].groups[0].groups[0].scrollAreas[0].uiElements[0].groups[0].groups[23].staticTexts
        .byName('Duplicate')
        .click();
      delay(d6);

      alert(
        '• ARCHICAD vai iniciar automaticamente\n• Copiou codeAndCustomerAndObjectAndDateSection & Paths (Use CloudClip) para aplicar em Publisher (Pode abrir o ficheiro Text)\n\n—\nAbrir o projecto "' +
          customerAndObjectAndCs4BimCloud +
          '" no BIMCloud e aplicar o XML ProjectInfo & Paths para Publisher!',
        ``
      );
      delay(d1);

      archicad23App.activate();

      if (intervention != 'Construção') {
        var interventionUpperCase = intervention.toUpperCase();
        saApp.setTheClipboardTo(interventionUpperCase);

        alert('Fazer Paste de "' + interventionUpperCase + '" no Vídeo Projecto, já está no Clipborad.', '');
      }

      //textEditApp.activate() // Para activar o doc TXT de Paths para PUBLISHER
    }

    if (option != '2. Projecto') {
      // if Projecto don't activate Finder, keep Archicad active
      finderApp.activate();
    }
  } else {
    alert(
      '🔴🔴🔴\n\nHá erro nas opções selecionadas\n\n—\n• Opções selecionadas não podem ser acima de 2 e devem ser combinadas devidamente.\n• As opções J5 & N5, devem ser selecionadas com Cotação ou Projecto ou Obra.',
      ''
    );
  }
}

// ------------------------------------------------- FUNCTIONS

function displayFilesToDuplicateInFolder() {
  const filesToDuplicateInFolderNames = filesToDuplicateInFolder.map(item => item.name);

  alert(filesToDuplicateInFolderNames.join('\n'));
}

/*
function generateDateFoldersAndDocuments(yearY4, monthM2, option) {
