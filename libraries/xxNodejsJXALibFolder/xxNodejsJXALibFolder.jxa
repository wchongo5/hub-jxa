function getQuoteAmountApproved() {
  var clipInfo = saApp.theClipboard();

  //if (clipInfo != "[NONE]" && Number(clipInfo.replace(/,/g, ""))) {

  if (clipInfo && !isNaN(clipInfo.replace(/,/g, ''))) {
    var quoteAmountApprovedD = clipInfo.replace(/,/g, '');
  } else {
    var quoteAmountApprovedD = '0.00';
  }

  return formatNumber(dialog('Valor da Factura (Cotação aprovada)', quoteAmountApprovedD), 2, 2);
}

