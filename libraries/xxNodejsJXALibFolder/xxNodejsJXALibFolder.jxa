function getGenderOptions(service, discipline, customer4Folders, object4Documents, projectSite) {
  // Last Letter of First Name
  var firstNameLastLetter = customer4Folders.split(' ')[0].slice(-1).toLowerCase();

  if (firstNameLastLetter == 'a') {
    if (customerType == 'Empresa Privada' || customerType == 'Estado') {
