function processLetteringInfoHtml(customer4Documents, object4Documents, cs, siteID, contractManager, propLocal) {
  const customer4DocumentsCapitalized = documentLib.capitalizeText(customer4Documents, 'WithExclusions');
  // const mainHeader1 = customer4DocumentsCapitalized + "\n" + contractManager + "\n\n" + propLocal

  // var mainHeader1 = `<div>${customer4DocumentsCapitalized}</div>
  // <div>${contractManager === "—" ? "" : contractManager}</div>
  // <div><br></div>
  // <div>${propLocal}</div>
  // `

  let mainHeader1 = `<div>${customer4DocumentsCapitalized}</div>`;

  if (contractManager !== '—') {
    mainHeader1 += `<div>${contractManager}</div>`;
  }

  mainHeader1 += `<div><br></div>
   <div>${propLocal}</div>`;

  const mainHeader2 = `<div>mainHeader2</div>`;
  const mainHeader2ShortName = `<div>mainHeader2ShortName</div>`;
  const mainHeader2WithShortName = `${mainHeader2}
	<div>—</div>
	${mainHeader2ShortName}`;

  const secondaryHeader = `<div>secondaryHeader</div>`;
  const secondaryHeaderShortName = `<div>secondaryHeaderShortName</div>`;
  const secondaryHeaderWithShortName = `${secondaryHeader}
	<div>—</div>
	${secondaryHeaderShortName}`;

  const supervisorResidentialHeader = `<div>supervisorResidentialHeader</div>`;
  const supervisorResidentialHeaderShortName = `<div>supervisorResidentialHeaderShortName</div>`;
  const supervisorResidentialHeaderWithShortName = `${supervisorResidentialHeader}
	<div>—</div>
	${supervisorResidentialHeaderShortName}`;

  const composingInfo = `<div><font color="#FF1F00">Assunto: Assunto Aqui</font></div>
	<div><font color="#FF1F00">—</font></div>
	<div><font color="#FF1F00">Prezados Senhores,</font></div>`;

  const objectDetails = `<ul>
	<li>${object4Documents} | ${siteID} | ${cs}</li>
	</ul>`;

  const peopleInfoItems = [];

  peopleInfoItems.push('1 | Walter Chongo | Director Geral | xdimag@gmail.com');

  if (cs[5] == 'F') {
    peopleInfoItems.push('1 | Nome Apelido | Fiscal Residente | fiscalresidente@gmail.com | No');
  }

  peopleInfoItems.push(`2 | ${customer4DocumentsCapitalized} | Central | nomeapelido@gmail.com`);

  // XDXFAP231102
  if (cs[2] != 'W') {
    peopleInfoItems.push('2 | Nome Apelido | Posição | nomeapelido@gmail.com');
  }

  if (cs[5] == 'F') {
    peopleInfoItems.push('3 | Nome Apelido | Director Geral | nomeapelido@gmail.com');
  }
  var peopleInfoStr = peopleInfoItems.map(item => '<div>' + item + '</div>').join('\n');

  var letteringInfoHtml = `<div><br></div>
	<div>•••••••••••••••</div>
	${mainHeader1}
	<div>——</div>
	${mainHeader2WithShortName}
	<div>———</div>
	${secondaryHeaderWithShortName}
	<div>———</div>
	${supervisorResidentialHeaderWithShortName}
	<div>———</div>
	${composingInfo}
	<div>———</div>
	${objectDetails}
	<div>————</div>
	${peopleInfoStr}
	<div>•••••••••••••••</div>
	<div><br></div>
	<div>Necessidades</div>
		<ul>
			<li>Item1</li>
		</ul>
	<div><br></div>
	<div>Levantamento YYYYMMDD-HHMMSS</div>
		<ul>
			<li>Item1</li>
		</ul>
	<div><br></div>
	<div>Actividades</div>
		<ul>
			<li>Item1</li>
		</ul>
	<div><br></div>
	<div>Produção</div>
		<ul>
			<li>Item1</li>
		</ul>
	<div><br></div>
	<div>Encontros & Apresentações</div>
	<div><br></div>
	<div>2023XXXX-XXXXXX Walter / MembrosDonoDaObra${cs[5] === 'F' ? ' / MembrosEmpreiteiro' : ''}</div>
		<ul>
			<li>Aspecto1</li>
		</ul>
	<div><br></div>
	<div>Correspondências</div>
	<div><br></div>
	<div>2023XXXX-XXXXXX DESTINATÁRIO (GRUPO WHATSAPP/NOMEDOMEMBRO) / MEIO (EMAIL/WHATSAPP/MENSAGEM)</div>
	<div><br></div>
	<div>CorpoDacorrespondência1</div>
	<div><br></div>`;

  return letteringInfoHtml;
}

function writeprojectInfoInCoverEstimate(
  estimatePathStr,
  customer4Documents,
  object4Documents,
  contractManager,
  endMmStrInPTAndEndYyyy
) {
  var docNumEstimateByQ = numbersApp.open(Path(estimatePathStr));

  var tableCover = docNumEstimateByQ.sheets['00 CAPA'].tables[0];

  tableCover.cells['A1'].value = `${customer4Documents}\n${contractManager.toUpperCase()}`;
  tableCover.cells['A2'].value = object4Documents.toUpperCase();
  tableCover.cells['A5'].value = endMmStrInPTAndEndYyyy;

  docNumEstimateByQ.save();
  delay(d1);
  docNumEstimateByQ.close();
}

// function setProjectInProjectInProcessTable(docNumXA5, customerName, invoiceCs) {
function setProjectInProjectInProcessTable(docNumXA5, invoiceCs) {
  var projectInProcessTable = docNumXA5.sheets['PROJECT IN PROCESS'].tables[0];
  var projectInProcessTableRowsL = projectInProcessTable.rowCount();

  projectInProcessTable.cells['L2'].value = invoiceCs[2] == 'W' ? 1 : 0;
  projectInProcessTable.cells['L3'].value = 0;
  projectInProcessTable.cells['L4'].value = invoiceCs[2] == 'W' ? 0 : 1;
  projectInProcessTable.cells['L6'].value = '';
  // São 8 TXT Estimate files, mas Cobertura não é frequente
  projectInProcessTable.cells['L7'].value = 7;
  projectInProcessTable.cells['L17'].value = 0;

  for (var i = 1; i < projectInProcessTableRowsL; i++) {
    const iSum = i + 1;
    // const customerNameInProcessTable = projectInProcessTable.cells['B' + iSum].value();
    const invoiceCsInProcessTable = projectInProcessTable.cells['C' + iSum].value();

    // if (customerNameInProcessTable == customerName) {
    if (invoiceCsInProcessTable == invoiceCs) {
      projectInProcessTable.cells['E' + iSum].value = 1;
    } else {
      projectInProcessTable.cells['E' + iSum].value = 0;
    }
  }
}

function writeSiteDimensions(projSheet, siteDimensions) {
  var tableDescription02ARQ = projSheet.tables['Memória 02ARQ'];

  var tableRowsL = tableDescription02ARQ.rowCount();
  for (var i = 0; i < tableRowsL; i++) {
    var iNum = i + 1;

    var infoLine = tableDescription02ARQ.cells['C' + iNum].value();

    if (infoLine.toLowerCase().includes('área do projecto')) {
      if (siteDimensions == 'LxC') {
        tableDescription02ARQ.cells['C' + (iNum + 1)].value = '—';
      } else {
        var siteDimensionsItems = siteDimensions.split('x');

        tableDescription02ARQ.cells['C' + (iNum + 1)].value =
          formatNumber(siteDimensionsItems[0], 2, 2) + 'mx' + formatNumber(siteDimensionsItems[1], 2, 2) + 'm';
      }
      break;
    }
  }
}

