function finderAutoHook() {
  try {
    var itemSelected = finderApp.selection()[0];

    if (itemSelected.kind() == 'Folder' || itemSelected.kind() == 'Alias') {
      var destinyFolder = itemSelected;
    } else {
      var destinyFolder = itemSelected.container();
    }

    var destinyFolderStr = getPathStrsFromPathObjs([destinyFolder])[0];
    var { provinceInfo } = spaceLib.getProvinceInfoByPathObjV2(destinyFolder);

    var { isDisciplineAndServicePath, discipline, service } = getDisciplineAndServiceFromPath(destinyFolderStr);

    const result = {
      destinyFolderStr,
      isDisciplineAndServicePath,
      discipline,
      service,
      provinceInfo,
    };

    console.log({ result });

    return JSON.stringify(result);
  } catch (error) {
    console.log(error);

    alert(`error: ${error}`);
  }
}

