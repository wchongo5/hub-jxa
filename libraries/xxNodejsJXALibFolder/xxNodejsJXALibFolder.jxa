function invoiceCsAndCustomer2Write(invoiceCs, customer4Folders) {
  var customerItems = customer4Folders.split(' ');

  if (customerItems.length > 1) {
    var customerFirstAndLastNames = customerItems[0] + ' ' + customerItems[customerItems.length - 1];
  } else {
    var customerFirstAndLastNames = customer4Folders;
  }

  return dialog('CS & Cliente — Exclusivamente para Contratos', invoiceCs + ' ' + customerFirstAndLastNames);
}

