function quoteNumber(quoteNumberD) {
  return addZero(Number(dialog('Número da Cotação Principal\n\n—\nNumeração automática, lendo as pastas.', quoteNumberD)));
}

function quoteFolderProcessing(quoteDate, quoteFolderStr, folder4QuoteFolder) {
  // 🔴🔴🔴 IN THE FUTURE TRY USE diskItems to USE one LOOP instead of MOVE FOLDERS and MOVE FILES

  //  🔴🔴🔴 IN THE FUTURE folder4QuoteFolderUrl and Others that use URL in variable rename them to …FolderStr to uniform with other variables

  var folder4QuoteFolderStr = getPathStrsFromPathObjs([folder4QuoteFolder])[0];

  // ------------- MOVE FOLDERS
  var quoteFoldersPathsStrs = getPathStrsFromPathStr(quoteFolderStr, 'folders');
  moveItems(quoteFoldersPathsStrs, folder4QuoteFolderStr);

  var invoicingFolderName = quoteFoldersPathsStrs
    .filter(url => url.includes('P&C'))[0]
    .split('/')
    .slice(-1)[0];

  // ------------- MOVE FILES IF EXIST
  var quoteFilesPathsStrs = getPathStrsFromPathStr(quoteFolderStr, 'files');

  if (quoteFilesPathsStrs.length > 0 && quoteFilesPathsStrs[0] != '') {
    var folder4QuoteFolderDocs = makeFolder(
      Path(getPathStrsFromPathObjs([folder4QuoteFolder])[0]),
      `+ ${quoteDate} S1Q DOCUMENTOS`
    );

    var folder4QuoteFolderDocsPathStr = getPathStrsFromPathObjs([folder4QuoteFolderDocs])[0];
    moveItems(quoteFilesPathsStrs, folder4QuoteFolderDocsPathStr);
  }

  // ------------- DELETE PROCESSED FOLDER
  delay(d0p3);
  finderApp.delete(Path(quoteFolderStr));
  delay(d0p3);

  // ------------- IN NEW PATH
  var folder4QuoteFolderUrl = getPathStrsFromPathObjs([folder4QuoteFolder])[0];

  var newInvoicingFolderAlias = seApp.aliases.byName(folder4QuoteFolderUrl + '/' + invoicingFolderName);

  // + 20211017 S1Q P&C | 20211017-20211024 | C431.00 1.5%
  var invoicingFolderNameItems = invoicingFolderName.split(' | ');

  var quoteAmountApproved = invoicingFolderNameItems[2].split(' ')[0].slice(1);
  var percentage = invoicingFolderName.match(/[A-Z0-9.]*%/)[0];

  var dueAmountAndInvoiceAmount = `R${quoteAmountApproved}-F${quoteAmountApproved}`;

  //  | ${invoicingFolderNameItems[3] Era Y ou Z para activa ou não da consultoria
  var invoicingFolderNewName = `${invoicingFolderNameItems[0]} | ${issueDateAndDueDate} | ${dueAmountAndInvoiceAmount} ${percentage}`;

  newInvoicingFolderAlias.name = invoicingFolderNewName;
}

function xdimAndpartnerQuoteFolderNames(partnershipIdentifier, originType, quoteFolderStr) {
  var partnerQuoteFolder = '';

  var quoteFolders = seApp.folders.byName(quoteFolderStr).folders;

  // GET QUOTE DATE & QUOTE APPROVED PRICE FROM FOLDER
  for (var i = 0; i < quoteFolders.length; i++) {
    var folderName = quoteFolders[i].name();

    // Cotação Normal - folderName.includes("COTA")
    // Cotação Concurso Público - folderName.includes("PROPOSTAS _ ")

    // COTA de COTAÇÃO, omissão de ÇÃO para evitar erros

    //if (folderName.includes("COTA") || folderName.includes("PROPOSTAS")) {

    if (folderName.includes('P&C')) {
      //Versioning20210904

      try {
        // Para DX, CL, CP, J5 & N5
        // Cotações DW não tem o valor da Cotação
        // Determinado apenas para verificar se existe ou não, para aplicação é extraído fora da função
        var quoteAmountApproved = folderName.match(/C(\d[,.0-9]*)/)[1];

        var xdimQuoteFolder = folderName;
      } catch {
        //
      }

      //var xdimQuoteFolder = folderName
    }

    if ((partnershipIdentifier == 'J' || partnershipIdentifier == 'N') && folderName.includes('%')) {
      if (partnerQuoteFolder == '') {
        // After set partnerQuoteFolder will not entry and change it
        var partnerQuoteFolder = folderName;
      }
    }
  }

  if (
    originType == 'Ajuste Directo (DX)' ||
    originType == 'Concurso Limitado (CL)' ||
    originType == 'Concurso Público (CP)' ||
    partnershipIdentifier == 'J' ||
    partnershipIdentifier == 'N'
  ) {
    if (quoteAmountApproved == undefined) {
      // Se for C0,000.00

      alert('Valor da Cotação não encontrado.\nIntroduze o valor!', '', ['Cancel', 'OK'], 2, 1);
    }
  }

  // Usamos "/" pois partnerQuoteFolder tem "|"
  // partnerQuoteFolder if is not J5 or N5 return "undefined"
  return xdimQuoteFolder + ' / ' + partnerQuoteFolder;
}
