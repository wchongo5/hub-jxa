function partnership(invoicingStage, quoteAmountApproved) {
  var partner = dialog('Parceiro', '');
  var partnerPrice = formatNumber(dialog('Valor do Parceiro', '0.00'), 2, 2);

  if (invoicingStage == 'Cotação') {
    var xdimPrice = formatNumber(dialog('Valor da X-DIM', '0.00'), 2, 2);
  } else if (invoicingStage == 'Factura') {
    var xdimPrice = quoteAmountApproved;
  }

  var comissionPartNumber = cflLib.cfl2Str(['1', '2'], 'Partes para percentagem - X-DIM (1) & (2) Mais Outra', '2');

  var percentageXDIM = dialog('Percentagem | X-DIM (X% - 35%)', '35');

  if (comissionPartNumber == '1') {
    var percentageStr = `${percentageXDIM}%${partnershipIdentifier}`;
  } else {
    var percentageOther = dialog('Percentagem | Outros (X% - 20%)', '20');
    var percentageStr = `${percentageXDIM}%${partnershipIdentifier}+${percentageOther}%C`;
  }

  return `${partner} | ${partnerPrice} | ${xdimPrice} | ${percentageStr}`;
}

