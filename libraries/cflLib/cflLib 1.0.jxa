const { alert, dialog } = Library('displayLib');

var currentApp = Application.currentApplication();
var saApp = ((currentApp.includeStandardAdditions = true), currentApp);

function cfl(list, prompt, defaultItems, multipleStatus) {
  if (multipleStatus == 'm') {
    return currentApp.chooseFromList(list, {
      withPrompt: prompt + '\n',
      defaultItems: defaultItems,
      multipleSelectionsAllowed: true,
    });
  }

  return currentApp.chooseFromList(list, { withPrompt: prompt + '\n', defaultItems: defaultItems });
}

